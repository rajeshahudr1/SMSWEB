<%- layout('../layouts/main') %>
<%
var s = userSettings || {};

var timezones = [
  'Asia/Kolkata','Asia/Dubai','Asia/Singapore','Asia/Tokyo','Asia/Karachi',
  'Asia/Dhaka','Asia/Bangkok','Asia/Shanghai','Asia/Seoul',
  'Europe/London','Europe/Paris','Europe/Berlin','Europe/Rome','Europe/Madrid',
  'America/New_York','America/Chicago','America/Denver','America/Los_Angeles',
  'America/Sao_Paulo','America/Toronto','America/Vancouver',
  'Africa/Cairo','Africa/Lagos','Africa/Nairobi',
  'Australia/Sydney','Australia/Melbourne','Pacific/Auckland','Pacific/Honolulu',
  'UTC',
];

var presetColors = [
  { label:'Blue',   value:'#0054a6' },
  { label:'Azure',  value:'#0ea5e9' },
  { label:'Indigo', value:'#4263eb' },
  { label:'Purple', value:'#9b59b6' },
  { label:'Teal',   value:'#0ca678' },
  { label:'Green',  value:'#2fb344' },
  { label:'Orange', value:'#f76707' },
  { label:'Red',    value:'#d63939' },
  { label:'Pink',   value:'#e91e8c' },
];
var curColor = s.theme_color || '#0054a6';
var isCustom  = !presetColors.some(function(c){ return c.value === curColor; });
%>

<div class="row g-4">

  <!-- ═══ LEFT: Settings forms ═══════════════════════════════════ -->
  <div class="col-xl-8 col-lg-7">

    <!-- ── Appearance ───────────────────────────────────────────── -->
    <div class="card mb-4">
      <div class="card-header">
        <div class="card-title">
          <i class="bi bi-palette me-2 text-primary"></i>
          <%- t('settings.appearance') %>
        </div>
        <div class="card-options text-secondary" style="font-size:12px;">Live preview updates automatically</div>
      </div>
      <div class="card-body">
        <div class="row g-4">

          <!-- Theme Colour — color picker + presets -->
          <div class="col-12">
            <label class="form-label fw-semibold mb-2"><%- t('settings.theme_color') %></label>
            <div class="d-flex flex-wrap align-items-center gap-2">
              <% presetColors.forEach(function(c) {
                   var isActive = curColor === c.value;
              %>
              <button type="button"
                      class="sms-cp-swatch <%- isActive ? 'active' : '' %>"
                      data-color="<%- c.value %>"
                      style="background:<%- c.value %>;"
                      title="<%- c.label %>">
                <i class="bi bi-check-lg"></i>
              </button>
              <% }); %>

              <!-- Native color picker input (full spectrum) -->
              <div class="sms-cp-picker-wrap <%- isCustom ? 'active' : '' %>" title="Custom colour">
                <input type="color" id="fColorPicker"
                       value="<%- curColor %>"
                       class="sms-cp-native"/>
                <i class="bi bi-eyedropper-fill sms-cp-picker-icon"></i>
                <% if (isCustom) { %><span class="sms-cp-picker-label"><%- curColor %></span><% } %>
              </div>

            </div>
            <input type="hidden" id="fThemeColor" name="theme_color" value="<%- curColor %>"/>
          </div>

          <!-- Mode -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.dark_mode') %></label>
            <select class="form-select" id="fDarkMode" name="dark_mode">
              <option value="0" <%- s.dark_mode != '1' ? 'selected' : '' %>>☀️ Light</option>
              <option value="1" <%- s.dark_mode == '1' ? 'selected' : '' %>>🌙 Dark</option>
            </select>
          </div>

          <!-- Direction -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.direction') %></label>
            <select class="form-select" id="fDirection" name="direction">
              <option value="ltr" <%- s.direction !== 'rtl' ? 'selected' : '' %>>⬅ LTR</option>
              <option value="rtl" <%- s.direction === 'rtl' ? 'selected' : '' %>>➡ RTL</option>
            </select>
          </div>

          <!-- Sidebar Theme -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.sidebar_style') %></label>
            <select class="form-select" id="fSidebarStyle" name="sidebar_style">
              <option value="dark"  <%- s.sidebar_style !== 'light' ? 'selected' : '' %>>🌑 Dark</option>
              <option value="light" <%- s.sidebar_style === 'light' ? 'selected' : '' %>>⬜ Light</option>
            </select>
          </div>

          <!-- Border Radius — visual buttons -->
          <div class="col-12">
            <label class="form-label fw-semibold"><%- t('settings.border_radius') %></label>
            <div class="d-flex flex-wrap gap-2">
              <% var radii = [
                { v:'none', label:'None',   rx:'0'   },
                { v:'sm',   label:'Small',  rx:'4'   },
                { v:'md',   label:'Medium', rx:'8'   },
                { v:'lg',   label:'Large',  rx:'12'  },
                { v:'xl',   label:'X-Large',rx:'16'  },
              ];
              var curRadius = s.border_radius || 'md';
              radii.forEach(function(r){ %>
              <button type="button"
                      class="sms-radius-option <%- curRadius === r.v ? 'active' : '' %>"
                      data-radius="<%- r.v %>">
                <svg width="28" height="28" viewBox="0 0 28 28">
                  <rect x="3" y="3" width="22" height="22"
                        rx="<%- r.rx %>"
                        fill="none" stroke="currentColor" stroke-width="2"/>
                </svg>
                <span><%- r.label %></span>
              </button>
              <% }); %>
            </div>
            <input type="hidden" id="fBorderRadius" name="border_radius" value="<%- curRadius %>"/>
          </div>

          <!-- Font Size — slider -->
          <div class="col-12">
            <label class="form-label fw-semibold d-flex justify-content-between">
              <%- t('settings.font_size') %>
              <span id="fFontSizeLabel" class="text-primary fw-bold"><%- s.font_size || '14px' %></span>
            </label>
            <div class="d-flex align-items-center gap-3">
              <span class="text-muted" style="font-size:10px;white-space:nowrap;">10px</span>
              <input type="range" class="form-range flex-fill" id="fFontSizeRange"
                     min="10" max="30" step="1"
                     value="<%- parseInt(s.font_size || '14') %>"/>
              <span class="text-muted" style="font-size:14px;white-space:nowrap;">30px</span>
            </div>
            <input type="hidden" id="fFontSize" name="font_size" value="<%- s.font_size || '14px' %>"/>
          </div>

        </div>
      </div>
    </div>

    <!-- ── Localisation ─────────────────────────────────────────── -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">
          <i class="bi bi-globe me-2 text-primary"></i>
          <%- t('settings.localization') %>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-4">

          <!-- Language -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.language') %></label>
            <select class="form-select select2" id="fLanguage" name="language">
              <% (supportedLanguages || []).forEach(function(lng){ %>
              <option value="<%- lng.code %>"
                <%- (s.language === lng.code || (!s.language && lng.code === 'en')) ? 'selected' : '' %>>
                <%- lng.flag %> <%- lng.nativeName %>
              </option>
              <% }); %>
            </select>
          </div>

          <!-- Date Format -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.date_format') %></label>
            <select class="form-select" id="fDateFormat" name="date_format">
              <option value="DD/MM/YYYY"   <%- (!s.date_format || s.date_format==='DD/MM/YYYY')   ? 'selected':'' %>>DD/MM/YYYY &nbsp; (31/01/2025)</option>
              <option value="MM/DD/YYYY"   <%- s.date_format==='MM/DD/YYYY'   ? 'selected':'' %>>MM/DD/YYYY &nbsp; (01/31/2025)</option>
              <option value="YYYY-MM-DD"   <%- s.date_format==='YYYY-MM-DD'   ? 'selected':'' %>>YYYY-MM-DD &nbsp; (2025-01-31)</option>
              <option value="DD MMM YYYY"  <%- s.date_format==='DD MMM YYYY'  ? 'selected':'' %>>DD MMM YYYY &nbsp; (31 Jan 2025)</option>
              <option value="DD MMMM YYYY" <%- s.date_format==='DD MMMM YYYY' ? 'selected':'' %>>DD MMMM YYYY &nbsp; (31 January 2025)</option>
            </select>
          </div>

          <!-- Time Format — NEW -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold">Time Format</label>
            <select class="form-select" id="fTimeFormat" name="time_format">
              <option value="12h" <%- (!s.time_format || s.time_format==='12h') ? 'selected':'' %>>12-hour &nbsp; (03:30 PM)</option>
              <option value="24h" <%- s.time_format==='24h' ? 'selected':'' %>>24-hour &nbsp; (15:30)</option>
            </select>
          </div>

          <!-- Timezone -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.timezone') %></label>
            <select class="form-select select2" id="fTimezone" name="timezone">
              <% timezones.forEach(function(tz){ %>
              <option value="<%- tz %>"
                <%- (s.timezone===tz || (!s.timezone && tz==='Asia/Kolkata')) ? 'selected':'' %>>
                <%- tz %>
              </option>
              <% }); %>
            </select>
          </div>

          <!-- Items per page -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.per_page') %></label>
            <select class="form-select" name="items_per_page" id="fItemsPerPage">
              <% [10,15,25,50,100,250,500,1000].forEach(function(n){ %>
              <option value="<%- n %>"
                <%- (s.items_per_page==n || (!s.items_per_page && n===15)) ? 'selected':'' %>>
                <%- n %> rows
              </option>
              <% }); %>
              <option value="all" <%- s.items_per_page==='all' ? 'selected':'' %>>All rows</option>
            </select>
          </div>

        </div>
      </div>
    </div>

  </div><!-- /col -->

  <!-- ═══ RIGHT: Live Preview ════════════════════════════════════ -->
  <div class="col-xl-4 col-lg-5">
    <div class="sms-preview-sticky">
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-eye me-2 text-primary"></i>Live Preview</div>
          <div class="card-options">
            <span class="badge bg-success-lt" id="previewChangedBadge" style="display:none;">
              <i class="bi bi-circle-fill me-1" style="font-size:7px;"></i>Changed
            </span>
          </div>
        </div>

        <!-- Preview viewport — simulates real UI -->
        <div class="sms-preview-viewport" id="previewViewport">

          <!-- Simulated sidebar -->
          <div class="sms-pv-sidebar" id="pvSidebar">
            <div class="sms-pv-brand">
              <span class="sms-pv-brand-icon"><i class="bi bi-recycle"></i></span>
              <span class="sms-pv-brand-name">SMS</span>
            </div>
            <div class="sms-pv-nav">
              <div class="sms-pv-nav-item active"><i class="bi bi-speedometer2"></i><span>Dashboard</span></div>
              <div class="sms-pv-nav-item"><i class="bi bi-people-fill"></i><span>Users</span></div>
              <div class="sms-pv-nav-item"><i class="bi bi-gear-fill"></i><span>Settings</span></div>
              <div class="sms-pv-nav-item"><i class="bi bi-shield-fill"></i><span>Roles</span></div>
            </div>
          </div>

          <!-- Simulated main area -->
          <div class="sms-pv-main">
            <!-- Header bar -->
            <div class="sms-pv-header" id="pvHeader">
              <span class="sms-pv-header-title">Dashboard</span>
              <span class="sms-pv-avatar" id="pvAvatar">A</span>
            </div>
            <!-- Content -->
            <div class="sms-pv-content">
              <!-- Stat card -->
              <div class="sms-pv-card" id="pvCard">
                <div class="sms-pv-card-top">
                  <span class="sms-pv-card-label">Active Users</span>
                  <span class="sms-pv-badge" id="pvBadge">+12%</span>
                </div>
                <div class="sms-pv-card-val" id="pvVal">1,247</div>
                <div class="sms-pv-bar"><div class="sms-pv-bar-fill" id="pvBar"></div></div>
              </div>
              <!-- Buttons -->
              <div class="d-flex gap-1 mt-2">
                <button class="sms-pv-btn sms-pv-btn--primary" id="pvBtnPrimary">Save</button>
                <button class="sms-pv-btn sms-pv-btn--outline">Cancel</button>
              </div>
              <!-- Font sample -->
              <div class="sms-pv-font-sample" id="pvFontSample">
                <div class="sms-pv-font-label">Font size</div>
                <div class="sms-pv-font-text" id="pvFontText">The quick brown fox</div>
              </div>
              <!-- DateTime sample -->
              <div class="sms-pv-datetime" id="pvDatetime"></div>
            </div>
          </div>

        </div><!-- /viewport -->

        <div class="card-footer text-muted" style="font-size:11px;">
          <i class="bi bi-info-circle me-1"></i>Preview updates live as you change settings
        </div>
      </div>
    </div>
  </div>

</div><!-- /row -->

<!-- Save / Reset bar -->
<div class="sms-settings-footer">
  <button type="button" id="btnSettingsReset" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-clockwise me-1"></i><%- t('settings.reset') %>
  </button>
  <button type="button" id="btnSettingsSave" class="btn btn-primary">
    <i class="bi bi-floppy me-1"></i><%- t('settings.save') %>
  </button>
</div>

<% block('scripts', '<script src="/js/pages/settings.js"></script><script>$(function(){ $(".select2").select2({theme:"bootstrap-5",width:"100%"}); });</script>') %>
