<%- layout('../layouts/main') %>
<%
var s = userSettings || {};

var timezones = [
  'Asia/Kolkata','Asia/Dubai','Asia/Singapore','Asia/Tokyo','Asia/Karachi',
  'Asia/Dhaka','Asia/Bangkok','Asia/Shanghai','Asia/Seoul',
  'Europe/London','Europe/Paris','Europe/Berlin','Europe/Rome','Europe/Madrid',
  'America/New_York','America/Chicago','America/Denver','America/Los_Angeles',
  'America/Sao_Paulo','America/Toronto','America/Vancouver',
  'Africa/Cairo','Africa/Lagos','Africa/Nairobi',
  'Australia/Sydney','Australia/Melbourne','Pacific/Auckland','Pacific/Honolulu',
  'UTC',
];

var presetColors = [
  { label:'Blue',   value:'#0054a6' },
  { label:'Azure',  value:'#0ea5e9' },
  { label:'Indigo', value:'#4263eb' },
  { label:'Purple', value:'#9b59b6' },
  { label:'Teal',   value:'#0ca678' },
  { label:'Green',  value:'#2fb344' },
  { label:'Orange', value:'#f76707' },
  { label:'Red',    value:'#d63939' },
  { label:'Pink',   value:'#e91e8c' },
];
var curColor = s.theme_color || '#0054a6';
var isCustom  = !presetColors.some(function(c){ return c.value === curColor; });

var presetTextColors = [
  { label:'Dark',     value:'#1a2332' },
  { label:'Charcoal', value:'#344054' },
  { label:'Black',    value:'#111827' },
  { label:'Navy',     value:'#1e3a5f' },
  { label:'Slate',    value:'#374151' },
  { label:'Gray',     value:'#4b5563' },
];
var curTextColor = s.text_color || '#1a2332';
var isCustomText = !presetTextColors.some(function(c){ return c.value === curTextColor; });

var presetIconColors = [
  { label:'Theme',    value:'theme' },
  { label:'Blue',     value:'#0054a6' },
  { label:'Indigo',   value:'#4263eb' },
  { label:'Teal',     value:'#0ca678' },
  { label:'Orange',   value:'#f76707' },
  { label:'Dark',     value:'#1a2332' },
  { label:'Gray',     value:'#667085' },
];
var curIconColor = s.icon_color || 'theme';
%>

<div class="row g-4">

  <!-- ═══ LEFT: Settings forms ═══════════════════════════════════ -->
  <div class="col-xl-8 col-lg-7">

    <!-- ── Appearance ───────────────────────────────────────────── -->
    <div class="card mb-4">
      <div class="card-header">
        <div class="card-title">
          <i class="bi bi-palette me-2 text-primary"></i>
          <%- t('settings.appearance') %>
        </div>
        <div class="card-options small">Live preview updates automatically</div>
      </div>
      <div class="card-body">
        <div class="row g-4">

          <!-- Theme Colour — color picker + presets -->
          <div class="col-12">
            <label class="form-label fw-semibold mb-2"><%- t('settings.theme_color') %></label>
            <div class="d-flex flex-wrap align-items-center gap-2">
              <% presetColors.forEach(function(c) {
                   var isActive = curColor === c.value;
              %>
              <button type="button"
                      class="sms-cp-swatch <%- isActive ? 'active' : '' %>"
                      data-color="<%- c.value %>"
                      style="background:<%- c.value %>;"
                      title="<%- c.label %>">
                <i class="bi bi-check-lg"></i>
              </button>
              <% }); %>

              <!-- Native color picker input (full spectrum) -->
              <div class="sms-cp-picker-wrap <%- isCustom ? 'active' : '' %>" title="Custom colour">
                <input type="color" id="fColorPicker"
                       value="<%- curColor %>"
                       class="sms-cp-native"/>
                <i class="bi bi-eyedropper-fill sms-cp-picker-icon"></i>
                <% if (isCustom) { %><span class="sms-cp-picker-label"><%- curColor %></span><% } %>
              </div>

            </div>
            <input type="hidden" id="fThemeColor" name="theme_color" value="<%- curColor %>"/>
          </div>

          <!-- Text Colour -->
          <div class="col-12">
            <label class="form-label fw-semibold mb-2"><%- t('settings.text_color', 'Text Colour') %></label>
            <div class="d-flex flex-wrap align-items-center gap-2">
              <% presetTextColors.forEach(function(c) {
                   var isActive = curTextColor === c.value;
              %>
              <button type="button"
                      class="sms-cp-swatch sms-tc-swatch <%- isActive ? 'active' : '' %>"
                      data-text-color="<%- c.value %>"
                      style="background:<%- c.value %>;"
                      title="<%- c.label %>">
                <i class="bi bi-check-lg"></i>
              </button>
              <% }); %>
              <div class="sms-cp-picker-wrap <%- isCustomText ? 'active' : '' %>" title="Custom text colour">
                <input type="color" id="fTextColorPicker" value="<%- curTextColor %>" class="sms-cp-native"/>
                <i class="bi bi-eyedropper-fill sms-cp-picker-icon"></i>
              </div>
            </div>
            <input type="hidden" id="fTextColor" name="text_color" value="<%- curTextColor %>"/>
          </div>

          <!-- Icon Colour -->
          <div class="col-12">
            <label class="form-label fw-semibold mb-2"><%- t('settings.icon_color', 'Icon Colour') %></label>
            <div class="d-flex flex-wrap align-items-center gap-2">
              <% presetIconColors.forEach(function(c) {
                   var isActive = curIconColor === c.value;
                   var bg = c.value === 'theme' ? (curColor) : c.value;
              %>
              <button type="button"
                      class="sms-cp-swatch sms-ic-swatch <%- isActive ? 'active' : '' %>"
                      data-icon-color="<%- c.value %>"
                      style="background:<%- bg %>;"
                      title="<%- c.label %>">
                <i class="bi bi-check-lg"></i>
              </button>
              <% }); %>
              <div class="sms-cp-picker-wrap" title="Custom icon colour">
                <input type="color" id="fIconColorPicker" value="<%- curIconColor === 'theme' ? curColor : curIconColor %>" class="sms-cp-native"/>
                <i class="bi bi-eyedropper-fill sms-cp-picker-icon"></i>
              </div>
            </div>
            <div class="form-hint">Use "Theme" to match your accent colour, or pick a custom icon colour.</div>
            <input type="hidden" id="fIconColor" name="icon_color" value="<%- curIconColor %>"/>
          </div>

          <!-- Mode -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.dark_mode') %></label>
            <select class="form-select" id="fDarkMode" name="dark_mode">
              <option value="0" <%- s.dark_mode != '1' ? 'selected' : '' %>>☀️ Light</option>
              <option value="1" <%- s.dark_mode == '1' ? 'selected' : '' %>>🌙 Dark</option>
            </select>
          </div>

          <!-- Direction -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.direction') %></label>
            <select class="form-select" id="fDirection" name="direction">
              <option value="ltr" <%- s.direction !== 'rtl' ? 'selected' : '' %>>⬅ LTR</option>
              <option value="rtl" <%- s.direction === 'rtl' ? 'selected' : '' %>>➡ RTL</option>
            </select>
          </div>

          <!-- Sidebar Theme -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.sidebar_style') %></label>
            <select class="form-select" id="fSidebarStyle" name="sidebar_style">
              <option value="dark"  <%- s.sidebar_style !== 'light' ? 'selected' : '' %>>🌑 Dark</option>
              <option value="light" <%- s.sidebar_style === 'light' ? 'selected' : '' %>>⬜ Light</option>
            </select>
          </div>

          <!-- Border Radius — visual buttons -->
          <div class="col-12">
            <label class="form-label fw-semibold"><%- t('settings.border_radius') %></label>
            <div class="d-flex flex-wrap gap-2">
              <% var radii = [
                { v:'none', label:'None',   rx:'0'   },
                { v:'sm',   label:'Small',  rx:'4'   },
                { v:'md',   label:'Medium', rx:'8'   },
                { v:'lg',   label:'Large',  rx:'12'  },
                { v:'xl',   label:'X-Large',rx:'16'  },
              ];
              var curRadius = s.border_radius || 'md';
              radii.forEach(function(r){ %>
              <button type="button"
                      class="sms-radius-option <%- curRadius === r.v ? 'active' : '' %>"
                      data-radius="<%- r.v %>">
                <svg width="28" height="28" viewBox="0 0 28 28">
                  <rect x="3" y="3" width="22" height="22"
                        rx="<%- r.rx %>"
                        fill="none" stroke="currentColor" stroke-width="2"/>
                </svg>
                <span><%- r.label %></span>
              </button>
              <% }); %>
            </div>
            <input type="hidden" id="fBorderRadius" name="border_radius" value="<%- curRadius %>"/>
          </div>

          <!-- Font Size — slider -->
          <div class="col-12">
            <label class="form-label fw-semibold d-flex justify-content-between">
              <%- t('settings.font_size') %>
              <span id="fFontSizeLabel" class="text-primary fw-bold"><%- s.font_size || '14px' %></span>
            </label>
            <div class="d-flex align-items-center gap-3">
              <span class="text-muted small" style="white-space:nowrap;">10px</span>
              <input type="range" class="form-range flex-fill" id="fFontSizeRange"
                     min="10" max="30" step="1"
                     value="<%- parseInt(s.font_size || '14') %>"/>
              <span class="text-muted" style="white-space:nowrap;">30px</span>
            </div>
            <input type="hidden" id="fFontSize" name="font_size" value="<%- s.font_size || '14px' %>"/>
          </div>

        </div>
      </div>
    </div>

    <!-- ── Localisation ─────────────────────────────────────────── -->
    <div class="card mb-4">
      <div class="card-header">
        <div class="card-title">
          <i class="bi bi-globe me-2 text-primary"></i>
          <%- t('settings.localization') %>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-4">

          <!-- Language -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.language') %></label>
            <select class="form-select select2" id="fLanguage" name="language">
              <% (supportedLanguages || []).forEach(function(lng){ %>
              <option value="<%- lng.code %>"
                <%- (s.language === lng.code || (!s.language && lng.code === 'en')) ? 'selected' : '' %>>
                <%- lng.flag %> <%- lng.nativeName %>
              </option>
              <% }); %>
            </select>
          </div>

          <!-- Module Language -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.module_language', 'Module Language') %></label>
            <select class="form-select select2" id="selModuleLanguage" name="module_language">
              <% (moduleLanguages || []).forEach(function(lng){ %>
              <option value="<%- lng.code %>"
                <%- (s.module_language === lng.code || (!s.module_language && lng.is_default)) ? 'selected' : '' %>>
                <%- lng.flag || '' %> <%- lng.native_name || lng.name %>
              </option>
              <% }); %>
            </select>
            <div class="form-hint"><%- t('settings.module_language_hint', 'Controls the language used for dropdown lists and module data.') %></div>
          </div>

          <!-- Date Format -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.date_format') %></label>
            <select class="form-select" id="fDateFormat" name="date_format">
              <option value="DD/MM/YYYY"   <%- (!s.date_format || s.date_format==='DD/MM/YYYY')   ? 'selected':'' %>>DD/MM/YYYY &nbsp; (31/01/2025)</option>
              <option value="MM/DD/YYYY"   <%- s.date_format==='MM/DD/YYYY'   ? 'selected':'' %>>MM/DD/YYYY &nbsp; (01/31/2025)</option>
              <option value="YYYY-MM-DD"   <%- s.date_format==='YYYY-MM-DD'   ? 'selected':'' %>>YYYY-MM-DD &nbsp; (2025-01-31)</option>
              <option value="DD MMM YYYY"  <%- s.date_format==='DD MMM YYYY'  ? 'selected':'' %>>DD MMM YYYY &nbsp; (31 Jan 2025)</option>
              <option value="DD MMMM YYYY" <%- s.date_format==='DD MMMM YYYY' ? 'selected':'' %>>DD MMMM YYYY &nbsp; (31 January 2025)</option>
            </select>
          </div>

          <!-- Time Format — NEW -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold">Time Format</label>
            <select class="form-select" id="fTimeFormat" name="time_format">
              <option value="12h" <%- (!s.time_format || s.time_format==='12h') ? 'selected':'' %>>12-hour &nbsp; (03:30 PM)</option>
              <option value="24h" <%- s.time_format==='24h' ? 'selected':'' %>>24-hour &nbsp; (15:30)</option>
            </select>
          </div>

          <!-- Timezone -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.timezone') %></label>
            <select class="form-select select2" id="fTimezone" name="timezone">
              <% timezones.forEach(function(tz){ %>
              <option value="<%- tz %>"
                <%- (s.timezone===tz || (!s.timezone && tz==='Asia/Kolkata')) ? 'selected':'' %>>
                <%- tz %>
              </option>
              <% }); %>
            </select>
          </div>

          <!-- Currency Symbol -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.currency_symbol', 'Currency Symbol') %></label>
            <select class="form-select" id="fCurrencySymbol" name="currency_symbol">
              <option value="€"  <%- s.currency_symbol==='€'  ? 'selected':'' %>>€ &nbsp; Euro</option>
              <option value="$"  <%- s.currency_symbol==='$'  ? 'selected':'' %>>$ &nbsp; US Dollar</option>
              <option value="£"  <%- s.currency_symbol==='£'  ? 'selected':'' %>>£ &nbsp; British Pound</option>
              <option value="₹"  <%- s.currency_symbol==='₹'  ? 'selected':'' %>>₹ &nbsp; Indian Rupee</option>
              <option value="R$" <%- s.currency_symbol==='R$' ? 'selected':'' %>>R$ &nbsp; Brazilian Real</option>
              <option value="¥"  <%- s.currency_symbol==='¥'  ? 'selected':'' %>>¥ &nbsp; Yen / Yuan</option>
              <option value="CHF" <%- s.currency_symbol==='CHF' ? 'selected':'' %>>CHF &nbsp; Swiss Franc</option>
              <option value="kr" <%- s.currency_symbol==='kr' ? 'selected':'' %>>kr &nbsp; Krone</option>
              <option value="zł" <%- s.currency_symbol==='zł' ? 'selected':'' %>>zł &nbsp; Polish Zloty</option>
              <option value="₺"  <%- s.currency_symbol==='₺'  ? 'selected':'' %>>₺ &nbsp; Turkish Lira</option>
            </select>
            <div class="form-hint"><%- t('settings.currency_hint', 'Displayed before all price values across the system.') %></div>
          </div>

          <!-- Autocomplete Suggestions Limit -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.autocomplete_limit', 'Autocomplete Suggestions') %></label>
            <select class="form-select" id="fAutocompleteLimit" name="autocomplete_limit">
              <% [5,10,15,20,25,30,50].forEach(function(n){ %>
              <option value="<%- n %>" <%- (parseInt(s.autocomplete_limit) === n || (!s.autocomplete_limit && n === 10)) ? 'selected' : '' %>><%- n %> items</option>
              <% }) %>
            </select>
            <div class="form-hint"><%- t('settings.autocomplete_hint', 'Number of suggestions shown in all dropdown searches across the system.') %></div>
          </div>

          <!-- Items per page (populated dynamically from SMS_PER_PAGE_OPTIONS in app.js) -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-semibold"><%- t('settings.per_page') %></label>
            <select class="form-select" name="items_per_page" id="fItemsPerPage"></select>
          </div>

        </div>
      </div>
    </div>

    <% if (user && (user.is_super_admin || user.is_org_admin)) { %>
    <!-- ── AI Configuration (Admin Only) ───────────────────────── -->
    <div class="card mb-4" id="aiConfigCard">
      <div class="card-header">
        <div class="card-title">
          <i class="bi bi-robot me-2 text-primary"></i>
          <%- t('settings.ai_config') %>
        </div>
        <div class="card-options">
          <span class="badge bg-info-lt"><i class="bi bi-shield-lock me-1"></i>Admin Only</span>
        </div>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-3"><%- t('settings.ai_config_desc') %></p>
        <div class="row g-4">

          <!-- AI Translation Toggle -->
          <div class="col-12">
            <label class="form-check form-switch">
              <input type="checkbox" class="form-check-input" id="fAiEnabled"
                     <%- (aiConfig && aiConfig.enabled) ? 'checked' : '' %>>
              <span class="form-check-label fw-semibold"><%- t('settings.ai_enabled') %></span>
            </label>
            <div class="form-hint"><%- t('settings.ai_enabled_hint') %></div>
          </div>

          <!-- AI Settings Panel (shown when enabled) -->
          <div class="col-12" id="aiSettingsPanel" style="<%- (aiConfig && aiConfig.enabled) ? '' : 'display:none;' %>">
            <div class="row g-3">

              <!-- Default Provider -->
              <div class="col-md-4">
                <label class="form-label fw-semibold"><%- t('settings.ai_provider') %></label>
                <select class="form-select" id="fAiProvider">
                  <option value="openai"  <%- (!aiConfig || aiConfig.provider !== 'gemini') ? 'selected' : '' %>>ChatGPT (OpenAI)</option>
                  <option value="gemini"  <%- (aiConfig && aiConfig.provider === 'gemini') ? 'selected' : '' %>>Gemini (Google)</option>
                </select>
              </div>

              <div class="col-12"><hr class="my-1"></div>

              <!-- OpenAI Section -->
              <div class="col-md-6">
                <div class="border rounded p-3">
                  <h6 class="fw-semibold mb-3"><i class="bi bi-chat-dots me-1"></i> OpenAI (ChatGPT)</h6>
                  <div class="mb-3">
                    <label class="form-label small fw-medium"><%- t('settings.ai_openai_key') %></label>
                    <div class="input-group">
                      <input type="password" class="form-control" id="fAiOpenaiKey"
                             value="<%- (aiConfig && aiConfig.openai_key) || '' %>"
                             placeholder="sk-xxxxxxxxxxxxxxxx" autocomplete="off">
                      <button class="btn btn-outline-secondary" type="button" onclick="toggleKeyVis(this)"><i class="bi bi-eye"></i></button>
                    </div>
                  </div>
                  <div class="mb-3">
                    <label class="form-label small fw-medium"><%- t('settings.ai_openai_model') %></label>
                    <input type="text" class="form-control" id="fAiOpenaiModel"
                           value="<%- (aiConfig && aiConfig.openai_model) || 'gpt-4o-mini' %>"
                           placeholder="gpt-4o-mini">
                  </div>
                  <button type="button" class="btn btn-sm btn-outline-primary" id="btnValidateOpenai" onclick="validateAiKey('openai')">
                    <i class="bi bi-check-circle me-1"></i><%- t('settings.ai_validate') %>
                  </button>
                  <span id="openaiStatus" class="ms-2 small"></span>
                </div>
              </div>

              <!-- Gemini Section -->
              <div class="col-md-6">
                <div class="border rounded p-3">
                  <h6 class="fw-semibold mb-3"><i class="bi bi-stars me-1"></i> Gemini (Google)</h6>
                  <div class="mb-3">
                    <label class="form-label small fw-medium"><%- t('settings.ai_gemini_key') %></label>
                    <div class="input-group">
                      <input type="password" class="form-control" id="fAiGeminiKey"
                             value="<%- (aiConfig && aiConfig.gemini_key) || '' %>"
                             placeholder="AIzaSyxxxxxxxxxxxxxxxx" autocomplete="off">
                      <button class="btn btn-outline-secondary" type="button" onclick="toggleKeyVis(this)"><i class="bi bi-eye"></i></button>
                    </div>
                  </div>
                  <div class="mb-3">
                    <label class="form-label small fw-medium"><%- t('settings.ai_gemini_model') %></label>
                    <input type="text" class="form-control" id="fAiGeminiModel"
                           value="<%- (aiConfig && aiConfig.gemini_model) || 'gemini-2.5-flash' %>"
                           placeholder="gemini-2.5-flash">
                  </div>
                  <button type="button" class="btn btn-sm btn-outline-success" id="btnValidateGemini" onclick="validateAiKey('gemini')">
                    <i class="bi bi-check-circle me-1"></i><%- t('settings.ai_validate') %>
                  </button>
                  <span id="geminiStatus" class="ms-2 small"></span>
                </div>
              </div>

            </div>

          </div>

          <!-- Disabled notice -->
          <div class="col-12" id="aiDisabledNotice" style="<%- (aiConfig && aiConfig.enabled) ? 'display:none;' : '' %>">
            <div class="alert alert-warning mb-0">
              <i class="bi bi-info-circle me-1"></i><%- t('settings.ai_disabled_note') %>
            </div>
          </div>

          <!-- Save AI Config Button — ALWAYS visible when card is shown -->
          <div class="col-12 text-end">
            <button type="button" class="btn btn-primary" id="btnSaveAiConfig" onclick="saveAiConfig()">
              <i class="bi bi-floppy me-1"></i><%- t('settings.ai_save') %>
            </button>
          </div>

        </div>
      </div>
    </div>
    <% } %>

    <% if (user && (user.is_super_admin || user.is_org_admin)) { %>
    <!-- ── Tax Configuration (Org Admin Only) ──────────────────── -->
    <div class="card mb-4" id="taxConfigCard">
      <div class="card-header">
        <div class="card-title">
          <i class="bi bi-receipt me-2 text-primary"></i>
          Tax Configuration
        </div>
        <div class="card-options">
          <span class="badge bg-info-lt"><i class="bi bi-shield-lock me-1"></i>Admin Only</span>
        </div>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-3">Configure tax types and percentages for your company. Based on your country's tax structure (GST, VAT, etc.).</p>

        <div id="taxRows">
          <div class="text-center py-3 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...</div>
        </div>

        <div class="d-flex gap-2 mt-3">
          <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddTax">
            <i class="bi bi-plus-lg me-1"></i>Add Tax
          </button>
          <button type="button" class="btn btn-sm btn-outline-primary" id="btnLoadTemplate">
            <i class="bi bi-magic me-1"></i>Load Country Template
          </button>
        </div>

        <div class="text-end mt-3">
          <button type="button" class="btn btn-primary" id="btnSaveTax" onclick="saveTaxConfig()">
            <i class="bi bi-floppy me-1"></i>Save Tax Configuration
          </button>
        </div>
      </div>
    </div>
    <% } %>

    <% if (user && (user.is_super_admin || user.is_org_admin)) { %>
    <!-- ── Vehicle Inventory Settings (Admin Only) ────────────── -->
    <div class="card mb-4" id="viSettingsCard">
      <div class="card-header collapsed" data-bs-toggle="collapse" data-bs-target="#viSettingsBody">
        <div class="card-title">
          <i class="bi bi-box-seam me-2"></i>
          Vehicle Inventory Settings
          <i class="bi bi-chevron-down ms-auto collapse-icon"></i>
        </div>
      </div>
      <div class="card-body collapse" id="viSettingsBody">
        <p class="text-muted small mb-3">Configure file upload limits for your company's vehicle inventory.</p>
        <div class="row g-3">
          <div class="col-md-3 col-sm-6">
            <label class="form-label fw-semibold">Max Image Size (MB)</label>
            <input type="number" class="form-control" id="fViMaxImageSize" min="1" max="50" value="5" placeholder="5"/>
            <div class="form-hint">Per file (1-50 MB)</div>
