<%- layout('../layouts/main') %>
<%
var rec = typeof record !== 'undefined' ? record : null;
var isEdit = !!rec;
var formAction = isEdit ? '/warehouses/' + rec.uuid : '/warehouses';
var orgs = typeof organizations !== 'undefined' ? organizations : [];
var isSuperAdmin = user && user.is_super_admin;
%>

<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/warehouses" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
  <h3 class="mb-0" style="font-size:16px;"><i class="bi bi-building me-2 text-primary"></i><%= isEdit ? 'Edit Warehouse' : 'Add Warehouse' %></h3>
</div>

<form id="frmMain" method="POST" action="<%- formAction %>" novalidate>
<div class="row g-3">

  <div class="col-lg-8">

    <% if (isSuperAdmin && orgs.length) { %>
    <div class="card shadow-sm mb-3">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-building me-1 text-primary"></i>Company</div>
      </div>
      <div class="card-body">
        <select name="company_id" id="fCompany" class="form-select">
          <option value="">Select Company *</option>
          <% orgs.forEach(function(o) { %>
          <option value="<%- o.id %>" <%- (isEdit && rec && rec.organization_id && String(rec.organization_id) === String(o.id)) ? 'selected' : '' %>><%- o.company_name %></option>
          <% }) %>
        </select>
        <div class="form-hint mt-1">Warehouse must belong to a company.</div>
      </div>
    </div>
    <% } %>

    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-info-circle me-1 text-primary"></i>Warehouse Information</div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-medium">Name <span class="text-danger">*</span></label>
            <input type="text" name="name" id="fName" class="form-control" required autofocus value="<%= isEdit ? (rec.name||'') : '' %>" placeholder="Warehouse name"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium">Code <span class="text-danger">*</span></label>
            <input type="text" name="code" id="fCode" class="form-control" required value="<%= isEdit ? (rec.code||'') : '' %>" placeholder="e.g. WH01"/>
          </div>
          <div class="col-md-12">
            <label class="form-label fw-medium">Description</label>
            <textarea name="description" id="fDescription" class="form-control" rows="3" placeholder="Optional description"><%= isEdit ? (rec.description||'') : '' %></textarea>
          </div>
          <div class="col-md-12">
            <label class="form-label fw-medium">Address</label>
            <input type="text" name="address" id="fAddress" class="form-control" value="<%= isEdit ? (rec.address||'') : '' %>" placeholder="Street address"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">City</label>
            <input type="text" name="city" id="fCity" class="form-control" value="<%= isEdit ? (rec.city||'') : '' %>" placeholder="City"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">State</label>
            <input type="text" name="state" id="fState" class="form-control" value="<%= isEdit ? (rec.state||'') : '' %>" placeholder="State"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">Country</label>
            <input type="text" name="country" id="fCountry" class="form-control" value="<%= isEdit ? (rec.country||'') : '' %>" placeholder="Country"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">Contact Person</label>
            <input type="text" name="contact_person" id="fContactPerson" class="form-control" value="<%= isEdit ? (rec.contact_person||'') : '' %>" placeholder="Contact name"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">Contact Phone</label>
            <input type="text" name="contact_phone" id="fContactPhone" class="form-control" value="<%= isEdit ? (rec.contact_phone||'') : '' %>" placeholder="Phone number"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">Contact Email</label>
            <input type="email" name="contact_email" id="fContactEmail" class="form-control" value="<%= isEdit ? (rec.contact_email||'') : '' %>" placeholder="Email address"/>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <% if (isEdit) { %>
    <div class="card shadow-sm mb-3">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-toggle-on me-1 text-primary"></i>Status</div></div>
      <div class="card-body"><select name="status" class="form-select"><option value="1" <%- parseInt(rec.status) ? 'selected' : '' %>>Active</option><option value="0" <%- !parseInt(rec.status) ? 'selected' : '' %>>Inactive</option></select></div>
    </div>
    <% } %>

    <div class="card shadow-sm">
      <div class="card-body py-3">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary" id="btnSubmit"><i class="bi bi-floppy me-1"></i><%= isEdit ? 'Update' : 'Create' %> Warehouse</button>
          <a href="/warehouses" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i>Cancel</a>
        </div>
      </div>
    </div>
  </div>

</div>
</form>

<script>
window._FORM_DATA = {
  isEdit: <%= isEdit ? 'true' : 'false' %>,
  isSuperAdmin: <%= (user && user.is_super_admin) ? 'true' : 'false' %>
};
</script>
<% block('scripts', '<script src="/js/pages/warehouses-form.js"></script>') %>
