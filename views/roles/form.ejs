<%- layout('../layouts/main') %>
<%
var r      = typeof role !== 'undefined' ? role : null;
var isEdit = !!r;
var assignedIds = isEdit && r.permissions ? r.permissions.map(function(p){ return parseInt(p.id); }) : [];
var formAction  = isEdit ? '/roles/' + r.uuid : '/roles';
var pageTitle   = isEdit ? 'Edit Role' : 'Add Role';
%>

<div class="page-header">
  <div class="row align-items-center">
    <div class="col">
      <div class="page-pretitle"><a href="/dashboard">Dashboard</a> / <a href="/roles">Roles</a></div>
      <h2 class="page-title"><%- pageTitle %></h2>
    </div>
    <div class="col-auto">
      <a href="/roles" class="btn btn-outline-secondary">
        <i class="bi bi-circle me-1"></i>Back
      </a>
    </div>
  </div>
</div>

<form id="frmRole" method="POST" action="<%- formAction %>" novalidate>
<div class="row g-4">

  <div class="col-lg-4">
    <!-- Role details -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-shield me-2"></i>Role Details</div>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label required">Role Name</label>
          <input type="text" name="name" class="form-control"
                 value="<%- isEdit ? (r.name||'') : '' %>"
                 placeholder="e.g. Yard Manager" required/>
        </div>
        <div class="mb-3">
          <label class="form-label">Panel Type</label>
          <select name="panel_type" class="form-select">
            <option value="b2b"  <%- (!isEdit||r.panel_type==='b2b')  ? 'selected':'' %>>B2B</option>
            <option value="b2c"  <%- isEdit&&r.panel_type==='b2c'  ? 'selected':'' %>>B2C</option>
            <option value="both" <%- isEdit&&r.panel_type==='both' ? 'selected':'' %>>Both</option>
          </select>
        </div>
        <% if (isEdit) { %>
        <div class="mb-3">
          <label class="form-label">Status</label>
          <select name="status" class="form-select">
            <option value="1" <%- parseInt(r.status) ? 'selected':'' %>>Active</option>
            <option value="0" <%- !parseInt(r.status) ? 'selected':'' %>>Inactive</option>
          </select>
        </div>
        <% } %>
        <div class="mb-0">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-control" rows="3"
                    placeholder="Optional description"><%- isEdit ? (r.description||'') : '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Save card -->
    <div class="card mt-4">
      <div class="card-body">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary" id="btnSubmit">
            <i class="bi bi-floppy me-1"></i><%- isEdit ? 'Update Role' : 'Create Role' %>
          </button>
          <a href="/roles" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i>Cancel</a>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-key me-2"></i>Permissions</div>
        <div class="card-options gap-2">
          <button type="button" class="btn btn-sm btn-outline-primary" id="btnSelectAll">Select All</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" id="btnClearAll">Clear All</button>
        </div>
      </div>
      <div class="card-body p-0" style="max-height:600px;overflow-y:auto;">
        <% if (typeof permissions !== 'undefined' && permissions && Object.keys(permissions).length) { %>
        <% Object.keys(permissions).forEach(function(groupName){ %>
        <div class="border-bottom">
          <div class="d-flex align-items-center justify-content-between px-4 py-2 bg-light">
            <span class="fw-semibold small text-uppercase text-muted" style="letter-spacing:.05em;"><%- groupName %></span>
            <label class="form-check mb-0">
              <input type="checkbox" class="form-check-input group-toggle" data-group="<%- groupName %>"/>
              <span class="form-check-label small">All</span>
            </label>
          </div>
          <div class="row g-0 px-4 py-3">
            <% permissions[groupName].forEach(function(p){ %>
            <div class="col-12 col-sm-6 col-lg-4 mb-2">
              <label class="form-check d-flex align-items-center gap-2 mb-0">
                <input type="checkbox" class="form-check-input flex-shrink-0 perm-check"
                       name="permission_ids[]" value="<%- p.id %>" data-group="<%- groupName %>"
                       <%- assignedIds.indexOf(parseInt(p.id)) !== -1 ? 'checked' : '' %>/>
                <span class="form-check-label" style="font-size:12.5px;">
                  <span class="badge badge-sm me-1
                    <%- p.action==='view'?'bg-azure-lt':p.action==='add'?'bg-green-lt':p.action==='edit'?'bg-orange-lt':p.action==='delete'?'bg-red-lt':'bg-secondary-lt' %>"
                        style="font-size:9.5px;"><%- p.action %></span>
                  <%- p.display_name %>
                </span>
              </label>
            </div>
            <% }) %>
          </div>
        </div>
        <% }) %>
        <% } else { %>
        <div class="text-center text-muted py-5">No permissions found.</div>
        <% } %>
      </div>
    </div>
  </div>

</div>
</form>

<% block('scripts', "<script>\n$(function(){\n  $('#frmRole').on('submit', function(e){\n    e.preventDefault();\n    var $btn = $('#btnSubmit');\n    btnLoading($btn);\n    smsAjax({\n      url: $(this).attr('action'),\n      data: $(this).serialize(),\n      btn: $btn,\n      success: function(r){\n        if(r.status===200||r.status===201){\n          toastr.success(r.message||'Saved.');\n          setTimeout(function(){ window.location='/roles'; }, 800);\n        } else {\n          toastr.error(r.message||'Error.');\n          btnReset($btn);\n        }\n      }\n    });\n  });\n});\n</script>") %>