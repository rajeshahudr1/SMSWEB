<%- layout('../layouts/main') %>
<%
var r      = typeof role !== 'undefined' ? role : null;
var isEdit = !!r;
var assignedIds = isEdit && r.permissions ? r.permissions.map(function(p){ return parseInt(p.id); }) : [];
// ✅ Use panel-specific arrays instead of combined
var assignedB2BIds = isEdit && r.b2b_permission_ids ? r.b2b_permission_ids.map(function(id){ return parseInt(id); }) : [];
var assignedB2CIds = isEdit && r.b2c_permission_ids ? r.b2c_permission_ids.map(function(id){ return parseInt(id); }) : [];
var formAction  = isEdit ? '/roles/' + r.uuid : '/roles';
var pageTitle   = isEdit ? t('roles.edit', 'Edit Role') : t('roles.add', 'Add Role');

/* Section mapping — groups permissions by menu section */
var SECTIONS = [
    { key: 'system',     label: 'System',          icon: 'bi-gear',          groups: ['Dashboard', 'Settings', 'Profile'] },
    { key: 'users',      label: 'User Management', icon: 'bi-people',        groups: ['Users', 'Roles', 'Permissions', 'Menus'] },
    { key: 'languages',  label: 'Languages',       icon: 'bi-translate',     groups: ['Languages', 'Master Languages'] },
    { key: 'parts',      label: 'Parts',           icon: 'bi-cpu',           groups: ['Part Types', 'Part Locations', 'Part Groups', 'Part Sides', 'Part Brands'] },
    { key: 'vehicle',    label: 'Vehicle',          icon: 'bi-truck',         groups: ['Vehicle Categories', 'Vehicle Fuels', 'Vehicle Years', 'Vehicle Types', 'Vehicle Makes', 'Vehicle Models', 'Vehicle Variants', 'Vehicle Engines'] },
    { key: 'location',   label: 'Location',         icon: 'bi-geo-alt',       groups: ['Countries', 'States', 'Cities'] },
    { key: 'reports',    label: 'Reports',           icon: 'bi-bar-chart',     groups: ['Activity Logs'] },
];

/* Split permissions by panel for B2B/B2C tabs, organized by section */
var b2bSections = [];
var b2cSections = [];
var b2bCount  = 0;
var b2cCount  = 0;
if (typeof permissions !== 'undefined' && permissions && Object.keys(permissions).length) {
    /* Also collect any groups not mapped to a section */
    var mappedGroups = {};
    SECTIONS.forEach(function(s) { s.groups.forEach(function(g) { mappedGroups[g] = true; }); });
    var unmapped = Object.keys(permissions).filter(function(g) { return !mappedGroups[g]; });
    if (unmapped.length) SECTIONS.push({ key: 'other', label: 'Other', icon: 'bi-three-dots', groups: unmapped });

    SECTIONS.forEach(function(sec) {
        var b2bGrps = {}, b2cGrps = {}, b2bC = 0, b2cC = 0;
        sec.groups.forEach(function(groupName) {
            if (!permissions[groupName]) return;
            permissions[groupName].forEach(function(p) {
                if (p.panel_type === 'b2b' || p.panel_type === 'both') {
                    if (!b2bGrps[groupName]) b2bGrps[groupName] = [];
                    b2bGrps[groupName].push(p); b2bC++; b2bCount++;
                }
                if (p.panel_type === 'b2c' || p.panel_type === 'both') {
                    if (!b2cGrps[groupName]) b2cGrps[groupName] = [];
                    b2cGrps[groupName].push(p); b2cC++; b2cCount++;
                }
            });
        });
        if (b2bC) b2bSections.push({ key: sec.key, label: sec.label, icon: sec.icon, groups: b2bGrps, count: b2bC });
        if (b2cC) b2cSections.push({ key: sec.key, label: sec.label, icon: sec.icon, groups: b2cGrps, count: b2cC });
    });
}
%>

<!-- ── Back bar ── -->
<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/roles" class="btn btn-sm btn-outline-secondary" title="<%- t('btn.back_to_list', 'Back to Roles list') %>">
    <i class="bi bi-arrow-left me-1"></i><%- t('btn.back', 'Back') %>
  </a>
  <h3 class="mb-0" style="font-size:16px;">
    <i class="bi bi-shield-check me-2 text-primary"></i><%- pageTitle %>
  </h3>
</div>

<form id="frmRole" method="POST" action="<%- formAction %>" novalidate>
<div class="row g-3">

  <!-- Left: Role details -->
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-info-circle me-1 text-primary"></i><%- t('roles.details', 'Role Details') %>
        </div>
      </div>
      <div class="card-body">
        <% if (typeof is_super_admin !== 'undefined' && is_super_admin) { %>
        <div class="mb-3">
          <label class="form-label fw-medium"><i class="bi bi-building me-1"></i><%- t('general.company', 'Company') %> <span class="text-danger">*</span></label>
          <select name="company_id" id="selCompany" class="form-select" required>
            <% (typeof organizations !== 'undefined' ? organizations : []).forEach(function(o) { %>
            <option value="<%- o.id %>" <%- (isEdit && r && r.organization_id == o.id) ? 'selected' : '' %>><%- o.company_name %></option>
            <% }) %>
          </select>
        </div>
        <% } %>
        <div class="mb-3">
          <label class="form-label fw-medium"><%- t("roles.name") %> <span class="text-danger">*</span></label>
          <input type="text" name="name" class="form-control" required autofocus
                 value="<%- isEdit ? (r.name||'') : '' %>"
                 placeholder="e.g. Yard Manager, Buyer…"/>
        </div>
        <% if (isEdit) { %>
        <div class="mb-3">
          <label class="form-label fw-medium"><%- t("users.status") %></label>
          <select name="status" class="form-select">
            <option value="1" <%- parseInt(r.status) ? 'selected':'' %>><%- t("users.active") %></option>
            <option value="0" <%- !parseInt(r.status) ? 'selected':'' %>><%- t("users.inactive") %></option>
          </select>
        </div>
        <% } %>
        <div class="mb-0">
          <label class="form-label fw-medium"><%- t("form.description") %></label>
          <textarea name="description" class="form-control" rows="3"
                    placeholder="Optional description…"><%- isEdit ? (r.description||'') : '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Save card -->
    <div class="card mt-3 shadow-sm">
      <div class="card-body py-3">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary" id="btnSubmit" title="<%- isEdit ? t('btn.update', 'Update') : t('btn.save', 'Save') %>">
            <i class="bi bi-floppy me-1"></i><%- isEdit ? t('btn.update', 'Update') : t('btn.save', 'Save') %>
          </button>
          <a href="/roles" class="btn btn-outline-secondary" title="<%- t('btn.discard', 'Discard and go back') %>"><i class="bi bi-x-lg me-1"></i><%- t("btn.cancel") %></a>
        </div>
      </div>
    </div>
  </div>

  <!-- Right: Permissions with B2B/B2C tabs -->
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-key me-1 text-primary"></i><%- t('roles.permissions', 'Permissions') %>
        </div>
        <div class="card-options gap-2">
          <button type="button" class="btn btn-sm btn-outline-primary" id="btnSelectAll" title="<%- t('roles.select_all_tip', 'Select all permissions in active tab') %>"><%- t("btn.select_all") %></button>
          <button type="button" class="btn btn-sm btn-outline-secondary" id="btnClearAll" title="<%- t('roles.clear_all_tip', 'Clear all permissions in active tab') %>"><%- t("btn.clear_all") %></button>
        </div>
      </div>

      <!-- B2B / B2C Tabs -->
      <div class="card-body p-0">
        <ul class="nav nav-tabs px-3 pt-2" role="tablist" id="permTabs">
          <li class="nav-item">
            <button class="nav-link active d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#tabB2B" type="button" role="tab">
              <i class="bi bi-building"></i>
              <%- t('roles.b2b_permissions', 'B2B Permissions') %>
              <span class="badge bg-primary-lt rounded-pill" style="font-size:10px;"><%- b2bCount %></span>
            </button>
          </li>
          <li class="nav-item">
            <button class="nav-link d-flex align-items-center gap-2" data-bs-toggle="tab" data-bs-target="#tabB2C" type="button" role="tab">
              <i class="bi bi-person"></i>
              <%- t('roles.b2c_permissions', 'B2C Permissions') %>
              <span class="badge bg-success-lt rounded-pill" style="font-size:10px;"><%- b2cCount %></span>
            </button>
          </li>
        </ul>

        <div class="tab-content" style="max-height:550px;overflow-y:auto;">

          <!-- B2B Tab -->
          <div class="tab-pane fade show active" id="tabB2B" role="tabpanel">
            <% if (b2bSections.length) { %>
            <% b2bSections.forEach(function(sec){ %>
            <!-- Section: <%- sec.label %> -->
            <div class="border-bottom" style="border-left:3px solid var(--tblr-primary) !important;">
              <div class="d-flex align-items-center justify-content-between px-4 py-2" style="background:var(--tblr-bg-surface-secondary);">
                <span class="fw-bold small text-primary"><i class="bi <%- sec.icon %> me-2"></i><%- sec.label %> <span class="badge bg-primary-lt rounded-pill ms-1" style="font-size:10px;"><%- sec.count %></span></span>
                <label class="form-check mb-0">
                  <input type="checkbox" class="form-check-input section-toggle" data-section="b2b_sec_<%- sec.key %>"/>
                  <span class="form-check-label small fw-semibold"><%- t('btn.select_all', 'Select All') %></span>
                </label>
              </div>
              <% Object.keys(sec.groups).forEach(function(groupName){ %>
              <div class="border-bottom border-light">
                <div class="d-flex align-items-center justify-content-between px-4 py-1" style="background:rgba(0,0,0,.02);">
                  <span class="fw-semibold small text-uppercase text-muted" style="letter-spacing:.05em;font-size:11px;"><%- groupName %></span>
                  <label class="form-check mb-0">
                    <input type="checkbox" class="form-check-input group-toggle" data-group="b2b_<%- groupName %>" data-section="b2b_sec_<%- sec.key %>"/>
                    <span class="form-check-label small"><%- t('general.all', 'All') %></span>
                  </label>
                </div>
                <div class="row g-0 px-4 py-2">
                  <% sec.groups[groupName].forEach(function(p){
                       var aColor = {view:'azure',add:'green',edit:'orange',delete:'red',export:'purple',import:'teal'};
                       var color  = aColor[p.action] || 'secondary';
                  %>
                  <div class="col-12 col-sm-6 col-lg-4 mb-2">
                    <label class="form-check d-flex align-items-center gap-2 mb-0">
                      <input type="checkbox" class="form-check-input flex-shrink-0 perm-check"
                             name="b2b_permission_ids[]" value="<%- p.id %>" data-group="b2b_<%- groupName %>" data-section="b2b_sec_<%- sec.key %>"
                              <%- assignedB2BIds.indexOf(parseInt(p.id)) !== -1 ? 'checked' : '' %>/>
                      <span class="form-check-label" style="font-size:12.5px;">
                        <span class="badge badge-sm me-1 bg-<%- color %>-lt" style="font-size:9.5px;"><%- p.action %></span>
                        <%- p.display_name %>
                      </span>
                    </label>
                  </div>
                  <% }) %>
                </div>
              </div>
              <% }) %>
            </div>
            <% }) %>
            <% } else { %>
            <div class="text-center text-muted py-5"><%- t('roles.no_b2b_permissions', 'No B2B permissions found.') %></div>
            <% } %>
          </div>

          <!-- B2C Tab -->
          <div class="tab-pane fade" id="tabB2C" role="tabpanel">
            <% if (b2cSections.length) { %>
            <% b2cSections.forEach(function(sec){ %>
            <div class="border-bottom" style="border-left:3px solid var(--tblr-success) !important;">
              <div class="d-flex align-items-center justify-content-between px-4 py-2" style="background:var(--tblr-bg-surface-secondary);">
                <span class="fw-bold small text-success"><i class="bi <%- sec.icon %> me-2"></i><%- sec.label %> <span class="badge bg-success-lt rounded-pill ms-1" style="font-size:10px;"><%- sec.count %></span></span>
                <label class="form-check mb-0">
                  <input type="checkbox" class="form-check-input section-toggle" data-section="b2c_sec_<%- sec.key %>"/>
                  <span class="form-check-label small fw-semibold"><%- t('btn.select_all', 'Select All') %></span>
                </label>
              </div>
              <% Object.keys(sec.groups).forEach(function(groupName){ %>
              <div class="border-bottom border-light">
                <div class="d-flex align-items-center justify-content-between px-4 py-1" style="background:rgba(0,0,0,.02);">
                  <span class="fw-semibold small text-uppercase text-muted" style="letter-spacing:.05em;font-size:11px;"><%- groupName %></span>
                  <label class="form-check mb-0">
                    <input type="checkbox" class="form-check-input group-toggle" data-group="b2c_<%- groupName %>" data-section="b2c_sec_<%- sec.key %>"/>
                    <span class="form-check-label small"><%- t('general.all', 'All') %></span>
                  </label>
                </div>
                <div class="row g-0 px-4 py-2">
                  <% sec.groups[groupName].forEach(function(p){
                       var aColor = {view:'azure',add:'green',edit:'orange',delete:'red',export:'purple',import:'teal'};
                       var color  = aColor[p.action] || 'secondary';
                  %>
                  <div class="col-12 col-sm-6 col-lg-4 mb-2">
                    <label class="form-check d-flex align-items-center gap-2 mb-0">
                      <input type="checkbox" class="form-check-input flex-shrink-0 perm-check"
                             name="b2c_permission_ids[]" value="<%- p.id %>" data-group="b2c_<%- groupName %>" data-section="b2c_sec_<%- sec.key %>"
                              <%- assignedB2CIds.indexOf(parseInt(p.id)) !== -1 ? 'checked' : '' %>/>
                      <span class="form-check-label" style="font-size:12.5px;">
                        <span class="badge badge-sm me-1 bg-<%- color %>-lt" style="font-size:9.5px;"><%- p.action %></span>
                        <%- p.display_name %>
                      </span>
                    </label>
                  </div>
                  <% }) %>
                </div>
              </div>
              <% }) %>
            </div>
            <% }) %>
            <% } else { %>
            <div class="text-center text-muted py-5"><%- t('roles.no_b2c_permissions', 'No B2C permissions found.') %></div>
            <% } %>
          </div>

        </div>
      </div>
    </div>
  </div>

</div>
</form>

<% block('scripts', `<script>
$(function(){
  /* ── Select All / Clear All — scoped to active tab ── */
  $('#btnSelectAll').on('click', function(){
    var activeTab = $('#permTabs .nav-link.active').attr('data-bs-target');
    $(activeTab).find('.perm-check').prop('checked', true);
    $(activeTab).find('.group-toggle').prop('checked', true);
    $(activeTab).find('.section-toggle').prop('checked', true);
  });
  $('#btnClearAll').on('click', function(){
    var activeTab = $('#permTabs .nav-link.active').attr('data-bs-target');
    $(activeTab).find('.perm-check').prop('checked', false);
    $(activeTab).find('.group-toggle').prop('checked', false);
    $(activeTab).find('.section-toggle').prop('checked', false);
  });

  /* ── Section toggle — select/deselect all groups + perms in section ── */
  $(document).on('change', '.section-toggle', function(){
    var sec = $(this).data('section');
    var checked = $(this).is(':checked');
    $('.perm-check[data-section="'+sec+'"]').prop('checked', checked);
    $('.group-toggle[data-section="'+sec+'"]').prop('checked', checked);
  });

  /* ── Group toggle — scoped by prefixed group name ── */
  $(document).on('change', '.group-toggle', function(){
    var g = $(this).data('group');
    $('.perm-check[data-group="'+g+'"]').prop('checked', $(this).is(':checked'));
    // Update section toggle state
    var sec = $(this).data('section');
    if (sec) {
      var allGroups = $('.group-toggle[data-section="'+sec+'"]');
      var allChecked = allGroups.length === allGroups.filter(':checked').length;
      $('.section-toggle[data-section="'+sec+'"]').prop('checked', allChecked);
    }
  });

  /* ── Submit ── */
$('#frmRole').on('submit', function(e){
  e.preventDefault();
  var $btn = $('#btnSubmit');
  var formData = $(this).serializeArray();

  // ✅ Ensure b2b_permission_ids[] always present
  var hasB2B = formData.some(function(f){ return f.name === 'b2b_permission_ids[]'; });
  if (!hasB2B) formData.push({ name: 'b2b_permission_ids[]', value: '' });

  // ✅ Ensure b2c_permission_ids[] always present
  var hasB2C = formData.some(function(f){ return f.name === 'b2c_permission_ids[]'; });
  if (!hasB2C) formData.push({ name: 'b2c_permission_ids[]', value: '' });

  smsAjax({
    url: $(this).attr('action'),
    data: $.param(formData),
    btn: $btn,
    success: function(r){
      if(r.status===200||r.status===201){
        toastr.success(r.message||'Saved.');
        setTimeout(function(){ window.location='/roles'; }, 800);
      } else {
        toastr.error(r.message||'Error.');
      }
    }
  });
});
});
</script>`) %>
