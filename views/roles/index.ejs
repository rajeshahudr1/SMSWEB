<%- layout('../layouts/main') %>

<div class="card shadow-sm">

  <!-- ── Card header ── -->
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto">
        <i class="bi bi-shield-check me-2 text-primary"></i>Roles
        <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span>
      </h3>

      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;" title="Rows per page"></select>

      <% if (can('add_roles')) { %>
      <a href="/roles/create" class="btn btn-sm btn-primary" title="Create a new role">
        <i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline"><%- t("roles.add") %></span>
      </a>
      <% } %>
    </div>
  </div>

  <!-- ── Filters ── -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <div class="col-12 col-sm-5 col-md-4">
        <input type="text" class="form-control form-control-sm sms-filter-search" id="searchInput"
               placeholder="&#128269;  Search roles…"/>
      </div>
      <div class="col-6 col-sm-3 col-md-2">
        <select class="form-select form-select-sm" id="filterStatus" style="width:100%;">
          <option value=""><%- t("general.all") %> <%- t("users.status") %></option>
          <option value="1"><%- t("users.active") %></option>
          <option value="0"><%- t("users.inactive") %></option>
        </select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-outline-secondary sms-filter-clear" id="btnClearFilters" title="Clear all filters">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Table ── -->
  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead>
        <tr>
          <th style="width:36px;" class="text-muted">#</th>
          <th class="sortable" data-field="name"><%- t("roles.name") %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th class="d-none d-md-table-cell"><%- t("nav.permissions") %></th>
          <th><%- t("users.status") %></th>
          <th class="text-end" style="width:100px;"><%- t("general.actions") %></th>
        </tr>
      </thead>
      <tbody id="tableBody">
        <tr><td colspan="5" class="text-center py-5 text-muted">
          <div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t("general.loading") %>
        </td></tr>
      </tbody>
    </table>
  </div>

  <div class="card-footer d-flex align-items-center flex-wrap gap-2">
    <div class="text-muted small" id="tableInfo"></div>
    <div class="ms-auto" id="tablePagination"></div>
  </div>
</div>

<% include ../partials/usage-modal %>

<% block('scripts', '<link rel="stylesheet" href="/css/permissions.css"/><script src="/js/pages/roles.js"></script>') %>
