<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
    <meta http-equiv="X-UA-Compatible" content="ie=edge"/>
    <title><%- page_title %> | <%- APP_NAME %></title>

    <!-- Tabler CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/css/tabler.min.css"/>
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"/>
    <!-- DataTables Bootstrap5 -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css"/>
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css"/>
    <!-- Toastr -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css"/>
    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"/>
    <!-- Custom -->
    <link rel="stylesheet" href="/css/app.css"/>

    <!-- Theme & font driven by user settings -->
    <style>
        :root {
            --tblr-primary:   <%- (settings && settings.theme_color) ? settings.theme_color : '#0054a6' %>;
            --tblr-font-size: <%- (settings && settings.font_size)   ? settings.font_size   : '14px'    %>;
        }
    </style>
</head>

<%
var bodyClass = (settings && settings.dark_mode == '1') ? 'antialiased theme-dark' : 'antialiased';
%>
<body class="<%- bodyClass %>">

<!-- Page-loading overlay -->
<div id="page-loading">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<div class="wrapper">

    <!-- ── SIDEBAR ──────────────────────────────── -->
    <% include ../partials/sidebar %>

    <!-- ── MAIN PAGE WRAPPER ────────────────────── -->
    <div class="page-wrapper">

        <!-- ── MOBILE TOPBAR (visible < 992px) ──── -->
        <div class="mobile-topbar d-lg-none">
            <button class="btn-menu" id="btnMobileMenu" aria-label="Open menu">
                <i class="ti ti-menu-2"></i>
            </button>
            <span class="page-title-mobile"><%- page_title %></span>
            <!-- Dark mode toggle on mobile -->
            <label class="form-check form-switch mb-0 me-2" title="Dark mode">
                <input class="form-check-input" type="checkbox" id="darkModeToggleMobile"
                       <%- (settings && settings.dark_mode == '1') ? 'checked' : '' %>>
            </label>
            <!-- User avatar dropdown on mobile -->
            <div class="dropdown">
                <div class="mobile-user-avatar" data-bs-toggle="dropdown">
                    <%- user ? user.name.charAt(0).toUpperCase() : 'U' %>
                </div>
                <div class="dropdown-menu dropdown-menu-end">
                    <div class="dropdown-header">
                        <strong><%- user ? user.name : '' %></strong>
                        <div class="text-secondary" style="font-size:12px;"><%- user ? user.email : '' %></div>
                    </div>
                    <div class="dropdown-divider"></div>
                    <a href="/profile"  class="dropdown-item"><i class="ti ti-user me-2"></i>Profile</a>
                    <a href="/settings" class="dropdown-item"><i class="ti ti-settings me-2"></i>Settings</a>
                    <div class="dropdown-divider"></div>
                    <a href="/logout"   class="dropdown-item text-danger"><i class="ti ti-logout me-2"></i>Logout</a>
                </div>
            </div>
        </div>

        <!-- ── DESKTOP HEADER (visible ≥ 992px) ─── -->
        <% include ../partials/header %>

        <!-- ── PAGE CONTENT ─────────────────────── -->
        <div class="page-body" id="divMainContainer">
            <div class="container-xl">

                <% if (locals.breadcrumbs && breadcrumbs.length > 0) { %>
                <div class="page-header d-print-none mb-3">
                    <div class="row align-items-center">
                        <div class="col">
                            <h2 class="page-title"><%- page_title %></h2>
                            <ol class="breadcrumb" aria-label="breadcrumbs">
                                <% breadcrumbs.forEach(function(crumb, i) { %>
                                    <% if (i === breadcrumbs.length - 1) { %>
                                        <li class="breadcrumb-item active"><a href="#"><%- crumb.name %></a></li>
                                    <% } else { %>
                                        <li class="breadcrumb-item"><a href="<%- crumb.url %>"><%- crumb.name %></a></li>
                                    <% } %>
                                <% }) %>
                            </ol>
                        </div>
                    </div>
                </div>
                <% } %>

                <%- body %>

            </div>
        </div>

        <!-- ── FOOTER ────────────────────────────── -->
        <% include ../partials/footer %>

    </div>
</div>

<!-- Global modal -->
<div class="modal fade" id="myModal" tabindex="-1"></div>

<!-- ── SCRIPTS ────────────────────────────────────── -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="/js/app.js"></script>

<script>
    var BASE_URL = '<%- BASE_URL %>';

    toastr.options = {
        closeButton: true, progressBar: true,
        positionClass: 'toast-top-right', timeOut: 4500,
        preventDuplicates: true,
    };
    <% if (locals.flash_success) { %>
    $(function(){ toastr.success('<%- (flash_success||"").replace(/'/g,"\\'") %>'); });
    <% } %>
    <% if (locals.flash_error) { %>
    $(function(){ toastr.error('<%- (flash_error||"").replace(/'/g,"\\'") %>'); });
    <% } %>

    // ── Mobile sidebar toggle ─────────────────────
    $(function () {
        var $sidebar = $('.navbar-vertical');
        var $body    = $('body');

        // Open
        $('#btnMobileMenu').on('click', function (e) {
            e.stopPropagation();
            $sidebar.addClass('show');
            $body.addClass('sidebar-open');
        });

        // Close on backdrop click
        $body.on('click', function (e) {
            if ($body.hasClass('sidebar-open') && !$sidebar.is(e.target) && !$sidebar.has(e.target).length) {
                $sidebar.removeClass('show');
                $body.removeClass('sidebar-open');
            }
        });

        // Close on nav link click (mobile)
        $sidebar.find('a.nav-link, a.dropdown-item').on('click', function () {
            if ($(window).width() < 992) {
                $sidebar.removeClass('show');
                $body.removeClass('sidebar-open');
            }
        });

        // Swipe-left to close sidebar on mobile
        var touchStartX = 0;
        document.addEventListener('touchstart', function (e) {
            touchStartX = e.changedTouches[0].clientX;
        }, { passive: true });
        document.addEventListener('touchend', function (e) {
            var dx = e.changedTouches[0].clientX - touchStartX;
            if (dx < -60 && $body.hasClass('sidebar-open')) {
                $sidebar.removeClass('show');
                $body.removeClass('sidebar-open');
            }
        }, { passive: true });

        // Dark mode toggle — mobile
        $('#darkModeToggleMobile').on('change', function () {
            $.post('/settings/user', { dark_mode: $(this).is(':checked') ? '1' : '0' }, function () {
                location.reload();
            });
        });

        // ── Flatpickr on all date inputs ─────────
        $('input[type="date"]').flatpickr({ dateFormat: 'Y-m-d', allowInput: true });
    });
</script>

</body>
</html>
