<%
var s         = settings || {};
var isDark    = s.dark_mode === '1';
var isRTL     = s.direction === 'rtl';
var collapsed = s.sidebar_collapsed === '1';
var themeColor= s.theme_color  || '#0054a6';
var fontSize  = s.font_size    || '14px';
var curLang   = lang           || 'en';
var _rmap     = {none:'0',sm:'4px',md:'8px',lg:'12px',xl:'16px'};
var borderRad = _rmap[s.border_radius] || '8px';
var bodyClass = 'antialiased' + (isDark ? ' theme-dark' : '') + (collapsed ? ' sms-sb-collapsed' : '');
var htmlDir   = isRTL ? 'rtl' : 'ltr';
%>
<!DOCTYPE html>
<html dir="<%- htmlDir %>" lang="<%- curLang %>">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
<meta http-equiv="X-UA-Compatible" content="ie=edge"/>
<title><%- page_title %> | <%- APP_NAME %></title>
<link rel="icon" type="image/svg+xml" href="/images/favicon.svg"/>

<!-- ALL LOCAL — no CDN -->
<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" crossorigin="anonymous"/>
<link rel="stylesheet" href="/libs/css/tabler.min.css"/>
<% if (isRTL) { %>
<link rel="stylesheet" href="/libs/css/tabler-rtl.min.css"/>
<% } %>
<link rel="stylesheet" href="/libs/css/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/libs/css/dataTables.bootstrap5.min.css"/>
<link rel="stylesheet" href="/libs/css/select2.min.css"/>
<link rel="stylesheet" href="/libs/css/select2-bootstrap-5-theme.min.css"/>
<link rel="stylesheet" href="/libs/css/toastr.min.css"/>
<link rel="stylesheet" href="/libs/css/flatpickr.min.css"/>
<link rel="stylesheet" href="/css/app.css"/>
<link rel="stylesheet" href="/css/modern-theme.css"/>
<link rel="stylesheet" href="/css/phone-group.css"/>
<%- block('styles') %>

<style>
:root{
  --tblr-primary:          <%- themeColor %>;
  --sms-text:              <%- (settings && settings.text_color) || '#1a2332' %>;
  --tblr-body-color:       <%- (settings && settings.text_color) || '#1a2332' %>;
  --sms-icon-color:        <%- (settings && settings.icon_color && settings.icon_color !== 'theme') ? settings.icon_color : ((settings && settings.theme_color) || '#0054a6') %>;
  --tblr-font-size:        <%- fontSize %>;
  --tblr-border-radius:    <%- borderRad %>;
  --tblr-border-radius-sm: calc(<%- borderRad %> * .6);
  --tblr-border-radius-lg: calc(<%- borderRad %> * 1.5);
}
</style>
</head>
<body class="<%- bodyClass %>">

<!-- Page loader -->
<div id="sms-loader"><div class="sms-loader-spin"></div></div>

<div class="wrapper">
  <% include ../partials/sidebar %>
  <div class="page-wrapper">
    <% include ../partials/header %>
    <div class="page-body">
      <div class="container-xl">

        <% if (locals.breadcrumbs && breadcrumbs.length > 0) { %>
        <div class="page-header d-print-none">
          <div class="row align-items-center">
            <div class="col">
              <div class="page-pretitle">
                <% breadcrumbs.slice(0,-1).forEach(function(c,i){ %>
                <a href="<%- c.url %>"><%- c.name %></a><% if(i<breadcrumbs.length-2){ %> / <% } %>
                <% }) %>
              </div>
              <h2 class="page-title"><%- page_title %></h2>
            </div>
          </div>
        </div>
        <% } %>

        <%- body %>

      </div>
    </div>
    <% include ../partials/footer %>
  </div>
</div>

<% include ../partials/theme-panel %>
<div class="modal fade" id="smsModal" tabindex="-1" aria-hidden="true"></div>

<!-- ═══ ALL SCRIPTS — jQuery first, then everything else ═══ -->
<script src="/libs/js/jquery.min.js"></script>
<script src="/libs/js/tabler.min.js"></script>
<script src="/libs/js/jquery.dataTables.min.js"></script>
<script src="/libs/js/dataTables.bootstrap5.min.js"></script>
<script src="/libs/js/select2.min.js"></script>
<script src="/libs/js/jquery.validate.min.js"></script>
<script src="/libs/js/flatpickr.min.js"></script>
<script src="/libs/js/toastr.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@ffmpeg/ffmpeg@0.11.6/dist/ffmpeg.min.js" crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" crossorigin="anonymous"></script>
<script>
/* Patch Fabric.js 5.x — fix deprecated 'alphabetical' textBaseline for modern Chrome */
(function(){if(typeof fabric!=='undefined'&&fabric.Text){var _o=fabric.Text.prototype._renderTextCommon;if(_o){fabric.Text.prototype._renderTextCommon=function(ctx,method){var _s=ctx.__lookupSetter__?null:undefined;try{_o.call(this,ctx,method);}catch(e){}};}}
if(typeof CanvasRenderingContext2D!=='undefined'){var _d=Object.getOwnPropertyDescriptor(CanvasRenderingContext2D.prototype,'textBaseline');if(_d&&_d.set){var origSet=_d.set;Object.defineProperty(CanvasRenderingContext2D.prototype,'textBaseline',{set:function(v){origSet.call(this,v==='alphabetical'?'alphabetic':v);},get:_d.get,configurable:true});}}})();
</script>
<script src="/js/app.js"></script>
<script src="/js/notifications.js"></script>

<script>
/* ── Global constants (jQuery already loaded above) ── */
var BASE_URL     = '<%- BASE_URL %>';
var SMS_LANG     = '<%- curLang %>';
var SMS_IS_RTL   = <%- isRTL ? 'true' : 'false' %>;
var SMS_SETTINGS = <%- JSON.stringify(s) %>;
var SMS_T_DICT   = <%- langDict_json %>;
function SMS_T(k,f){ return SMS_T_DICT[k]||f||k; }

window.H = window.H||{};
H.esc = function(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); };
H.trunc = function(s, max, cls) {
    if (!s) return '';
    max = max || 20;
    var e = H.esc(String(s));
    if (String(s).length <= max) return '<span'+(cls?' class="'+cls+'"':'')+'>'+e+'</span>';
    var short = H.esc(String(s).substring(0, max)) + '…';
    return '<span'+(cls?' class="'+cls+'"':'')+' title="'+e+'" data-bs-toggle="tooltip" data-bs-placement="top">'+short+'</span>';
};

var SMS_PENDING_THEME = {
  theme_color:   SMS_SETTINGS.theme_color   || '#0054a6',
  text_color:    SMS_SETTINGS.text_color    || '#1a2332',
  icon_color:    SMS_SETTINGS.icon_color    || 'theme',
  dark_mode:     SMS_SETTINGS.dark_mode      || '0',
  direction:     SMS_SETTINGS.direction      || 'ltr',
  border_radius: SMS_SETTINGS.border_radius  || 'md',
  font_size:     SMS_SETTINGS.font_size       || '14px',
  sidebar_style: SMS_SETTINGS.sidebar_style  || 'dark',
  language:      SMS_SETTINGS.language       || 'en',
};

var _RM = {none:'0',sm:'4px',md:'8px',lg:'12px',xl:'16px'};
function smsLiveTheme(){
  var r = document.documentElement, rad = _RM[SMS_PENDING_THEME.border_radius]||'8px';
  r.style.setProperty('--tblr-primary',         SMS_PENDING_THEME.theme_color);
  r.style.setProperty('--sms-text',              SMS_PENDING_THEME.text_color);
  r.style.setProperty('--tblr-body-color',       SMS_PENDING_THEME.text_color);
  var _ic = SMS_PENDING_THEME.icon_color === 'theme' ? SMS_PENDING_THEME.theme_color : SMS_PENDING_THEME.icon_color;
  r.style.setProperty('--sms-icon-color',        _ic);
  r.style.setProperty('--tblr-font-size',        SMS_PENDING_THEME.font_size);
  r.style.setProperty('--tblr-border-radius',    rad);
  r.style.setProperty('--tblr-border-radius-sm', 'calc('+rad+'*.6)');
  r.style.setProperty('--tblr-border-radius-lg', 'calc('+rad+'*1.5)');
  SMS_PENDING_THEME.dark_mode==='1' ? $('body').addClass('theme-dark') : $('body').removeClass('theme-dark');
}

toastr.options = {
  closeButton:true, progressBar:true,
  positionClass: SMS_IS_RTL ? 'toast-top-left' : 'toast-top-right',
  timeOut:4500, preventDuplicates:true
};

<% if (locals.flash_success) { %>
$(function(){ toastr.success("<%- (flash_success||'').replace(/\\/g,'\\\\').replace(/"/g,'\\"') %>"); });
<% } %>
<% if (locals.flash_error) { %>
$(function(){ toastr.error("<%- (flash_error||'').replace(/\\/g,'\\\\').replace(/"/g,'\\"') %>"); });
<% } %>

$(function(){
  /* ── Sidebar: mobile open/close ── */
  /* ════════════════════════════════════════
     SIDEBAR — Mobile + Desktop + Flyout/Tooltip
  ════════════════════════════════════════ */
  var $sb  = $('#smsSidebar');
  var $bd  = $('#smsSidebarBackdrop');
  var SB_KEY = 'sms_sb_collapsed';

  /* ── Mobile: open / close ── */
  function openMobileSb(){
    $sb.addClass('sms-sidebar--open');
    $bd.addClass('show');
    $('body').css('overflow','hidden');
  }
  function closeMobileSb(){
    $sb.removeClass('sms-sidebar--open');
    $bd.removeClass('show');
    $('body').css('overflow','');
  }
  $('#smsBtnMenu').on('click', function(e){ e.stopPropagation(); openMobileSb(); });
  $bd.on('click', closeMobileSb);
  $sb.on('click','.sms-nav__link:not([data-bs-toggle]),.sms-subnav__link,.sms-flyout__link',function(){
    if($(window).width()<992){ closeMobileSb(); }
  });

  /* ── Desktop: collapse / expand ── */
  var isCollapsed = localStorage.getItem(SB_KEY) === '1';

  function setSidebarCollapsed(collapsed, save){
    isCollapsed = collapsed;
    if(collapsed){
      $sb.addClass('sms-sidebar--collapsed');
      $('body').addClass('sms-sb-collapsed');
      $('#smsToggleIcon').removeClass('bi-layout-sidebar').addClass('bi-layout-sidebar-reverse');
    } else {
      $sb.removeClass('sms-sidebar--collapsed');
      $('body').removeClass('sms-sb-collapsed');
      $('#smsToggleIcon').removeClass('bi-layout-sidebar-reverse').addClass('bi-layout-sidebar');
      /* Close any open flyout/tooltip when expanding */
      hideAllFlyouts(false);
    }
    if(save){
      localStorage.setItem(SB_KEY, collapsed ? '1' : '0');
      $.post(BASE_URL+'/settings/theme',{sidebar_collapsed: collapsed?'1':'0'}).fail(function(){});
    }
  }

  if($(window).width() >= 992){
    $sb.css('transition','none');
    setSidebarCollapsed(isCollapsed, false);
    setTimeout(function(){ $sb.css('transition',''); }, 50);
  }

  $('#smsSidebarToggle').on('click', function(){
    setSidebarCollapsed(!isCollapsed, true);
  });

  $(window).on('resize', function(){
    if($(window).width() < 992){ closeMobileSb(); hideAllFlyouts(false); }
    else { setSidebarCollapsed(isCollapsed, false); }
  });

  /* ════════════════════════════════════════
     FLYOUT + TOOLTIP — collapsed sidebar
     Key fixes:
     1. Flyout/tooltip wrapper is flush with sidebar (no gap)
     2. Click icon → pin flyout open (stays until click elsewhere)
     3. Hover icon → show flyout, leave to flyout → keep open
  ════════════════════════════════════════ */
  var $pinnedFlyout  = null;   /* currently pinned (clicked) flyout */
  var $hoveredFlyout = null;   /* currently hovered flyout */
  var hideTimer      = null;

  function showFlyout($flyout, $item) {
    hideAllFlyouts(true);
    var rect = $item[0].getBoundingClientRect();
    $flyout.css({ top: rect.top + 'px', display: 'block' });
    $hoveredFlyout = $flyout;
  }

  function hideAllFlyouts(keepPinned) {
    clearTimeout(hideTimer);
    $('.sms-flyout:visible').each(function(){
      if(keepPinned && $(this).hasClass('sms-flyout--pinned')) return;
      $(this).hide().removeClass('sms-flyout--pinned');
    });
    $('.sms-tooltip:visible').hide();
    if(!keepPinned) { $pinnedFlyout = null; }
    $hoveredFlyout = null;
  }

  /* Click outside → close pinned */
  $(document).on('click.flyout', function(e){
    if(!$(e.target).closest('.sms-flyout, .sms-nav__item').length){
      hideAllFlyouts(false);
    }
  });

  /* ── Flyout items (parent with children) ── */

  /* Hover on nav item → show flyout */
  $sb.on('mouseenter.flyout', '.sms-has-flyout', function(){
    if(!isCollapsed || $(window).width() < 992) return;
    clearTimeout(hideTimer);
    var $item   = $(this);
    var $flyout = $item.find('.sms-flyout');
    if(!$flyout.length || $flyout.hasClass('sms-flyout--pinned')) return;
    showFlyout($flyout, $item);
  });

  /* Leave nav item → start hide timer (cancelled if entering flyout panel) */
  $sb.on('mouseleave.flyout', '.sms-has-flyout', function(e){
    if(!isCollapsed) return;
    var $flyout = $(this).find('.sms-flyout');
    if($flyout.hasClass('sms-flyout--pinned')) return;
    /* Small delay — mouse travelling to flyout panel */
    hideTimer = setTimeout(function(){
      if($hoveredFlyout && !$flyout.is(':hover')){
        $flyout.hide();
        $hoveredFlyout = null;
      }
    }, 150);
  });

  /* Mouse enters flyout panel → cancel hide */
  $sb.on('mouseenter.flyout', '.sms-flyout', function(){
    clearTimeout(hideTimer);
    $hoveredFlyout = $(this);
  });

  /* Mouse leaves flyout panel → hide (unless pinned) */
  $sb.on('mouseleave.flyout', '.sms-flyout', function(){
    if($(this).hasClass('sms-flyout--pinned')) return;
    var $f = $(this);
    hideTimer = setTimeout(function(){ $f.hide(); $hoveredFlyout = null; }, 80);
  });

  /* Click icon → PIN flyout (stays open until click elsewhere) */
  $sb.on('click.flyout', '.sms-has-flyout > .sms-nav__link', function(e){
    if(!isCollapsed || $(window).width() < 992) return;
    e.preventDefault(); e.stopPropagation();
    var $item   = $(this).parent();
    var $flyout = $item.find('.sms-flyout');
    if(!$flyout.length) return;

    if($flyout.hasClass('sms-flyout--pinned')){
      /* Already pinned → unpin and close */
      $flyout.hide().removeClass('sms-flyout--pinned');
      $pinnedFlyout = null;
    } else {
      /* Unpin any previously pinned */
      if($pinnedFlyout) {
        $pinnedFlyout.hide().removeClass('sms-flyout--pinned');
      }
      showFlyout($flyout, $item);
      $flyout.addClass('sms-flyout--pinned');
      $pinnedFlyout = $flyout;
    }
  });

  /* ── Tooltip items (no children) ── */
  $sb.on('mouseenter.tooltip', '.sms-has-tooltip', function(){
    if(!isCollapsed || $(window).width() < 992) return;
    var $item    = $(this);
    var $tooltip = $item.find('.sms-tooltip');
    if(!$tooltip.length) return;
    hideAllFlyouts(true);
    var rect = $item[0].getBoundingClientRect();
    $tooltip.css({
      top: (rect.top + rect.height/2) + 'px',
      transform: 'translateY(-50%)',
      display: 'block'
    });
  });
  $sb.on('mouseleave.tooltip', '.sms-has-tooltip', function(){
    $(this).find('.sms-tooltip').hide();
  });

  /* ── Hide loader ── */
  $('#sms-loader').addClass('hide');
  setTimeout(function(){ $('#sms-loader').hide(); }, 300);

  /* ── Year fill ── */
  var yr = document.getElementById('sms-year');
  if(yr) yr.textContent = new Date().getFullYear();

  /* ── Flatpickr ── */
  if(typeof flatpickr !== 'undefined'){
    $('input[type="date"]').flatpickr({ dateFormat:'Y-m-d', allowInput:true });
  }

  /* ── Dark mode toggle ── */
  $(document).on('change','#smsDarkToggle,#smsDarkToggleMobile', function(){
    $.post(BASE_URL+'/settings/theme',{dark_mode:$(this).is(':checked')?'1':'0'},function(r){
      if(r.status===200) location.reload();
    });
  });

  /* ── Language switch ── */
  $(document).on('click','.sms-lang-btn',function(e){
    e.preventDefault();
    var lg=$(this).data('lang'); if(!lg) return;
    $.post(BASE_URL+'/settings/language',{lang:lg},function(r){
      if(r.status===200) location.reload();
      else toastr.error(SMS_T('general.error','Error'));
    });
  });

  /* ── Theme panel open/close ── */
  $(document).on('click','#smsBtnTheme,#smsBtnThemeMobile',function(){
    $('#smsThemePanel').addClass('open'); $('#smsThemeBd').addClass('show');
  });
  $(document).on('click','#smsThemeBd,#smsBtnCloseTheme',function(){
    $('#smsThemePanel').removeClass('open'); $('#smsThemeBd').removeClass('show');
  });

  /* ── Theme panel: colour ── */
  $(document).on('click','.tp-color[data-color]',function(){
    var c=$(this).data('color');
    $('.tp-color').removeClass('active').empty();
    $(this).addClass('active').html('<i class="bi bi-check-lg"></i>');
    SMS_PENDING_THEME.theme_color=c; smsLiveTheme();
  });
  $(document).on('input','#tpCustomColor',function(){
    $('.tp-color[data-color]').removeClass('active').empty();
    SMS_PENDING_THEME.theme_color=$(this).val(); smsLiveTheme();
  });
  /* Icon colour */
  $(document).on('click','.tp-icon-color[data-icon-color]',function(){
    var c=$(this).data('icon-color');
    $('.tp-icon-color').removeClass('active').empty();
    $(this).addClass('active').html('<i class="bi bi-check-lg" style="color:#fff;"></i>');
    SMS_PENDING_THEME.icon_color=c; smsLiveTheme();
  });
  $(document).on('input','#tpCustomIconColor',function(){
    $('.tp-icon-color[data-icon-color]').removeClass('active').empty();
    SMS_PENDING_THEME.icon_color=$(this).val(); smsLiveTheme();
  });
  /* Text colour */
  $(document).on('click','.tp-text-color[data-text-color]',function(){
    var c=$(this).data('text-color');
    $('.tp-text-color').removeClass('active').empty();
    $(this).addClass('active').html('<i class="bi bi-check-lg" style="color:#fff;"></i>');
    SMS_PENDING_THEME.text_color=c; smsLiveTheme();
  });
  $(document).on('input','#tpCustomTextColor',function(){
    $('.tp-text-color[data-text-color]').removeClass('active').empty();
    SMS_PENDING_THEME.text_color=$(this).val(); smsLiveTheme();
  });

  /* ── Theme panel: buttons ── */
  $(document).on('click','.tp-btn[data-mode]',function(){
    $(this).closest('.tp-group').find('.tp-btn').removeClass('active');
    $(this).addClass('active');
    SMS_PENDING_THEME.dark_mode=$(this).data('mode')==='dark'?'1':'0'; smsLiveTheme();
  });
  $(document).on('click','.tp-btn[data-dir]',function(){
    $(this).closest('.tp-group').find('.tp-btn').removeClass('active');
    $(this).addClass('active'); SMS_PENDING_THEME.direction=$(this).data('dir');
  });
  $(document).on('click','.tp-btn[data-radius]',function(){
    $(this).closest('.tp-group').find('.tp-btn').removeClass('active');
    $(this).addClass('active'); SMS_PENDING_THEME.border_radius=$(this).data('radius'); smsLiveTheme();
  });
  $(document).on('click','.tp-btn[data-font]',function(){
    $(this).closest('.tp-group').find('.tp-btn').removeClass('active');
    $(this).addClass('active'); SMS_PENDING_THEME.font_size=$(this).data('font'); smsLiveTheme();
  });
  $(document).on('click','.tp-btn[data-sb]',function(){
    $(this).closest('.tp-group').find('.tp-btn').removeClass('active');
    $(this).addClass('active'); SMS_PENDING_THEME.sidebar_style=$(this).data('sb');
  });
  $(document).on('click','.tp-btn[data-lang]',function(){
    $(this).closest('.tp-group').find('.tp-btn').removeClass('active');
    $(this).addClass('active'); SMS_PENDING_THEME.language=$(this).data('lang');
  });

  /* ── Theme panel: save ── */
  $(document).on('click','#smsBtnSaveTheme',function(){
    var $b=$(this).prop('disabled',true).html('<span class="spinner-border spinner-border-sm me-1"></span>');
    $.post(BASE_URL+'/settings/theme',SMS_PENDING_THEME,function(r){
      $b.prop('disabled',false).html('<i class="bi bi-floppy me-1"></i>Save');
      if(r.status===200){
        var reload = SMS_PENDING_THEME.language!==      (SMS_SETTINGS.language     ||'en') ||
                     SMS_PENDING_THEME.direction!==     (SMS_SETTINGS.direction    ||'ltr')||
                     SMS_PENDING_THEME.dark_mode!==     (SMS_SETTINGS.dark_mode    ||'0') ||
                     SMS_PENDING_THEME.sidebar_style!==(SMS_SETTINGS.sidebar_style||'dark');
        if(reload){ location.reload(); }
        else{ toastr.success(SMS_T('settings.saved','Saved.')); Object.assign(SMS_SETTINGS,SMS_PENDING_THEME);
              $('#smsThemePanel').removeClass('open'); $('#smsThemeBd').removeClass('show'); }
      } else toastr.error(SMS_T('general.error','Error saving.'));
    }).fail(function(){ $b.prop('disabled',false).html('<i class="bi bi-floppy me-1"></i>Save'); toastr.error(SMS_T('general.error')); });
  });

  /* ── Theme panel: reset ── */
  $(document).on('click','#smsBtnResetTheme',function(){
    $.post(BASE_URL+'/settings/theme',{theme_color:'#0054a6',dark_mode:'0',direction:'ltr',
      border_radius:'md',font_size:'14px',sidebar_style:'dark',language:'en'},function(r){
      if(r.status===200) location.reload();
    });
  });

  /* ── Offcanvas form: icon picker (Bootstrap Icons) ── */
  $(document).on('input','#iconInput',function(){
    $('#iconPreviewI').attr('class','bi '+($(this).val().trim()||'bi-circle'));
  });
  $(document).on('click','.icon-pick',function(){
    var ic=$(this).data('icon');
    $('#iconInput').val(ic); $('#iconPreviewI').attr('class','bi '+ic);
  });

  /* ── Roles form: permissions matrix ── */
  $(document).on('change','.group-toggle',function(){
    var g=$(this).data('group');
    $('.perm-check[data-group="'+g+'"]').prop('checked',$(this).is(':checked'));
  });
  $(document).on('click','#btnSelectAll',function(){
    $('.perm-check,.group-toggle').prop('checked',true);
  });
  $(document).on('click','#btnClearAll',function(){
    $('.perm-check,.group-toggle').prop('checked',false);
  });
});
</script>

<%- block('scripts') %>
</body>
</html>
