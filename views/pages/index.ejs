<%- layout('../layouts/main') %>

<div class="card shadow-sm">

  <!-- ── Card header matching users/roles style ── -->
  <div class="card-header py-3 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto">
        <i class="bi bi-file-earmark-ruled me-2 text-primary"></i>Legal Pages
        <span class="badge bg-secondary-lt rounded-pill ms-1" style="font-size:11px;vertical-align:middle;"><%- pages ? pages.length : 0 %></span>
      </h3>
    </div>
  </div>

  <div class="card-body">
    <p class="text-muted mb-4" style="font-size:13px;">
      <i class="bi bi-info-circle me-1"></i>
      Manage your Terms &amp; Conditions and Privacy Policy. Changes reflect immediately on public pages visible to all visitors.
    </p>

    <% if (pages && pages.length > 0) { %>
    <div class="row g-3">
      <% pages.forEach(function(pg) { %>
      <div class="col-md-6">
        <div class="card border shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex align-items-start gap-3">

              <!-- Icon -->
              <div class="flex-shrink-0">
                <% if (pg.slug === 'terms') { %>
                <span class="avatar avatar-lg rounded-3 bg-primary-lt">
                  <i class="bi bi-file-earmark-text" style="font-size:24px;"></i>
                </span>
                <% } else if (pg.slug === 'privacy') { %>
                <span class="avatar avatar-lg rounded-3 bg-green-lt">
                  <i class="bi bi-shield-lock" style="font-size:24px;"></i>
                </span>
                <% } else { %>
                <span class="avatar avatar-lg rounded-3 bg-azure-lt">
                  <i class="bi bi-file-earmark-ruled" style="font-size:24px;"></i>
                </span>
                <% } %>
              </div>

              <!-- Details -->
              <div class="flex-fill">
                <div class="d-flex align-items-center justify-content-between mb-1">
                  <h4 class="mb-0" style="font-size:16px;font-weight:700;"><%- pg.title %></h4>
                  <% if (parseInt(pg.status)) { %>
                  <span class="badge bg-success-lt"><i class="bi bi-check-circle me-1"></i>Published</span>
                  <% } else { %>
                  <span class="badge bg-secondary-lt"><i class="bi bi-pencil me-1"></i>Draft</span>
                  <% } %>
                </div>

                <div class="text-muted mb-3" style="font-size:12px;">
                  <i class="bi bi-link-45deg me-1"></i>
                  <a href="/<%- pg.slug %>" target="_blank" class="text-muted text-decoration-underline">/<%- pg.slug %></a>
                  <span class="mx-1">&middot;</span>
                  <i class="bi bi-clock me-1"></i>
                  <%- pg.updated_at ? H.formatDateTimeSetting(pg.updated_at, settings) : 'Never updated' %>
                </div>

                <div class="d-flex gap-2">
                  <a href="/pages/<%- pg.uuid %>/edit" class="btn btn-primary btn-sm px-3">
                    <i class="bi bi-pencil-square me-1"></i> Edit Content
                  </a>
                  <a href="/<%- pg.slug %>" target="_blank" class="btn btn-outline-secondary btn-sm px-3">
                    <i class="bi bi-eye me-1"></i> Preview
                  </a>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-file-earmark-ruled d-block mb-3" style="font-size:48px;opacity:.25;"></i>
      <h3 class="text-muted mb-2">No pages found</h3>
      <p class="text-muted mb-0">Run the seeder: <code>npx knex seed:run --specific=0007_pages_seeder.js</code></p>
    </div>
    <% } %>
  </div>
</div>
