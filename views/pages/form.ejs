<%- layout('../layouts/main') %>

<% var pg = page || {}; %>

<div class="card shadow-sm mb-4">
  <div class="card-header py-3 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto d-flex align-items-center gap-2">
        <% if (pg.slug === 'terms') { %>
        <i class="bi bi-file-earmark-text text-primary" style="font-size:20px;"></i>
        <% } else if (pg.slug === 'privacy') { %>
        <i class="bi bi-shield-lock text-success" style="font-size:20px;"></i>
        <% } else if (pg.slug === 'faq') { %>
        <i class="bi bi-question-circle text-purple" style="font-size:20px;"></i>
        <% } else { %>
        <i class="bi bi-file-earmark-ruled text-primary" style="font-size:20px;"></i>
        <% } %>
        Edit: <%- pg.title %>
      </h3>
      <a href="/<%- pg.slug %>" target="_blank" class="btn btn-outline-secondary btn-sm px-3">
        <i class="bi bi-eye me-1"></i> Preview
      </a>
      <a href="/pages" class="btn btn-outline-secondary btn-sm px-3">
        <i class="bi bi-arrow-left me-1"></i> Back
      </a>
    </div>
  </div>
</div>

<form id="pageForm" autocomplete="off">
  <div class="row g-4">

    <!-- ═══ Main Editor ═══ -->
    <div class="col-lg-9">
      <div class="card shadow-sm">
        <div class="card-header py-2">
          <div class="card-title mb-0 d-flex align-items-center gap-2">
            <i class="bi bi-pencil-square text-primary"></i> Page Content
          </div>
        </div>
        <div class="card-body p-0">

          <!-- ── Toolbar ── -->
          <div style="display:flex;flex-wrap:wrap;align-items:center;gap:2px;padding:8px 12px;background:#f8fafc;border-bottom:1px solid #e9ecef;">
            <div class="d-flex align-items-center gap-1">
              <button type="button" class="ed-btn" data-cmd="bold" title="Bold"><i class="bi bi-type-bold"></i></button>
              <button type="button" class="ed-btn" data-cmd="italic" title="Italic"><i class="bi bi-type-italic"></i></button>
              <button type="button" class="ed-btn" data-cmd="underline" title="Underline"><i class="bi bi-type-underline"></i></button>
              <button type="button" class="ed-btn" data-cmd="strikeThrough" title="Strike"><i class="bi bi-type-strikethrough"></i></button>
            </div>
            <span class="ed-sep"></span>
            <div class="d-flex align-items-center gap-1">
              <select id="edHeading" class="ed-select" title="Heading">
                <option value="">Normal</option>
                <option value="h2">Heading 2</option>
                <option value="h3">Heading 3</option>
                <option value="h4">Heading 4</option>
              </select>
            </div>
            <span class="ed-sep"></span>
            <div class="d-flex align-items-center gap-1">
              <button type="button" class="ed-btn" data-cmd="insertUnorderedList" title="Bullet List"><i class="bi bi-list-ul"></i></button>
              <button type="button" class="ed-btn" data-cmd="insertOrderedList" title="Numbered List"><i class="bi bi-list-ol"></i></button>
            </div>
            <span class="ed-sep"></span>
            <div class="d-flex align-items-center gap-1">
              <button type="button" class="ed-btn" data-cmd="justifyLeft" title="Align Left"><i class="bi bi-text-left"></i></button>
              <button type="button" class="ed-btn" data-cmd="justifyCenter" title="Center"><i class="bi bi-text-center"></i></button>
            </div>
            <span class="ed-sep"></span>
            <div class="d-flex align-items-center gap-1">
              <button type="button" class="ed-btn" id="btnLink" title="Insert Link"><i class="bi bi-link-45deg"></i></button>
              <button type="button" class="ed-btn" data-cmd="unlink" title="Remove Link"><i class="bi bi-link"></i></button>
              <button type="button" class="ed-btn" id="btnHR" title="Horizontal Rule"><i class="bi bi-dash-lg"></i></button>
            </div>
            <span class="ed-sep"></span>
            <div class="d-flex align-items-center gap-1">
              <button type="button" class="ed-btn" data-cmd="undo" title="Undo"><i class="bi bi-arrow-counterclockwise"></i></button>
              <button type="button" class="ed-btn" data-cmd="redo" title="Redo"><i class="bi bi-arrow-clockwise"></i></button>
            </div>
            <span class="ed-sep"></span>
            <div class="d-flex align-items-center gap-1">
              <button type="button" class="ed-btn" id="btnSource" title="Toggle HTML Source"><i class="bi bi-code-slash"></i></button>
            </div>
          </div>

          <!-- ── Editable area ── -->
          <div id="edContent"
               class="sms-legal-body"
               contenteditable="true"
               spellcheck="true"
               style="min-height:500px;padding:2rem;outline:none;font-size:14px;line-height:1.85;color:#4a5568;"><%- pg.content || '' %></div>

          <!-- ── Source view (hidden) ── -->
          <textarea id="edSource"
                    style="display:none;width:100%;min-height:500px;border:none;padding:1.5rem;font-family:Consolas,Monaco,monospace;font-size:13px;line-height:1.7;background:#1e293b;color:#e2e8f0;resize:vertical;outline:none;"
                    spellcheck="false"></textarea>
        </div>
      </div>
    </div>

    <!-- ═══ Sidebar ═══ -->
    <div class="col-lg-3">
      <div class="card shadow-sm mb-3">
        <div class="card-header py-2">
          <div class="card-title mb-0"><i class="bi bi-gear me-2"></i>Settings</div>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Page Title</label>
            <input type="text" class="form-control" id="fTitle" value="<%- pg.title %>" required/>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">URL Slug</label>
            <input type="text" class="form-control bg-light" value="/<%- pg.slug %>" disabled readonly/>
            <small class="text-muted">Cannot be changed.</small>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Status</label>
            <select class="form-select" id="fStatus">
              <option value="1" <%- pg.status == 1 ? 'selected' : '' %>>Published</option>
              <option value="0" <%- pg.status == 0 ? 'selected' : '' %>>Draft</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary w-100" id="btnSave">
            <i class="bi bi-check-lg me-1"></i> Save Changes
          </button>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <div class="text-muted" style="font-size:12px;">
            <div class="mb-2"><i class="bi bi-info-circle me-1 text-primary"></i><strong>Tips:</strong></div>
            <ul class="ps-3 mb-0" style="line-height:1.8;">
              <li>Use headings to structure sections</li>
              <li>Click <code>&lt;/&gt;</code> to edit raw HTML</li>
              <li>Changes go live on <a href="/<%- pg.slug %>" target="_blank">/<%- pg.slug %></a> after save</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

  </div>
</form>

<%
var _s = ''
+ '<style>'
+ '.ed-btn{display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border:none;background:transparent;border-radius:6px;color:#495057;font-size:15px;cursor:pointer;transition:all .15s}'
+ '.ed-btn:hover{background:#e9ecef;color:#212529}'
+ '.ed-btn.active{background:var(--tblr-primary);color:#fff}'
+ '.ed-sep{width:1px;height:22px;background:#dee2e6;margin:0 6px}'
+ '.ed-select{height:32px;padding:0 8px;border:1px solid #dee2e6;border-radius:6px;font-size:12px;background:#fff}'
+ '#edContent:focus{box-shadow:inset 0 0 0 2px rgba(0,84,166,.12)}'
+ '#edContent h3{font-size:16px;font-weight:700;color:#1a2332;margin:2.25rem 0 .85rem;padding-bottom:.6rem;border-bottom:2px solid #eef4ff;display:flex;align-items:center;gap:10px}'
+ '#edContent h3 .sec-num{font-size:13px;font-weight:700;color:#fff;background:#0054a6;border-radius:6px;padding:1px 8px;flex-shrink:0}'
+ '</style>'
+ '<script>'
+ '$(function(){'
+ 'var $ed=$("#edContent"),$src=$("#edSource"),sm=false;'
+ '$(document).on("click",".ed-btn[data-cmd]",function(e){e.preventDefault();if(sm)return;document.execCommand($(this).data("cmd"),false,null);$ed.focus();});'
+ '$("#edHeading").on("change",function(){if(sm)return;var v=$(this).val();document.execCommand("formatBlock",false,v?"<"+v+">":"<p>");$(this).val("");$ed.focus();});'
+ '$("#btnLink").on("click",function(e){e.preventDefault();if(sm)return;var u=prompt("Enter URL:","https://");if(u)document.execCommand("createLink",false,u);$ed.focus();});'
+ '$("#btnHR").on("click",function(e){e.preventDefault();if(sm)return;document.execCommand("insertHTML",false,"<hr/>");$ed.focus();});'
+ '$("#btnSource").on("click",function(e){e.preventDefault();if(sm){$ed.html($src.val());$src.hide();$ed.show().focus();$(this).removeClass("active");sm=false;}else{$src.val($ed.html());$ed.hide();$src.show().focus();$(this).addClass("active");sm=true;}});'
+ '$("#pageForm").on("submit",function(e){e.preventDefault();if(sm)$ed.html($src.val());var t=$("#fTitle").val().trim();if(!t){toastr.error("Title is required.");return;}'
+ 'var $b=$("#btnSave").prop("disabled",true).html(\'<span class="spinner-border spinner-border-sm me-1"></span>Saving...\');'
+ '$.ajax({url:"/pages/' + pg.uuid + '",type:"POST",contentType:"application/json",'
+ 'data:JSON.stringify({title:t,content:$ed.html(),status:$("#fStatus").val()}),'
+ 'success:function(r){$b.prop("disabled",false).html(\'<i class="bi bi-check-lg me-1"></i>Save Changes\');r.status===200?toastr.success(r.message||"Saved."):toastr.error(r.message||"Failed.");},'
+ 'error:function(){$b.prop("disabled",false).html(\'<i class="bi bi-check-lg me-1"></i>Save Changes\');toastr.error("Network error.");}'
+ '});});'
+ '});'
+ '<\/script>';
%>
<% block('scripts', _s) %>
