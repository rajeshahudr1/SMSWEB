<%- layout('../layouts/main') %>

<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto">
        <i class="bi bi-translate me-2"></i><%- t('master_lang.title') %>
        <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">-</span>
      </h3>

      <select class="form-select form-select-sm" id="perPageSel" style="width:90px;"></select>

      <!-- Export -->
      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
          <i class="bi bi-download me-1"></i><span class="d-none d-sm-inline"><%- t('btn.export', 'Export') %></span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li>
          <li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li>
        </ul>
      </div>

      <!-- Expand / Collapse all rows details -->
      <div class="btn-group btn-group-sm">
        <button class="btn btn-outline-secondary" id="btnExpandAll" title="Expand all rows">
          <i class="bi bi-chevron-bar-down"></i>
        </button>
        <button class="btn btn-outline-secondary" id="btnCollapseAll" title="Collapse all rows">
          <i class="bi bi-chevron-bar-up"></i>
        </button>
      </div>

      <!-- Add -->
      <button class="btn btn-sm btn-primary" onclick="openForm()">
        <i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline"><%- t('master_lang.add') %></span>
      </button>
    </div>
  </div>

  <!-- Filters -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <div class="col-12 col-sm-5 col-md-4">
        <input type="text" class="form-control form-control-sm" id="searchInput" placeholder="&#128269;  <%- t('general.search') %>..."/>
      </div>
      <div class="col-6 col-sm-3 col-md-2">
        <select class="form-select form-select-sm" id="filterStatus">
          <option value=""><%- t('general.all_status') %></option>
          <option value="1"><%- t('general.active') %></option>
          <option value="0"><%- t('general.inactive') %></option>
        </select>
      </div>
      <% if (typeof is_super_admin !== 'undefined' && is_super_admin) { %>
      <div class="col-6 col-sm-3 col-md-2">
        <select class="form-select form-select-sm" id="filterCompany">
          <option value=""><%- t('general.companies', 'Companies') %></option>
          <option value="global"><%- t('general.global_super_admin', 'Global (Super Admin)') %></option>
        </select>
      </div>
      <% } %>
      <div class="col-auto">
        <button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button>
      </div>
    </div>
  </div>

  <!-- Table -->
  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead>
        <tr>
          <th style="width:36px;" class="text-muted">#</th>
          <th style="width:50px;"><%- t('master_lang.flag') %></th>
          <th class="sortable" data-field="name"><%- t('master_lang.name') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th class="sortable" data-field="code"><%- t('master_lang.code') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th class="d-none d-md-table-cell"><%- t('master_lang.native_name') %></th>
          <% if (typeof is_super_admin !== 'undefined' && is_super_admin) { %>
          <th class="d-none d-md-table-cell"><%- t('general.company', 'Company') %></th>
          <% } %>
          <th><%- t('master_lang.default') %></th>
          <th class="sortable" data-field="sort_order"><%- t('master_lang.sort_order') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th><%- t('general.status') %></th>
          <th class="text-end" style="width:120px;"><%- t('general.actions') %></th>
        </tr>
      </thead>
      <tbody id="tableBody">
        <tr><td colspan="10" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t('general.loading') %></td></tr>
      </tbody>
    </table>
  </div>

  <div class="card-footer d-flex align-items-center flex-wrap gap-2">
    <div class="text-muted small" id="tableInfo"></div>
    <div class="ms-auto" id="tablePagination"></div>
  </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="modalForm" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width:560px;">
    <div class="modal-content">
      <div class="modal-header py-3">
        <h5 class="modal-title fw-semibold" id="modalTitle"><i class="bi bi-translate me-2"></i><%- t('master_lang.add') %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="frmLang" novalidate>
        <div class="modal-body">
          <input type="hidden" id="editUuid" value=""/>
          <% if (typeof is_super_admin !== 'undefined' && is_super_admin) { %>
          <div class="mb-3">
            <label class="form-label fw-medium"><i class="bi bi-building me-1 text-info"></i><%- t('general.company', 'Company') %></label>
            <select class="form-select" id="fCompany">
              <option value=""><%- t('general.global_super_admin', 'Global (Super Admin)') %></option>
            </select>
            <div class="form-hint"><%- t('general.company_hint', 'Select which company this record belongs to.') %></div>
          </div>
          <% } %>
          <div class="mb-3 pb-3 border-bottom" id="ddlWrap">
            <label class="form-label fw-medium"><i class="bi bi-list-check me-1 text-info"></i><%- t('master_lang.select_available') %></label>
            <select class="form-select" id="ddlAvailable" style="width:100%;"><option value="">- <%- t('master_lang.select_ph') %> -</option></select>
            <div class="form-hint mt-1"><%- t('master_lang.select_hint') %></div>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-medium"><%- t('master_lang.name') %> <span class="text-danger">*</span></label>
              <input type="text" name="name" id="fName" class="form-control" required placeholder="e.g. Hindi"/>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium"><%- t('master_lang.code') %> <span class="text-danger">*</span></label>
              <input type="text" name="code" id="fCode" class="form-control" required placeholder="e.g. hi-IN" maxlength="10"/>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium"><%- t('master_lang.native_name') %></label>
              <input type="text" name="native_name" id="fNative" class="form-control" placeholder="e.g. &#2361;&#2367;&#2306;&#2342;&#2368;"/>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-medium"><%- t('master_lang.flag') %></label>
              <input type="text" name="flag" id="fFlag" class="form-control text-center" placeholder="&#127470;&#127475;" maxlength="10" style="font-size:20px;"/>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-medium"><%- t('master_lang.sort_order') %></label>
              <input type="number" name="sort_order" id="fSort" class="form-control" value="0" min="0"/>
            </div>
            <div class="col-12">
              <div class="d-flex gap-3">
                <label class="form-check form-switch">
                  <input type="checkbox" class="form-check-input" name="is_default" id="fDefault" value="1"/>
                  <span class="form-check-label"><%- t('master_lang.default_language') %></span>
                </label>
                <label class="form-check form-switch">
                  <input type="checkbox" class="form-check-input" name="status" id="fStatus" value="1" checked/>
                  <span class="form-check-label"><%- t('general.active') %></span>
                </label>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer py-2">
          <button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.cancel') %></button>
          <button type="submit" class="btn btn-primary btn-sm" id="btnSave"><i class="bi bi-floppy me-1"></i><%- t('btn.save') %></button>
        </div>
      </form>
    </div>
  </div>
</div>

<% include ../partials/usage-modal %>

<script>var IS_SUPER=<%= (typeof is_super_admin !== 'undefined' && is_super_admin) ? 'true' : 'false' %>;</script>
<% block('scripts', '<script src="/js/pages/master-languages.js"></script>') %>
