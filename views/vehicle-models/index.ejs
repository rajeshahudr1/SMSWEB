<%- layout('../layouts/main') %>
<%
var orgs = typeof organizations !== 'undefined' ? organizations : [];
var isSuperAdmin = user && user.is_super_admin;
%>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-car-front-fill me-2 text-primary"></i><%- t('vehicle_models.title') || 'Vehicle Models' %> <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <% if (can('export_vehicle_models')) { %>
      <div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-download me-1"></i><span class="d-none d-sm-inline"><%- t('btn.export') %></span></button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li><li><a class="dropdown-item" href="#" onclick="doExport('excel');return false;"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Excel</a></li><li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li></ul>
      </div><% } %>
      <% if (can('import_vehicle_models')) { %><button class="btn btn-sm btn-outline-info" onclick="openImport()"><i class="bi bi-upload me-1"></i><span class="d-none d-sm-inline"><%- t('btn.import') %></span></button><% } %>
      <% if (can('add_vehicle_models')) { %><a href="/vehicle-models/create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline"><%- t('vehicle_models.add') || 'Add Model' %></span></a><% } %>
    </div>
  </div>

  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="d-flex align-items-center gap-2">
      <div class="flex-grow-1"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="&#128269;  Search by model name, type, make, or year..."/></div>
      <div id="activeFiltersBar" class="d-flex gap-1 flex-wrap"></div>
      <button class="btn btn-sm btn-outline-primary" id="btnAdvFilter" data-bs-toggle="offcanvas" data-bs-target="#filterSidebar"><i class="bi bi-funnel me-1"></i><span class="d-none d-sm-inline"><%- t('general.filters', 'Filters') %></span> <span class="badge bg-primary-lt ms-1 d-none" id="filterCount">0</span></button>
    </div>
  </div>

  <div id="bulkBar" class="d-none">
    <div class="sms-bulk-bar rounded-0 border-bottom px-3 py-2">
      <span class="fw-semibold"><span id="bulkCount">0</span> <%- t('general.selected', 'selected') %></span>
      <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-outline-light" onclick="bulkAction('deactivate')"><i class="bi bi-toggle-off me-1"></i><%- t('bulk.deactivate', 'Deactivate') %></button>
        <button class="btn btn-sm btn-outline-light" onclick="bulkAction('activate')"><i class="bi bi-toggle-on me-1"></i><%- t('bulk.activate', 'Activate') %></button>
        <button class="btn btn-sm btn-danger" onclick="bulkAction('delete')"><i class="bi bi-trash3 me-1"></i><%- t('btn.delete') %></button>
        <button class="btn btn-sm btn-outline-light d-none" id="btnBulkRecover" onclick="bulkAction('recover')"><i class="bi bi-arrow-counterclockwise me-1"></i><%- t('bulk.recover', 'Recover') %></button>
        <button class="btn btn-sm btn-outline-light" id="btnClearBulk"><i class="bi bi-x-lg"></i></button>
      </div>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead><tr>
        <th style="width:42px;"><input type="checkbox" class="form-check-input" id="selectAll"/></th>
        <th style="width:36px;" class="text-muted">#</th>
        <th style="width:60px;"><%- t('general.image') || 'Image' %></th>
        <th class="sortable" data-field="name"><%- t('vehicle_models.name', 'Model Name') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th><%- t('vehicle_models.vehicle_type', 'Vehicle Type') %></th>
        <th><%- t('vehicle_models.vehicle_year', 'Vehicle Year') %></th>
        <th><%- t('vehicle_makes.name', 'Make Name') %></th>
        <th><%- t('vehicle_models.start_year', 'Start Year') %></th>
        <th><%- t('vehicle_models.end_year', 'End Year') %></th>
        <th class="sortable" data-field="status"><%- t('general.status') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th class="d-none d-md-table-cell sortable" data-field="created_at"><%- t('general.created_at') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th class="text-end" style="width:160px;"><%- t('general.actions') %></th>
      </tr></thead>
      <tbody id="tableBody"><tr><td colspan="12" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t('general.loading') %></td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- ═══ ADVANCED FILTER ═══ -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="filterSidebar" style="width:360px;">
  <div class="offcanvas-header border-bottom py-3">
    <h5 class="offcanvas-title fw-semibold mb-0"><i class="bi bi-funnel me-2 text-primary"></i><%- t('general.filters', 'Filters') %></h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body">
    <% if (isSuperAdmin && orgs.length) { %>
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><%- t('general.companies', 'Company') %></label>
      <select class="form-select form-select-sm" id="filterCompany">
        <option value="all"><%- t('dash.all_companies', 'All Companies') %></option>
        <option value="global"><%- t('general.global_super_admin', 'Global (Super Admin)') %></option>
        <% orgs.forEach(function(o) { %><option value="<%- o.id %>"><%- o.company_name %></option><% }) %>
      </select>
    </div>
    <% } %>
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><%- t('vehicle_models.vehicle_year', 'Vehicle Year') %></label>
      <select class="form-select form-select-sm" id="filterVehicleYear" multiple style="width:100%;"></select>
    </div>
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><%- t('vehicle_models.vehicle_type', 'Vehicle Type') %></label>
      <select class="form-select form-select-sm" id="filterVehicleType" multiple style="width:100%;"></select>
    </div>
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><%- t('vehicle_makes.name', 'Vehicle Make') %></label>
      <select class="form-select form-select-sm" id="filterVehicleMake" multiple style="width:100%;"></select>
      <div class="form-hint mt-1" style="font-size:11px;">Filtered by selected type</div>
    </div>

    <!-- Production Period Filters -->
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><i class="bi bi-calendar-range me-1"></i><%- t('vehicle_models.start_year', 'Start Year') %></label>
      <div class="row g-2">
        <div class="col-6">
          <input type="number" class="form-control form-control-sm" id="filterStartYearFrom" placeholder="From" min="1900" max="2100"/>
        </div>
        <div class="col-6">
          <input type="number" class="form-control form-control-sm" id="filterStartYearTo" placeholder="To" min="1900" max="2100"/>
        </div>
      </div>
    </div>
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><i class="bi bi-calendar-range me-1"></i><%- t('vehicle_models.end_year', 'End Year') %></label>
      <div class="row g-2">
        <div class="col-6">
          <input type="number" class="form-control form-control-sm" id="filterEndYearFrom" placeholder="From" min="1900" max="2100"/>
        </div>
        <div class="col-6">
          <input type="number" class="form-control form-control-sm" id="filterEndYearTo" placeholder="To" min="1900" max="2100"/>
        </div>
      </div>
    </div>
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><i class="bi bi-calendar-month me-1"></i>Month Initial / Month Final</label>
      <div class="row g-2">
        <div class="col-6">
          <select class="form-select form-select-sm" id="filterMonthInitial">
            <option value="">Month Initial</option>
            <% for (var m = 1; m <= 12; m++) { %><option value="<%- m %>"><%- m %></option><% } %>
          </select>
        </div>
        <div class="col-6">
          <select class="form-select form-select-sm" id="filterMonthFinal">
            <option value="">Month Final</option>
            <% for (var m = 1; m <= 12; m++) { %><option value="<%- m %>"><%- m %></option><% } %>
          </select>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><%- t('general.status', 'Status') %></label>
      <select class="form-select form-select-sm" id="filterStatus">
        <option value=""><%- t('general.all_status', 'All Status') %></option>
        <option value="1"><%- t('general.active') %></option>
        <option value="0"><%- t('general.inactive') %></option>
      </select>
    </div>
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><%- t('general.created', 'Created') %></label>
      <div class="row g-2">
        <div class="col-6">
          <input type="date" class="form-control form-control-sm" id="filterDateFrom"/>
          <div class="form-hint mt-1" style="font-size:10px;">From date</div>
        </div>
        <div class="col-6">
          <input type="date" class="form-control form-control-sm" id="filterDateTo"/>
          <div class="form-hint mt-1" style="font-size:10px;">To date</div>
        </div>
      </div>
    </div>
    <div class="mb-4">
      <label class="form-label fw-medium small text-muted text-uppercase" style="letter-spacing:.5px;font-size:11px;"><%- t('general.all_records', 'Records') %></label>
      <select class="form-select form-select-sm" id="filterDeleted">
        <option value=""><%- t('general.active_records', 'Active Records') %></option>
        <option value="only"><%- t('general.deleted_only', 'Deleted Only') %></option>
        <option value="all"><%- t('general.all_records', 'All Records') %></option>
      </select>
    </div>
  </div>
  <div class="offcanvas-footer border-top p-3">
    <div class="d-flex gap-2">
      <button class="btn btn-primary btn-sm flex-fill" id="btnApplyFilters"><i class="bi bi-check-lg me-1"></i><%- t('general.apply', 'Apply') %></button>
      <button class="btn btn-outline-secondary btn-sm flex-fill" id="btnClearFilters"><i class="bi bi-x-lg me-1"></i><%- t('btn.clear_all', 'Clear All') %></button>
    </div>
  </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="modalView" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:700px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-car-front-fill me-2 text-primary"></i><%- t('vehicle_models.details', 'Model Details') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-0" id="viewBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close') %></button></div></div></div></div>

<!-- Image Modal -->
<div class="modal fade" id="modalImage" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:600px;"><div class="modal-content"><div class="modal-header py-2"><h6 class="modal-title fw-semibold mb-0" id="imgModalTitle"><i class="bi bi-image me-2 text-primary"></i>Images</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-3" id="imgModalBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close') %></button></div></div></div></div>

<!-- Import Modal — wider -->
<div class="modal fade" id="modalImport" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:980px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-upload me-2 text-info"></i><%- t('vehicle_models.import_title', 'Import Vehicle Models') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<div class="modal-body" style="max-height:75vh;overflow-y:auto;">
  <!-- Processing spinner (hidden by default) -->
  <div id="importProcessing" class="d-none">
    <div class="text-center py-5">
      <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;"></div>
      <h5 class="text-primary mb-1"><%- t('general.import_in_process', 'Import in process...') %></h5>
      <p class="text-muted small mb-0"><%- t('general.please_wait', 'Please wait while we process your file.') %></p>
    </div>
  </div>
  <div id="importStep1">
    <div class="sms-import-instructions" style="background:#f0f6ff;border:1px solid #c5d9f1;border-radius:8px;padding:20px;">
      <h6 class="mb-3"><i class="bi bi-info-circle me-1 text-primary"></i>Import Instructions — Vehicle Models</h6>
      <div class="sms-import-columns mb-3 d-flex flex-wrap gap-2">
        <span class="badge bg-danger-lt px-2 py-1"><code>name</code> <small>(required)</small></span>
        <span class="badge bg-danger-lt px-2 py-1"><code>vehicle_type</code> <small>(required)</small></span>
        <span class="badge bg-danger-lt px-2 py-1"><code>vehicle_make</code> <small>(required)</small></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>vehicle_year</code></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>month_initial</code></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>month_final</code></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>start_year</code></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>end_year</code></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>image_url</code></span>
        <span class="badge bg-green-lt px-2 py-1"><code>Language name/code</code></span>
      </div>
      <div class="table-responsive mb-3">
        <table class="table table-sm table-bordered mb-0" style="font-size:12px;">
          <thead class="table-light"><tr><th style="width:150px;">Column</th><th style="width:70px;">Required</th><th>Description</th><th style="width:120px;">Example</th></tr></thead>
          <tbody>
            <tr><td><code>name</code></td><td class="text-center"><span class="text-danger fw-bold">Yes</span></td><td>Model name (2–100 chars). Must be unique per type + make combination.</td><td><code>Fortuner</code></td></tr>
            <tr><td><code>vehicle_type</code></td><td class="text-center"><span class="text-danger fw-bold">Yes</span></td><td>Vehicle type name. <strong>Smart match:</strong> company → global → auto-create.</td><td><code>SUV</code></td></tr>
            <tr><td><code>vehicle_make</code></td><td class="text-center"><span class="text-danger fw-bold">Yes</span></td><td>Make/brand name. <strong>Smart match:</strong> company → global → auto-create linked to type.</td><td><code>Toyota</code></td></tr>
            <tr><td><code>vehicle_year</code></td><td class="text-center text-muted">No</td><td>Year integer (1900–2100). <strong>Smart match:</strong> auto-creates if not found.</td><td><code>2024</code></td></tr>
            <tr><td><code>month_initial</code></td><td class="text-center text-muted">No</td><td>Production start month (1–12).</td><td><code>1</code></td></tr>
            <tr><td><code>month_final</code></td><td class="text-center text-muted">No</td><td>Production end month (1–12).</td><td><code>12</code></td></tr>
            <tr><td><code>start_year</code></td><td class="text-center text-muted">No</td><td>Production start year (1900–2100).</td><td><code>2018</code></td></tr>
            <tr><td><code>end_year</code></td><td class="text-center text-muted">No</td><td>Production end year (1900–2100).</td><td><code>2024</code></td></tr>
            <tr><td><code>image_url</code></td><td class="text-center text-muted">No</td><td>External image URL (https://...).</td><td><code>https://img.com/car.jpg</code></td></tr>
            <tr><td><code>Hindi</code> / <code>hi</code></td><td class="text-center text-muted">No</td><td>Translation column. Use language name or ISO code as header.</td><td><code>फॉर्च्यूनर</code></td></tr>
          </tbody>
        </table>
      </div>
      <div class="row g-3">
        <div class="col-md-6"><div class="border rounded p-2 bg-white" style="font-size:12px;"><strong class="text-success"><i class="bi bi-check-circle me-1"></i>Smart Match Rules:</strong><ul class="mb-0 mt-1 ps-3"><li>Type, Make, Year resolved by name — no IDs needed</li><li>Searches company records first, then global</li><li>Auto-creates if no match found</li><li>Same model allowed under different type+make</li></ul></div></div>
        <div class="col-md-6"><div class="border rounded p-2 bg-white" style="font-size:12px;"><strong class="text-info"><i class="bi bi-file-earmark-text me-1"></i>File Requirements:</strong><ul class="mb-0 mt-1 ps-3"><li>Formats: <strong>.csv</strong>, <strong>.xlsx</strong>, <strong>.xls</strong></li><li><strong>Unlimited rows</strong> per import</li><li>First row = column headers</li><li>Headers are case-insensitive</li><li><code>vehicle_type</code> = <code>vehicle type</code></li></ul></div></div>
      </div>
    </div>
    <div class="mt-3 d-flex align-items-center gap-3">
      <a href="/templates/vehicle-models-import-template.csv" class="btn btn-sm btn-outline-primary" download><i class="bi bi-download me-1"></i><%- t('import.download_template', 'Download Template') %></a>
      <form id="frmImport" enctype="multipart/form-data" class="d-flex align-items-center gap-2 flex-grow-1">
        <div class="flex-grow-1"><input type="file" name="file" id="importFile" class="form-control form-control-sm" accept=".csv,.xlsx,.xls" required/></div>
        <button type="submit" class="btn btn-info btn-sm" id="btnImport"><i class="bi bi-upload me-1"></i><%- t('btn.import') %></button>
      </form>
    </div>
  </div>
  <div id="importStep2" class="d-none">
    <div id="importSummary" class="mb-3"></div>
    <div id="importResultTable" style="max-height:450px;overflow-y:auto;overflow-x:auto;"></div>
    <div id="importErrorActions" class="d-none mt-3 d-flex gap-2">
      <button class="btn btn-sm btn-warning" id="btnRetryAllErrors"><i class="bi bi-arrow-repeat me-1"></i>Retry All Errors</button>
    </div>
  </div>
  <!-- Background import progress -->
  <div id="importStep3" class="d-none">
    <div class="text-center py-4">
      <div class="mb-3"><i class="bi bi-cloud-upload text-primary" style="font-size:48px;"></i></div>
      <h5 class="fw-semibold mb-1">Importing in background...</h5>
      <p class="text-muted small mb-3">Processing your file. You can keep this window open.</p>
      <div class="progress mb-3" style="height:24px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated" id="impProgressBar" role="progressbar" style="width:0%;font-size:12px;"><span id="impPercent">0%</span></div>
      </div>
      <div class="d-flex justify-content-center gap-4 text-center">
        <div><div class="text-muted small">Total</div><strong id="impTotal">0</strong></div>
        <div><div class="text-muted small">Processed</div><strong id="impProcessed">0</strong></div>
        <div><div class="text-muted small text-success">Success</div><strong id="impSuccess" class="text-success">0</strong></div>
        <div><div class="text-muted small text-danger">Errors</div><strong id="impErrors" class="text-danger">0</strong></div>
      </div>
    </div>
  </div>
</div>
<div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close') %></button></div>
</div></div></div>

<% include ../partials/usage-modal %>

<script>window._IS_SUPER = <%= isSuperAdmin ? 'true' : 'false' %>;</script>
<% block('scripts', '<script src="/js/pages/vehicle-models.js"></script>') %>
