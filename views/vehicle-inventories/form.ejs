<%- layout('../layouts/main') %>
<% block('styles', '<link rel="stylesheet" href="/css/vehicle-inventories.css"/>') %>
<%
var rec = typeof record !== 'undefined' ? record : null;
var isEdit = !!rec;
var formAction = isEdit ? '/vehicle-inventories/' + rec.uuid : '/vehicle-inventories';
// Helper to format date for HTML input (YYYY-MM-DD)
function fmtDate(v) {
  if (!v) return '';
  var s = String(v);
  if (s.length >= 10) return s.substring(0, 10);
  return s;
}
%>


<div class="d-flex align-items-center gap-2 mb-2">
  <a href="/vehicle-inventories" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-left me-1"></i><%- t('general.back', 'Back') %></a>
  <% if (isEdit && rec.vehicle_internal_id) { %><span class="badge bg-primary-lt" style="font-size:12px;">#<%- rec.vehicle_internal_id %></span><% } %>
  <% if (isEdit && rec.registration_plate_no) { %><span class="badge bg-azure-lt" style="font-size:12px;"><%- rec.registration_plate_no %></span><% } %>
</div>

<form id="frmVehicleInventory" method="POST" action="<%- formAction %>" enctype="multipart/form-data" novalidate>

<!-- Bootstrap Tabs -->
<ul class="nav nav-tabs mb-3" id="vehicleTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="tab-vehicle-info" data-bs-toggle="tab" data-bs-target="#pane-vehicle-info" type="button" role="tab" aria-controls="pane-vehicle-info" aria-selected="true">
      <i class="bi bi-car-front me-1"></i><%- t('vehicle_inventories.tab_vehicle_info', 'Vehicle Info') %>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= !isEdit ? ' disabled' : '' %>" id="tab-extra-info" data-bs-toggle="<%= isEdit ? 'tab' : '' %>" data-bs-target="#pane-extra-info" type="button" role="tab" aria-controls="pane-extra-info" aria-selected="false"<%= !isEdit ? ' tabindex="-1" aria-disabled="true" title="Save vehicle first"' : '' %>>
      <i class="bi bi-card-list me-1"></i><%- t('vehicle_inventories.tab_extra_info', 'Extra Info') %><% if (!isEdit) { %> <i class="bi bi-lock-fill ms-1" style="font-size:10px;"></i><% } %>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= !isEdit ? ' disabled' : '' %>" id="tab-images" data-bs-toggle="<%= isEdit ? 'tab' : '' %>" data-bs-target="#pane-images" type="button" role="tab" aria-controls="pane-images" aria-selected="false"<%= !isEdit ? ' tabindex="-1" aria-disabled="true" title="Save vehicle first"' : '' %>>
      <i class="bi bi-images me-1"></i><%- t('vehicle_inventories.tab_images', 'Images') %><% if (!isEdit) { %> <i class="bi bi-lock-fill ms-1" style="font-size:10px;"></i><% } %>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= !isEdit ? ' disabled' : '' %>" id="tab-videos" data-bs-toggle="<%= isEdit ? 'tab' : '' %>" data-bs-target="#pane-videos" type="button" role="tab" aria-controls="pane-videos" aria-selected="false"<%= !isEdit ? ' tabindex="-1" aria-disabled="true" title="Save vehicle first"' : '' %>>
      <i class="bi bi-camera-video me-1"></i><%- t('vehicle_inventories.tab_videos', 'Videos') %><% if (!isEdit) { %> <i class="bi bi-lock-fill ms-1" style="font-size:10px;"></i><% } %>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= !isEdit ? ' disabled' : '' %>" id="tab-owner" data-bs-toggle="<%= isEdit ? 'tab' : '' %>" data-bs-target="#pane-owner" type="button" role="tab" aria-controls="pane-owner" aria-selected="false"<%= !isEdit ? ' tabindex="-1" aria-disabled="true" title="Save vehicle first"' : '' %>>
      <i class="bi bi-person me-1"></i><%- t('vehicle_inventories.tab_owner', 'Owner') %><% if (!isEdit) { %> <i class="bi bi-lock-fill ms-1" style="font-size:10px;"></i><% } %>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= !isEdit ? ' disabled' : '' %>" id="tab-documents" data-bs-toggle="<%= isEdit ? 'tab' : '' %>" data-bs-target="#pane-documents" type="button" role="tab" aria-controls="pane-documents" aria-selected="false"<%= !isEdit ? ' tabindex="-1" aria-disabled="true" title="Save vehicle first"' : '' %>>
      <i class="bi bi-file-earmark-text me-1"></i><%- t('vehicle_inventories.tab_documents', 'Documents') %><% if (!isEdit) { %> <i class="bi bi-lock-fill ms-1" style="font-size:10px;"></i><% } %>
    </button>
  </li>
</ul>

<div class="tab-content" id="vehicleTabContent">

  <!-- ============================================================ -->
  <!-- TAB 1: Vehicle Info -->
  <!-- ============================================================ -->
  <div class="tab-pane fade show active" id="pane-vehicle-info" role="tabpanel" aria-labelledby="tab-vehicle-info">

    <!-- Section: Vehicle Selection -->
    <div class="card shadow-sm section-card">
      <div class="card-header py-2">
        <div class="card-title mb-0"><i class="bi bi-car-front me-1 text-primary"></i><%- t('vehicle_inventories.vehicle_selection', 'Vehicle Selection') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_type', 'Vehicle Type') %> <span class="text-danger">*</span></label>
            <select name="vehicle_type_id" id="selVehicleType" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_year', 'Vehicle Year') %> <span class="text-danger">*</span></label>
            <select name="vehicle_year_id" id="selVehicleYear" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_make', 'Vehicle Make') %> <span class="text-danger">*</span></label>
            <select name="vehicle_make_id" id="selVehicleMake" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_model', 'Vehicle Model') %> <span class="text-danger">*</span></label>
            <select name="vehicle_model_id" id="selVehicleModel" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_variant', 'Vehicle Variant') %> <span class="text-danger">*</span></label>
            <select name="vehicle_variant_id" id="selVehicleVariant" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_engine', 'Vehicle Engine') %></label>
            <select name="vehicle_engine_id" id="selVehicleEngine" class="form-select" style="width:100%;"></select>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_fuel', 'Vehicle Fuel') %></label>
            <select name="vehicle_fuel_id" id="selVehicleFuel" class="form-select" style="width:100%;"></select>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_category', 'Vehicle Category') %></label>
            <select name="vehicle_category_id" id="selVehicleCategory" class="form-select" style="width:100%;"></select>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Registration & Identification -->
    <div class="card shadow-sm section-card">
      <div class="card-header py-2">
        <div class="card-title mb-0"><i class="bi bi-card-text me-1 text-primary"></i><%- t('vehicle_inventories.registration_identification', 'Registration & Identification') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.registration_plate_no', 'Registration Plate No') %></label>
            <input type="text" name="registration_plate_no" id="fRegistrationPlateNo" class="form-control" value="<%= isEdit ? (rec.registration_plate_no||'') : '' %>" placeholder="<%- t('vehicle_inventories.registration_plate_no', 'Registration Plate No') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.registration_no', 'Registration No') %></label>
            <input type="text" name="registration_no" id="fRegistrationNo" class="form-control" value="<%= isEdit ? (rec.registration_no||'') : '' %>" placeholder="<%- t('vehicle_inventories.registration_no', 'Registration No') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_vin', 'Vehicle VIN') %></label>
            <input type="text" name="vehicle_vin" id="fVehicleVin" class="form-control" value="<%= isEdit ? (rec.vehicle_vin||'') : '' %>" placeholder="<%- t('vehicle_inventories.vehicle_vin', 'Vehicle VIN') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.certificate_number', 'Certificate Number') %></label>
            <input type="text" name="certificate_number" id="fCertificateNumber" class="form-control" value="<%= isEdit ? (rec.certificate_number||'') : '' %>" placeholder="<%- t('vehicle_inventories.certificate_number', 'Certificate Number') %>"/>
          </div>
          <!-- Internal ID shown in top header badge only -->
        </div>
      </div>
    </div>

    <!-- Section: Process Dates -->
    <div class="card shadow-sm section-card">
      <div class="card-header py-2">
        <div class="card-title mb-0"><i class="bi bi-calendar-range me-1 text-primary"></i><%- t('vehicle_inventories.process_dates', 'Process Dates') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.process_start_date', 'Process Start Date') %></label>
            <input type="date" name="process_start_date" id="fProcessStartDate" class="form-control" value="<%= isEdit ? fmtDate(rec.process_start_date) : '' %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.process_end_date', 'Process End Date') %></label>
            <input type="date" name="process_end_date" id="fProcessEndDate" class="form-control" value="<%= isEdit ? fmtDate(rec.process_end_date) : '' %>"/>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Vehicle Details -->
    <div class="card shadow-sm section-card">
      <div class="card-header py-2">
        <div class="card-title mb-0"><i class="bi bi-info-circle me-1 text-primary"></i><%- t('vehicle_inventories.vehicle_details', 'Vehicle Details') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.brand', 'Brand') %></label>
            <input type="text" name="brand" id="fBrand" class="form-control" value="<%= isEdit ? (rec.brand||'') : '' %>" placeholder="<%- t('vehicle_inventories.brand', 'Brand') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.booklet_model', 'Booklet Model') %></label>
            <input type="text" name="booklet_model" id="fBookletModel" class="form-control" value="<%= isEdit ? (rec.booklet_model||'') : '' %>" placeholder="<%- t('vehicle_inventories.booklet_model', 'Booklet Model') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_model_text', 'Vehicle Model Text') %></label>
            <input type="text" name="vehicle_model_text" id="fVehicleModelText" class="form-control" value="<%= isEdit ? (rec.vehicle_model_text||'') : '' %>" placeholder="<%- t('vehicle_inventories.vehicle_model_text', 'Vehicle Model Text') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_tare', 'Vehicle Tare') %></label>
            <input type="text" name="vehicle_tare" id="fVehicleTare" class="form-control" value="<%= isEdit ? (rec.vehicle_tare||'') : '' %>" placeholder="<%- t('vehicle_inventories.vehicle_tare', 'Vehicle Tare') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_year_text', 'Vehicle Year Text') %></label>
            <input type="number" name="vehicle_year_text" id="fVehicleYearText" class="form-control" min="1900" max="2100" value="<%= isEdit ? (rec.vehicle_year_text||'') : '' %>" placeholder="e.g. 2024"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_kms', 'Vehicle KMS') %></label>
            <input type="number" name="vehicle_kms" id="fVehicleKms" class="form-control" step="0.01" min="0" value="<%= isEdit ? (rec.vehicle_kms||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_doors', 'Vehicle Doors') %></label>
            <select name="vehicle_doors" id="selVehicleDoors" class="form-select">
              <option value="">-- <%- t('general.select', 'Select') %> --</option>
              <% for (var d = 1; d <= 5; d++) { %>
              <option value="<%- d %>" <%- (isEdit && rec.vehicle_doors && parseInt(rec.vehicle_doors) === d) ? 'selected' : '' %>><%- d %></option>
              <% } %>
            </select>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_approval', 'Vehicle Approval') %></label>
            <input type="text" name="vehicle_approval" id="fVehicleApproval" class="form-control" value="<%= isEdit ? (rec.vehicle_approval||'') : '' %>" placeholder="<%- t('vehicle_inventories.vehicle_approval', 'Vehicle Approval') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_color', 'Vehicle Color') %></label>
            <input type="text" name="vehicle_color" id="fVehicleColor" class="form-control" value="<%= isEdit ? (rec.vehicle_color||'') : '' %>" placeholder="<%- t('vehicle_inventories.vehicle_color', 'Vehicle Color') %>"/>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Dimensions & Weight -->
    <div class="card shadow-sm section-card">
      <div class="card-header py-2">
        <div class="card-title mb-0"><i class="bi bi-rulers me-1 text-primary"></i><%- t('vehicle_inventories.dimensions_weight', 'Dimensions & Weight') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_total_gross_weight', 'Vehicle Total Gross Weight') %></label>
            <input type="number" name="vehicle_total_gross_weight" id="fVehicleTotalGrossWeight" class="form-control" step="0.01" min="0" value="<%= isEdit ? (rec.vehicle_total_gross_weight||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_parts', 'Vehicle Parts') %></label>
            <input type="number" name="vehicle_parts" id="fVehicleParts" class="form-control" step="0.01" min="0" value="<%= isEdit ? (rec.vehicle_parts||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_eei', 'Vehicle EEI') %></label>
            <input type="number" name="vehicle_eei" id="fVehicleEei" class="form-control" step="0.01" min="0" value="<%= isEdit ? (rec.vehicle_eei||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_experience_value', 'Vehicle Experience Value') %></label>
            <input type="number" name="vehicle_experience_value" id="fVehicleExperienceValue" class="form-control" step="0.01" min="0" value="<%= isEdit ? (rec.vehicle_experience_value||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_cylinder', 'Vehicle Cylinder') %></label>
            <input type="number" name="vehicle_cylinder" id="fVehicleCylinder" class="form-control" step="0.01" min="0" value="<%= isEdit ? (rec.vehicle_cylinder||'') : '' %>" placeholder="0.00"/>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Engine & Performance -->
    <div class="card shadow-sm section-card">
      <div class="card-header py-2">
        <div class="card-title mb-0"><i class="bi bi-speedometer me-1 text-primary"></i><%- t('vehicle_inventories.engine_performance', 'Engine & Performance') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.motorization', 'Motorization') %></label>
            <input type="text" name="motorization" id="fMotorization" class="form-control" value="<%= isEdit ? (rec.motorization||'') : '' %>" placeholder="<%- t('vehicle_inventories.motorization', 'Motorization') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.ccm3', 'Ccm3') %></label>
            <input type="text" name="ccm3" id="fCcm3" class="form-control" value="<%= isEdit ? (rec.ccm3||'') : '' %>" placeholder="<%- t('vehicle_inventories.ccm3', 'Ccm3') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.power_kw', 'Power Kw') %></label>
            <input type="text" name="power_kw" id="fPowerKw" class="form-control" value="<%= isEdit ? (rec.power_kw||'') : '' %>" placeholder="<%- t('vehicle_inventories.power_kw', 'Power Kw') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.hp', 'HP') %></label>
            <input type="text" name="hp" id="fHp" class="form-control" value="<%= isEdit ? (rec.hp||'') : '' %>" placeholder="<%- t('vehicle_inventories.hp', 'HP') %>"/>
          </div>
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_provenance', 'Vehicle Provenance') %></label>
            <input type="text" name="vehicle_provenance" id="fVehicleProvenance" class="form-control" value="<%= isEdit ? (rec.vehicle_provenance||'') : '' %>" placeholder="<%- t('vehicle_inventories.vehicle_provenance', 'Vehicle Provenance') %>"/>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: References -->
    <div class="card shadow-sm section-card">
      <div class="card-header py-2">
        <div class="card-title mb-0"><i class="bi bi-bookmark me-1 text-primary"></i><%- t('vehicle_inventories.references', 'References') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_internal_reference', 'Vehicle Internal Reference') %></label>
            <input type="text" name="vehicle_internal_reference" id="fVehicleInternalReference" class="form-control" value="<%= isEdit ? (rec.vehicle_internal_reference||'') : '' %>" placeholder="<%- t('vehicle_inventories.vehicle_internal_reference', 'Vehicle Internal Reference') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.vehicle_external_reference', 'Vehicle External Reference') %></label>
            <input type="text" name="vehicle_external_reference" id="fVehicleExternalReference" class="form-control" value="<%= isEdit ? (rec.vehicle_external_reference||'') : '' %>" placeholder="<%- t('vehicle_inventories.vehicle_external_reference', 'Vehicle External Reference') %>"/>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Status & Classification -->
    <div class="card shadow-sm section-card">
      <div class="card-header py-2">
        <div class="card-title mb-0"><i class="bi bi-tags me-1 text-primary"></i><%- t('vehicle_inventories.status_classification', 'Status & Classification') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-3 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.inventory_status', 'Inventory Status') %></label>
            <select name="inventory_status" id="selInventoryStatus" class="form-select">
              <option value="1" <%- (!isEdit || parseInt(rec.inventory_status) === 1) ? 'selected' : '' %>><%- t('vehicle_inventories.in_stock', 'In Stock') %></option>
              <option value="2" <%- (isEdit && parseInt(rec.inventory_status) === 2) ? 'selected' : '' %>><%- t('vehicle_inventories.out_of_stock', 'Out of Stock') %></option>
              <option value="3" <%- (isEdit && parseInt(rec.inventory_status) === 3) ? 'selected' : '' %>><%- t('vehicle_inventories.sent_to_wastage', 'Sent to Wastage') %></option>
            </select>
          </div>
          <div class="col-md-3 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.depolution_status', 'Depolution Status') %></label>
            <select name="depolution_status" id="selDepolutionStatus" class="form-select">
              <option value="1" <%- (!isEdit || parseInt(rec.depolution_status) === 1) ? 'selected' : '' %>><%- t('vehicle_inventories.pending', 'Pending') %></option>
              <option value="2" <%- (isEdit && parseInt(rec.depolution_status) === 2) ? 'selected' : '' %>><%- t('vehicle_inventories.in_depollution', 'In Depollution') %></option>
              <option value="3" <%- (isEdit && parseInt(rec.depolution_status) === 3) ? 'selected' : '' %>><%- t('vehicle_inventories.depolluted', 'Depolluted') %></option>
            </select>
          </div>
          <div class="col-md-3 col-sm-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.dismantle_status', 'Dismantle Status') %></label>
            <select name="dismantle_status" id="selDismantleStatus" class="form-select">
              <option value="1" <%- (!isEdit || parseInt(rec.dismantle_status) === 1) ? 'selected' : '' %>><%- t('vehicle_inventories.pending', 'Pending') %></option>
              <option value="2" <%- (isEdit && parseInt(rec.dismantle_status) === 2) ? 'selected' : '' %>><%- t('vehicle_inventories.in_dismantling', 'In Dismantling') %></option>
              <option value="3" <%- (isEdit && parseInt(rec.dismantle_status) === 3) ? 'selected' : '' %>><%- t('vehicle_inventories.dismantled', 'Dismantled') %></option>
            </select>
          </div>
