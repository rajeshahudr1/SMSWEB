          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.postal_code', 'Postal Code') %></label>
            <input type="text" name="owner_postal_code" id="fOwnerPostalCode" class="form-control" value="<%= isEdit ? (rec.owner_postal_code||'') : '' %>" placeholder="<%- t('vehicle_inventories.postal_code', 'Postal Code') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.country', 'Country') %></label>
            <select name="owner_country_id" id="selOwnerCountry" class="form-select" style="width:100%;"></select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.nif', 'NIF') %></label>
            <input type="text" name="owner_nif" id="fOwnerNif" class="form-control" value="<%= isEdit ? (rec.owner_nif||'') : '' %>" placeholder="<%- t('vehicle_inventories.nif', 'NIF') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.bicc', 'BICC') %></label>
            <input type="text" name="owner_bicc" id="fOwnerBicc" class="form-control" value="<%= isEdit ? (rec.owner_bicc||'') : '' %>" placeholder="<%- t('vehicle_inventories.bicc', 'BICC') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.telephone', 'Telephone') %></label>
            <input type="text" name="owner_telephone" id="fOwnerTelephone" class="form-control" value="<%= isEdit ? (rec.owner_telephone||'') : '' %>" placeholder="<%- t('vehicle_inventories.telephone', 'Telephone') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.cellphone', 'CellPhone') %></label>
            <input type="text" name="owner_cellphone" id="fOwnerCellphone" class="form-control" value="<%= isEdit ? (rec.owner_cellphone||'') : '' %>" placeholder="<%- t('vehicle_inventories.cellphone', 'CellPhone') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.email', 'Email') %></label>
            <input type="email" name="owner_email" id="fOwnerEmail" class="form-control" value="<%= isEdit ? (rec.owner_email||'') : '' %>" placeholder="<%- t('vehicle_inventories.email', 'Email') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.company_certificate_code', 'Company Certificate Code') %></label>
            <input type="text" name="owner_company_certificate_code" id="fOwnerCompanyCertificateCode" class="form-control" value="<%= isEdit ? (rec.owner_company_certificate_code||'') : '' %>" placeholder="<%- t('vehicle_inventories.company_certificate_code', 'Company Certificate Code') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.validity', 'Validity') %></label>
            <input type="date" name="owner_validity" id="fOwnerValidity" class="form-control" value="<%= isEdit ? fmtDate(rec.owner_validity) : '' %>"/>
          </div>
          <div class="col-md-12">
            <label class="form-label fw-medium"><%- t('vehicle_inventories.address', 'Address') %></label>
            <textarea name="owner_address" id="fOwnerAddress" class="form-control" rows="3" placeholder="<%- t('vehicle_inventories.address', 'Address') %>"><%= isEdit ? (rec.owner_address||'') : '' %></textarea>
          </div>

        </div>
      </div>
    </div>
    <% if (isEdit) { %>
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <button type="button" class="btn btn-outline-primary sms-tab-prev" data-target="#tab-videos"><i class="bi bi-chevron-left me-1"></i><%- t('general.previous','Prev') %></button>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" id="btnSubmitTab5"><i class="bi bi-floppy me-1"></i><%- t('vehicle_inventories.save_owner', 'Save') %></button>
        <button type="button" class="btn btn-outline-primary sms-tab-next" data-target="#tab-documents"><%- t('general.next','Next') %> <i class="bi bi-chevron-right ms-1"></i></button>
      </div>
    </div>
    <% } %>
  </div>

  <!-- ============================================================ -->
  <!-- TAB 6: Documents -->
  <!-- ============================================================ -->
  <div class="tab-pane fade" id="pane-documents" role="tabpanel" aria-labelledby="tab-documents">
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-file-earmark-text me-1 text-primary"></i><%- t('vehicle_inventories.documents', 'Documents') %> <% if (isEdit) { %><span class="badge bg-primary-lt ms-1" style="font-size:10px;" id="documentCount">0</span><% } %></div>
      </div>
      <div class="card-body">
        <% if (isEdit) { %>
        <!-- Add document row -->
        <div class="border rounded p-3 mb-3" style="background:var(--tblr-bg-surface-secondary);">
          <div class="row g-2 align-items-end">
            <div class="col-md-3">
              <label class="form-label fw-medium small"><%- t('vehicle_inventories.document_type', 'Type') %> <span class="text-danger">*</span></label>
              <select id="selDocumentType" class="form-select form-select-sm">
                <option value="">-- <%- t('general.select', 'Select') %> --</option>
                <option value="1"><%- t('vehicle_inventories.doc_citizen_card', 'Citizen Card') %></option>
                <option value="2"><%- t('vehicle_inventories.doc_certificate', 'Certificate') %></option>
                <option value="3"><%- t('vehicle_inventories.doc_single_car', 'Single Car') %></option>
                <option value="4"><%- t('vehicle_inventories.doc_model_imtt', 'Model IMTT') %></option>
                <option value="5"><%- t('vehicle_inventories.doc_chassis_number', 'Chassis Number') %></option>
                <option value="6"><%- t('vehicle_inventories.doc_tax_authority', 'Tax Authority File') %></option>
                <option value="7"><%- t('vehicle_inventories.doc_other', 'Other File') %></option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-medium small"><%- t('vehicle_inventories.document_file', 'File') %> <span class="text-danger">*</span></label>
              <input type="file" id="fDocumentFile" class="form-control form-control-sm"/>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium small"><%- t('vehicle_inventories.document_comment', 'Comment') %></label>
              <input type="text" id="txtDocumentComment" class="form-control form-control-sm" placeholder="<%- t('vehicle_inventories.optional_comment', 'Optional...') %>"/>
            </div>
            <div class="col-md-2">
              <button type="button" class="btn btn-sm btn-outline-primary w-100" id="btnAddDocToQueue"><i class="bi bi-plus-lg me-1"></i><%- t('general.add', 'Add') %></button>
            </div>
          </div>
          <div class="form-hint mt-1 small"><%- t('vehicle_inventories.doc_hint', 'Types 1-6: one document per type. Type "Other File": multiple allowed.') %></div>
        </div>

        <!-- Document queue (pending upload) -->
        <div id="docQueue" class="mb-3"></div>

        <hr class="my-3"/>

        <!-- Document list -->
        <div id="documentList">
          <div class="text-muted small text-center py-3" id="noDocumentsMsg"><%- t('vehicle_inventories.no_documents', 'No documents uploaded yet.') %></div>
        </div>
        <% } else { %>
        <div class="text-muted small text-center py-3"><%- t('vehicle_inventories.documents_after_save', 'Documents can be uploaded after saving the record.') %></div>
        <% } %>
      </div>
    </div>
    <% if (isEdit) { %>
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <button type="button" class="btn btn-outline-primary sms-tab-prev" data-target="#tab-owner"><i class="bi bi-chevron-left me-1"></i><%- t('general.previous','Prev') %></button>
      <button type="button" class="btn btn-primary" id="btnUploadDocument"><i class="bi bi-cloud-upload me-1"></i><%- t('vehicle_inventories.add_save_document', 'Add & Save Document') %></button>
    </div>
    <% } %>
  </div>

</div>
<!-- /tab-content -->

<!-- ============================================================ -->
<!-- Bottom section: Status + Cancel (edit only) -->
<!-- ============================================================ -->
<% if (isEdit) { %>
<div class="card mt-3 shadow-sm">
  <div class="card-body py-3">
    <div class="row align-items-center">
      <div class="col-md-4 mb-2 mb-md-0">
        <label class="form-label fw-medium mb-1"><%- t('general.status', 'Status') %></label>
        <select name="status" class="form-select">
          <option value="1" <%- (isEdit && parseInt(rec.status)) ? 'selected' : '' %>><%- t('general.active', 'Active') %></option>
          <option value="0" <%- (isEdit && !parseInt(rec.status)) ? 'selected' : '' %>><%- t('general.inactive', 'Inactive') %></option>
        </select>
      </div>
      <div class="col-md-8">
        <div class="d-flex gap-2 justify-content-end">
          <a href="/vehicle-inventories" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i><%- t('btn.cancel', 'Cancel') %></a>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

</form>

<script>
window._FORM_DATA = {
  isEdit: <%= isEdit ? 'true' : 'false' %>,
  uuid: '<%= isEdit ? rec.uuid : '' %>',
  vehicleType: <%- isEdit && rec.vehicle_type_id ? JSON.stringify({id: rec.vehicle_type_id, text: rec.vehicle_type_name || ''}) : 'null' %>,
  vehicleYear: <%- isEdit && rec.vehicle_year_id ? JSON.stringify({id: rec.vehicle_year_id, text: rec.vehicle_year_name || ''}) : 'null' %>,
  vehicleMake: <%- isEdit && rec.vehicle_make_id ? JSON.stringify({id: rec.vehicle_make_id, text: rec.vehicle_make_name || ''}) : 'null' %>,
  vehicleModel: <%- isEdit && rec.vehicle_model_id ? JSON.stringify({id: rec.vehicle_model_id, text: rec.vehicle_model_name || ''}) : 'null' %>,
  vehicleVariant: <%- isEdit && rec.vehicle_variant_id ? JSON.stringify({id: rec.vehicle_variant_id, text: rec.vehicle_variant_name || ''}) : 'null' %>,
  vehicleEngine: <%- isEdit && rec.vehicle_engine_id ? JSON.stringify({id: rec.vehicle_engine_id, text: rec.vehicle_engine_name || ''}) : 'null' %>,
  vehicleFuel: <%- isEdit && rec.vehicle_fuel_id ? JSON.stringify({id: rec.vehicle_fuel_id, text: rec.vehicle_fuel_name || ''}) : 'null' %>,
  vehicleCategory: <%- isEdit && rec.vehicle_category_id ? JSON.stringify({id: rec.vehicle_category_id, text: rec.vehicle_category_name || ''}) : 'null' %>,
  ownerCountry: <%- isEdit && rec.owner_country_id ? JSON.stringify({id: rec.owner_country_id, text: rec.owner_country_name || ''}) : 'null' %>,
  images: <%- isEdit && rec.images ? JSON.stringify(rec.images) : '[]' %>,
  videos: <%- isEdit && rec.videos ? JSON.stringify(rec.videos) : '[]' %>,
  documents: <%- isEdit && rec.documents ? JSON.stringify(rec.documents) : '[]' %>
};
</script>

<!-- Preview Modal (for image/video preview) -->
<div class="modal fade" id="modalView" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title"><i class="bi bi-eye me-1"></i><%- t('general.preview','Preview') %></h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="viewBody"></div>
    </div>
  </div>
</div>

<% block('scripts', '<script src="/js/common/image-editor.js"></script><script src="/js/common/video-editor.js"></script><script src="/js/pages/vehicle-inventories-form.js"></script>') %>
