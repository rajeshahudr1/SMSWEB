<%- layout('../layouts/main') %>
<%
var isSuperAdmin = user && user.is_super_admin;
%>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-truck me-2 text-primary"></i><%- t('vehicle_inventories.title', 'Vehicle Inventory') %> <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <% if (can('export_vehicle_inventories')) { %>
      <div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-download me-1"></i><span class="d-none d-sm-inline"><%- t('btn.export', 'Export') %></span></button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li><li><a class="dropdown-item" href="#" onclick="doExport('excel');return false;"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Excel</a></li><li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li></ul>
      </div><% } %>
      <% if (can('add_vehicle_inventories')) { %><a href="/vehicle-inventories/create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline"><%- t('vehicle_inventories.add', 'Add Vehicle') %></span></a><% } %>
    </div>
  </div>

  <!-- Inline Filters -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <div class="col-12 col-sm-6 col-lg-4"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="&#128269;  <%- t('vehicle_inventories.search_ph', 'Search by ID, plate, VIN, brand, model, color, owner...') %>"/></div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterStatus"><option value=""><%- t('general.all_status', 'All Status') %></option><option value="1"><%- t('general.active', 'Active') %></option><option value="0"><%- t('general.inactive', 'Inactive') %></option></select>
      </div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterDeleted"><option value=""><%- t('general.active_records', 'Active Records') %></option><option value="only"><%- t('general.deleted_only', 'Deleted Only') %></option><option value="all"><%- t('general.all_records', 'All Records') %></option></select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="offcanvas" data-bs-target="#filterSidebar" title="<%- t('general.filters', 'Filters') %>"><i class="bi bi-funnel me-1"></i><span class="d-none d-sm-inline"><%- t('general.filters', 'Filters') %></span> <span class="badge bg-primary-lt ms-1 d-none" id="filterCount">0</span></button>
        <button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button>
      </div>
    </div>
  </div>

  <!-- Bulk bar -->
  <div id="bulkBar" class="d-none">
    <div class="sms-bulk-bar rounded-0 border-bottom px-3 py-2">
      <span class="fw-semibold"><span id="bulkCount">0</span> <%- t('general.selected_count', 'selected') %></span>
      <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-outline-light" onclick="bulkAction('deactivate')"><i class="bi bi-toggle-off me-1"></i><%- t('bulk.deactivate', 'Deactivate') %></button>
        <button class="btn btn-sm btn-outline-light" onclick="bulkAction('activate')"><i class="bi bi-toggle-on me-1"></i><%- t('bulk.activate', 'Activate') %></button>
        <button class="btn btn-sm btn-danger" onclick="bulkAction('delete')"><i class="bi bi-trash3 me-1"></i><%- t('btn.delete', 'Delete') %></button>
        <button class="btn btn-sm btn-outline-light d-none" id="btnBulkRecover" onclick="bulkAction('recover')"><i class="bi bi-arrow-counterclockwise me-1"></i><%- t('bulk.recover', 'Recover') %></button>
        <button class="btn btn-sm btn-outline-light" id="btnClearBulk"><i class="bi bi-x-lg"></i></button>
      </div>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead id="viTableHead"><tr><td colspan="20" class="text-center py-3 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading columns...</td></tr></thead>
      <tbody id="tableBody"><tr><td colspan="20" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t('general.loading', 'Loading...') %></td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- ═══ ADVANCED FILTER SIDEBAR ═══ -->
<!-- ═══ ADVANCED FILTER SIDEBAR (tabbed sections) ═══ -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="filterSidebar" style="width:420px;">
  <div class="offcanvas-header py-2">
    <h5 class="offcanvas-title fw-semibold mb-0"><i class="bi bi-funnel me-2"></i>Advanced Filters</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>
  <!-- Filter tabs -->
  <ul class="nav nav-tabs px-3 pt-1" style="font-size:12px;">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#ftVehicle">Vehicle</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ftStatus">Status</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ftDates">Dates</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ftOther">Other</a></li>
  </ul>
  <div class="offcanvas-body tab-content" style="padding-top:12px;">

    <!-- Tab: Vehicle (dependent cascading) -->
    <div class="tab-pane fade show active" id="ftVehicle">
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Vehicle Type</label>
        <select class="form-select form-select-sm" id="filterVehicleType" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Vehicle Make</label>
        <select class="form-select form-select-sm" id="filterVehicleMake" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Vehicle Model</label>
        <select class="form-select form-select-sm" id="filterVehicleModel" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Vehicle Variant</label>
        <select class="form-select form-select-sm" id="filterVehicleVariant" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Vehicle Year</label>
        <select class="form-select form-select-sm" id="filterVehicleYear" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Vehicle Fuel</label>
        <select class="form-select form-select-sm" id="filterVehicleFuel" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Vehicle Category</label>
        <select class="form-select form-select-sm" id="filterVehicleCategory" style="width:100%;"></select>
      </div>
    </div>

    <!-- Tab: Status -->
    <div class="tab-pane fade" id="ftStatus">
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Inventory Status</label>
        <select class="form-select form-select-sm" id="filterInventoryStatus">
          <option value="">All</option><option value="1">In Stock</option><option value="2">Out of Stock</option><option value="3">Sent to Wastage</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Depolution Status</label>
        <select class="form-select form-select-sm" id="filterDepolutionStatus">
          <option value="">All</option><option value="1">Pending</option><option value="2">In Depollution</option><option value="3">Depolluted</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Dismantle Status</label>
        <select class="form-select form-select-sm" id="filterDismantleStatus">
          <option value="">All</option><option value="1">Pending</option><option value="2">In Dismantling</option><option value="3">Dismantled</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">State Parking</label>
        <select class="form-select form-select-sm" id="filterStateParking">
          <option value="">All</option><option value="1">With Declaration</option><option value="2">With Certificate</option><option value="3">Pending to Accept</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Steering Side</label>
        <select class="form-select form-select-sm" id="filterSteeringSide">
          <option value="">All</option><option value="1">Left</option><option value="2">Right</option><option value="3">Not Applicable</option>
        </select>
      </div>
    </div>

    <!-- Tab: Dates -->
    <div class="tab-pane fade" id="ftDates">
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Arrival Date From</label>
        <input type="date" class="form-control form-control-sm" id="filterArrivalFrom"/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Arrival Date To</label>
        <input type="date" class="form-control form-control-sm" id="filterArrivalTo"/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Process Start From</label>
        <input type="date" class="form-control form-control-sm" id="filterProcessStartFrom"/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Process Start To</label>
        <input type="date" class="form-control form-control-sm" id="filterProcessStartTo"/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Created From</label>
        <input type="date" class="form-control form-control-sm" id="filterCreatedFrom"/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Created To</label>
        <input type="date" class="form-control form-control-sm" id="filterCreatedTo"/>
      </div>
    </div>

    <!-- Tab: Other -->
    <div class="tab-pane fade" id="ftOther">
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">VIN</label>
        <input type="text" class="form-control form-control-sm" id="filterVin" placeholder="Search VIN..."/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Color</label>
        <input type="text" class="form-control form-control-sm" id="filterColor" placeholder="Color..."/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Brand</label>
        <input type="text" class="form-control form-control-sm" id="filterBrand" placeholder="Brand..."/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Owner Name</label>
        <input type="text" class="form-control form-control-sm" id="filterOwner" placeholder="Owner..."/>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Registration Plate</label>
        <input type="text" class="form-control form-control-sm" id="filterPlate" placeholder="Plate No..."/>
      </div>
    </div>

  </div>
  <div class="offcanvas-footer border-top p-3 d-flex gap-2">
    <button class="btn btn-sm btn-outline-secondary flex-fill" id="btnClearAdvFilters"><i class="bi bi-x-lg me-1"></i>Clear All</button>
    <button class="btn btn-sm btn-primary flex-fill" data-bs-dismiss="offcanvas"><i class="bi bi-check-lg me-1"></i>Apply</button>
  </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="modalView" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl" style="max-width:960px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-truck me-2 text-primary"></i><%- t('vehicle_inventories.details', 'Vehicle Inventory Details') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-0" id="viewBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close', 'Close') %></button></div></div></div></div>

<!-- Image Modal -->
<div class="modal fade" id="modalImage" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:600px;"><div class="modal-content"><div class="modal-header py-2"><h6 class="modal-title fw-semibold mb-0" id="imgModalTitle"><i class="bi bi-image me-2 text-primary"></i><%- t('vehicle_inventories.image_title', 'Vehicle Image') %></h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-3" id="imgModalBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close', 'Close') %></button></div></div></div></div>

<!-- Usage Modal -->
<% include ../partials/usage-modal %>

<script>window._IS_SUPER = <%= isSuperAdmin ? 'true' : 'false' %>;</script>
<% block('scripts', '<script src="/js/pages/vehicle-inventories.js"></script>') %>
