<%- layout('../layouts/main') %>
<%
var p = profile || {};
var isGoogleOnly    = p.auth_provider === 'google' && !p.password;
var isOrgAdmin      = p.is_org_admin == 1;
var isSuperAdmin    = p.is_super_admin == 1;
/* Company user = has an org but is NOT the org admin and NOT super admin */
var isCompanyUser   = !isSuperAdmin && !isOrgAdmin && !!p.organization_id;
var showCompanyTab  = isOrgAdmin || isCompanyUser;
%>

<div class="row g-4">

  <!-- ════════ LEFT COLUMN — Avatar card ════════ -->
  <div class="col-lg-3 col-md-4">

    <!-- Avatar / Identity card -->
    <div class="card text-center sms-profile-card">
      <div class="card-body pt-4">

        <!-- Avatar with upload overlay -->
        <div class="sms-avatar-upload-wrap mb-3" id="avatarClickZone" title="Click to change photo">
          <div class="sms-avatar-circle" id="avatarDisplay">
            <% if (p.profile_image_url) { %>
              <img src="<%- p.profile_image_url %>" alt="avatar" class="sms-avatar-img" id="avatarImg"/>
            <% } else { %>
              <span class="sms-avatar-initials" id="avatarInitials">
                <%- p.name ? p.name.charAt(0).toUpperCase() : 'U' %>
              </span>
            <% } %>
          </div>
          <div class="sms-avatar-overlay">
            <i class="bi bi-camera-fill"></i>
            <span>Change Photo</span>
          </div>
          <!-- Hidden file input -->
          <input type="file" id="avatarFile" accept="image/jpeg,image/png,image/gif,image/webp"
                 style="display:none;"/>
        </div>

        <!-- Upload progress -->
        <div id="avatarUploadProgress" style="display:none;" class="mb-2">
          <div class="progress" style="height:4px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary w-100"></div>
          </div>
          <div class="small text-muted mt-1">Uploading...</div>
        </div>

        <h4 class="fw-bold mb-0"><%- H.escape(p.name || '') %></h4>
        <p class="text-muted small mb-2"><%- p.email || '' %></p>

        <% if (p.role_name) { %>
          <span class="badge bg-primary-lt mb-1"><%- p.role_name %></span>
        <% } %>
        <br/>
        <span class="badge <%- p.status==1 ? 'bg-success-lt' : 'bg-danger-lt' %>">
          <span class="status-dot <%- p.status==1 ? 'bg-success' : 'bg-danger' %> me-1"></span>
          <%- p.status==1 ? 'Active' : 'Inactive' %>
        </span>
      </div>

      <!-- Stats row -->
      <div class="card-footer p-0">
        <div class="row g-0 text-center">
          <div class="col-6 py-2 border-end">
            <div class="fw-bold text-primary"><%- (p.panel_access||'').toUpperCase() || '—' %></div>
            <div class="text-muted" style="font-size:11px;">Panel</div>
          </div>
          <div class="col-6 py-2">
            <div class="fw-bold text-primary"><%- isOrgAdmin ? 'Admin' : 'User' %></div>
            <div class="text-muted" style="font-size:11px;">Role</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Address proof card -->
    <% if (p.address_proof_url) { %>
      <div class="card mt-3">
        <div class="card-body py-3">
          <div class="d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-file-earmark-check-fill text-success"></i>
            <span class="fw-semibold small">Address Proof</span>
          </div>
          <a href="<%- p.address_proof_url %>" target="_blank"
             class="btn btn-sm btn-outline-success w-100">
            <i class="bi bi-eye me-1"></i>View Document
          </a>
        </div>
      </div>
    <% } %>

    <!-- Quick info -->
    <div class="card mt-3">
      <div class="card-body py-2">
        <% if (p.country_name || p.state_name || p.city_name) { %>
          <div class="d-flex align-items-start gap-2 py-2 border-bottom">
            <i class="bi bi-geo-alt-fill text-primary mt-1" style="font-size:13px;"></i>
            <div class="small">
              <div class="fw-medium"><%- [p.city_name, p.state_name, p.country_name].filter(Boolean).join(', ') %></div>
              <% if (p.zip_code) { %><div class="text-muted"><%- p.zip_code %></div><% } %>
            </div>
          </div>
        <% } %>
        <% if (p.phone) { %>
          <div class="d-flex align-items-center gap-2 py-2 border-bottom">
            <i class="bi bi-telephone-fill text-primary" style="font-size:13px;"></i>
            <span class="small"><%- p.phone %></span>
          </div>
        <% } %>
        <% if (p.gender) { %>
          <div class="d-flex align-items-center gap-2 py-2 border-bottom">
            <i class="bi bi-person-fill text-primary" style="font-size:13px;"></i>
            <span class="small text-capitalize"><%- p.gender %></span>
          </div>
        <% } %>
        <% if (p.company_name) { %>
          <div class="d-flex align-items-center gap-2 py-2">
            <i class="bi bi-building-fill text-primary" style="font-size:13px;"></i>
            <span class="small"><%- p.company_name %></span>
          </div>
        <% } %>
      </div>
    </div>

  </div>

  <!-- ════════ RIGHT COLUMN — Forms ════════ -->
  <div class="col-lg-9 col-md-8">
    <div class="card">

      <!-- Tab header — pill style -->
      <div class="sms-profile-tabs-wrap">
        <div class="sms-profile-tabs" id="profileTabs">
          <a href="#tab-info" class="sms-profile-tab active" data-sms-tab="tab-info">
            <span class="sms-profile-tab__icon"><i class="bi bi-person-fill"></i></span>
            <span class="sms-profile-tab__label">Profile Info</span>
          </a>
          <% if (showCompanyTab) { %>
            <a href="#tab-company" class="sms-profile-tab" data-sms-tab="tab-company">
              <span class="sms-profile-tab__icon"><i class="bi bi-building-fill"></i></span>
              <span class="sms-profile-tab__label">Company</span>
              <% if (isCompanyUser) { %><span class="sms-profile-tab__badge">View</span><% } %>
            </a>
          <% } %>
          <a href="#tab-password" class="sms-profile-tab" data-sms-tab="tab-password">
            <span class="sms-profile-tab__icon"><i class="bi bi-shield-lock-fill"></i></span>
            <span class="sms-profile-tab__label"><%- isGoogleOnly ? 'Set Password' : 'Change Password' %></span>
          </a>
        </div>
      </div>

      <div class="card-body tab-content p-4">

        <!-- ── Profile Info Tab ─────────────────────── -->
        <div class="tab-pane active" id="tab-info">
          <form id="frmProfile" novalidate autocomplete="off">
            <div class="row g-3">

              <!-- Name -->
              <div class="col-md-6">
                <label class="form-label required">Full Name</label>
                <input type="text" name="name" id="pName" class="form-control"
                       value="<%- H.escape(p.name||'') %>"
                       placeholder="Your full name" required/>
                <div class="invalid-feedback" id="err-pName"></div>
              </div>

              <!-- Email (readonly) -->
              <div class="col-md-6">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" value="<%- p.email||'' %>"
                       readonly tabindex="-1"
                       style="background:var(--tblr-bg-surface-secondary,#f8fafc);cursor:default;"/>
                <div class="form-hint"><i class="bi bi-info-circle me-1"></i>Email cannot be changed.</div>
              </div>

              <!-- Phone -->
              <div class="col-md-6">
                <label class="form-label required">Phone</label>
                <div id="pPhoneWrap"></div>
                <input type="hidden" name="phone" id="pPhone" value="<%- H.escape(p.phone||'') %>"/>
                <div class="invalid-feedback d-block" id="err-pPhone"></div>
              </div>

              <!-- Gender -->
              <div class="col-md-6">
                <label class="form-label">Gender</label>
                <select name="gender" class="form-select">
                  <option value="">— Select —</option>
                  <option value="male"   <%- p.gender==='male'   ? 'selected':'' %>>Male</option>
                  <option value="female" <%- p.gender==='female' ? 'selected':'' %>>Female</option>
                  <option value="other"  <%- p.gender==='other'  ? 'selected':'' %>>Other</option>
                </select>
              </div>

              <!-- DOB -->
              <div class="col-md-6">
                <label class="form-label">Date of Birth</label>
                <input type="date" name="dob" class="form-control"
                       value="<%- p.dob ? String(p.dob).slice(0,10) : '' %>"/>
              </div>

              <!-- PAN -->
              <div class="col-md-6">
                <label class="form-label">PAN Number</label>
                <input type="text" name="pan_no" class="form-control text-uppercase"
                       value="<%- H.escape(p.pan_no||'') %>"
                       placeholder="ABCDE1234F" maxlength="10"
                       style="letter-spacing:1px;"/>
                <div class="form-hint">Format: ABCDE1234F</div>
              </div>

              <!-- Aadhar -->
              <div class="col-md-6">
                <label class="form-label">Aadhar Number</label>
                <input type="text" name="aadhar_no" id="pAadhar" class="form-control"
                       value="<%- H.escape(p.aadhar_no||'') %>"
                       placeholder="XXXX XXXX XXXX" maxlength="14"/>
                <div class="form-hint">12-digit Aadhar number</div>
              </div>

              <!-- Location divider -->
              <div class="col-12">
                <div class="d-flex align-items-center gap-2 my-1">
                  <i class="bi bi-geo-alt-fill text-primary"></i>
                  <span class="fw-semibold small text-muted text-uppercase" style="letter-spacing:.5px;">Location</span>
                  <hr class="flex-fill m-0"/>
                </div>
              </div>

              <!-- Country -->
              <div class="col-md-4">
                <label class="form-label required">Country</label>
                <select name="country_id" id="pCountry" class="form-select select2-location" required>
                  <option value="">— Select Country —</option>
                </select>
                <div class="invalid-feedback" id="err-pCountry"></div>
              </div>

              <!-- State -->
              <div class="col-md-4">
                <label class="form-label required">State</label>
                <select name="state_id" id="pState" class="form-select" required disabled>
                  <option value="">— Select State —</option>
                </select>
                <div class="invalid-feedback" id="err-pState"></div>
              </div>

              <!-- City -->
              <div class="col-md-4">
                <label class="form-label required">City</label>
                <select name="city_id" id="pCity" class="form-select" required disabled>
                  <option value="">— Select City —</option>
                </select>
                <div class="invalid-feedback" id="err-pCity"></div>
              </div>

              <!-- ZIP -->
              <div class="col-md-4">
                <label class="form-label required">ZIP / Postal Code</label>
                <input type="text" name="zip_code" id="pZip" class="form-control"
                       value="<%- H.escape(p.zip_code||'') %>"
                       placeholder="400001" required maxlength="10"/>
                <div class="invalid-feedback" id="err-pZip"></div>
              </div>

              <!-- Address -->
              <div class="col-12">
                <label class="form-label required">Address</label>
                <textarea name="address" id="pAddress" class="form-control" rows="2"
                          placeholder="Plot No, Street, Area, Landmark" required><%- H.escape(p.address||'') %></textarea>
                <div class="invalid-feedback" id="err-pAddress"></div>
              </div>

            </div><!-- /row -->

            <!-- Hidden prefill -->
            <input type="hidden" id="prefillCountryId" value="<%- p.country_id||'' %>"/>
            <input type="hidden" id="prefillStateId"   value="<%- p.state_id||'' %>"/>
            <input type="hidden" id="prefillCityId"    value="<%- p.city_id||'' %>"/>

            <div class="d-flex justify-content-end mt-4 pt-3 border-top">
              <button type="button" id="btnProfileReset" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
              </button>
              <button type="submit" id="btnProfile" class="btn btn-primary">
                <i class="bi bi-floppy me-1"></i>Save Profile
              </button>
            </div>
          </form>
        </div>

        <!-- ── Company Tab (org admin = editable, company user = read-only) ── -->
        <% if (showCompanyTab) { %>
          <div class="tab-pane" id="tab-company">

            <% if (isOrgAdmin) { %>
              <div class="sms-tab-notice sms-tab-notice--info mb-4">
                <i class="bi bi-info-circle-fill"></i>
                <span>Updating company details here will sync to your organisation profile.</span>
              </div>
            <% } else { %>
              <div class="sms-tab-notice sms-tab-notice--view mb-4">
                <i class="bi bi-eye-fill"></i>
                <span>You can view your company information. Contact your administrator to make changes.</span>
              </div>
            <% } %>

            <!-- READ-ONLY VIEW for company users -->
            <% if (isCompanyUser) { %>
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="sms-info-row">
                    <div class="sms-info-row__label"><i class="bi bi-building me-2"></i>Company Name</div>
                    <div class="sms-info-row__value"><%- H.escape(p.company_name||'—') %></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="sms-info-row">
                    <div class="sms-info-row__label"><i class="bi bi-hash me-2"></i>Registration Number</div>
                    <div class="sms-info-row__value"><%- H.escape(p.registration_number||'—') %></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="sms-info-row">
                    <div class="sms-info-row__label"><i class="bi bi-telephone me-2"></i>Company Phone</div>
                    <div class="sms-info-row__value"><%- H.escape(p.org_phone||'—') %></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="sms-info-row">
                    <div class="sms-info-row__label"><i class="bi bi-globe me-2"></i>Website</div>
                    <div class="sms-info-row__value">
                      <% if (p.org_website) { %>
                        <a href="<%- H.escape(p.org_website) %>" target="_blank" class="text-primary">
                          <%- H.escape(p.org_website) %>
                        </a>
                      <% } else { %>—<% } %>
                    </div>
                  </div>
                </div>
                <% if (p.address_proof_url) { %>
                  <div class="col-12">
                    <div class="sms-info-row">
                      <div class="sms-info-row__label"><i class="bi bi-file-earmark-check me-2"></i>Address Proof</div>
                      <div class="sms-info-row__value">
                        <a href="<%- p.address_proof_url %>" target="_blank" class="btn btn-sm btn-outline-success">
                          <i class="bi bi-eye me-1"></i>View Document
                        </a>
                      </div>
                    </div>
                  </div>
                <% } %>
              </div>
            <% } else { %>
              <!-- EDITABLE FORM for org admins -->
              <form id="frmCompany" novalidate autocomplete="off">
                <div class="row g-3">

                  <div class="col-md-6">
                    <label class="form-label required">Company Name</label>
                    <input type="text" name="company_name" id="cName" class="form-control"
                           value="<%- H.escape(p.company_name||'') %>" required/>
                    <div class="invalid-feedback" id="err-cName"></div>
                  </div>

                  <div class="col-md-6">
                    <label class="form-label">Registration Number</label>
                    <input type="text" name="registration_number" class="form-control"
                           value="<%- H.escape(p.registration_number||'') %>"/>
                  </div>

                  <div class="col-md-6">
                    <label class="form-label">Company Phone</label>
                    <div id="orgPhoneWrap"></div>
                    <input type="hidden" name="org_phone" id="orgPhone"
                           value="<%- H.escape(p.org_phone||'') %>"/>
                  </div>

                  <div class="col-md-6">
                    <label class="form-label">Website</label>
                    <div class="input-group">
                      <span class="input-group-text"><i class="bi bi-globe"></i></span>
                      <input type="url" name="org_website" class="form-control"
                             value="<%- H.escape(p.org_website||'') %>"
                             placeholder="https://yourcompany.com"/>
                    </div>
                  </div>

                  <!-- Address Proof -->
                  <div class="col-12">
                    <label class="form-label">Address Proof</label>
                    <% if (p.address_proof_url) { %>
                      <div class="sms-proof-current mb-2">
                        <div class="d-flex align-items-center gap-2 p-2 border rounded-2">
                          <i class="bi bi-file-earmark-check-fill text-success fs-5"></i>
                          <div class="flex-fill">
                            <div class="small fw-medium">Current document</div>
                            <div class="text-muted" style="font-size:11px;">Uploaded address proof</div>
                          </div>
                          <a href="<%- p.address_proof_url %>" target="_blank"
                             class="btn btn-sm btn-outline-success">
                            <i class="bi bi-eye me-1"></i>View
                          </a>
                        </div>
                      </div>
                      <label class="form-label small text-muted">Upload new (replaces current):</label>
                    <% } %>
                    <input type="file" name="address_proof" id="orgProofFile"
                           class="form-control"
                           accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"/>
                    <div class="form-hint">Accepted: JPG, PNG, PDF, DOC. Max 10MB.</div>
                  </div>

                </div>

                <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                  <button type="submit" id="btnCompany" class="btn btn-primary">
                    <i class="bi bi-floppy me-1"></i>Save Company Details
                  </button>
                </div>
              </form>
            <% } %>

          </div>
        <% } %>

        <!-- ── Password Tab ──────────────────────────── -->
        <div class="tab-pane" id="tab-password">
          <% if (isGoogleOnly) { %>
            <div class="alert alert-info-lt border-0 d-flex gap-2 mb-4"
                 style="background:var(--tblr-info-lt,#e8f4fd);border-radius:8px;padding:12px 16px;">
              <i class="bi bi-google me-2 text-info mt-1" style="flex-shrink:0;"></i>
              <div class="small">You signed in with Google. Set a password to also login with email & password.</div>
            </div>
          <% } %>

          <form id="frmPassword" novalidate autocomplete="off" style="max-width:460px;">
            <div class="row g-3">

              <!-- Current password (only for local auth) -->
              <% if (!isGoogleOnly) { %>
                <div class="col-12">
                  <label class="form-label required">Current Password</label>
                  <div class="input-group">
                    <input type="password" name="current_password" id="curPwd"
                           class="form-control" placeholder="Enter current password" required/>
                    <button type="button" class="btn btn-outline-secondary sms-pwd-toggle" tabindex="-1">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                  <div class="invalid-feedback d-block" id="err-curPwd"></div>
                </div>
              <% } %>

              <div class="col-12">
                <label class="form-label required">New Password</label>
                <div class="input-group">
                  <input type="password" name="<%= isGoogleOnly ? 'new_password' : 'password' %>"
                         id="newPwd" class="form-control"
                         placeholder="Min 8 characters" required minlength="8"/>
                  <button type="button" class="btn btn-outline-secondary sms-pwd-toggle" tabindex="-1">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
                <!-- Strength bar -->
                <div id="pwdStrengthBar" class="mt-1" style="display:none;">
                  <div class="progress" style="height:4px;">
                    <div id="pwdStrengthFill" class="progress-bar" style="width:0%;transition:width .3s;"></div>
                  </div>
                  <div id="pwdStrengthLabel" class="form-hint mt-1"></div>
                </div>
                <div class="invalid-feedback d-block" id="err-newPwd"></div>
              </div>

              <div class="col-12">
                <label class="form-label required">Confirm New Password</label>
                <div class="input-group">
                  <input type="password" name="confirm_password" id="confPwd"
                         class="form-control" placeholder="Repeat new password" required/>
                  <button type="button" class="btn btn-outline-secondary sms-pwd-toggle" tabindex="-1">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
                <div class="invalid-feedback d-block" id="err-confPwd"></div>
              </div>

              <!-- Password rules hint -->
              <div class="col-12">
                <div class="sms-pwd-rules">
                  <div class="sms-pwd-rule" id="rule-len"><i class="bi bi-circle"></i> At least 8 characters</div>
                  <div class="sms-pwd-rule" id="rule-upper"><i class="bi bi-circle"></i> One uppercase letter</div>
                  <div class="sms-pwd-rule" id="rule-num"><i class="bi bi-circle"></i> One number</div>
                </div>
              </div>

            </div>

            <div class="d-flex justify-content-end mt-4 pt-3 border-top">
              <button type="submit" id="btnPassword" class="btn btn-primary">
                <i class="bi <%- isGoogleOnly ? 'bi-key' : 'bi-lock' %> me-1"></i>
                <%- isGoogleOnly ? 'Set Password' : 'Change Password' %>
              </button>
            </div>
          </form>
        </div>

      </div><!-- /tab-content -->
    </div><!-- /card -->
  </div>

</div><!-- /row -->

<!-- Profile data for JS — used by company form to pass required personal fields -->
<script>
  window.SMS_PROFILE = <%- JSON.stringify({
    name:       p.name       || '',
    phone:      p.phone      || '',
    country_id: p.country_id || '',
    state_id:   p.state_id   || '',
    city_id:    p.city_id    || '',
    zip_code:   p.zip_code   || '',
    address:    p.address    || '',
  }) %>;
</script>

<% block('scripts', '<script src="/js/common/location.js"></script><script src="/js/common/phone.js"></script><script src="/js/pages/profile.js"></script>') %>
