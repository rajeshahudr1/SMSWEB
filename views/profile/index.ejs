<%- layout('../layouts/main') %>

<div class="row">

    <!-- Left: avatar + basic info -->
    <div class="col-md-3 mb-4">
        <div class="card">
            <div class="card-body text-center">
                <% if (profile && profile.profile_image) { %>
                    <span class="avatar avatar-xl mb-3 avatar-rounded"
                          style="background-image: url(<%- profile.profile_image %>)"></span>
                <% } else { %>
                    <span class="avatar avatar-xl bg-primary text-white mb-3 avatar-rounded"
                          style="font-size:36px;">
                        <%- profile ? profile.name.charAt(0).toUpperCase() : 'U' %>
                    </span>
                <% } %>
                <h3 class="mb-1"><%- profile ? profile.name : '' %></h3>
                <p class="text-secondary small mb-3"><%- profile ? profile.email : '' %></p>
                <span class="badge <%- (profile && profile.status == 1) ? 'bg-success-lt' : 'bg-danger-lt' %>">
                    <%- (profile && profile.status == 1) ? 'Active' : 'Inactive' %>
                </span>
            </div>
        </div>
    </div>

    <!-- Right: tabs with profile info + change password -->
    <div class="col-md-9">
        <div class="card">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs" data-bs-toggle="tabs">
                    <li class="nav-item">
                        <a href="#tab-profile" class="nav-link active" data-bs-toggle="tab">
                            <i class="ti ti-user me-1"></i> Profile
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#tab-password" class="nav-link" data-bs-toggle="tab">
                            <i class="ti ti-lock me-1"></i> Change Password
                        </a>
                    </li>
                </ul>
            </div>

            <div class="card-body">
                <div class="tab-content">

                    <!-- Profile tab -->
                    <div class="tab-pane active" id="tab-profile">
                        <form id="frmProfile" method="POST" action="/profile" novalidate>
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="form-label required">Full Name</label>
                                    <input type="text" name="name" class="form-control"
                                           value="<%- profile ? profile.name : '' %>" required/>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Phone</label>
                                    <input type="text" name="phone" class="form-control"
                                           value="<%- profile ? (profile.phone || '') : '' %>"/>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Gender</label>
                                    <select name="gender" class="form-select">
                                        <option value="">-- Select --</option>
                                        <option value="male"   <%- (profile && profile.gender === 'male')   ? 'selected' : '' %>>Male</option>
                                        <option value="female" <%- (profile && profile.gender === 'female') ? 'selected' : '' %>>Female</option>
                                        <option value="other"  <%- (profile && profile.gender === 'other')  ? 'selected' : '' %>>Other</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Date of Birth</label>
                                    <input type="date" name="dob" class="form-control"
                                           value="<%- (profile && profile.dob) ? profile.dob.substring(0,10) : '' %>"/>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Address</label>
                                    <input type="text" name="address" class="form-control"
                                           value="<%- profile ? (profile.address || '') : '' %>"/>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">PAN Number</label>
                                    <input type="text" name="pan_no" class="form-control text-uppercase"
                                           value="<%- profile ? (profile.pan_no || '') : '' %>"
                                           placeholder="ABCDE1234F" maxlength="10"/>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Aadhar Number</label>
                                    <input type="text" name="aadhar_no" class="form-control"
                                           value="<%- profile ? (profile.aadhar_no || '') : '' %>"
                                           placeholder="12-digit Aadhar" maxlength="12"/>
                                </div>

                            </div>
                            <div class="mt-4 text-end">
                                <button type="submit" id="btnProfile" class="btn btn-primary"
                                        data-loading="Saving..." data-original-text="Save Profile">
                                    Save Profile
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Change Password tab -->
                    <div class="tab-pane" id="tab-password">
                        <form id="frmPassword" method="POST" action="/profile/change-password" novalidate>
                            <div class="row g-3" style="max-width:450px;">

                                <div class="col-12">
                                    <label class="form-label required">Current Password</label>
                                    <input type="password" name="current_password"
                                           class="form-control" required placeholder="Current password"/>
                                </div>

                                <div class="col-12">
                                    <label class="form-label required">New Password</label>
                                    <input type="password" name="password" id="newPwd"
                                           class="form-control" required placeholder="Min 8 characters" minlength="8"/>
                                </div>

                                <div class="col-12">
                                    <label class="form-label required">Confirm New Password</label>
                                    <input type="password" name="confirm_password"
                                           class="form-control" required placeholder="Repeat new password"/>
                                </div>

                            </div>
                            <div class="mt-4 text-end" style="max-width:450px;">
                                <button type="submit" id="btnPassword" class="btn btn-primary"
                                        data-loading="Updating..." data-original-text="Change Password">
                                    Change Password
                                </button>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>

<script src="/js/pages/profile.js"></script>
