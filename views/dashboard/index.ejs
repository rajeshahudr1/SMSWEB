<%- layout('../layouts/main') %>

<!-- Stat cards 2x2 mobile, 4 col desktop -->
<div class="row row-deck row-cards mb-3 g-3">
  <%
  var stats_cards = [
    { icon:'ti-users',         label:'Total Users',    val: stats ? stats.total_users : 0,       color:'blue',   trend:'+12%',  badge:'bg-success-lt' },
    { icon:'ti-car',           label:'Vehicles Today', val: stats ? (stats.vehicles_today||0):0,  color:'green',  trend:'Today', badge:'bg-green-lt'   },
    { icon:'ti-shield-lock',   label:'Roles',          val: stats ? stats.total_roles : 0,        color:'orange', trend:'RBAC',  badge:'bg-yellow-lt'  },
    { icon:'ti-key',           label:'Permissions',    val: stats ? stats.total_permissions : 0,  color:'purple', trend:'Active',badge:'bg-purple-lt'  },
  ];
  %>
  <% stats_cards.forEach(function(sc){ %>
  <div class="col-6 col-lg-3">
    <div class="card card-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-start justify-content-between mb-3">
          <span class="avatar bg-<%- sc.color %>-lt" style="font-size:20px; width:40px; height:40px;">
            <i class="ti <%- sc.icon %> text-<%- sc.color %>"></i>
          </span>
          <span class="badge <%- sc.badge %> small"><%- sc.trend %></span>
        </div>
        <div class="h2 mb-1" style="font-size:1.8rem;"><%- sc.val %></div>
        <div class="text-secondary small"><%- sc.label %></div>
      </div>
    </div>
  </div>
  <% }) %>
</div>

<!-- Welcome card -->
<div class="row g-3 mb-3">
  <div class="col-lg-8">
    <div class="card h-100">
      <div class="card-body">
        <div class="row align-items-center g-3">
          <div class="col-auto">
            <span class="avatar avatar-lg bg-primary-lt" style="width:60px;height:60px;font-size:26px;">
              <i class="ti ti-<%= (user && user.is_org_admin) ? 'crown' : 'user' %> text-primary"></i>
            </span>
          </div>
          <div class="col">
            <h3 class="mb-1">Welcome back, <strong><%- user ? user.name : 'User' %></strong> 👋</h3>
            <p class="text-secondary mb-0 small">
              <i class="ti ti-badge me-1"></i><%- (user && user.is_org_admin) ? 'Administrator' : 'Staff User' %>
              <% if (user && user.organization_name) { %>
              &nbsp;·&nbsp;<i class="ti ti-building me-1"></i><%- user.organization_name %>
              <% } %>
            </p>
          </div>
          <div class="col-12 col-sm-auto d-flex flex-wrap gap-2">
            <a href="/profile"  class="btn btn-sm btn-outline-primary"><i class="ti ti-user me-1"></i>Profile</a>
            <a href="/users"    class="btn btn-sm btn-primary"><i class="ti ti-users me-1"></i>Manage Users</a>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card h-100">
      <div class="card-header py-2">
        <div class="card-title small"><i class="ti ti-database me-1 text-secondary"></i>Storage Used</div>
      </div>
      <div class="card-body py-3">
        <div class="d-flex justify-content-between mb-1">
          <span class="small text-secondary">6.5 GB of 10 GB</span>
          <span class="small fw-semibold text-primary">65%</span>
        </div>
        <div class="progress mb-3" style="height:8px; border-radius:4px;">
          <div class="progress-bar bg-primary" style="width:65%;"></div>
        </div>
        <div class="row text-center g-2">
          <div class="col-4">
            <div class="fw-bold text-blue" style="font-size:13px;">915 MB</div>
            <div class="text-muted" style="font-size:11px;">Regular</div>
          </div>
          <div class="col-4">
            <div class="fw-bold text-orange" style="font-size:13px;">415 MB</div>
            <div class="text-muted" style="font-size:11px;">System</div>
          </div>
          <div class="col-4">
            <div class="fw-bold text-green" style="font-size:13px;">3.5 GB</div>
            <div class="text-muted" style="font-size:11px;">Free</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Quick modules -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title"><i class="ti ti-layout-grid me-2 text-primary"></i>Quick Access</h3>
  </div>
  <div class="card-body">
    <div class="row g-3">
      <% [
        { icon:'ti-users',       label:'Users',      url:'/users',    color:'blue',   desc:'Manage accounts' },
        { icon:'ti-shield-lock', label:'Roles',       url:'/roles',    color:'green',  desc:'Access control'  },
        { icon:'ti-settings',    label:'Settings',    url:'/settings', color:'orange', desc:'App preferences' },
        { icon:'ti-user-circle', label:'My Profile',  url:'/profile',  color:'purple', desc:'Update info'     },
      ].forEach(function(m){ %>
      <div class="col-6 col-md-3">
        <a href="<%- m.url %>" class="card card-link border text-decoration-none h-100"
           style="transition:box-shadow .18s; cursor:pointer;"
           onmouseenter="this.style.boxShadow='0 4px 16px rgba(0,0,0,.1)'"
           onmouseleave="this.style.boxShadow=''">
          <div class="card-body text-center py-3 px-2">
            <span class="avatar avatar-md bg-<%- m.color %>-lt mb-2" style="font-size:22px;">
              <i class="ti <%- m.icon %> text-<%- m.color %>"></i>
            </span>
            <div class="fw-semibold" style="font-size:13.5px;"><%- m.label %></div>
            <div class="text-muted" style="font-size:11.5px;"><%- m.desc %></div>
          </div>
        </a>
      </div>
      <% }) %>
    </div>
  </div>
</div>
