<%- layout('../layouts/main') %>
<% var r = typeof record !== 'undefined' && record ? record : null; var isEdit = !!r; %>
<div class="card shadow-sm" style="max-width:700px;margin:0 auto;">
  <div class="card-header py-3"><h3 class="card-title mb-0"><i class="bi bi-map me-2 text-primary"></i><%- isEdit ? t('states.edit', 'Edit State') : t('states.add', 'Add State') %></h3></div>
  <div class="card-body">
    <form id="frmSave">
      <div class="mb-3"><label class="form-label"><%- t('states.name', 'State Name') %> <span class="text-danger">*</span></label><input type="text" class="form-control" name="name" id="fldName" value="<%= r ? r.name : '' %>" required autofocus/></div>
      <div class="mb-3">
        <label class="form-label"><%- t('states.country', 'Country') %> <span class="text-danger">*</span></label>
        <select class="form-select" name="country_id" id="fldCountry" required style="width:100%;"></select>
      </div>
      <div class="mb-3"><label class="form-label"><%- t('general.status', 'Status') %></label><select class="form-select" name="status" id="fldStatus"><option value="1" <%= r && !parseInt(r.status) ? '' : 'selected' %>><%- t('general.active', 'Active') %></option><option value="0" <%= r && !parseInt(r.status) ? 'selected' : '' %>><%- t('general.inactive', 'Inactive') %></option></select></div>
      <div class="d-flex gap-2"><button type="submit" class="btn btn-primary" id="btnSave"><i class="bi bi-check-lg me-1"></i><%- isEdit ? t('btn.update', 'Update') : t('btn.save', 'Save') %></button><a href="/states" class="btn btn-ghost-secondary"><%- t('btn.cancel', 'Cancel') %></a></div>
    </form>
  </div>
</div>
<script>
window._FORM = { isEdit: <%= isEdit ? 'true':'false' %>, uuid: '<%= r ? r.uuid : '' %>', fkId: <%= r && r.country_id ? r.country_id : 0 %>, fkName: '<%= r && r.country_name ? r.country_name : '' %>' };
</script>
<% block('scripts', '<script src="/js/pages/states-form.js"></script>') %>
