<%- layout('../layouts/main') %>

<div class="card shadow-sm">

  <!-- ── Card header: title + panel toggle + view switch + add ── -->
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto">
        <i class="bi bi-key me-2 text-primary"></i>Permissions
        <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span>
      </h3>

      <!-- B2B / B2C pill toggle -->
      <div class="sms-panel-toggle" id="panelGroup">
        <button class="sms-panel-btn active" data-panel="b2b">
          <i class="bi bi-building"></i><span>B2B</span>
        </button>
        <button class="sms-panel-btn" data-panel="b2c">
          <i class="bi bi-person"></i><span>B2C</span>
        </button>
      </div>

      <div class="vr d-none d-sm-block" style="height:20px;opacity:.2;"></div>

      <!-- View toggle — pill style -->
      <div class="sms-view-toggle">
        <button class="sms-view-btn active" id="btnViewGroup" title="Grouped by menu">
          <i class="bi bi-grid-3x3-gap"></i><span class="d-none d-md-inline">Grouped</span>
        </button>
        <button class="sms-view-btn" id="btnViewFlat" title="Flat table">
          <i class="bi bi-table"></i><span class="d-none d-md-inline">Table</span>
        </button>
      </div>

      <% if (can('add_permissions')) { %>
      <button class="btn btn-sm btn-primary" id="btnAddPerm">
        <i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline">Add Permission</span>
      </button>
      <% } %>
    </div>
  </div>

  <!-- ── Filters: search + menu + action ── -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <div class="col-12 col-sm-4 col-lg-3">
        <input type="text" class="form-control form-control-sm sms-filter-search" id="searchInput"
               placeholder="&#128269;  Search name or key…"/>
      </div>
      <div class="col-6 col-sm-3 col-lg-3">
        <select class="form-select form-select-sm" id="filterGroup" style="width:100%;">
          <option value="">All Menus</option>
        </select>
      </div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterAction" style="width:100%;">
          <option value="">All Actions</option>
        </select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-outline-secondary sms-filter-clear" id="btnClearFilters" title="Clear all filters">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Grouped view ── -->
  <div id="groupedView">
    <div class="card-body p-3" id="permGroups">
      <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading…
      </div>
    </div>
  </div>

  <!-- ── Flat table view ── -->
  <div id="flatView" class="d-none">
    <div class="table-responsive">
      <table class="table table-hover table-vcenter mb-0">
        <thead>
          <tr>
            <th style="width:36px;" class="text-muted">#</th>
            <th>Permission Key</th>
            <th class="d-none d-sm-table-cell">Display Name</th>
            <th class="d-none d-md-table-cell">Menu / Group</th>
            <th class="d-none d-md-table-cell">Action</th>
            <th>Panel</th>
            <th class="text-end" style="width:80px;">Actions</th>
          </tr>
        </thead>
        <tbody id="flatTableBody"></tbody>
      </table>
    </div>
    <div class="card-footer d-flex align-items-center flex-wrap gap-2">
      <div class="text-muted small" id="tableInfo"></div>
      <div class="ms-auto" id="tablePagination"></div>
    </div>
  </div>
</div>

<!-- ════════ Add / Edit Permission Modal ════════ -->
<div class="modal fade" id="modalPerm" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width:500px;">
    <div class="modal-content">
      <div class="modal-header border-bottom py-3">
        <h5 class="modal-title fw-semibold" id="modalPermTitle">
          <i class="bi bi-key me-2 text-primary"></i>Add Permission
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="frmPermission" novalidate>
        <input type="hidden" id="editUuid" value=""/>
        <div class="modal-body p-3">
          <div class="row g-3">

            <!-- Menu (replaces Group / Module text input) -->
            <div class="col-12">
              <label class="form-label fw-medium">Menu <span class="text-danger">*</span></label>
              <select name="menu_id" id="fldMenuId" class="form-select" required style="width:100%;">
                <option value="">— Select Menu —</option>
              </select>
              <div class="form-hint">Permissions are linked to a menu. Select which menu this permission belongs to.</div>
            </div>

            <!-- Action (dynamic from API enum) -->
            <div class="col-sm-6">
              <label class="form-label fw-medium">Action <span class="text-danger">*</span></label>
              <select name="action" id="fldAction" class="form-select" required style="width:100%;"></select>
            </div>

            <!-- Panel Type (locked to active tab) -->
            <div class="col-sm-6">
              <label class="form-label fw-medium">Panel</label>
              <input type="hidden" name="panel_type" id="fldPanelType"/>
              <div class="form-control bg-body-secondary d-flex align-items-center gap-2" id="panelDisplay"
                   style="pointer-events:none;min-height:38px;"></div>
            </div>

            <!-- Display Name (auto-generated, editable) -->
            <div class="col-12">
              <label class="form-label fw-medium">Display Name <span class="text-danger">*</span></label>
              <input type="text" name="display_name" id="fldDisplayName" class="form-control" required
                     placeholder="Auto-generated from menu + action"/>
              <div class="form-hint">Auto-filled. You can edit if needed.</div>
            </div>

            <!-- Permission Key (readonly, edit only) -->
            <div class="col-12" id="permKeyRow" style="display:none;">
              <label class="form-label fw-medium">Permission Key</label>
              <input type="text" class="form-control form-control-sm bg-body-secondary" id="permKeyDisplay" readonly/>
              <div class="form-hint">Auto-generated. Cannot be changed.</div>
            </div>

          </div>
        </div>
        <div class="modal-footer py-2 border-top">
          <button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary btn-sm" id="btnPermSave">
            <i class="bi bi-floppy me-1"></i>Create
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<% block('scripts', '<link rel="stylesheet" href="/css/permissions.css"/><script src="/js/pages/permissions.js"></script>') %>
