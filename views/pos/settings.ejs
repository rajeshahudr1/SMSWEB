<% if (typeof _spa === 'undefined' || !_spa) { %><%- layout('../layouts/pos-layout') %><% } %>

<!-- Business / Invoice Details (GST) -->
<div class="card shadow-sm mb-3">
  <div class="card-header py-2 border-bottom">
    <h3 class="card-title mb-0"><i class="bi bi-building me-2 text-primary"></i>Business &amp; Invoice Details</h3>
    <small class="text-muted ms-2">Used on invoices printed/emailed to customers. GST &amp; PAN for compliance.</small>
  </div>
  <div class="card-body">
    <ul class="nav nav-tabs mb-3" id="bizTabs">
      <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#bizIdentity"><i class="bi bi-card-heading me-1"></i>Identity &amp; GST</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#bizBank"><i class="bi bi-bank me-1"></i>Bank Details</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#bizInvoice"><i class="bi bi-receipt me-1"></i>Invoice Defaults</a></li>
    </ul>
    <div class="tab-content">
      <div class="tab-pane fade show active" id="bizIdentity">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Legal Business Name</label>
            <input type="text" class="form-control" id="biz_legal_name" placeholder="e.g., ABC Auto Spares Pvt. Ltd."/>
            <small class="form-hint">Registered legal name. If blank, uses company name.</small>
          </div>
          <div class="col-md-6">
            <label class="form-label">GSTIN</label>
            <input type="text" class="form-control" id="biz_gst_number" placeholder="15-digit GSTIN" maxlength="15"/>
          </div>
          <div class="col-md-3">
            <label class="form-label">State Code</label>
            <input type="text" class="form-control" id="biz_state_code" placeholder="e.g., 27" maxlength="2"/>
            <small class="form-hint">First 2 digits of GSTIN.</small>
          </div>
          <div class="col-md-3">
            <label class="form-label">PAN</label>
            <input type="text" class="form-control" id="biz_pan_number" placeholder="ABCDE1234F" maxlength="10"/>
          </div>
          <div class="col-md-6">
            <label class="form-label">CIN (optional)</label>
            <input type="text" class="form-control" id="biz_cin_number" placeholder="Corporate Identification Number"/>
          </div>
          <div class="col-12">
            <label class="form-label">Billing / Registered Address</label>
            <textarea class="form-control" id="biz_billing_address" rows="2" placeholder="Full registered address shown on invoice"></textarea>
            <small class="form-hint">Leave blank to use main company address.</small>
          </div>
          <div class="col-md-6">
            <label class="form-label">CGST/SGST or IGST</label>
            <select class="form-select" id="biz_include_cgst_sgst">
              <option value="1">CGST + SGST (intra-state)</option>
              <option value="0">IGST only (inter-state)</option>
            </select>
            <small class="form-hint">Most small businesses: CGST+SGST. Change per-order if selling to other states.</small>
          </div>
        </div>
      </div>
      <div class="tab-pane fade" id="bizBank">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Bank Name</label>
            <input type="text" class="form-control" id="biz_bank_name" placeholder="e.g., HDFC Bank"/>
          </div>
          <div class="col-md-6">
            <label class="form-label">Account Number</label>
            <input type="text" class="form-control" id="biz_bank_account_number" placeholder="Account number"/>
          </div>
          <div class="col-md-6">
            <label class="form-label">IFSC Code</label>
            <input type="text" class="form-control" id="biz_bank_ifsc_code" placeholder="e.g., HDFC0001234"/>
          </div>
          <div class="col-md-6">
            <label class="form-label">Branch</label>
            <input type="text" class="form-control" id="biz_bank_branch" placeholder="Branch name/city"/>
          </div>
        </div>
        <small class="form-hint d-block mt-2">These appear on the invoice footer so customers can pay via bank transfer.</small>
      </div>
      <div class="tab-pane fade" id="bizInvoice">
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label">Invoice Prefix</label>
            <input type="text" class="form-control" id="biz_invoice_prefix" value="INV" maxlength="10"/>
            <small class="form-hint">Used in numbers like <code>INV-202604-0001</code>.</small>
          </div>
          <div class="col-md-9">
            <label class="form-label">Signature Image URL (optional)</label>
            <input type="text" class="form-control" id="biz_signature_url" placeholder="https://... or upload later"/>
          </div>
          <div class="col-12">
            <label class="form-label">Default Terms &amp; Conditions</label>
            <textarea class="form-control" id="biz_invoice_terms" rows="3" placeholder="e.g., Goods once sold will not be taken back..."></textarea>
          </div>
          <div class="col-12">
            <label class="form-label">Default Notes (Thank-you line)</label>
            <textarea class="form-control" id="biz_invoice_notes" rows="2" placeholder="e.g., Thank you for your business!"></textarea>
          </div>
        </div>
      </div>
    </div>
    <% if (can('edit_pos_settings')) { %>
    <div class="mt-3">
      <button type="button" class="btn btn-primary" id="btnSaveBiz"><i class="bi bi-check-lg me-1"></i>Save Business Details</button>
    </div>
    <% } %>
  </div>
</div>

<!-- Payment Gateway -->
<div class="card shadow-sm mb-3">
  <div class="card-header py-2 border-bottom">
    <h3 class="card-title mb-0"><i class="bi bi-credit-card-2-front me-2 text-primary"></i>Online Payment Gateway</h3>
    <small class="text-muted ms-2">For online card / UPI / pay-by-link. Secrets never leave the server.</small>
  </div>
  <div class="card-body">
    <p class="text-muted small mb-3"><i class="bi bi-info-circle me-1"></i>Enable any gateway you want available in the POS. If both are enabled, the cashier picks at checkout time. If neither is enabled, online payment is hidden in the POS.</p>

    <!-- Razorpay (India) — with inline Enable toggle -->
    <div class="card border mb-3">
      <div class="card-header py-2 d-flex align-items-center" style="background:var(--pv2-surface-alt);">
        <h5 class="mb-0 fw-semibold flex-grow-1"><i class="bi bi-bank me-2"></i>Razorpay <span class="text-muted small ms-1">(India)</span></h5>
        <div class="form-check form-switch m-0">
          <input class="form-check-input" type="checkbox" id="pg_razorpay_enabled" role="switch">
          <label class="form-check-label fw-semibold" for="pg_razorpay_enabled">Enable</label>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Razorpay Key ID</label>
            <input type="text" class="form-control" id="pg_razorpay_key_id" placeholder="rzp_live_...  /  rzp_test_..."/>
          </div>
          <div class="col-md-6">
            <label class="form-label">Razorpay Key Secret</label>
            <input type="password" class="form-control" id="pg_razorpay_key_secret" placeholder="••••••••"/>
            <small class="form-hint">Leave blank to keep the existing secret.</small>
          </div>
          <div class="col-md-12">
            <label class="form-label">Razorpay Webhook Secret</label>
            <input type="password" class="form-control" id="pg_razorpay_webhook_secret" placeholder="••••••••"/>
            <small class="form-hint">Set this to the same value in Razorpay dashboard → Webhooks. URL: <code>/api/pos/payment/webhook/razorpay</code></small>
          </div>
        </div>
      </div>
    </div>

    <!-- Stripe (International) — with inline Enable toggle -->
    <div class="card border mb-3">
      <div class="card-header py-2 d-flex align-items-center" style="background:var(--pv2-surface-alt);">
        <h5 class="mb-0 fw-semibold flex-grow-1"><i class="bi bi-globe me-2"></i>Stripe <span class="text-muted small ms-1">(International)</span></h5>
        <div class="form-check form-switch m-0">
          <input class="form-check-input" type="checkbox" id="pg_stripe_enabled" role="switch">
          <label class="form-check-label fw-semibold" for="pg_stripe_enabled">Enable</label>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Stripe Publishable Key</label>
            <input type="text" class="form-control" id="pg_stripe_publishable_key" placeholder="pk_live_... / pk_test_..."/>
          </div>
          <div class="col-md-6">
            <label class="form-label">Stripe Secret Key</label>
            <input type="password" class="form-control" id="pg_stripe_secret_key" placeholder="••••••••"/>
          </div>
          <div class="col-md-12">
            <label class="form-label">Stripe Webhook Secret</label>
            <input type="password" class="form-control" id="pg_stripe_webhook_secret" placeholder="whsec_...  (••••••••)"/>
            <small class="form-hint">Stripe dashboard → Developers → Webhooks. URL: <code>/api/pos/payment/webhook/stripe</code></small>
          </div>
        </div>
      </div>
    </div>
    <% if (can('edit_pos_settings')) { %>
    <div class="mt-3">
      <button type="button" class="btn btn-primary" id="btnSavePg"><i class="bi bi-check-lg me-1"></i>Save Gateway Settings</button>
    </div>
    <% } %>
  </div>
</div>

<!-- Label Printer moved to dedicated Printer Settings page -->
<div class="alert alert-info d-flex align-items-center gap-2 mb-3" style="border:1px solid var(--pv2-border);background:var(--pv2-brand-ghost);color:var(--pv2-text);">
  <i class="bi bi-printer-fill" style="font-size:20px;color:var(--pv2-brand);"></i>
  <div class="flex-grow-1">
    <div style="font-weight:600;">Printer configuration has moved</div>
    <div class="small text-muted">Label, receipt, A4 and QR printers are now managed in the dedicated Printer Settings page — scan USB &amp; network printers, assign roles, and test in one place.</div>
  </div>
  <a href="/sales/printer-settings" class="btn btn-sm btn-primary"><i class="bi bi-arrow-right"></i> Open Printer Settings</a>
</div>

<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <h3 class="card-title mb-0"><i class="bi bi-gear me-2 text-primary"></i>POS Settings</h3>
  </div>
  <div class="card-body">
    <form id="settingsForm">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="mb-3">
            <label class="form-label">Default Warehouse</label>
            <select class="form-select" id="pos_default_warehouse" name="pos_default_warehouse">
              <option value="">-- All Warehouses --</option>
            </select>
            <small class="form-hint">Default warehouse for POS product listing</small>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <label class="form-label">Low Stock Alert Threshold</label>
            <input type="number" class="form-control" id="pos_low_stock_alert" name="pos_low_stock_alert" value="5" min="0"/>
            <small class="form-hint">Alert when stock falls below this quantity</small>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="pos_enable_discount" name="pos_enable_discount" checked/>
              <label class="form-check-label" for="pos_enable_discount">Enable Discounts</label>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="pos_enable_tax" name="pos_enable_tax" checked/>
              <label class="form-check-label" for="pos_enable_tax">Enable Tax Calculation</label>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="pos_show_vehicle_tab" name="pos_show_vehicle_tab" checked/>
              <label class="form-check-label" for="pos_show_vehicle_tab">Show Vehicle Tab</label>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="pos_allow_multi_warehouse" name="pos_allow_multi_warehouse" checked/>
              <label class="form-check-label" for="pos_allow_multi_warehouse">Allow Multi-Warehouse</label>
            </div>
          </div>
        </div>
        <div class="col-12">
          <div class="mb-3">
            <label class="form-label">Receipt Header</label>
            <textarea class="form-control" id="pos_receipt_header" name="pos_receipt_header" rows="2" placeholder="Company name, address, etc."></textarea>
          </div>
        </div>
        <div class="col-12">
          <div class="mb-3">
            <label class="form-label">Receipt Footer</label>
            <textarea class="form-control" id="pos_receipt_footer" name="pos_receipt_footer" rows="2" placeholder="Thank you message, return policy, etc."></textarea>
          </div>
        </div>
      </div>
      <% if (can('edit_pos_settings')) { %>
      <div class="mt-3">
        <button type="submit" class="btn btn-primary" id="btnSave"><i class="bi bi-check-lg me-1"></i>Save Settings</button>
      </div>
      <% } %>
    </form>
  </div>
</div>

<script>
$(function(){
  // Load settings
  $.get('/sales/settings/data', function(res){
    if(res.status===200 && res.data){
      var d = res.data;
      Object.keys(d).forEach(function(k){
        var el = $('#'+k);
        if(!el.length) return;
        if(el.is(':checkbox')) el.prop('checked', d[k]==='1'||d[k]===true||d[k]==='true');
        else el.val(d[k]||'');
      });
      // Load warehouses for dropdown
      if(d._warehouses){
        d._warehouses.forEach(function(w){
          $('#pos_default_warehouse').append('<option value="'+w.id+'" '+(String(d.pos_default_warehouse)===String(w.id)?'selected':'')+'>'+w.warehouse_name+'</option>');
        });
      }
    }
  });

  /* ───── Business / Invoice Details ───── */
  var bizFields = ['legal_name','gst_number','state_code','pan_number','cin_number','billing_address',
                   'bank_name','bank_account_number','bank_ifsc_code','bank_branch',
                   'invoice_prefix','invoice_terms','invoice_notes','signature_url'];
  $.get('/sales/invoice-settings', function(res){
    if(res.status!==200 || !res.data) return;
    bizFields.forEach(function(k){
      var el = $('#biz_'+k);
      if(el.length) el.val(res.data[k]||'');
    });
    $('#biz_include_cgst_sgst').val(res.data.include_cgst_sgst===false||res.data.include_cgst_sgst==='0' ? '0' : '1');
  });
  $('#btnSaveBiz').on('click', function(){
    var body = { include_cgst_sgst: $('#biz_include_cgst_sgst').val()==='1' };
    bizFields.forEach(function(k){ body[k] = $('#biz_'+k).val(); });
    $.ajax({ url:'/sales/invoice-settings', type:'PUT', contentType:'application/json',
      data: JSON.stringify(body),
      success:function(r){
        if(r.status===200) toastr.success('Business details saved');
        else toastr.error(r.message||'Failed');
      },
      error:function(){ toastr.error('Failed to save business details'); }
    });
  });

  /* ───── Payment Gateway — toggles per provider ───── */
  $.get('/sales/payment/config', function(res){
    if(res.status!==200||!res.data)return;
    var d = res.data;
    /* Map saved payment_gateway string → individual toggles. New shape:
       razorpay_enabled / stripe_enabled (booleans). Falls back to the legacy
       payment_gateway='razorpay'|'stripe' for backwards compat. */
    var rzEnabled = d.razorpay_enabled === true || d.razorpay_enabled === '1' || d.payment_gateway === 'razorpay';
    var stEnabled = d.stripe_enabled   === true || d.stripe_enabled   === '1' || d.payment_gateway === 'stripe';
    $('#pg_razorpay_enabled').prop('checked', !!rzEnabled);
    $('#pg_stripe_enabled').prop('checked',   !!stEnabled);
    $('#pg_razorpay_key_id').val(d.razorpay_key_id||'');
    $('#pg_razorpay_key_secret').attr('placeholder', d.razorpay_key_secret_set?'••••••••':'Secret (paste to set)');
    $('#pg_razorpay_webhook_secret').attr('placeholder', d.razorpay_webhook_secret_set?'••••••••':'Webhook secret');
    $('#pg_stripe_publishable_key').val(d.stripe_publishable_key||'');
    $('#pg_stripe_secret_key').attr('placeholder', d.stripe_secret_key_set?'••••••••':'Secret (paste to set)');
    $('#pg_stripe_webhook_secret').attr('placeholder', d.stripe_webhook_secret_set?'••••••••':'Webhook secret');
  });
  $('#btnSavePg').on('click', function(){
    var rz = $('#pg_razorpay_enabled').is(':checked');
    var st = $('#pg_stripe_enabled').is(':checked');
    /* Compute legacy single-string for any older code reading payment_gateway:
       priority razorpay > stripe; if neither enabled → empty. */
    var primary = rz ? 'razorpay' : (st ? 'stripe' : '');
    var body = {
      payment_gateway: primary,
      razorpay_enabled: rz ? '1' : '0',
      stripe_enabled:   st ? '1' : '0',
      razorpay_key_id: $('#pg_razorpay_key_id').val().trim(),
      razorpay_key_secret: $('#pg_razorpay_key_secret').val().trim(),
      razorpay_webhook_secret: $('#pg_razorpay_webhook_secret').val().trim(),
      stripe_publishable_key: $('#pg_stripe_publishable_key').val().trim(),
      stripe_secret_key: $('#pg_stripe_secret_key').val().trim(),
      stripe_webhook_secret: $('#pg_stripe_webhook_secret').val().trim(),
    };
    $.ajax({ url:'/sales/payment/config', type:'PUT', contentType:'application/json',
      data: JSON.stringify(body),
      success:function(r){
        if(r.status===200){ toastr.success('Gateway settings saved'); $('#pg_razorpay_key_secret,#pg_razorpay_webhook_secret,#pg_stripe_secret_key,#pg_stripe_webhook_secret').val(''); }
        else toastr.error(r.message||'Failed');
      },
      error:function(){ toastr.error('Failed to save gateway settings'); }
    });
  });

  /* Label Printer config moved to /sales/printer-settings */
  // (Label Printer UI moved to /sales/printer-settings — see banner at top of page)

  // Save
  $('#settingsForm').on('submit', function(e){
    e.preventDefault();
    var data = {};
    $(this).find('input,select,textarea').each(function(){
      var el=$(this), k=el.attr('name');
      if(!k) return;
      if(el.is(':checkbox')) data[k] = el.is(':checked') ? '1' : '0';
      else data[k] = el.val();
    });
    $.ajax({
      url:'/sales/settings', type:'PUT', contentType:'application/json',
      data: JSON.stringify(data),
      success:function(res){
        if(res.status===200) toastr.success('Settings saved successfully');
        else toastr.error(res.message||'Failed');
      },
      error:function(){ toastr.error('Failed to save settings'); }
    });
  });

  /* Explicit tab wiring — works whether the page is refreshed directly or
     loaded through pos.js SPA nav. Bootstrap's auto-wiring only fires on
     initial DOMContentLoaded; SPA-inserted markup misses it, so the Business
     sub-tabs (Identity / Bank / Invoice) silently stop working. */
  $(document).off('click.posSettingsTabs').on('click.posSettingsTabs', '#bizTabs a[data-bs-toggle="tab"]', function(e){
    e.preventDefault();
    var href = $(this).attr('href');
    $('#bizTabs a').removeClass('active');
    $(this).addClass('active');
    $('#bizTabs').closest('.card-body, .pos-page-content, body').find('.tab-pane').removeClass('show active');
    $(href).addClass('show active');
  });
});
</script>
