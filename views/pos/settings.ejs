  $('#ssSaveAll').on('click', function(){
    var dk = dirtyKeys();
    if (!dk.length) return;
    var groups = new Set();
    dk.forEach(function(k){
      var g = $('#'+k).attr('data-bind') || '';
      groups.add(g);
    });
    var $btn = $('#ssSaveAll').prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Saving…');
    var jobs = [];
    if (groups.has('biz')) {
      jobs.push($.ajax({ url:'/sales/invoice-settings', type:'PUT', contentType:'application/json', data: JSON.stringify(buildBizPayload()) }));
    }
    if (groups.has('pg')) {
      jobs.push($.ajax({ url:'/sales/payment/config', type:'PUT', contentType:'application/json', data: JSON.stringify(buildPgPayload()) }).then(function(){
        // Clear secret inputs after save so the masked placeholders take over.
        ['pg_razorpay_key_secret','pg_razorpay_webhook_secret','pg_stripe_secret_key','pg_stripe_webhook_secret'].forEach(function(id){ $('#'+id).val(''); });
      }));
    }
    if (groups.has('pos_setting')) {
      jobs.push($.ajax({ url:'/sales/settings', type:'PUT', contentType:'application/json', data: JSON.stringify(buildPosSettingPayload()) }));
    }
    if (groups.has('wallet')) {
      var walletPayload = {};
      ['wallet_default_terms_days','wallet_default_grace_days','wallet_default_late_fee_pct',
       'wallet_reminder_days_before','wallet_overdue_reminder_days',
       'wallet_email_subject','wallet_email_body','wallet_late_fee_mode'].forEach(function(k){
        walletPayload[k] = $('#'+k).val();
      });
      jobs.push($.ajax({ url:'/sales/wallet/settings', type:'PUT', contentType:'application/json', data: JSON.stringify(walletPayload) }));
    }
    <% if (isSuper) { %>
    if (groups.has('vi')) {
      jobs.push($.ajax({ url:'/vehicle-inventories/settings', type:'POST', contentType:'application/json', data: JSON.stringify(buildViPayload()) }));
    }
    if (groups.has('pi')) {
      jobs.push($.ajax({ url:'/part-inventories/settings', type:'POST', contentType:'application/json', data: JSON.stringify(buildPiPayload()) }));
    }
    <% } %>
    Promise.all(jobs).then(function(){
      toastr.success('Settings saved.');
      snapshotInitial();
      $btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> Save changes');
    }).catch(function(xhr){
      var m = (xhr && xhr.responseJSON && xhr.responseJSON.message) || 'Save failed.';
      toastr.error(m);
      $btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> Save changes');
    });
  });

  $('#ssDiscard').on('click', function(){
    Object.keys(initial).forEach(function(k){ writeControl($('#'+k), initial[k]); });
    syncImagePreview('biz_signature', 'biz_signature_url');
    syncImagePreview('biz_quality',   'biz_quality_badge_image');
    refreshDirty();
    toastr.info('Discarded unsaved changes.');
  });

  // ── Image upload widgets ──────────────────────────────────────
  function syncImagePreview(prefix, urlInputId){
    var url = $('#'+urlInputId).val() || '';
    var $thumb = $('#'+prefix+'_thumb');
    if (url){
      $('#'+prefix+'_preview').attr('src', url).show();
      $('#'+prefix+'_empty').hide();
      $('#'+prefix+'_clear').show();
      $thumb.addClass('has-img');
    } else {
      $('#'+prefix+'_preview').attr('src','').hide();
      $('#'+prefix+'_empty').show();
      $('#'+prefix+'_clear').hide();
      $thumb.removeClass('has-img');
    }
  }
  function wireImgUpload(fileSel, kind, urlInputId, prefix){
    $(fileSel).on('change', function(){
      var file = this.files && this.files[0]; if (!file) return;
      var fd = new FormData(); fd.append('file', file);
      var $row = $(this).closest('.ss-row');
      $row.find('label.ss-btn').css('opacity', .5);
      $.ajax({ url:'/sales/settings/upload/'+kind, type:'POST', data:fd, processData:false, contentType:false, success: function(r){
        $row.find('label.ss-btn').css('opacity', 1);
        if (r && r.status === 200 && r.data && r.data.url){
          $('#'+urlInputId).val(r.data.url).trigger('change');
          syncImagePreview(prefix, urlInputId);
          toastr.success('Uploaded.');
        } else { toastr.error((r && r.message) || 'Upload failed.'); }
      }, error: function(xhr){
        $row.find('label.ss-btn').css('opacity', 1);
        toastr.error((xhr.responseJSON && xhr.responseJSON.message) || 'Upload failed.');
      }});
      this.value = '';
    });
  }
  wireImgUpload('#biz_signature_file', 'biz_signature', 'biz_signature_url',       'biz_signature');
  wireImgUpload('#biz_quality_file',   'biz_quality',   'biz_quality_badge_image', 'biz_quality');
  $(document).on('click','#biz_signature_clear', function(){ $('#biz_signature_url').val('').trigger('change'); syncImagePreview('biz_signature','biz_signature_url'); });
  $(document).on('click','#biz_quality_clear',   function(){ $('#biz_quality_badge_image').val('').trigger('change'); syncImagePreview('biz_quality','biz_quality_badge_image'); });

