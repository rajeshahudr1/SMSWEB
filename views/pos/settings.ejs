          $('#rPrev_thanks').text((d.invoice_notes || (d.invoice_thank_you||'').split('\n')[0] || 'Thank you!'));
          // (#payUpiIdPreview was the UPI method card label — removed
          //  from the Payment methods section; the UPI ID itself lives
          //  in the Business profile / receipt section now.)
        }
      }),
      $.get('/sales/payment/config').then(function(r){
        if (r && r.status === 200 && r.data){
          var d = r.data;
          writeControl($('#pg_razorpay_enabled'), (d.razorpay_enabled===true||d.razorpay_enabled==='1'||d.payment_gateway==='razorpay') ? '1' : '0');
          writeControl($('#pg_stripe_enabled'),   (d.stripe_enabled===true||d.stripe_enabled==='1'||d.payment_gateway==='stripe') ? '1' : '0');
          writeControl($('#pg_razorpay_key_id'), d.razorpay_key_id||'');
          $('#pg_razorpay_key_secret').attr('placeholder', d.razorpay_key_secret_set ? '••••••••' : 'Secret');
          $('#pg_razorpay_webhook_secret').attr('placeholder', d.razorpay_webhook_secret_set ? '••••••••' : 'Webhook secret');
          writeControl($('#pg_stripe_publishable_key'), d.stripe_publishable_key||'');
          $('#pg_stripe_secret_key').attr('placeholder', d.stripe_secret_key_set ? '••••••••' : 'Secret');
          $('#pg_stripe_webhook_secret').attr('placeholder', d.stripe_webhook_secret_set ? '••••••••' : 'Webhook secret');
          writeControl($('#pg_stripe_currency'), (d.stripe_currency||'USD').toUpperCase());
          // Status pills next to each gateway card in the Payments section.
          // (#rzpInline / #stripeInline used to live in the Integrations
          // card too; that whole section was removed.)
          $('#rzpStatus').toggle(!!d.razorpay_key_id);
          $('#stripeStatus').toggle(!!d.stripe_publishable_key);
          updateGatewayFieldVisibility();
        }
      }),
      $.get('/sales/settings/data').then(function(r){
        if (r && r.status === 200 && r.data){
          var d = r.data;
          // Invoicing toggles
          writeControl($('#pos_auto_email_invoice'),     d.pos_auto_email_invoice === '1');
          writeControl($('#pos_invoice_show_qr'),        d.pos_invoice_show_qr   !== '0');
          writeControl($('#pos_allow_partial_payments'), d.pos_allow_partial_payments !== '0');
          // POS preferences
          writeControl($('#pos_default_warehouse'),      d.pos_default_warehouse || '');
          writeControl($('#pos_low_stock_alert'),        d.pos_low_stock_alert   || 5);
          writeControl($('#pos_enable_discount'),        d.pos_enable_discount        !== '0');
          writeControl($('#pos_enable_tax'),             d.pos_enable_tax             !== '0');
          writeControl($('#pos_show_vehicle_tab'),       d.pos_show_vehicle_tab       !== '0');
          writeControl($('#pos_allow_multi_warehouse'),  d.pos_allow_multi_warehouse  !== '0');
          writeControl($('#pos_keyboard_enabled'),       d.pos_keyboard_enabled       !== '0');

          // Thermal-receipt text fields — every key in POS_RECEIPT_TEXT_KEYS
          // maps 1:1 to a same-named input id, so we just push the value in.
          // Empty/missing values stay blank instead of "undefined".
          POS_RECEIPT_TEXT_KEYS.forEach(function(k){
            writeControl($('#'+k), d[k] == null ? '' : d[k]);
          });
          // Visibility toggles — most default ON if the value is missing
          // (a blank value means the org never explicitly turned it off).
          // Barcode + signature default OFF since most stores don't print them.
          var DEFAULT_OFF = ['pos_receipt_show_barcode','pos_receipt_show_signature'];
          POS_RECEIPT_TOGGLE_KEYS.forEach(function(k){
            var v = d[k];
            var on = (v === '1' || v === 1 || v === true) ||
                     (v == null && DEFAULT_OFF.indexOf(k) === -1);
            $('#'+k).toggleClass('on', !!on);
          });
          // Image previews for receipt logo / QR / signature
          syncImagePreview('pos_receipt_logo',      'pos_receipt_logo_url');
          syncImagePreview('pos_receipt_qr',        'pos_receipt_qr_image_url');
          syncImagePreview('pos_receipt_signature', 'pos_receipt_signature_url');
        }
      }),
      $.get('/sales/warehouses').then(function(r){
        if (r && r.status === 200 && Array.isArray(r.data)){
          var $sel = $('#pos_default_warehouse');
          var current = $sel.val();
          $sel.find('option:not(:first)').remove();
