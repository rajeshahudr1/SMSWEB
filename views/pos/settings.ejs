  // Scroll-spy — manual scroll listener that finds the section currently
  // closest to the top of the viewport (or the .pos-page-content scroll
  // container if it has its own scrollbar). IntersectionObserver was
  // sometimes flickering between adjacent cards because two sections were
  // visible at once and both fired `isIntersecting=true` simultaneously.
  function _findScrollContainer(){
    var el = document.querySelector('.sales-settings');
    while (el && el !== document.body){
      var oy = window.getComputedStyle(el).overflowY;
      if (oy === 'auto' || oy === 'scroll') return el;
      el = el.parentElement;
    }
    return window;
  }
  function _spy(){
    var sections = document.querySelectorAll('.sales-settings .ss-card[id]');
    if (!sections.length) return;
    var container = _findScrollContainer();
    var topRef = (container === window) ? 0 : container.getBoundingClientRect().top;
    var bestId = null, bestDist = Infinity;
    sections.forEach(function(s){
      var r = s.getBoundingClientRect();
      // Distance from the section's top to a "trigger line" 100px below the
      // top of the scrolling region. Most-negative AND closest-to-zero wins.
      var d = (r.top - topRef) - 100;
      // Prefer sections whose top is at or just above the trigger line.
      if (d <= 0 && d > -window.innerHeight){
        if (Math.abs(d) < bestDist) { bestDist = Math.abs(d); bestId = s.id; }
      }
    });
    if (!bestId) bestId = sections[0].id;
    document.querySelectorAll('.ss-quicknav a').forEach(function(l){
      l.classList.toggle('active', l.getAttribute('href') === '#' + bestId);
    });
    document.querySelectorAll('.ss-tab').forEach(function(t){
      t.classList.toggle('active', t.dataset.section === bestId);
    });
  }
  // Throttle with rAF
  var spyTicking = false;
  function _onScroll(){
    if (spyTicking) return;
    spyTicking = true;
    requestAnimationFrame(function(){ _spy(); spyTicking = false; });
  }
  // Bind to whichever container is actually scrolling
  setTimeout(function(){
    var c = _findScrollContainer();
    if (c === window) window.addEventListener('scroll', _onScroll, { passive: true });
    else c.addEventListener('scroll', _onScroll, { passive: true });
    _spy();   // initial pass
  }, 200);

  // ── Reset POS theme (danger zone) ─────────────────────────────
  window.ssResetTheme = function(){
    if (typeof posConfirm === 'function') {
      posConfirm({ title:'Reset POS theme?', msg:'All custom UI Kit colors will revert to defaults.\nCannot be undone.', confirmText:'Reset theme', cancelText:'Keep mine', confirmColor:'var(--ss-red)', icon:'bi-arrow-counterclockwise', iconColor:'var(--ss-red)', onConfirm: function(){
        $.ajax({ url:'/sales/theme', type:'PUT', contentType:'application/json', data:'{"theme":{}}', success: function(r){ if (r.status === 200){ toastr.success('Theme reset.'); try { localStorage.removeItem('pv2Theme'); } catch(_){} location.reload(); } else toastr.error(r.message||'Failed.'); }, error: function(){ toastr.error('Failed.'); } });
      }});
    }
  };

  // ── Warn before navigating away with unsaved changes ─────────
  // We intercept in-app navigation (sidebar links, back arrow, SPA tab
  // clicks) and show our themed posConfirm dialog instead of the native
  // browser "Changes you may not be saved" box. The beforeunload listener
  // is only kept as a safety net for HARD navigation (tab close, browser
  // refresh, typing a new URL) — those paths the browser MUST handle
  // with its own dialog, no app can customise it.
  function _hasUnsavedChanges(){ return dirtyKeys().length > 0; }
  function _confirmDiscardThen(go){
    if (!_hasUnsavedChanges()) { go(); return; }
    if (typeof posConfirm !== 'function') { go(); return; }
    posConfirm({
      title:        'Discard unsaved changes?',
      msg:          'You have ' + dirtyKeys().length + ' unsaved change' + (dirtyKeys().length > 1 ? 's' : '') + ' on this page. Leaving now will lose them.',
      confirmText:  'Discard and leave',
      cancelText:   'Stay on page',
      confirmColor: 'var(--ss-red, #dc2626)',
      icon:         'bi-exclamation-triangle-fill',
      iconColor:    'var(--ss-amber, #f59e0b)',
      onConfirm:    go,
    });
  }
  // Intercept anchor clicks (sidebar links, back arrow, breadcrumbs, etc.)
  $(document).on('click.ssDirty', '.sales-settings a[href], .pos-sidebar a[href], .pos-sidebar .ps-btn, .mob-topbar a[href], #mobMoreMenu .mob-mm-item', function(e){
    var $t = $(this);
    var href = $t.attr('href');
    var onclick = $t.attr('onclick') || '';
    // Skip pure-anchor (#hash) clicks — they don't navigate away.
    if (href && href.charAt(0) === '#') return;
    if (!href && !onclick) return;
    if (!_hasUnsavedChanges()) return;            // Nothing dirty — let it through
    e.preventDefault(); e.stopImmediatePropagation();
    _confirmDiscardThen(function(){
      // Temporarily silence beforeunload so re-firing the click doesn't
      // re-prompt with the browser dialog after the user already confirmed.
      window._ssSkipBeforeUnload = true;
      if (href) { window.location.href = href; }
      else      { (new Function(onclick)).call($t[0]); }
    });
  });
  // Safety net for hard navigation only (tab close / refresh / external URL).
  // The browser shows its own un-customisable message here; nothing we can
  // do about that — but at least the dialog only appears for cases that
  // bypass our in-app interceptor above.
  window.addEventListener('beforeunload', function(e){
    if (window._ssSkipBeforeUnload) { window._ssSkipBeforeUnload = false; return; }
    if (_hasUnsavedChanges()) { e.preventDefault(); e.returnValue = ''; return ''; }
  });

  // ── Bootstrap! ────────────────────────────────────────────────
  $(function(){ loadAll(); });
})();
</script>
