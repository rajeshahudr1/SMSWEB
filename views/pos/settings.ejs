            <div class="ss-row-control"><input type="number" id="fPiMaxImageCount" data-bind="pi" min="1" max="100" placeholder="20"/></div>
          </div>
          <div class="ss-row">
            <div class="ss-row-label">Max video size (MB)</div>
            <div class="ss-row-control"><input type="number" id="fPiMaxVideoSize" data-bind="pi" min="1" max="500" placeholder="50"/></div>
          </div>
          <div class="ss-row">
            <div class="ss-row-label">Max videos count</div>
