<!-- Sticky action bar -->
<div class="ss-action-bar" id="ssActionBar">
  <div class="inner">
    <span class="pending clean" id="ssPending"><i class="bi bi-check2-circle" style="font-size:14px;"></i> No unsaved changes</span>
    <div style="flex:1;"></div>
    <button type="button" class="ss-btn ss-btn-ghost" id="ssDiscard" disabled>Discard</button>
    <% if (can('edit_pos_settings')) { %>
      <button type="button" class="ss-btn ss-btn-primary" id="ssSaveAll" disabled><i class="bi bi-check-lg"></i> Save changes</button>
    <% } %>
  </div>
</div>

<script>
/* ════════════════════════════════════════════════════════════════════
   SALES SETTINGS — unified state + save flow
   Single shared state object tracks every input across the page.
   `data-bind` attribute on each input picks the destination endpoint:
     biz             → /sales/invoice-settings  (PUT)
     pg              → /sales/payment/config   (PUT)
     pos_setting     → /sales/settings         (PUT)
     vi              → /sales/vehicle-inventories/settings  (POST)
     pi              → /sales/part-inventories/settings     (POST)
   On Save, we fan out one batched request per touched group.
   ════════════════════════════════════════════════════════════════════ */
(function(){
  var initial = {};   // values when page loaded
  var current = {};   // live values

  // ── Helpers ────────────────────────────────────────────────────
  function readControl($el){
    if ($el.is('button.ss-switch')) return $el.hasClass('on') ? '1' : '0';
    if ($el.attr('type') === 'checkbox') return $el.prop('checked') ? '1' : '0';
    return $el.val();
  }
  function writeControl($el, val){
    if ($el.is('button.ss-switch')) {
      $el.toggleClass('on', val === '1' || val === true || val === 1);
    } else if ($el.attr('type') === 'checkbox') {
      $el.prop('checked', val === '1' || val === true || val === 1);
    } else {
      $el.val(val == null ? '' : val);
    }
  }
  function snapshotInitial(){
    $('[data-bind]').each(function(){
      var id = $(this).attr('id');
      if (id) initial[id] = readControl($(this));
    });
    current = Object.assign({}, initial);
    refreshDirty();
  }
  function snapshotCurrent(){
    $('[data-bind]').each(function(){
      var id = $(this).attr('id');
      if (id) current[id] = readControl($(this));
    });
  }
  function dirtyKeys(){
    snapshotCurrent();
    return Object.keys(current).filter(function(k){ return String(current[k]) !== String(initial[k] == null ? '' : initial[k]); });
  }
  function refreshDirty(){
    var dk = dirtyKeys();
    var n = dk.length;
    var $p = $('#ssPending'), $s = $('#ssSaveStatus');
    if (n === 0){
      $p.removeClass().addClass('pending clean').html('<i class="bi bi-check2-circle" style="font-size:14px;"></i> No unsaved changes');
      $('#ssDiscard,#ssSaveAll').prop('disabled', true);
      $s.removeClass('dirty').html('<span class="ss-pulse"></span> All changes saved');
    } else {
      $p.removeClass().addClass('pending').html('<i class="bi bi-exclamation-circle" style="font-size:14px;"></i> ' + n + ' unsaved change' + (n>1?'s':''));
      $('#ssDiscard,#ssSaveAll').prop('disabled', false);
      $s.addClass('dirty').html('<span class="ss-pulse"></span> ' + n + ' pending change' + (n>1?'s':''));
    }
    // Quicknav progress — % of fields filled out
    var total = $('[data-bind]').length;
    var filled = $('[data-bind]').filter(function(){ var v = readControl($(this)); return v && String(v).trim() !== '' && v !== '0'; }).length;
    var pct = total ? Math.round(filled / total * 100) : 0;
    $('#ssProgressBar').css('width', pct + '%');
    $('#ssProgressLabel').text(pct + '%');
  }
  // Bind change events
  $(document).on('input change', '.sales-settings [data-bind]', refreshDirty);
  $(document).on('click', '.sales-settings .ss-switch', function(){
    if ($(this).attr('data-bind')) { $(this).toggleClass('on'); refreshDirty(); }
    else { $(this).toggleClass('on'); }   // visual-only switches (e.g. method cards)
  });

  // ── Live "Next invoice" preview ──────────────────────────────
  // Rebuilds the preview as the user types in the prefix box so admins
  // see what the next invoice will look like (e.g. "TT-0003") without
  // saving + reloading. The trailing digits come from the server on
  // boot (window._invSeqSuffix), the prefix portion is whatever's
  // currently typed in the input.
  function renderInvoicePreview(){
    var $p = $('#biz_invoice_prefix');
    if (!$p.length) return;
    var prefix = String($p.val() || '');
    var suffix = window._invSeqSuffix || '0001';
    $('#seqPreview').text('Next invoice → ' + (prefix || '') + suffix);
  }
  $(document).on('input.invPreview', '#biz_invoice_prefix', renderInvoicePreview);

  // ── Load state from each backend ──────────────────────────────
