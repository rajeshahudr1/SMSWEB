            <div class="ss-row-control"><input type="text" id="wallet_overdue_reminder_days" data-bind="wallet" placeholder="1,7,15" style="max-width:200px;"/></div>
          </div>
          <div class="ss-row">
            <div>
              <div class="ss-row-label">Reminder email subject</div>
