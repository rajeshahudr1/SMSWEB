  // ── Save: fan out per-group ───────────────────────────────────
  function buildBizPayload(){
    var keys = ['legal_name','gst_number','state_code','pan_number','cin_number','billing_address',
      'bank_name','bank_account_number','bank_ifsc_code','bank_branch',
      'invoice_prefix','invoice_terms','invoice_notes','signature_url',
      'tagline','upi_id','invoice_default_notes','invoice_thank_you',
      'quality_badge_line1','quality_badge_line2','quality_badge_image'];
    var p = {};
    keys.forEach(function(k){ p[k] = $('#biz_'+k).val(); });
    return p;
  }
  function buildPgPayload(){
    var rz = $('#pg_razorpay_enabled').hasClass('on'), st = $('#pg_stripe_enabled').hasClass('on');
    return {
      payment_gateway: rz ? 'razorpay' : (st ? 'stripe' : ''),
      razorpay_enabled: rz ? '1' : '0',
      stripe_enabled:   st ? '1' : '0',
      razorpay_key_id: ($('#pg_razorpay_key_id').val()||'').trim(),
      razorpay_key_secret: ($('#pg_razorpay_key_secret').val()||'').trim(),
      razorpay_webhook_secret: ($('#pg_razorpay_webhook_secret').val()||'').trim(),
      stripe_publishable_key: ($('#pg_stripe_publishable_key').val()||'').trim(),
      stripe_secret_key: ($('#pg_stripe_secret_key').val()||'').trim(),
      stripe_webhook_secret: ($('#pg_stripe_webhook_secret').val()||'').trim(),
      stripe_currency: ($('#pg_stripe_currency').val() || 'USD').toUpperCase(),
    };
  }
  // Thermal-receipt key lists, kept here so load + save iterate the same set.
  // Order doesn't matter — these go into the settings table by key.
  var POS_RECEIPT_TEXT_KEYS = [
    // Company info
    'pos_receipt_company_name','pos_receipt_tagline','pos_receipt_phone','pos_receipt_alt_mobile',
    'pos_receipt_email','pos_receipt_website','pos_receipt_address','pos_receipt_city','pos_receipt_pincode',
    'pos_receipt_tax_line','pos_receipt_counter_no',
    // Format
    'pos_receipt_size','pos_receipt_default_print_type','pos_receipt_copies',
    'pos_receipt_currency_symbol','pos_receipt_date_format',
    'pos_receipt_payment_modes','pos_receipt_extra_charges_label',
    // Text blocks
    'pos_receipt_header','pos_receipt_footer','pos_receipt_thank_you',
    'pos_receipt_return_policy','pos_receipt_terms',
    // UPI
    'pos_receipt_upi_id','pos_receipt_upi_payee_name',
    // Image URLs (set by upload handlers; written to the same hidden inputs)
    'pos_receipt_logo_url','pos_receipt_qr_image_url','pos_receipt_signature_url',
  ];
  var POS_RECEIPT_TOGGLE_KEYS = [
    'pos_receipt_show_logo','pos_receipt_show_invoice_number','pos_receipt_show_cashier',
    'pos_receipt_show_customer','pos_receipt_show_gst','pos_receipt_show_tax_breakdown',
    'pos_receipt_show_discount','pos_receipt_show_payment_method','pos_receipt_show_barcode',
    'pos_receipt_show_qr','pos_receipt_show_signature','pos_receipt_show_terms',
  ];
  function buildPosSettingPayload(){
    var p = {
      // Invoicing toggles
      pos_auto_email_invoice:     $('#pos_auto_email_invoice').hasClass('on') ? '1' : '0',
      pos_invoice_show_qr:        $('#pos_invoice_show_qr').hasClass('on') ? '1' : '0',
      pos_allow_partial_payments: $('#pos_allow_partial_payments').hasClass('on') ? '1' : '0',
      // POS preferences
      pos_default_warehouse:      $('#pos_default_warehouse').val() || '',
      pos_low_stock_alert:        $('#pos_low_stock_alert').val() || '5',
      pos_enable_discount:        $('#pos_enable_discount').hasClass('on') ? '1' : '0',
      pos_enable_tax:             $('#pos_enable_tax').hasClass('on') ? '1' : '0',
      pos_show_vehicle_tab:       $('#pos_show_vehicle_tab').hasClass('on') ? '1' : '0',
      pos_allow_multi_warehouse:  $('#pos_allow_multi_warehouse').hasClass('on') ? '1' : '0',
      pos_keyboard_enabled:       $('#pos_keyboard_enabled').hasClass('on') ? '1' : '0',
    };
    // Thermal-receipt fields — text inputs, selects, hidden URLs all read .val()
    POS_RECEIPT_TEXT_KEYS.forEach(function(k){ p[k] = ($('#'+k).val() || '').toString(); });
    // Thermal-receipt visibility toggles — '1' if on, '0' otherwise
    POS_RECEIPT_TOGGLE_KEYS.forEach(function(k){ p[k] = $('#'+k).hasClass('on') ? '1' : '0'; });
    return p;
  }
  function buildViPayload(){
