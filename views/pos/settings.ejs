          });
          if (current) $sel.val(current);
        }
      }).catch(function(){}),
      <% if (isSuper) { %>
      $.get('/vehicle-inventories/settings').then(function(r){
        if (r && r.status === 200 && r.data){
          var d = r.data;
          writeControl($('#fViMaxImageSize'),  d.max_image_size  || 5);
          writeControl($('#fViMaxImageCount'), d.max_image_count || 20);
          writeControl($('#fViMaxVideoSize'),  d.max_video_size  || 50);
          writeControl($('#fViMaxVideoCount'), d.max_video_count || 10);
        }
      }).catch(function(){}),
      $.get('/part-inventories/settings').then(function(r){
        if (r && r.status === 200 && r.data){
          var d = r.data;
          writeControl($('#fPiMaxImageSize'),  d.max_image_size  || 5);
          writeControl($('#fPiMaxImageCount'), d.max_image_count || 20);
          writeControl($('#fPiMaxVideoSize'),  d.max_video_size  || 50);
          writeControl($('#fPiMaxVideoCount'), d.max_video_count || 10);
        }
      }).catch(function(){}),
      <% } %>
      $.get('/sales/next-invoice-number').then(function(r){
        if (r && r.status === 200 && r.data){
          // Stash the trailing sequence digits ("0003" out of "INV-0003")
          // so the preview can rebuild instantly as the user edits the
          // prefix — no server round-trip required.
          var next = String(r.data.next || '');
          var m = next.match(/(\d+)$/);
          window._invSeqSuffix = m ? m[1] : '';
          renderInvoicePreview();
        }
      }).catch(function(){ $('#seqPreview').text('—'); }),
      // Wallet defaults
      $.get('/sales/wallet/settings').then(function(r){
        if (r && r.status === 200 && r.data){
          var d = r.data;
          ['wallet_default_terms_days','wallet_default_grace_days','wallet_default_late_fee_pct',
           'wallet_reminder_days_before','wallet_overdue_reminder_days',
           'wallet_email_subject','wallet_email_body','wallet_late_fee_mode'].forEach(function(k){
            writeControl($('#'+k), d[k]||'');
          });
        }
      }).catch(function(){}),
    ]).then(snapshotInitial);
  }

  function updateGatewayFieldVisibility(){
    $('#rzpFields').toggle($('#pg_razorpay_enabled').hasClass('on'));
    $('#stripeFields').toggle($('#pg_stripe_enabled').hasClass('on'));
