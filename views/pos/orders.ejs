<% if (typeof _spa === 'undefined' || !_spa) { %><%- layout('../layouts/pos-layout') %><% } %>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-bag-check me-2 text-primary"></i>Sales Orders <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">-</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-download me-1"></i>Export</button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li><li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li></ul>
      </div>
      <a href="/pos" class="btn btn-sm btn-primary"><i class="bi bi-receipt me-1"></i>Open POS</a>
    </div>
  </div>
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="d-flex align-items-center gap-2">
      <div class="flex-grow-1"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="Search order number, customer..."/></div>
      <select class="form-select form-select-sm" id="filterOrderStatus" style="width:130px;"><option value="">All Status</option><option value="completed">Completed</option><option value="confirmed">Confirmed</option><option value="draft">Draft</option><option value="cancelled">Cancelled</option><option value="returned">Returned</option></select>
      <select class="form-select form-select-sm" id="filterPayStatus" style="width:130px;"><option value="">All Payment</option><option value="paid">Paid</option><option value="partial">Partial</option><option value="unpaid">Unpaid</option></select>
      <input type="date" class="form-control form-control-sm" id="filterFrom" style="width:130px;"/>
      <input type="date" class="form-control form-control-sm" id="filterTo" style="width:130px;"/>
      <button class="btn btn-sm btn-outline-secondary" id="btnClear"><i class="bi bi-x-lg"></i></button>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead><tr><th style="width:36px;">#</th><th>Order #</th><th>Customer</th><th>Type</th><th>Items</th><th class="text-end">Total</th><th>Payment</th><th>Status</th><th>Date</th><th class="text-end" style="width:120px;">Actions</th></tr></thead>
      <tbody id="tableBody"><tr><td colspan="10" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...</td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- View Modal -->
<div class="modal fade" id="viewModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:700px;"><div class="modal-content">
  <div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-bag-check me-2 text-primary"></i>Order Details</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body p-0" id="viewBody"></div>
  <div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal">Close</button></div>
</div></div></div>

<script>
var _page=1,_pp=15;
_pp=smsInitPerPage('#perPageSel');$('#perPageSel').on('change',function(){_pp=parseInt($(this).val())||15;_page=1;loadData();});
var ostMap={completed:{cls:'bg-success-lt',label:'Completed'},confirmed:{cls:'bg-info-lt',label:'Confirmed'},draft:{cls:'bg-warning-lt',label:'Draft'},cancelled:{cls:'bg-danger-lt',label:'Cancelled'},returned:{cls:'bg-secondary-lt',label:'Returned'}};
var pstMap={paid:{cls:'bg-success-lt',label:'Paid'},partial:{cls:'bg-warning-lt',label:'Partial'},unpaid:{cls:'bg-danger-lt',label:'Unpaid'},refunded:{cls:'bg-secondary-lt',label:'Refunded'}};

function buildPagination(pg){if(!pg||pg.last_page<=1){$('#tablePagination').html('');return;}var h='<ul class="pagination pagination-sm mb-0">';h+='<li class="page-item'+(pg.current_page<=1?' disabled':'')+'"><a class="page-link" href="#" data-page="'+(pg.current_page-1)+'"><i class="bi bi-chevron-left"></i></a></li>';var s=Math.max(1,pg.current_page-2),e=Math.min(pg.last_page,pg.current_page+2);if(s>1){h+='<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';if(s>2)h+='<li class="page-item disabled"><span class="page-link">…</span></li>';}for(var i=s;i<=e;i++)h+='<li class="page-item'+(i===pg.current_page?' active':'')+'"><a class="page-link" href="#" data-page="'+i+'">'+i+'</a></li>';if(e<pg.last_page){if(e<pg.last_page-1)h+='<li class="page-item disabled"><span class="page-link">…</span></li>';h+='<li class="page-item"><a class="page-link" href="#" data-page="'+pg.last_page+'">'+pg.last_page+'</a></li>';}h+='<li class="page-item'+(pg.current_page>=pg.last_page?' disabled':'')+'"><a class="page-link" href="#" data-page="'+(pg.current_page+1)+'"><i class="bi bi-chevron-right"></i></a></li></ul>';$('#tablePagination').html(h);}

function loadData(){
    $('#tableBody').html('<tr><td colspan="10" class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>');
    $.post(BASE_URL+'/pos/orders/paginate',{page:_page,per_page:_pp,search:$('#searchInput').val().trim(),order_status:$('#filterOrderStatus').val(),payment_status:$('#filterPayStatus').val(),date_from:$('#filterFrom').val(),date_to:$('#filterTo').val()},function(res){
        if(!res||res.status!==200){$('#tableBody').html('<tr><td colspan="10" class="text-center text-danger py-4">Failed.</td></tr>');return;}
        var data=res.data&&res.data.data?res.data.data:[],pg=res.data&&res.data.pagination?res.data.pagination:{};
        $('#badgeTotal').text((pg.total||0).toLocaleString());
        if(!data.length){$('#tableBody').html('<tr><td colspan="10" class="text-center py-5 text-muted"><i class="bi bi-bag d-block mb-2" style="font-size:36px;opacity:.3;"></i>No orders found</td></tr>');$('#tableInfo').text('');$('#tablePagination').html('');return;}
        var rows='';
        data.forEach(function(o,i){
            var os=ostMap[o.order_status]||ostMap.draft,ps=pstMap[o.payment_status]||pstMap.unpaid;
            var canDel=o.order_status!=='cancelled'&&o.order_status!=='returned';
            rows+='<tr class="ord-row" data-uuid="'+H.esc(o.uuid)+'">';
            rows+='<td class="text-muted">'+((pg.from||1)+i)+'</td>';
            rows+='<td class="fw-medium">'+H.esc(o.order_number)+'</td>';
            rows+='<td>'+(o.customer_name?H.esc(o.customer_name):'<span class="text-muted">Walk-in</span>')+'</td>';
            rows+='<td><span class="badge bg-azure-lt" style="text-transform:capitalize;">'+H.esc(o.order_type)+'</span></td>';
            rows+='<td class="text-muted">-</td>';
            rows+='<td class="text-end fw-medium">'+H.currency(o.total_amount)+'</td>';
            rows+='<td><span class="badge '+ps.cls+'">'+ps.label+'</span></td>';
            rows+='<td><span class="badge '+os.cls+'">'+os.label+'</span></td>';
            rows+='<td class="text-muted small">'+smsFormatDateTime(o.created_at)+'</td>';
            rows+='<td class="text-end" style="white-space:nowrap;">';
            rows+='<button class="btn btn-sm btn-ghost-primary" title="View" onclick="viewOrder(\''+H.esc(o.uuid)+'\')"><i class="bi bi-eye"></i></button>';
            if(canDel)rows+='<button class="btn btn-sm btn-ghost-danger ord-del-btn" title="Cancel Order" onclick="cancelOrder(\''+H.esc(o.uuid)+'\')"><i class="bi bi-trash3"></i></button>';
            rows+='</td></tr>';
        });
        $('#tableBody').html(rows);
        $('#tableInfo').text('Showing '+(pg.from||1)+'\u2013'+(pg.to||data.length)+' of '+(pg.total||0));
        buildPagination(pg);
    });
}

function viewOrder(uuid){
    var $b=$('#viewBody');$b.html('<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>');
    bootstrap.Modal.getOrCreateInstance($('#viewModal')[0]).show();
    $.get(BASE_URL+'/pos/orders/'+uuid,function(res){
        if(!res||res.status!==200||!res.data){$b.html('<div class="alert alert-danger m-3">Not found.</div>');return;}
        var o=res.data,os=ostMap[o.order_status]||ostMap.draft,ps=pstMap[o.payment_status]||pstMap.unpaid;
        var h='<div class="p-3 border-bottom" style="background:var(--tblr-bg-surface-secondary);">';
        h+='<div class="d-flex align-items-center gap-3"><div><h5 class="mb-0 fw-bold">'+H.esc(o.order_number)+'</h5><div class="text-muted small">'+smsFormatDateTime(o.created_at)+'</div></div>';
        h+='<div class="ms-auto d-flex gap-2"><span class="badge '+os.cls+' fs-6">'+os.label+'</span><span class="badge '+ps.cls+' fs-6">'+ps.label+'</span></div></div></div>';
        h+='<div class="p-3">';
        h+='<div class="row g-2 mb-3"><div class="col-sm-4"><div class="text-muted small">Customer</div><div class="fw-medium">'+(o.customer_name?H.esc(o.customer_name):'Walk-in')+'</div></div>';
        h+='<div class="col-sm-4"><div class="text-muted small">Payment</div><div style="text-transform:capitalize;">'+H.esc(o.payment_method||'-')+'</div></div>';
        h+='<div class="col-sm-4"><div class="text-muted small">Type</div><div style="text-transform:capitalize;">'+H.esc(o.order_type)+'</div></div></div>';
        // Items table
        h+='<h6 class="fw-semibold mb-2"><i class="bi bi-list-check me-1 text-primary"></i>Items</h6>';
        h+='<table class="table table-sm mb-3"><thead><tr><th>Item</th><th>Qty</th><th class="text-end">Price</th><th class="text-end">Total</th></tr></thead><tbody>';
        (o.items||[]).forEach(function(it){
            h+='<tr><td><div class="fw-medium">'+H.esc(it.item_name)+'</div><div class="text-muted small">'+H.esc(it.item_code||'')+'</div></td><td>'+it.quantity+'</td><td class="text-end">'+H.currency(it.unit_price)+'</td><td class="text-end fw-medium">'+H.currency(it.total_price)+'</td></tr>';
        });
        h+='</tbody></table>';
        // Totals
        h+='<div class="border rounded p-2" style="max-width:250px;margin-left:auto;font-size:13px;">';
        h+='<div class="d-flex justify-content-between"><span class="text-muted">Subtotal</span><span>'+H.currency(o.subtotal)+'</span></div>';
        if(parseFloat(o.discount_amount)>0)h+='<div class="d-flex justify-content-between"><span class="text-muted">Discount</span><span class="text-success">-'+H.currency(o.discount_amount)+'</span></div>';
        if(parseFloat(o.tax_total)>0)h+='<div class="d-flex justify-content-between"><span class="text-muted">Tax</span><span>'+H.currency(o.tax_total)+'</span></div>';
        h+='<div class="d-flex justify-content-between fw-bold border-top pt-1 mt-1"><span>Total</span><span>'+H.currency(o.total_amount)+'</span></div>';
        h+='<div class="d-flex justify-content-between"><span class="text-muted">Paid</span><span class="text-success">'+H.currency(o.amount_paid)+'</span></div>';
        if(parseFloat(o.amount_due)>0)h+='<div class="d-flex justify-content-between"><span class="text-muted">Due</span><span class="text-danger fw-bold">'+H.currency(o.amount_due)+'</span></div>';
        h+='</div>';
        if(o.notes)h+='<div class="mt-2 text-muted small"><i class="bi bi-chat-left-text me-1"></i>'+H.esc(o.notes)+'</div>';
        h+='</div>';
        $b.html(h);
    });
}

function cancelOrder(uuid){
    smsConfirm({title:'Cancel Order',msg:'Cancel this order? Stock will be restored.',btnClass:'btn-danger',btnText:'Cancel Order',onConfirm:function(){
        $.post(BASE_URL+'/pos/orders/'+uuid+'/cancel',function(r){if(r.status===200){toastr.success('Cancelled.');loadData();}else toastr.error(r.message||'Failed.');});
    }});
}

function doExport(fmt){
    showLoading();
    $.post(BASE_URL+'/pos/orders/export',{search:$('#searchInput').val().trim(),order_status:$('#filterOrderStatus').val(),date_from:$('#filterFrom').val(),date_to:$('#filterTo').val()},function(res){
        hideLoading();
        if(!res||res.status!==200||!res.data||!res.data.rows||!res.data.rows.length){toastr.error('No data.');return;}
        var rows=res.data.rows,cols=Object.keys(rows[0]);
        if(fmt==='csv'){var csv=cols.map(function(c){return '"'+c+'"';}).join(',')+String.fromCharCode(10);rows.forEach(function(r){csv+=cols.map(function(c){return '"'+String(r[c]==null?'':r[c]).replace(/"/g,'""')+'"';}).join(',')+String.fromCharCode(10);});var blob=new Blob([csv],{type:'text/csv'});var url=URL.createObjectURL(blob);var a=document.createElement('a');a.href=url;a.download='orders-'+Date.now()+'.csv';document.body.appendChild(a);a.click();document.body.removeChild(a);toastr.success('Exported.');}
        else{var html='<html><head><title>Orders</title><style>body{font-family:Arial;font-size:12px;padding:20px;}table{border-collapse:collapse;width:100%;}th,td{border:1px solid #ccc;padding:6px 8px;}th{background:#f0f4f8;}</style></head><body><h2>Sales Orders ('+rows.length+')</h2><table><tr>';cols.forEach(function(c){html+='<th>'+H.esc(c)+'</th>';});html+='</tr>';rows.forEach(function(r){html+='<tr>';cols.forEach(function(c){html+='<td>'+H.esc(String(r[c]||''))+'</td>';});html+='</tr>';});html+='</table></body></html>';var w=window.open('','_blank');w.document.write(html);w.document.close();setTimeout(function(){w.print();},400);}
    }).fail(function(){hideLoading();toastr.error('Failed.');});
}

// Mobile swipe-to-delete on order rows
var _swSt=null,_swRow=null;
$(document).on('touchstart','.ord-row',function(e){
    _swSt=e.originalEvent.touches[0].clientX;_swRow=$(this);
    $('.ord-row').removeClass('swiped');$('#ordSwipeDel').remove();
});
$(document).on('touchmove','.ord-row',function(e){
    if(!_swSt||!_swRow)return;
    var dx=_swSt-e.originalEvent.touches[0].clientX;
    if(dx>50){
        _swRow.addClass('swiped');
        if(!$('#ordSwipeDel').length){
            var rect=_swRow[0].getBoundingClientRect();
            var uuid=_swRow.data('uuid');
            $('body').append('<div id="ordSwipeDel" class="ord-swipe-overlay" style="display:flex;top:'+rect.top+'px;height:'+rect.height+'px;" onclick="cancelOrder(\''+H.esc(uuid)+'\');$(this).remove();"><i class="bi bi-trash3"></i> Cancel</div>');
        }
    } else if(dx<-20){_swRow.removeClass('swiped');$('#ordSwipeDel').remove();}
});
$(document).on('touchend',function(){_swSt=null;_swRow=null;});

$(function(){loadData();
    var st;$('#searchInput').on('input',function(){clearTimeout(st);st=setTimeout(function(){_page=1;loadData();},300);});
    $('#filterOrderStatus,#filterPayStatus').on('change',function(){_page=1;loadData();});
    $('#filterFrom,#filterTo').on('change',function(){_page=1;loadData();});
    $('#btnClear').on('click',function(){$('#searchInput').val('');$('#filterOrderStatus').val('');$('#filterPayStatus').val('');$('#filterFrom').val('');$('#filterTo').val('');_page=1;loadData();});
    $(document).on('click','#tablePagination .page-link',function(e){e.preventDefault();var p=parseInt($(this).data('page'));if(p&&p>=1){_page=p;loadData();}});
});
</script>
