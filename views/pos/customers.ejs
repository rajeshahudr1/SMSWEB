<% if (typeof _spa === 'undefined' || !_spa) { %><%- layout('../layouts/pos-layout') %><% } %>
<div class="pos-page-card">
  <div class="card-header">
    <h3><i class="bi bi-people text-primary"></i> Customers <span class="badge bg-primary-lt" id="badgeTotal">-</span></h3>
    <div style="display:flex;gap:6px;margin-left:auto;flex-wrap:wrap;">
      <select class="ph-sel" id="perPageSel"><option value="15">15</option><option value="30">30</option><option value="50">50</option></select>
      <button class="pos-btn-primary" onclick="openForm()"><i class="bi bi-plus-lg"></i> Add Customer</button>
    </div>
  </div>
  <div style="padding:10px 16px;border-bottom:1px solid var(--border);display:flex;gap:6px;flex-wrap:wrap;align-items:center;">
    <div style="flex:1;min-width:180px;position:relative;"><i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;"></i><input type="text" class="pos-input" id="searchInput" placeholder="Search name, phone, email..." style="padding-left:34px;"/></div>
    <select class="ph-sel" id="filterType"><option value="">All Types</option><option value="regular">Regular</option><option value="wholesale">Wholesale</option><option value="walk_in">Walk-in</option></select>
    <button class="pos-btn-outline pos-btn-sm" onclick="$('#searchInput').val('');$('#filterType').val('');_page=1;loadData();"><i class="bi bi-x-lg"></i> Clear</button>
  </div>
  <div style="overflow-x:auto;">
    <table class="table table-hover mb-0" style="font-size:13px;">
      <thead><tr><th>#</th><th>Name</th><th>Phone</th><th>Email</th><th>Type</th><th class="text-end">Purchases</th><th>Orders</th><th class="text-end">Actions</th></tr></thead>
      <tbody id="tableBody"><tr><td colspan="8" class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr></tbody>
    </table>
  </div>
  <div style="padding:10px 16px;display:flex;align-items:center;flex-wrap:wrap;gap:8px;border-top:1px solid var(--border);"><span class="text-muted" style="font-size:12px;" id="tableInfo"></span><div style="margin-left:auto;" id="tablePagination"></div></div>
</div>

<!-- Form Modal (POS style) -->
<div class="pos-modal-overlay" id="formOverlay" onclick="if(event.target===this)closeForm();">
  <div class="pos-modal" style="max-width:480px;">
    <div style="padding:18px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;">
      <h3 style="font-size:16px;font-weight:800;margin:0;flex:1;" id="formTitle"><i class="bi bi-person-plus text-primary" style="margin-right:6px;"></i>Add Customer</h3>
      <button onclick="closeForm()" style="width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:none;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;"><i class="bi bi-x-lg"></i></button>
    </div>
    <div style="padding:16px 20px;">
      <input type="hidden" id="custUuid"/>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div><label style="font-size:11px;font-weight:600;color:var(--text2);display:block;margin-bottom:3px;">Name *</label><input type="text" class="pos-input" id="custName" required/></div>
        <div><label style="font-size:11px;font-weight:600;color:var(--text2);display:block;margin-bottom:3px;">Phone</label><input type="tel" class="pos-input" id="custPhone"/></div>
        <div><label style="font-size:11px;font-weight:600;color:var(--text2);display:block;margin-bottom:3px;">Email</label><input type="email" class="pos-input" id="custEmail"/></div>
        <div><label style="font-size:11px;font-weight:600;color:var(--text2);display:block;margin-bottom:3px;">Type</label><select class="pos-input" id="custType"><option value="regular">Regular</option><option value="wholesale">Wholesale</option><option value="walk_in">Walk-in</option></select></div>
        <div style="grid-column:1/-1;"><label style="font-size:11px;font-weight:600;color:var(--text2);display:block;margin-bottom:3px;">Address</label><textarea class="pos-input" id="custAddr" rows="2" style="resize:none;"></textarea></div>
        <div><label style="font-size:11px;font-weight:600;color:var(--text2);display:block;margin-bottom:3px;">GST Number</label><input type="text" class="pos-input" id="custGst"/></div>
        <div><label style="font-size:11px;font-weight:600;color:var(--text2);display:block;margin-bottom:3px;">PAN Number</label><input type="text" class="pos-input" id="custPan"/></div>
      </div>
    </div>
    <div style="padding:12px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;">
      <button class="pos-btn-outline" onclick="closeForm()">Cancel</button>
      <button class="pos-btn-primary" onclick="saveCust()"><i class="bi bi-check-lg"></i> Save</button>
    </div>
  </div>
</div>

<script>
var _page=1,_pp=15,BASE_URL='';
var typeMap={regular:{cls:'bg-primary-lt',label:'Regular'},wholesale:{cls:'bg-success-lt',label:'Wholesale'},walk_in:{cls:'bg-secondary-lt',label:'Walk-in'}};
var H=window.H||{esc:function(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');},currency:function(v){return parseFloat(v||0).toFixed(2);}};

function buildPg(pg){
    if(!pg||pg.last_page<=1){$('#tablePagination').html('');return;}
    var h='<div class="pos-pagination">';
    h+='<button '+(pg.current_page<=1?'disabled':'')+' onclick="_page='+(pg.current_page-1)+';loadData();"><i class="bi bi-chevron-left"></i></button>';
    h+='<span style="padding:0 6px;">'+pg.current_page+' / '+pg.last_page+'</span>';
    h+='<button '+(pg.current_page>=pg.last_page?'disabled':'')+' onclick="_page='+(pg.current_page+1)+';loadData();"><i class="bi bi-chevron-right"></i></button>';
    h+='</div>';$('#tablePagination').html(h);
}

function loadData(){
    $('#tableBody').html('<tr><td colspan="8" class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>');
    $.post(BASE_URL+'/pos/customers/paginate',{page:_page,per_page:_pp,search:$('#searchInput').val().trim(),customer_type:$('#filterType').val()},function(res){
        if(!res||res.status!==200){$('#tableBody').html('<tr><td colspan="8" class="text-center text-danger py-4">Failed</td></tr>');return;}
        var data=res.data&&res.data.data?res.data.data:[],pg=res.data&&res.data.pagination?res.data.pagination:{};
        $('#badgeTotal').text((pg.total||0).toLocaleString());
        if(!data.length){$('#tableBody').html('<tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-people" style="font-size:32px;opacity:.2;display:block;margin-bottom:6px;"></i>No customers</td></tr>');$('#tableInfo').text('');$('#tablePagination').html('');return;}
        var rows='';
        data.forEach(function(c,i){
            var tp=typeMap[c.customer_type]||typeMap.regular;
            rows+='<tr><td class="text-muted">'+((pg.from||1)+i)+'</td><td class="fw-medium">'+H.esc(c.name)+'</td><td>'+H.esc(c.phone||'-')+'</td><td>'+H.esc(c.email||'-')+'</td><td><span class="badge '+tp.cls+'" style="font-size:10px;">'+tp.label+'</span></td><td class="text-end">'+H.currency(c.total_purchases)+'</td><td>'+c.total_orders+'</td>';
            rows+='<td class="text-end" style="white-space:nowrap;"><button class="pos-btn-outline pos-btn-sm" onclick="editCust(\''+H.esc(c.uuid)+'\')" style="margin-right:4px;"><i class="bi bi-pencil"></i></button><button class="pos-btn-danger" onclick="delCust(\''+H.esc(c.uuid)+'\')"><i class="bi bi-trash3"></i></button></td></tr>';
        });
        $('#tableBody').html(rows);$('#tableInfo').text((pg.from||1)+'-'+(pg.to||data.length)+' of '+(pg.total||0));buildPg(pg);
    });
}

function openForm(){$('#custUuid').val('');$('#custName,#custPhone,#custEmail,#custAddr,#custGst,#custPan').val('');$('#custType').val('regular');$('#formTitle').html('<i class="bi bi-person-plus text-primary" style="margin-right:6px;"></i>Add Customer');$('#formOverlay').css('display','flex');}
function closeForm(){$('#formOverlay').hide();}

function editCust(uuid){
    $.get(BASE_URL+'/pos/customers/'+uuid,function(r){
        if(!r||r.status!==200||!r.data)return;var c=r.data;
        $('#custUuid').val(c.uuid);$('#custName').val(c.name);$('#custPhone').val(c.phone);$('#custEmail').val(c.email);$('#custType').val(c.customer_type);$('#custAddr').val(c.address);$('#custGst').val(c.gst_number);$('#custPan').val(c.pan_number);
        $('#formTitle').html('<i class="bi bi-pencil text-primary" style="margin-right:6px;"></i>Edit Customer');
        $('#formOverlay').css('display','flex');
    });
}

function saveCust(){
    var uuid=$('#custUuid').val(),data={name:$('#custName').val(),phone:$('#custPhone').val(),email:$('#custEmail').val(),customer_type:$('#custType').val(),address:$('#custAddr').val(),gst_number:$('#custGst').val(),pan_number:$('#custPan').val()};
    if(!data.name){toastr.warning('Name required.');return;}
    $.ajax({url:BASE_URL+'/pos/customers'+(uuid?'/'+uuid:''),type:uuid?'PUT':'POST',contentType:'application/json',data:JSON.stringify(data),success:function(r){
        if(r.status===200||r.status===201){toastr.success(uuid?'Updated.':'Created.');closeForm();loadData();}else toastr.error(r.message||'Failed.');
    }});
}

function delCust(uuid){
    posConfirm('Delete this customer?',function(){
        $.ajax({url:BASE_URL+'/pos/customers/'+uuid,type:'DELETE',success:function(r){if(r.status===200){toastr.success('Deleted.');loadData();}else toastr.error(r.message||'Failed.');}});
    });
}

$(function(){
    loadData();
    var st;$('#searchInput').on('input',function(){clearTimeout(st);st=setTimeout(function(){_page=1;loadData();},300);});
    $('#filterType').on('change',function(){_page=1;loadData();});
    $('#perPageSel').on('change',function(){_pp=parseInt($(this).val())||15;_page=1;loadData();});
});
</script>
