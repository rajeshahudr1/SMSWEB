<%- layout('../layouts/pos-layout') %>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-people me-2 text-primary"></i>Customers <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">-</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <button class="btn btn-sm btn-primary" onclick="openForm()"><i class="bi bi-plus-lg me-1"></i>Add Customer</button>
    </div>
  </div>
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="d-flex align-items-center gap-2">
      <div class="flex-grow-1"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="Search name, phone, email..."/></div>
      <select class="form-select form-select-sm" id="filterType" style="width:130px;"><option value="">All Types</option><option value="regular">Regular</option><option value="wholesale">Wholesale</option><option value="walk_in">Walk-in</option></select>
      <button class="btn btn-sm btn-outline-secondary" id="btnClear"><i class="bi bi-x-lg"></i></button>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead><tr><th style="width:36px;">#</th><th>Name</th><th>Phone</th><th>Email</th><th>Type</th><th class="text-end">Total Purchases</th><th>Orders</th><th class="text-end" style="width:100px;">Actions</th></tr></thead>
      <tbody id="tableBody"><tr><td colspan="8" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...</td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- Form Modal -->
<div class="modal fade" id="formModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content">
  <div class="modal-header py-3"><h5 class="modal-title fw-semibold" id="formTitle"><i class="bi bi-person-plus me-2 text-primary"></i>Add Customer</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <form id="custForm">
      <input type="hidden" id="custUuid"/>
      <div class="row g-3">
        <div class="col-md-6"><label class="form-label small fw-semibold">Name *</label><input type="text" class="form-control form-control-sm" id="custName" required/></div>
        <div class="col-md-6"><label class="form-label small fw-semibold">Phone</label><input type="tel" class="form-control form-control-sm" id="custPhone"/></div>
        <div class="col-md-6"><label class="form-label small fw-semibold">Email</label><input type="email" class="form-control form-control-sm" id="custEmail"/></div>
        <div class="col-md-6"><label class="form-label small fw-semibold">Type</label><select class="form-select form-select-sm" id="custType"><option value="regular">Regular</option><option value="wholesale">Wholesale</option><option value="walk_in">Walk-in</option></select></div>
        <div class="col-12"><label class="form-label small fw-semibold">Address</label><textarea class="form-control form-control-sm" id="custAddr" rows="2"></textarea></div>
        <div class="col-md-6"><label class="form-label small fw-semibold">GST Number</label><input type="text" class="form-control form-control-sm" id="custGst"/></div>
        <div class="col-md-6"><label class="form-label small fw-semibold">PAN Number</label><input type="text" class="form-control form-control-sm" id="custPan"/></div>
      </div>
    </form>
  </div>
  <div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="button" class="btn btn-primary btn-sm" id="btnSave"><i class="bi bi-floppy me-1"></i>Save</button></div>
</div></div></div>

<% block('scripts', `
<script>
var _page=1,_pp=15;
_pp=smsInitPerPage('#perPageSel');$('#perPageSel').on('change',function(){_pp=parseInt($(this).val())||15;_page=1;loadData();});
var typeMap={regular:{cls:'bg-primary-lt',label:'Regular'},wholesale:{cls:'bg-success-lt',label:'Wholesale'},walk_in:{cls:'bg-secondary-lt',label:'Walk-in'}};

function buildPagination(pg){if(!pg||pg.last_page<=1){$('#tablePagination').html('');return;}var h='<ul class="pagination pagination-sm mb-0">';h+='<li class="page-item'+(pg.current_page<=1?' disabled':'')+'"><a class="page-link" href="#" data-page="'+(pg.current_page-1)+'"><i class="bi bi-chevron-left"></i></a></li>';var s=Math.max(1,pg.current_page-2),e=Math.min(pg.last_page,pg.current_page+2);for(var i=s;i<=e;i++)h+='<li class="page-item'+(i===pg.current_page?' active':'')+'"><a class="page-link" href="#" data-page="'+i+'">'+i+'</a></li>';h+='<li class="page-item'+(pg.current_page>=pg.last_page?' disabled':'')+'"><a class="page-link" href="#" data-page="'+(pg.current_page+1)+'"><i class="bi bi-chevron-right"></i></a></li></ul>';$('#tablePagination').html(h);}

function loadData(){
    $('#tableBody').html('<tr><td colspan="8" class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>');
    $.post(BASE_URL+'/pos/customers/paginate',{page:_page,per_page:_pp,search:$('#searchInput').val().trim(),customer_type:$('#filterType').val()},function(res){
        if(!res||res.status!==200){$('#tableBody').html('<tr><td colspan="8" class="text-center text-danger py-4">Failed.</td></tr>');return;}
        var data=res.data&&res.data.data?res.data.data:[],pg=res.data&&res.data.pagination?res.data.pagination:{};
        $('#badgeTotal').text((pg.total||0).toLocaleString());
        if(!data.length){$('#tableBody').html('<tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-people d-block mb-2" style="font-size:36px;opacity:.3;"></i>No customers</td></tr>');$('#tableInfo').text('');$('#tablePagination').html('');return;}
        var rows='';
        data.forEach(function(c,i){
            var tp=typeMap[c.customer_type]||typeMap.regular;
            rows+='<tr><td class="text-muted">'+((pg.from||1)+i)+'</td><td class="fw-medium">'+H.esc(c.name)+'</td><td>'+H.esc(c.phone||'-')+'</td><td>'+H.esc(c.email||'-')+'</td><td><span class="badge '+tp.cls+'">'+tp.label+'</span></td><td class="text-end">'+H.currency(c.total_purchases)+'</td><td>'+c.total_orders+'</td>';
            rows+='<td class="text-end"><button class="btn btn-sm btn-ghost-primary" onclick="editCust(\\\''+c.uuid+'\\\')"><i class="bi bi-pencil"></i></button><button class="btn btn-sm btn-ghost-danger" onclick="delCust(\\\''+c.uuid+'\\\')"><i class="bi bi-trash3"></i></button></td></tr>';
        });
        $('#tableBody').html(rows);$('#tableInfo').text('Showing '+(pg.from||1)+'\u2013'+(pg.to||data.length)+' of '+(pg.total||0));buildPagination(pg);
    });
}

function openForm(uuid){$('#custUuid').val('');$('#custName,#custPhone,#custEmail,#custAddr,#custGst,#custPan').val('');$('#custType').val('regular');$('#formTitle').html('<i class="bi bi-person-plus me-2 text-primary"></i>Add Customer');bootstrap.Modal.getOrCreateInstance($('#formModal')[0]).show();}

function editCust(uuid){
    $.get(BASE_URL+'/pos/customers/'+uuid,function(r){
        if(!r||r.status!==200||!r.data)return;var c=r.data;
        $('#custUuid').val(c.uuid);$('#custName').val(c.name);$('#custPhone').val(c.phone);$('#custEmail').val(c.email);$('#custType').val(c.customer_type);$('#custAddr').val(c.address);$('#custGst').val(c.gst_number);$('#custPan').val(c.pan_number);
        $('#formTitle').html('<i class="bi bi-pencil me-2 text-primary"></i>Edit Customer');
        bootstrap.Modal.getOrCreateInstance($('#formModal')[0]).show();
    });
}

$('#btnSave').on('click',function(){
    var uuid=$('#custUuid').val(),data={name:$('#custName').val(),phone:$('#custPhone').val(),email:$('#custEmail').val(),customer_type:$('#custType').val(),address:$('#custAddr').val(),gst_number:$('#custGst').val(),pan_number:$('#custPan').val()};
    if(!data.name){toastr.warning('Name required.');return;}
    var url=uuid?BASE_URL+'/pos/customers/'+uuid:BASE_URL+'/pos/customers';
    var method=uuid?'PUT':'POST';
    $.ajax({url:url,type:method,contentType:'application/json',data:JSON.stringify(data),success:function(r){
        if(r.status===200||r.status===201){toastr.success(uuid?'Updated.':'Created.');bootstrap.Modal.getInstance($('#formModal')[0]).hide();loadData();}else toastr.error(r.message||'Failed.');
    }});
});

function delCust(uuid){smsConfirm({title:'Delete',msg:'Delete this customer?',btnClass:'btn-danger',btnText:'Delete',onConfirm:function(){
    $.ajax({url:BASE_URL+'/pos/customers/'+uuid,type:'DELETE',success:function(r){if(r.status===200){toastr.success('Deleted.');loadData();}else toastr.error(r.message);}});
}});}

$(function(){loadData();
    var st;$('#searchInput').on('input',function(){clearTimeout(st);st=setTimeout(function(){_page=1;loadData();},300);});
    $('#filterType').on('change',function(){_page=1;loadData();});
    $('#btnClear').on('click',function(){$('#searchInput').val('');$('#filterType').val('');_page=1;loadData();});
    $(document).on('click','#tablePagination .page-link',function(e){e.preventDefault();var p=parseInt($(this).data('page'));if(p&&p>=1){_page=p;loadData();}});
});
</script>
`); %>
