<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>POS · UI Kit | <%- APP_NAME %></title>
<link rel="icon" type="image/svg+xml" href="/images/favicon.svg"/>
<link rel="stylesheet" href="/libs/css/tabler.min.css"/>
<link rel="stylesheet" href="/libs/css/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/libs/css/toastr.min.css"/>
<link rel="stylesheet" href="/css/pos.css?v=<%= Date.now() %>"/>
<style>
  html,body{height:auto;overflow:auto;}
  body.pos-mode{overflow:auto;height:auto;}
  .pv2-kit-top{position:sticky;top:0;z-index:20;background:var(--pv2-surface);border-bottom:1px solid var(--pv2-border);padding:14px 24px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
  .pv2-kit-top .logo{width:36px;height:36px;border-radius:8px;background:var(--pv2-brand);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px;letter-spacing:-0.3px;}
  .pv2-kit-wrap{display:grid;grid-template-columns:320px 1fr;gap:0;min-height:calc(100vh - 70px);}
  @media(max-width:900px){.pv2-kit-wrap{grid-template-columns:1fr;}}
  .pv2-editor{background:var(--pv2-surface);border-right:1px solid var(--pv2-border);padding:20px;position:sticky;top:70px;align-self:start;max-height:calc(100vh - 70px);overflow-y:auto;}
  .pv2-editor h3{font-size:12px;font-weight:700;color:var(--pv2-text);text-transform:uppercase;letter-spacing:0.6px;margin-bottom:10px;margin-top:18px;}
  .pv2-editor h3:first-child{margin-top:0;}
  .pv2-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px dashed var(--pv2-border);}
  .pv2-row:last-child{border-bottom:none;}
  .pv2-row label{flex:1;font-size:12.5px;color:var(--pv2-text);font-weight:500;}
  .pv2-row input[type=color]{width:40px;height:32px;padding:0;border:1px solid var(--pv2-border-strong);border-radius:6px;cursor:pointer;background:none;}
  .pv2-row .hex{width:88px;padding:6px 8px;font-family:var(--pv2-font-mono);font-size:11.5px;border:1px solid var(--pv2-border-strong);border-radius:6px;text-align:center;color:var(--pv2-text);background:var(--pv2-surface);}
  .pv2-editor-actions{display:flex;gap:8px;margin-top:18px;padding-top:14px;border-top:1px solid var(--pv2-border);}
  .pv2-editor-actions button{flex:1;}
  .pv2-presets{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;margin-top:10px;}
  .pv2-preset{padding:8px 10px;border:1px solid var(--pv2-border-strong);border-radius:7px;background:var(--pv2-surface);cursor:pointer;display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--pv2-text);}
  .pv2-preset:hover{border-color:var(--pv2-brand);}
  .pv2-preset .dot{width:14px;height:14px;border-radius:50%;flex-shrink:0;box-shadow:inset 0 0 0 1px rgba(0,0,0,.06);}
  .pv2-preview{padding:24px;background:var(--pv2-surface-alt);}
  .pv2-hint{font-size:11.5px;color:var(--pv2-muted);margin-top:6px;line-height:1.4;}
  .pv2-scope-banner{background:var(--pv2-brand-ghost);border:1px solid var(--pv2-border);border-radius:7px;padding:8px 11px;font-size:11.5px;color:var(--pv2-muted);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
  .pv2-scope-banner i{color:var(--pv2-brand);font-size:14px;}

  /* Mini POS preview mock */
  .mock-shell{display:grid;grid-template-columns:64px 1fr 300px;background:var(--pv2-surface);border:1px solid var(--pv2-border);border-radius:14px;overflow:hidden;box-shadow:var(--pv2-shadow-md);height:520px;margin-bottom:20px;}
  .mock-side{background:var(--pv2-ink);display:flex;flex-direction:column;align-items:center;padding:14px 0;gap:6px;}
  .mock-side .slogo{width:36px;height:36px;border-radius:9px;background:var(--pv2-brand);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;margin-bottom:16px;}
  .mock-side .sbtn{width:44px;height:44px;border-radius:9px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.55);font-size:17px;}
  .mock-side .sbtn.on{background:var(--pv2-brand);color:#fff;}
  .mock-mid{display:flex;flex-direction:column;background:var(--pv2-surface-alt);}
  .mock-top{height:48px;background:var(--pv2-surface);border-bottom:1px solid var(--pv2-border);display:flex;align-items:center;padding:0 16px;gap:10px;}
  .mock-top h4{font-size:14px;font-weight:700;letter-spacing:-0.2px;color:var(--pv2-text);margin:0;}
  .mock-pill{margin-left:auto;display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:999px;background:var(--pv2-brand-ghost);border:1px solid rgba(11,18,32,.08);color:var(--pv2-brand);font-size:11px;font-weight:600;}
  .mock-pill .pd{width:6px;height:6px;border-radius:50%;background:var(--pv2-success);animation:pv2-pulseDot 2s infinite;}
  .mock-grid{flex:1;padding:14px;display:grid;grid-template-columns:repeat(3,1fr);gap:10px;overflow:hidden;}
  .mock-card{background:var(--pv2-surface);border:1px solid var(--pv2-border);border-radius:8px;padding:10px;display:flex;flex-direction:column;gap:6px;min-height:112px;}
  .mock-card .ci{width:40px;height:40px;border-radius:5px;background:var(--pv2-surface-sunken);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--pv2-subtle);font-family:var(--pv2-font-mono);}
  .mock-card .nm{font-size:12px;font-weight:600;color:var(--pv2-text);}
  .mock-card .sku{font-size:10.5px;color:var(--pv2-subtle);font-family:var(--pv2-font-mono);}
  .mock-card .pr{display:flex;justify-content:space-between;align-items:center;margin-top:auto;}
  .mock-card .pr .pv{font-size:13px;font-weight:700;color:var(--pv2-text);}
  .mock-card .fab{width:22px;height:22px;border-radius:11px;background:var(--pv2-brand);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;}
  .mock-right{background:var(--pv2-surface);border-left:1px solid var(--pv2-border);display:flex;flex-direction:column;}
  .mock-rh{padding:12px 14px;border-bottom:1px solid var(--pv2-border);display:flex;align-items:center;gap:8px;}
  .mock-rh .av{width:32px;height:32px;border-radius:50%;background:var(--pv2-brand-light);color:var(--pv2-brand);font-weight:700;font-size:12px;display:flex;align-items:center;justify-content:center;}
  .mock-rh .nm{font-size:13px;font-weight:600;color:var(--pv2-text);}
  .mock-rh .sub{font-size:11px;color:var(--pv2-muted);}
  .mock-items{flex:1;padding:8px 12px;overflow:hidden;}
  .mock-li{padding:8px 0;border-bottom:1px solid var(--pv2-border);display:flex;gap:10px;align-items:center;font-size:12px;}
  .mock-li .ln{flex:1;color:var(--pv2-text);font-weight:500;}
  .mock-li .lp{font-family:var(--pv2-font-mono);color:var(--pv2-text);font-weight:700;}
  .mock-tot{padding:10px 14px;background:var(--pv2-surface-alt);border-top:1px solid var(--pv2-border);display:flex;justify-content:space-between;align-items:baseline;}
  .mock-tot .tl{font-size:13px;font-weight:700;}
  .mock-tot .tv{font-size:20px;font-weight:700;font-family:var(--pv2-font-sans);letter-spacing:-0.4px;}
  .mock-pay{margin:12px;padding:12px;background:var(--pv2-brand);color:#fff;border-radius:7px;font-weight:700;font-size:14px;display:flex;align-items:center;justify-content:center;gap:8px;border:none;cursor:pointer;}
  .mock-pay:hover{background:var(--pv2-brand-dark);}

  /* ── Custom preset (color-picker tile inside Presets grid) ── */
  .pv2-preset.custom{position:relative; cursor:pointer; overflow:hidden; border-style:dashed;}
  .pv2-preset.custom:hover{border-color:var(--pv2-brand); background:var(--pv2-brand-ghost);}
  .pv2-preset.custom input[type=color]{position:absolute; inset:0; width:100%; height:100%; opacity:0; cursor:pointer; padding:0; border:none; background:none;}
  .pv2-preset.custom .dot{background:linear-gradient(135deg,#ef4444 0%,#f59e0b 25%,#10b981 50%,#3b82f6 75%,#8b5cf6 100%);}

  /* ── Responsive preview canvas — adapts to current viewport ── */
  .pv2-prev-tabs{display:flex;gap:6px;margin-bottom:10px;}
  .pv2-prev-tab{
    padding:6px 12px;border:1px solid var(--pv2-border);border-radius:6px;
    background:var(--pv2-surface);font-size:12px;font-weight:600;color:var(--pv2-text);
    cursor:pointer;display:inline-flex;align-items:center;gap:5px;
  }
  .pv2-prev-tab.on{background:var(--pv2-brand);color:#fff;border-color:var(--pv2-brand);}
  .pv2-prev-viewport{
    background:var(--pv2-surface);border:1px solid var(--pv2-border);border-radius:14px;
    overflow:hidden;box-shadow:var(--pv2-shadow-md);
    margin:0 auto;transition:max-width .2s,height .2s;
  }
  .pv2-prev-viewport[data-mode="desktop"]{max-width:100%;height:520px;}
  .pv2-prev-viewport[data-mode="tablet"] {max-width:768px;height:560px;}
  .pv2-prev-viewport[data-mode="mobile"] {max-width:390px;height:640px;border-radius:24px;}

  /* Inside the viewport, the mock adapts to the viewport width (not screen) */
  .pv2-prev-viewport .mock-shell{
    grid-template-columns:64px 1fr 300px; border:none; border-radius:inherit; box-shadow:none;
    height:100%;margin:0;
  }
  .pv2-prev-viewport[data-mode="tablet"] .mock-shell{grid-template-columns:64px 1fr 260px;}
  .pv2-prev-viewport[data-mode="mobile"] .mock-shell{
    grid-template-columns:1fr; grid-template-rows:auto auto 1fr auto;
  }
  .pv2-prev-viewport[data-mode="mobile"] .mock-side{
    order:4; flex-direction:row; width:100%; height:auto; padding:8px 14px; gap:0; justify-content:space-around;
  }
  .pv2-prev-viewport[data-mode="mobile"] .mock-side .slogo{display:none;}
  .pv2-prev-viewport[data-mode="mobile"] .mock-side .sbtn{width:44px;height:40px;}
  .pv2-prev-viewport[data-mode="mobile"] .mock-right{display:none;}
  .pv2-prev-viewport[data-mode="mobile"] .mock-grid{grid-template-columns:repeat(2,1fr);}

  /* Tablet mode: shrink cart slightly */
  .pv2-prev-viewport[data-mode="tablet"] .mock-grid{grid-template-columns:repeat(2,1fr);}

  /* Extra live previews — tabs, rail, filter chips, part-detail header, autocomplete, cart lines */
  .pv2-live-row{display:grid;grid-template-columns:1fr;gap:14px;margin-bottom:20px;}
  .pv2-live-card{background:var(--pv2-surface);border:1px solid var(--pv2-border);border-radius:10px;overflow:hidden;}
  .pv2-live-card .lc-hdr{padding:8px 12px;font-size:11px;font-weight:700;color:var(--pv2-muted);text-transform:uppercase;letter-spacing:0.5px;background:var(--pv2-surface-alt);border-bottom:1px solid var(--pv2-border);}

  .lc-tabs{display:flex;gap:6px;padding:12px 14px 0;background:var(--pv2-surface);border-bottom:1px solid var(--pv2-border);}
  .lc-tabs .t{padding:8px 14px;font-size:13px;font-weight:500;color:var(--pv2-muted);border-bottom:2px solid transparent;display:inline-flex;align-items:center;gap:6px;margin-bottom:-1px;}
  .lc-tabs .t.on{color:var(--pv2-brand);background:var(--pv2-brand-light);border-bottom-color:var(--pv2-brand);font-weight:600;border-radius:6px 6px 0 0;}

  .lc-rail{display:flex;flex-direction:column;padding:10px 8px;background:var(--pv2-surface);}
  .lc-rail .r{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:6px;font-size:12.5px;color:var(--pv2-muted);font-weight:500;}
  .lc-rail .r.on{background:var(--pv2-brand-light);color:var(--pv2-brand);font-weight:600;}
  .lc-rail .r .ct{margin-left:auto;font-size:10.5px;opacity:.7;}

  .lc-chips{display:flex;gap:6px;flex-wrap:wrap;padding:12px 14px;background:var(--pv2-surface);}
  .lc-chip{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;background:var(--pv2-brand);color:#fff;font-size:11.5px;font-weight:600;}
  .lc-chip .x{cursor:pointer;opacity:.8;font-size:14px;line-height:1;}

  .lc-pdt{background:var(--pv2-surface);padding:14px;display:flex;align-items:flex-start;gap:14px;flex-wrap:wrap;}
  .lc-pdt .lc-pdt-main{flex:1;min-width:180px;}
  .lc-pdt .lc-sku{display:inline-flex;padding:3px 9px;border-radius:4px;background:var(--pv2-surface-sunken);color:var(--pv2-text);font-size:11px;font-weight:700;font-family:var(--pv2-font-mono);margin-right:6px;}
  .lc-pdt .lc-chip-brand{display:inline-flex;padding:3px 9px;border-radius:999px;background:var(--pv2-brand-light);color:var(--pv2-brand);font-size:11px;font-weight:600;margin-right:4px;}
  .lc-pdt .lc-chip-success{display:inline-flex;padding:3px 9px;border-radius:999px;background:var(--pv2-success-bg);color:var(--pv2-success);font-size:11px;font-weight:600;margin-right:4px;}
  .lc-pdt .lc-chip-warning{display:inline-flex;padding:3px 9px;border-radius:999px;background:var(--pv2-warning-bg);color:var(--pv2-warning);font-size:11px;font-weight:600;}
  .lc-pdt .lc-title{font-size:18px;font-weight:800;color:var(--pv2-text);letter-spacing:-0.4px;margin-top:6px;}
  .lc-pdt .lc-price{text-align:right;}
  .lc-pdt .lc-price .v{font-size:22px;font-weight:800;color:var(--pv2-text);font-family:var(--pv2-font-mono);letter-spacing:-0.5px;}
  .lc-pdt .lc-price .s{font-size:11px;color:var(--pv2-muted);}

  .lc-ac{background:var(--pv2-surface);padding:14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
  .lc-ac-trigger{min-width:160px;padding:7px 10px;border:1px solid var(--pv2-border);border-radius:6px;color:var(--pv2-text);font-size:12.5px;font-weight:500;display:flex;align-items:center;justify-content:space-between;gap:8px;}
  .lc-ac-trigger.focused{border-color:var(--pv2-brand);box-shadow:0 0 0 3px rgba(0,84,166,.12);}
  .lc-ac-trigger i{color:var(--pv2-muted);font-size:10px;}

  .lc-cart{background:var(--pv2-surface);padding:10px 14px;display:flex;flex-direction:column;gap:2px;}
  .lc-cart-line{display:flex;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid var(--pv2-border);}
  .lc-cart-line:last-child{border-bottom:none;}
  .lc-cart-line .ic{width:36px;height:36px;border-radius:5px;background:var(--pv2-surface-sunken);display:flex;align-items:center;justify-content:center;font-size:9px;font-family:var(--pv2-font-mono);color:var(--pv2-subtle);flex-shrink:0;}
  .lc-cart-line .nm{flex:1;font-size:12.5px;font-weight:600;color:var(--pv2-text);}
  .lc-cart-line .pr{font-family:var(--pv2-font-mono);font-weight:700;color:var(--pv2-text);}
</style>
</head>
<body class="pos-mode">
<script>
/* Apply saved theme (injected from the server so there's no flash of default colors) */
window.__pv2SavedTheme = <%- JSON.stringify(savedTheme || {}) %>;
(function(){ try{ var t=window.__pv2SavedTheme||{}; Object.keys(t).forEach(function(k){ document.documentElement.style.setProperty(k,t[k]); }); }catch(e){} })();
</script>

<div class="pv2-kit-top">
  <div class="logo">S</div>
  <div>
    <div style="font-size:15px;font-weight:700;letter-spacing:-0.3px;">POS &middot; UI Kit</div>
    <div style="font-size:11.5px;color:var(--pv2-muted);">Theme editor &middot; saves per company; applies to every POS user.</div>
  </div>
  <a class="pos-btn-outline pos-btn-sm" href="/sales" style="margin-left:auto;"><i class="bi bi-arrow-left"></i> Back to POS</a>
</div>

<div class="pv2-kit-wrap">

  <!-- EDITOR -->
  <aside class="pv2-editor">
    <div class="pv2-scope-banner"><i class="bi bi-shield-check"></i> Saved theme is shared across your organization.</div>

    <h3>Presets</h3>
    <div class="pv2-presets" id="presets"></div>

    <h3>Brand</h3>
    <div id="grpBrand"></div>

    <h3>Surfaces</h3>
    <div id="grpSurf"></div>

    <h3>Text &amp; Borders</h3>
    <div id="grpText"></div>

    <h3>Semantic</h3>
    <div id="grpSem"></div>

    <div class="pv2-editor-actions">
      <button class="pos-btn-outline pos-btn-sm" onclick="resetTheme()"><i class="bi bi-arrow-counterclockwise"></i> Reset</button>
      <button class="pos-btn-primary pos-btn-sm" id="btnSaveTheme" onclick="saveTheme()"><i class="bi bi-check-lg"></i> Save &amp; apply</button>
    </div>
    <div class="pv2-hint" id="saveHint">Click Save to store this theme for your organization.</div>
  </aside>

  <!-- PREVIEW + KIT -->
  <section class="pv2-preview">

    <div style="display:flex;align-items:center;margin-bottom:12px;">
      <div style="font-size:12.5px;font-weight:700;color:var(--pv2-text);text-transform:uppercase;letter-spacing:0.6px;flex:1;">Live preview</div>
      <div class="pv2-prev-tabs" id="prevTabs">
        <button type="button" class="pv2-prev-tab" data-mode="desktop"><i class="bi bi-display"></i> Desktop</button>
        <button type="button" class="pv2-prev-tab" data-mode="tablet"><i class="bi bi-tablet"></i> Tablet</button>
        <button type="button" class="pv2-prev-tab" data-mode="mobile"><i class="bi bi-phone"></i> Mobile</button>
      </div>
    </div>
    <div class="pv2-prev-viewport" id="prevViewport" data-mode="desktop">
    <div class="mock-shell">
      <div class="mock-side">
        <div class="slogo">S</div>
        <div class="sbtn on"><i class="bi bi-grid-1x2-fill"></i></div>
        <div class="sbtn"><i class="bi bi-receipt"></i></div>
        <div class="sbtn"><i class="bi bi-people"></i></div>
        <div class="sbtn"><i class="bi bi-gear"></i></div>
      </div>
      <div class="mock-mid">
        <div class="mock-top">
          <i class="bi bi-grid-1x2-fill" style="color:var(--pv2-brand);font-size:15px;"></i>
          <h4>POS</h4>
          <div class="mock-pill"><span class="pd"></span>Register open</div>
        </div>
        <div class="mock-grid">
          <div class="mock-card"><div class="ci">8821</div><div class="nm">Headlight assembly</div><div class="sku">P-8821 &middot; VW Golf VII</div><div class="pr"><div class="pv">&euro; 185</div><div class="fab">+</div></div></div>
          <div class="mock-card"><div class="ci">8817</div><div class="nm">Alternator 140A</div><div class="sku">P-8817 &middot; Ford Focus</div><div class="pr"><div class="pv">&euro; 95</div><div class="fab">+</div></div></div>
          <div class="mock-card"><div class="ci">8814</div><div class="nm">Front bumper skin</div><div class="sku">P-8814 &middot; Corolla 2014</div><div class="pr"><div class="pv">&euro; 210</div><div class="fab">+</div></div></div>
        </div>
      </div>
      <div class="mock-right">
        <div class="mock-rh">
          <div class="av">GM</div>
          <div style="flex:1;"><div class="nm">Giulia Moretti</div><div class="sub">Wholesale &middot; 3 items</div></div>
        </div>
        <div class="mock-items">
          <div class="mock-li"><span class="ln">Headlight assembly</span><span class="lp">&euro; 185</span></div>
          <div class="mock-li"><span class="ln">Alternator &times;2</span><span class="lp">&euro; 190</span></div>
          <div class="mock-li"><span class="ln">Tail light (L)</span><span class="lp">&euro; 48</span></div>
        </div>
        <div class="mock-tot"><span class="tl">Total</span><span class="tv">&euro; 527</span></div>
        <button class="mock-pay"><i class="bi bi-check-lg"></i> Charge &euro; 527</button>
      </div>
    </div>
    </div><!-- /pv2-prev-viewport -->

    <!-- Extra live previews reflecting the existing POS design -->
    <div class="pv2-live-row" style="grid-template-columns:1fr 1fr;">
      <div class="pv2-live-card">
        <div class="lc-hdr">Parts / Vehicles tabs</div>
        <div class="lc-tabs">
          <div class="t on"><i class="bi bi-gear-wide-connected"></i> Parts</div>
          <div class="t"><i class="bi bi-truck-front"></i> Vehicles</div>
        </div>
        <div style="height:48px;background:var(--pv2-surface-alt);"></div>
      </div>
      <div class="pv2-live-card">
        <div class="lc-hdr">Autocomplete dropdowns</div>
        <div class="lc-ac">
          <div class="lc-ac-trigger focused">All Warehouses <i class="bi bi-chevron-down"></i></div>
          <div class="lc-ac-trigger">20 <i class="bi bi-chevron-down"></i></div>
          <div class="lc-ac-trigger">Most recent <i class="bi bi-chevron-down"></i></div>
        </div>
      </div>
    </div>

    <div class="pv2-live-row" style="grid-template-columns:220px 1fr;">
      <div class="pv2-live-card">
        <div class="lc-hdr">Category rail</div>
        <div class="lc-rail">
          <div class="r on"><i class="bi bi-grid-3x3-gap-fill"></i><span>All parts</span><span class="ct">2,108</span></div>
          <div class="r"><i class="bi bi-gear"></i><span>Engine</span><span class="ct">412</span></div>
          <div class="r"><i class="bi bi-layers"></i><span>Body</span><span class="ct">358</span></div>
          <div class="r"><i class="bi bi-lightbulb"></i><span>Lights</span><span class="ct">297</span></div>
          <div class="r"><i class="bi bi-box"></i><span>Suspension</span><span class="ct">214</span></div>
        </div>
      </div>
      <div class="pv2-live-card">
        <div class="lc-hdr">Part detail header</div>
        <div class="lc-pdt">
          <div class="lc-pdt-main">
            <div>
