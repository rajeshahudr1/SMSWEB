<script src="/libs/js/jquery.min.js"></script>
<script src="/libs/js/toastr.min.js"></script>
<script>toastr.options={closeButton:true,progressBar:true,positionClass:'toast-top-right',timeOut:2500};</script>
<script>
/* ─── Theme editor (DB-backed, per-organization) ─── */
var TOKENS = {
  brand: [
    ['--pv2-brand',       'Brand',        '#0054a6'],
    ['--pv2-brand-dark',  'Brand dark',   '#003d7a'],
    ['--pv2-brand-light', 'Brand light',  '#e6f0fa'],
    ['--pv2-brand-ghost', 'Brand ghost',  '#f4f8fc'],
    ['--pv2-accent',      'Accent',       '#14b8a6']
  ],
  surf: [
    ['--pv2-ink',            'Ink (sidebar)',  '#0b1220'],
    ['--pv2-surface',        'Surface',        '#ffffff'],
    ['--pv2-surface-alt',    'Surface alt',    '#f7f9fc'],
    ['--pv2-surface-sunken', 'Surface sunken', '#f1f4f8']
  ],
  text: [
    ['--pv2-text',          'Text',          '#1a2332'],
    ['--pv2-muted',         'Muted',         '#5b6578'],
    ['--pv2-subtle',        'Subtle',        '#8a94a6'],
    ['--pv2-border',        'Border',        '#e8ecf1'],
    ['--pv2-border-strong', 'Border strong', '#d3d9e2']
  ],
  sem: [
    ['--pv2-success', 'Success', '#0d9f6e'],
    ['--pv2-warning', 'Warning', '#d97706'],
    ['--pv2-danger',  'Danger',  '#dc2626'],
    ['--pv2-purple',  'Purple',  '#8b5cf6']
  ]
};
var DEFAULTS = {};
Object.keys(TOKENS).forEach(function(g){ TOKENS[g].forEach(function(t){ DEFAULTS[t[0]] = t[2]; }); });

var PRESETS = [
  { name: 'ScrapMS (default)', brand:'#0054a6', ink:'#0b1220', accent:'#14b8a6' },
  { name: 'Shopify green',     brand:'#008060', ink:'#111827', accent:'#2563eb' },
  { name: 'Indigo',            brand:'#4f46e5', ink:'#1e1b4b', accent:'#06b6d4' },
  { name: 'Sunset',            brand:'#ea580c', ink:'#1c1917', accent:'#f59e0b' },
  { name: 'Crimson',           brand:'#be123c', ink:'#111827', accent:'#8b5cf6' },
  { name: 'Midnight',          brand:'#10b981', ink:'#020617', accent:'#38bdf8' }
];

function getCurrent(name){ return (window.__pv2SavedTheme && window.__pv2SavedTheme[name]) || DEFAULTS[name]; }
function setVar(name,val){ document.documentElement.style.setProperty(name,val); }
function hexToRgb(h){h=h.replace('#','');if(h.length===3)h=h.split('').map(function(c){return c+c;}).join('');var n=parseInt(h,16);return [n>>16&255,n>>8&255,n&255];}
function rgbToHex(r,g,b){return '#'+[r,g,b].map(function(v){return ('0'+Math.max(0,Math.min(255,v|0)).toString(16)).slice(-2);}).join('');}
function mix(hex, withWhite, t){ var a=hexToRgb(hex), b=hexToRgb(withWhite); return rgbToHex(a[0]+(b[0]-a[0])*t, a[1]+(b[1]-a[1])*t, a[2]+(b[2]-a[2])*t); }

function renderGroup(groupKey, containerId){
  var rows = TOKENS[groupKey].map(function(t){
    var name=t[0], label=t[1], cur=getCurrent(name);
    return '<div class="pv2-row" data-var="'+name+'">'
      + '<label>'+label+'</label>'
      + '<input type="color" class="pick" value="'+cur+'"/>'
      + '<input type="text" class="hex" value="'+cur+'" maxlength="9"/>'
      + '</div>';
  }).join('');
  document.getElementById(containerId).innerHTML = rows;
}
['brand','surf','text','sem'].forEach(function(g,i){ renderGroup(g, ['grpBrand','grpSurf','grpText','grpSem'][i]); });

function bindEditors(){
  document.querySelectorAll('.pv2-row').forEach(function(row){
    var name = row.getAttribute('data-var');
    var pick = row.querySelector('.pick');
    var hex  = row.querySelector('.hex');
    function apply(v){
      if(!/^#[0-9a-fA-F]{3,8}$/.test(v)) return;
      setVar(name,v); pick.value = v.slice(0,7); hex.value = v;
      if(name==='--pv2-brand'){
        var saved = window.__pv2SavedTheme || {};
        if(!saved['--pv2-brand-dark'])  { var d = mix(v,'#000000',0.4); setVar('--pv2-brand-dark',d);  var r=document.querySelector('[data-var="--pv2-brand-dark"]');  if(r){r.querySelector('.pick').value=d.slice(0,7); r.querySelector('.hex').value=d;} }
        if(!saved['--pv2-brand-light']) { var l = mix(v,'#ffffff',0.85); setVar('--pv2-brand-light',l); var r2=document.querySelector('[data-var="--pv2-brand-light"]'); if(r2){r2.querySelector('.pick').value=l.slice(0,7); r2.querySelector('.hex').value=l;} }
        if(!saved['--pv2-brand-ghost']) { var g = mix(v,'#ffffff',0.95); setVar('--pv2-brand-ghost',g); var r3=document.querySelector('[data-var="--pv2-brand-ghost"]'); if(r3){r3.querySelector('.pick').value=g.slice(0,7); r3.querySelector('.hex').value=g;} }
      }
    }
    pick.addEventListener('input', function(){ apply(pick.value); });
    hex.addEventListener('input',  function(){ apply(hex.value.trim()); });
  });
}
bindEditors();

/* Presets — plus a "Custom" tile with an inline color-picker */
var presetsHtml = PRESETS.map(function(p,i){
  return '<div class="pv2-preset" data-i="'+i+'"><span class="dot" style="background:'+p.brand+';"></span>'+p.name+'</div>';
}).join('');
presetsHtml += '<div class="pv2-preset custom" title="Pick any brand color"><span class="dot"></span>Custom color<input type="color" id="presetPick" value="#0054a6"/></div>';
document.getElementById('presets').innerHTML = presetsHtml;

function applyBrandPalette(brandHex, inkHex, accentHex){
  setRow('--pv2-brand',       brandHex);
  setRow('--pv2-brand-dark',  mix(brandHex, '#000000', 0.4));
  setRow('--pv2-brand-light', mix(brandHex, '#ffffff', 0.85));
  setRow('--pv2-brand-ghost', mix(brandHex, '#ffffff', 0.95));
  if (inkHex)    setRow('--pv2-ink',    inkHex);
  if (accentHex) setRow('--pv2-accent', accentHex);
}
document.getElementById('presets').addEventListener('click', function(e){
  var el = e.target.closest('.pv2-preset'); if (!el) return;
  if (el.classList.contains('custom')) return; /* color input handles itself */
  var p = PRESETS[parseInt(el.getAttribute('data-i'))];
  applyBrandPalette(p.brand, p.ink, p.accent);
});
/* Custom color picker — live-updates as the user drags; no preset ink/accent override */
document.getElementById('presetPick').addEventListener('input', function(){
  applyBrandPalette(this.value);
});

/* ── Preview viewport mode switcher (Desktop / Tablet / Mobile) ── */
(function(){
  var $vp = document.getElementById('prevViewport');
  var tabs = document.querySelectorAll('#prevTabs .pv2-prev-tab');
  function setMode(m){
    $vp.setAttribute('data-mode', m);
    tabs.forEach(function(t){ t.classList.toggle('on', t.getAttribute('data-mode') === m); });
  }
  tabs.forEach(function(t){ t.addEventListener('click', function(){ setMode(t.getAttribute('data-mode')); }); });
  /* Auto-pick mode based on current browser window width */
  function autoMode(){
    var w = window.innerWidth;
    if (w <= 640) setMode('mobile');
    else if (w <= 1024) setMode('tablet');
    else setMode('desktop');
  }
  autoMode();
  window.addEventListener('resize', autoMode);
})();
function setRow(name,val){
  setVar(name,val);
  var row = document.querySelector('[data-var="'+name+'"]');
  if(row){ row.querySelector('.pick').value = val.slice(0,7); row.querySelector('.hex').value = val; }
}

function collectTheme(){
  var map = {};
  document.querySelectorAll('.pv2-row').forEach(function(r){
    var name = r.getAttribute('data-var');
    var val  = r.querySelector('.hex').value.trim();
    if(val && val !== DEFAULTS[name]) map[name] = val;
  });
  return map;
}

function saveTheme(){
  var $btn = $('#btnSaveTheme');
  var map = collectTheme();
  $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Saving…');
  $.ajax({
    url: '/sales/theme', method: 'PUT',
    contentType: 'application/json', data: JSON.stringify({ theme: map }),
    success: function(r){
      $btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> Save & apply');
      if(r && r.status === 200){
        window.__pv2SavedTheme = (r.data && r.data.theme) || map;
        try { localStorage.setItem('pv2Theme', JSON.stringify(window.__pv2SavedTheme)); } catch(_){}
        toastr.success('Theme saved for your organization.');
        var hint = document.getElementById('saveHint');
        hint.textContent = 'Saved. POS tabs will update instantly.';
        hint.style.color = 'var(--pv2-success)';
        setTimeout(function(){ hint.textContent = 'Click Save to store this theme for your organization.'; hint.style.color=''; }, 2800);
      } else {
        toastr.error((r && r.message) || 'Save failed.');
      }
    },
    error: function(xhr){
      $btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> Save & apply');
      var msg = (xhr.responseJSON && xhr.responseJSON.message) || 'Save failed.';
      toastr.error(msg);
    }
  });
}

function resetTheme(){
  if(!confirm('Reset the POS theme to the ScrapMS default for the whole organization?')) return;
  var $btn = $('#btnSaveTheme');
  $btn.prop('disabled', true);
  $.ajax({
    url: '/sales/theme', method: 'PUT',
    contentType: 'application/json', data: JSON.stringify({ theme: {} }),
    success: function(r){
      $btn.prop('disabled', false);
      window.__pv2SavedTheme = {};
      try { localStorage.setItem('pv2Theme', '{}'); } catch(_){}
      Object.keys(DEFAULTS).forEach(function(k){ setVar(k, DEFAULTS[k]); setRow(k, DEFAULTS[k]); });
      toastr.success('Theme reset to default.');
    },
    error: function(){ $btn.prop('disabled', false); toastr.error('Reset failed.'); }
  });
}
window.saveTheme = saveTheme; window.resetTheme = resetTheme;

/* Static reference content */
var swatches = [
  ['Brand','var(--pv2-brand)','#0054a6'],['Brand dark','var(--pv2-brand-dark)','#003d7a'],['Brand light','var(--pv2-brand-light)','#e6f0fa'],['Brand ghost','var(--pv2-brand-ghost)','#f4f8fc'],
  ['Ink','var(--pv2-ink)','#0b1220'],['Accent','var(--pv2-accent)','#14b8a6'],
  ['Success','var(--pv2-success)','#0d9f6e'],['Warning','var(--pv2-warning)','#d97706'],['Danger','var(--pv2-danger)','#dc2626'],['Purple','var(--pv2-purple)','#8b5cf6'],
  ['Muted','var(--pv2-muted)','#5b6578'],['Border','var(--pv2-border)','#e8ecf1']
];
document.getElementById('swatches').innerHTML = swatches.map(function(s){
  return '<div class="pv2-swatch"><div class="pv2-swatch-chip" style="background:'+s[1]+';"></div><div class="pv2-swatch-meta"><div class="pv2-swatch-name">'+s[0]+'</div><div class="pv2-swatch-hex">'+s[2]+'</div></div></div>';
}).join('');
var types = [
  ['Display',40,800,'Charge € 527'],
  ['H1',26,800,'POS'],
  ['H2',19,700,'Section heading'],
  ['H3',15,700,'Card title'],
  ['Body',14,400,'Description line for cart items.'],
  ['Small',12,500,'Helper text · timestamps · meta'],
  ['Mono',13,600,'ORD-3321 · € 527 · P-8821', true]
];
document.getElementById('typePanel').innerHTML = types.map(function(t){
  var mono = t[4] ? 'font-family:var(--pv2-font-mono);' : '';
  return '<div style="display:flex;align-items:baseline;gap:16px;padding:10px 0;border-bottom:1px solid var(--pv2-border);">'
    + '<div style="width:90px;font-size:11.5px;color:var(--pv2-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.4px;">'+t[0]+'</div>'
    + '<div style="width:90px;font-size:11.5px;color:var(--pv2-muted);font-family:var(--pv2-font-mono);">'+t[1]+'/'+t[2]+'</div>'
    + '<div style="flex:1;font-size:'+t[1]+'px;font-weight:'+t[2]+';color:var(--pv2-text);letter-spacing:'+(t[1]>20?'-0.5px':'0')+';'+mono+'">'+t[3]+'</div>'
    + '</div>';
}).join('');
</script>
</body>
</html>
