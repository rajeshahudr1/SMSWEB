            <button class="co-pay-btn"><i class="bi bi-credit-card-2-front"></i><span>Card</span></button>
            <button class="co-pay-btn"><i class="bi bi-bank"></i><span>Bank</span></button>
            <button class="co-pay-btn"><i class="bi bi-phone"></i><span>UPI</span></button>
