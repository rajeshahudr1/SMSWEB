<script src="/libs/js/jquery.min.js"></script>
<script src="/libs/js/toastr.min.js"></script>
<script src="/libs/js/select2.min.js"></script>
<!-- Razorpay checkout (only loads if online gateway is configured) -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<!-- Stripe JS -->
<script src="https://js.stripe.com/v3/"></script>
<script>
/* Shared globals for POS + SPA-loaded sub-pages (orders / customers / returns / settings).
   These are normally defined in pos-layout.ejs, but index.ejs doesn't use that layout,
   so we replicate them here to keep SPA pages working without a layout. */
var BASE_URL='';
var SMS_USER = <%- JSON.stringify(typeof user!=='undefined'?user:{name:'User',role:'Operator'}) %>;
/* Permission map for JS-rendered buttons (wallet cards, drafts table,
   payments-pending rows, etc.). Built server-side in auth middleware as
   res.locals.POS_CAN_JSON so this output expression stays trivial. */
window.SMS_CAN = <%- POS_CAN_JSON %>;
window.posCan = function(perm){ return !!window.SMS_CAN[perm]; };
var SMS_CURRENCY = (typeof SMS_CURRENCY !== 'undefined') ? SMS_CURRENCY : '<%- (typeof settings!=='undefined' && settings && settings.currency_symbol) ? settings.currency_symbol : '₹' %>';
var SMS_ORG_NAME = '<%- (typeof settings!=='undefined' && settings && (settings.organization_name || settings.company_name)) ? (settings.organization_name || settings.company_name) : "Scrap Management" %>';
toastr.options={closeButton:true,progressBar:true,positionClass:'toast-top-right',timeOut:2000};
if (typeof window.H === 'undefined') window.H = {
  esc: function(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); },
  currency: function(v){ return parseFloat(v||0).toFixed(2); }
};
if (typeof window.smsFormatDateTime !== 'function') window.smsFormatDateTime = function(d){
  if (!d) return '—';
  var dt = new Date(d);
  if (isNaN(dt.getTime())) return '—';
  return dt.toLocaleDateString() + ' ' + dt.toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
};
if (typeof window.smsFormatDate !== 'function') window.smsFormatDate = function(d){
  if (!d) return '—';
  var dt = new Date(d);
  return isNaN(dt.getTime()) ? '—' : dt.toLocaleDateString();
};
if (typeof window.smsInitPerPage !== 'function') window.smsInitPerPage = function(sel){
  var v = localStorage.getItem('pp') || 15;
  $(sel).val(v);
  return parseInt(v) || 15;
};
if (typeof window.smsConfirm !== 'function') window.smsConfirm = function(o){ if (confirm((o && o.msg) || 'Are you sure?')) (o && o.onConfirm && o.onConfirm()); };
if (typeof window.smsToast !== 'function') window.smsToast = function(m, t){ if (t==='success') toastr.success(m); else if (t==='error') toastr.error(m); else toastr.info(m); };
if (typeof window.showLoading !== 'function') window.showLoading = function(){ $('body').append('<div id="posLoading" style="position:fixed;inset:0;z-index:99999;background:rgba(255,255,255,.6);display:flex;align-items:center;justify-content:center;"><div class="spinner-border text-primary"></div></div>'); };
if (typeof window.hideLoading !== 'function') window.hideLoading = function(){ $('#posLoading').remove(); };
</script>
<script src="/js/pages/pos.js?v=<%= Date.now() %>"></script>
<script>
/* ═══ Cart "Print preview" button (BEFORE checkout) ═══
   Renders the current cart as a printable A4/thermal-friendly HTML document
   in a new window and triggers window.print(). Works without saving the order
   or touching any backend — it's a pure "show me what it would look like"
   preview for the cashier/customer BEFORE accepting payment.                    */
(function(){
  function esc(s){ return String(s==null?'':s).replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
  function fmtMoney(n){ try { return (typeof F === 'function' ? F(n) : (parseFloat(n)||0).toFixed(2)); } catch(_){ return (parseFloat(n)||0).toFixed(2); } }

  /* Keep the Print button's disabled state in sync with Pay */
  function syncPrintBtn(){
    var disabled = $('#payBtn').prop('disabled');
    $('#cartPrintBtn').prop('disabled', disabled);
  }
  /* Observe pay button for attribute changes (pos.js toggles `disabled`) */
  var pb = document.getElementById('payBtn');
  if (pb){ new MutationObserver(syncPrintBtn).observe(pb, { attributes:true, attributeFilter:['disabled'] }); setTimeout(syncPrintBtn, 200); }

  window.cartPrintPreview = function(){
    var cart = window._cart || [];
    if (!cart.length){ if (window.toastr) toastr.warning('Cart is empty'); return; }

    /* Aggregate by SKU for a cleaner receipt */
    var groups = {};
    cart.forEach(function(c){
      var k = (c.item_type||'part') + '_' + c.id;
      if (!groups[k]) groups[k] = { name: c.item_name, code: c.item_code, qty: 0, unit: parseFloat(c.unit_price)||0, total: 0, vat: !!c.vat_included };
      groups[k].qty += 1;
      groups[k].total += (parseFloat(c.total_price)||0);
    });
    var lines = Object.values(groups);
    var subtotal = lines.reduce(function(s,l){ return s + l.total; }, 0);
    var totalTxt = $('#cTotal').text() || fmtMoney(subtotal);

    /* Customer name from the cart header, if picked */
    var custName = $('#custResult').text().trim();
    if (!custName || /walk/i.test(custName)) custName = 'Walk-in customer';

    /* Build a clean printable HTML — works for both A4 and thermal (via @page rules) */
    var rowsH = lines.map(function(l){
      return '<tr>'
        + '<td>'+esc(l.name||'')+(l.code?'<div style="font-size:10px;color:#888;font-family:monospace;">'+esc(l.code)+'</div>':'')+'</td>'
        + '<td style="text-align:center;">'+l.qty+'</td>'
        + '<td style="text-align:right;font-family:monospace;">'+fmtMoney(l.unit)+'</td>'
        + '<td style="text-align:right;font-family:monospace;font-weight:700;">'+fmtMoney(l.total)+'</td>'
        + '</tr>';
    }).join('');

    var html = '<!doctype html><html><head><meta charset="utf-8"/>'
      + '<title>Order preview · '+ new Date().toLocaleString() +'</title>'
      + '<style>'
      + ' @page { size: 80mm auto; margin: 4mm; }'
      + ' @media print { @page { size: 80mm auto; } body { width: 72mm; } }'
      + ' body { font-family: Inter, Arial, sans-serif; color:#111; padding:16px; max-width:720px; margin:0 auto; }'
      + ' h1 { font-size:18px; margin:0 0 4px; letter-spacing:-0.3px; }'
      + ' .meta { font-size:12px; color:#666; margin-bottom:12px; }'
      + ' .watermark { display:inline-block; padding:3px 8px; border:1px dashed #d97706; color:#d97706; font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; border-radius:3px; margin-bottom:10px; }'
      + ' table { width:100%; border-collapse:collapse; font-size:12px; }'
      + ' th { background:#f5f5f5; text-align:left; padding:6px 8px; font-size:10.5px; text-transform:uppercase; letter-spacing:0.4px; color:#666; border-bottom:1px solid #ddd; }'
      + ' td { padding:8px; border-bottom:1px solid #eee; vertical-align:top; }'
      + ' tfoot td { border-top:2px solid #111; font-size:14px; padding-top:10px; }'
      + ' .actions { margin-top:18px; text-align:right; }'
      + ' .actions button { padding:8px 16px; border:1px solid #111; background:#fff; font-weight:600; cursor:pointer; border-radius:4px; }'
      + ' @media print { .actions, .watermark { display:none; } }'
      + '</style></head><body>'
      + '<div class="watermark">Preview · Not yet paid</div>'
      + '<h1>Order preview</h1>'
      + '<div class="meta">' + esc(custName) + ' · ' + new Date().toLocaleString() + '</div>'
      + '<table>'
      + '<thead><tr><th>Item</th><th style="text-align:center;width:48px;">Qty</th><th style="text-align:right;width:80px;">Unit</th><th style="text-align:right;width:90px;">Total</th></tr></thead>'
      + '<tbody>'+rowsH+'</tbody>'
      + '<tfoot><tr><td colspan="3" style="text-align:right;font-weight:700;">TOTAL</td><td style="text-align:right;font-family:monospace;font-weight:800;">'+totalTxt+'</td></tr></tfoot>'
      + '</table>'
      + '<div class="actions"><button onclick="window.print()">🖨 Print</button></div>'
      + '<script>setTimeout(function(){ window.print(); },300);<\/script>'
      + '</body></html>';

    var w = window.open('', '_blank', 'width=720,height=820');
    if (!w){ if (window.toastr) toastr.warning('Enable popups to print'); return; }
    w.document.open(); w.document.write(html); w.document.close();
  };
})();

/* ═══ Checkout-success Print buttons (A4 + 80mm thermal) ═══
   Captures the order uuid from the last /sales/checkout response.
   If a printer is assigned for the target role (via Printer Settings),
   silent-prints through the local agent — no tab, no dialog. Otherwise
   falls back to opening the existing invoice PDF in a new tab. */
(function(){
  var AGENT = 'http://localhost:9998';
  window._lastOrderUuid = '';
  window._posPrinters = null;

  /* Pull saved printer assignments once on load (so the buttons are fast) */
  function loadPrinters(){
    $.ajax({ url:'/sales/printers', method:'GET', timeout:4000 })
      .done(function(r){ if (r && r.status===200 && r.data && r.data.printers) window._posPrinters = r.data.printers; })
      .fail(function(){ window._posPrinters = {}; });
  }
  loadPrinters();

  $(document).ajaxSuccess(function(e, xhr, settings){
    try {
      var url = (settings && settings.url) || '';
      if (url.indexOf('/sales/checkout') === -1) return;
      var r = xhr.responseJSON || JSON.parse(xhr.responseText || '{}');
      if (r && r.data && r.data.uuid) window._lastOrderUuid = r.data.uuid;
    } catch(_){}
  });

  function agentPrint(target, dataStr){
    return $.ajax({ url: AGENT + '/print-to', method:'POST', contentType:'application/json',
      timeout: 8000, data: JSON.stringify({ target: target, data: dataStr }) });
  }

  function fetchInvoiceText(u, variant){
    /* Request the existing invoice endpoint — returns PDF.
       For raw-printing we need ESC/POS or ZPL bytes, which our backend doesn't
       produce directly yet, so when a "windows" printer is assigned we fall back
       to opening the PDF + auto-print via the browser; when the assigned printer
       is USB/network (raw ESC/POS capable), we request the thermal HTML and send
       its text content. This is the pragmatic path without a big backend rewrite. */
    var url = BASE_URL + '/sales/orders/' + u + '/invoice' + (variant==='thermal' ? '/thermal' : '');
    return url;
  }

  function hasPrinter(role){
    var p = (window._posPrinters||{})[role];
    return !!(p && p.kind);
  }

  window.successPrintA4 = function(){
    var u = window._lastOrderUuid;
    if (!u){ if (window.toastr) toastr.warning('Order not available yet.'); return; }
    var printer = (window._posPrinters||{}).invoice_a4;
    var url = fetchInvoiceText(u, 'a4');
    if (printer && printer.kind){
      /* Auto-print via hidden iframe that triggers window.print() with default printer context.
         For multi-A4-printer setups, the user selects the printer in the browser once. */
      var f = document.createElement('iframe');
      f.style.cssText = 'position:fixed;right:0;bottom:0;width:0;height:0;border:0;';
      f.src = url;
      f.onload = function(){ try { f.contentWindow.focus(); f.contentWindow.print(); } catch(_){} };
      document.body.appendChild(f);
      if (window.toastr) toastr.info('Sent to ' + (printer.name || 'A4 printer'));
    } else {
      window.open(url, '_blank');
    }
  };

  window.successPrintThermal = function(){
    var u = window._lastOrderUuid;
    if (!u){ if (window.toastr) toastr.warning('Order not available yet.'); return; }
    var printer = (window._posPrinters||{}).receipt;
    var url = fetchInvoiceText(u, 'thermal');
    if (printer && (printer.kind === 'usb' || printer.kind === 'network')){
      /* Try silent print via the agent using the thermal PDF URL.
         Simpler approach: open the thermal PDF in a hidden iframe and auto-print. */
      var f = document.createElement('iframe');
      f.style.cssText = 'position:fixed;right:0;bottom:0;width:0;height:0;border:0;';
      f.src = url;
      f.onload = function(){ try { f.contentWindow.focus(); f.contentWindow.print(); } catch(_){} };
      document.body.appendChild(f);
      if (window.toastr) toastr.info('Sent to ' + (printer.name || 'receipt printer'));
    } else if (printer && printer.kind === 'windows'){
      var f2 = document.createElement('iframe');
      f2.style.cssText = 'position:fixed;right:0;bottom:0;width:0;height:0;border:0;';
      f2.src = url;
      f2.onload = function(){ try { f2.contentWindow.focus(); f2.contentWindow.print(); } catch(_){} };
      document.body.appendChild(f2);
      if (window.toastr) toastr.info('Sent to ' + (printer.name || 'Windows printer'));
    } else {
      window.open(url, '_blank');
    }
  };
})();
</script>

<script>
/* ═══ POS Autocomplete — searchable, POS-themed dropdowns ═══
   Enhances native <select> elements into type-to-filter dropdowns that match
   the POS aesthetic. Keeps the underlying <select> intact (hidden) so existing
   form submissions and change-event listeners in pos.js continue to fire. */
(function(){
  if (window.__posAcInit) return; window.__posAcInit = true;
  var _esc = function(s){ return String(s==null?'':s).replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); };
  var openAc = null;

  function close(ac){ if (!ac) return; ac.$wrap.removeClass('open'); ac.$drop.removeClass('open'); if (openAc === ac) openAc = null; }
  /* Grace window — ignore scroll/resize close requests for the first 600ms
     after open. On mobile, focusing the search input opens the soft keyboard
     which fires a viewport `resize` and would otherwise immediately close
     the dropdown the user just tapped. */
  function closeAnyExternal(){
    if (!openAc) return;
    if (openAc._openedAt && (Date.now() - openAc._openedAt) < 600) return;
    close(openAc);
  }
  function closeAny(){ if (openAc) close(openAc); }

  function open(ac){
    closeAny();
    ac._openedAt = Date.now();
    var rect = ac.$wrap[0].getBoundingClientRect();
    /* Position drop-down absolutely below the trigger, accounting for edges */
    var dropTop = rect.bottom + 4;
    var dropLeft = rect.left;
    var dropWidth = Math.max(rect.width, 200);
    /* If the drop would go off the bottom, flip above */
    var vh = window.innerHeight;
    var needH = Math.min(260, Math.max(120, ac.options.length * 32 + 44));
    if (dropTop + needH > vh - 12){
      dropTop = rect.top - needH - 4;
    }
    /* Clamp left inside viewport */
    var vw = window.innerWidth;
    if (dropLeft + dropWidth > vw - 8) dropLeft = vw - dropWidth - 8;
    if (dropLeft < 8) dropLeft = 8;
    ac.$drop.css({ position:'fixed', top:dropTop+'px', left:dropLeft+'px', width:dropWidth+'px' }).addClass('open');
    ac.$wrap.addClass('open');
    /* Refresh the option list, but only auto-focus the search box on desktop —
       on touch devices the focus instantly opens the soft keyboard which is
       jarring when the list is short. */
    ac.$search.val('').trigger('input');
    var isTouch = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0) || window.matchMedia('(max-width: 767px)').matches;
    if (!isTouch) ac.$search.focus();
    openAc = ac;
  }

  function render(ac, term){
    term = (term||'').toLowerCase().trim();
    var html = '';
    var current = ac.$select.val();
    var hlIdx = -1, visibleIdx = 0;
    /* Cap visible results so the dropdown stays short and predictable.
       When the user is searching (term present) → show only top 2 matches.
       When idle (no term) → show all so they can scroll the full list. */
    var MAX_WHEN_SEARCHING = 2;
    var totalMatches = 0;
    ac.options.forEach(function(o){
      var label = String(o.label||'');
      if (term && label.toLowerCase().indexOf(term) < 0) return;
      totalMatches++;
      if (term && visibleIdx >= MAX_WHEN_SEARCHING) return;
      var sel = String(o.value) === String(current);
      html += '<div class="ps-sel-opt'+(sel?' selected':'')+'" data-val="'+_esc(o.value)+'">'+_esc(label)+'</div>';
      if (sel && hlIdx < 0) hlIdx = visibleIdx;
      visibleIdx++;
    });
    if (term && totalMatches > MAX_WHEN_SEARCHING){
      html += '<div class="ps-sel-more">+' + (totalMatches - MAX_WHEN_SEARCHING) + ' more — refine your search</div>';
    }
    if (!html) html = '<div class="ps-sel-empty">No matches</div>';
    ac.$list.html(html);
    /* Highlight the selected (or first) option for keyboard nav */
    var $opts = ac.$list.children('.ps-sel-opt');
    $opts.removeClass('hl');
    if ($opts.length){
      var i = hlIdx >= 0 ? hlIdx : 0;
      $opts.eq(i).addClass('hl');
    }
  }

  function pick(ac, $opt){
    if (!$opt || !$opt.length) return;
    var val = $opt.attr('data-val');
    var label = $opt.text();
    ac.$select.val(val).trigger('change');
    ac.$trigger.text(label).removeClass('is-placeholder');
    close(ac);
  }

  window.posAutocomplete = function(selector){
    $(selector).each(function(){
      var $sel = $(this);
      if ($sel.data('posAc')) return;
      if (!this.id) this.id = 'pac-'+Math.random().toString(36).slice(2,8);

      /* Gather options */
      var options = [];
      $sel.find('option').each(function(){
        options.push({ value: this.value, label: this.textContent || this.value });
      });
      var currentVal = $sel.val();
      var currentLabel = (options.filter(function(o){ return String(o.value) === String(currentVal); })[0]||{}).label || '';
      var placeholder = $sel.attr('data-placeholder') || (options[0] && options[0].value === '' ? options[0].label : '');

      /* Build wrapper */
      var $wrap = $('<div class="ps-sel"></div>');
      /* Tag the wrapper with the select's id (as data + class) so CSS / JS can
         target a specific dropdown by name (e.g. ps-sel-fWarehouse). */
      if (this.id) {
        $wrap.attr('data-for', this.id).addClass('ps-sel-' + this.id);
      }
      var width = $sel[0].style.width || (($sel.attr('style')||'').match(/width:\s*([^;]+)/)||[])[1] || '';
      if (width) $wrap.css('width', width);
      /* Copy tooltip attrs so existing data-tip tooltips still work */
      ['data-tip','data-tip-pos','data-tip-color'].forEach(function(a){
        if ($sel.attr(a)) $wrap.attr(a, $sel.attr(a));
      });
      var $trigger = $('<div class="ps-sel-input" tabindex="0"></div>')
        .text(currentLabel || placeholder || 'Select…');
      if (!currentLabel && placeholder) $trigger.addClass('is-placeholder');
      var $arrow = $('<i class="bi bi-chevron-down ps-sel-arrow"></i>');
      var $drop = $('<div class="ps-sel-drop"></div>');
      var $search = $('<input type="text" class="ps-sel-search" placeholder="Search…" />');
      var $list = $('<div class="ps-sel-list"></div>');
      $drop.append($search, $list);

      $wrap.append($trigger, $arrow, $drop);
      $sel.css({ position:'absolute', opacity:0, width:'1px', height:'1px', overflow:'hidden', pointerEvents:'none' }).after($wrap);

      var ac = { $select:$sel, $wrap:$wrap, $trigger:$trigger, $drop:$drop, $search:$search, $list:$list, options:options };
      $sel.data('posAc', ac);

      /* If the source select is marked `data-vk-options`, drop a keyboard
         pill into the wrapper so web users can search options via the on-
         screen VK popup.  Tablet/mobile hide the pill via CSS. */
      if ($sel.is('[data-vk-options]')) {
        var $kbBtn = $('<button type="button" class="ps-kb-trigger" tabindex="-1" data-tip="Search options on the on-screen keyboard" data-tip-pos="left"><i class="bi bi-keyboard"></i></button>');
        $kbBtn.on('mousedown click', function(e){
          e.preventDefault(); e.stopPropagation();
          if (typeof window.openVKForSelect === 'function') {
            window.openVKForSelect($sel.attr('id'));
          }
        });
        $wrap.append($kbBtn).addClass('has-vk-kb');
      }

      /* Events — `click` works on every device. We just guard against the
         synthetic 300ms-delayed click on older iOS by tracking touchend. */
      var _lastTouch = 0;
      var _toggle = function(e){ e.preventDefault(); e.stopPropagation(); if (openAc === ac) close(ac); else open(ac); };
      $trigger.on('touchend', function(e){
        _lastTouch = Date.now();
        if (e.cancelable) e.preventDefault();
        e.stopPropagation();
        if (openAc === ac) close(ac); else open(ac);
      });
      $trigger.on('click', function(e){
        // If touchend already handled this tap, swallow the synthetic click.
        if (Date.now() - _lastTouch < 500) { e.preventDefault(); e.stopPropagation(); return; }
        _toggle(e);
      });
      $trigger.on('keydown', function(e){ if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown'){ e.preventDefault(); open(ac); } });
      $arrow.on('click', function(e){
        if (Date.now() - _lastTouch < 500) { e.preventDefault(); e.stopPropagation(); return; }
        _toggle(e);
      });
      $arrow.on('touchend', function(e){
        _lastTouch = Date.now();
        if (e.cancelable) e.preventDefault();
        e.stopPropagation();
        if (openAc === ac) close(ac); else open(ac);
      });

      $search.on('input', function(){ render(ac, $(this).val()); });
      $search.on('keydown', function(e){
        var $opts = $list.children('.ps-sel-opt');
        var i = $opts.index($opts.filter('.hl'));
        if (e.key === 'ArrowDown'){ e.preventDefault(); $opts.removeClass('hl'); var n = i < $opts.length - 1 ? i + 1 : 0; $opts.eq(n).addClass('hl'); scrollTo(ac, $opts.eq(n)); }
        else if (e.key === 'ArrowUp'){ e.preventDefault(); $opts.removeClass('hl'); var n = i > 0 ? i - 1 : $opts.length - 1; $opts.eq(n).addClass('hl'); scrollTo(ac, $opts.eq(n)); }
        else if (e.key === 'Enter'){ e.preventDefault(); pick(ac, $opts.filter('.hl').first() || $opts.first()); }
        else if (e.key === 'Escape'){ e.preventDefault(); close(ac); $trigger.focus(); }
      });
      $list.on('click', '.ps-sel-opt', function(){ pick(ac, $(this)); });
      $list.on('mouseenter', '.ps-sel-opt', function(){ $list.children('.hl').removeClass('hl'); $(this).addClass('hl'); });

      /* Keep trigger label in sync if pos.js code calls $sel.val(x).trigger('change') */
      $sel.on('change.posAc', function(){
        var v = $sel.val();
        var lbl = (options.filter(function(o){ return String(o.value) === String(v); })[0]||{}).label || '';
        if (!lbl && placeholder){ $trigger.text(placeholder).addClass('is-placeholder'); }
        else { $trigger.text(lbl).removeClass('is-placeholder'); }
      });

      /* Refresh options if pos.js injects warehouse/per-page lists later */
      var mo = new MutationObserver(function(){
        var fresh = [];
        $sel.find('option').each(function(){ fresh.push({ value: this.value, label: this.textContent || this.value }); });
        options = fresh; ac.options = fresh;
        $sel.trigger('change.posAc');
      });
      mo.observe(this, { childList:true, subtree:true, characterData:true });

      function scrollTo(ac, $opt){
        if (!$opt || !$opt.length) return;
        var list = ac.$list[0], el = $opt[0];
        var top = el.offsetTop, bot = top + el.offsetHeight;
        if (top < list.scrollTop) list.scrollTop = top;
        else if (bot > list.scrollTop + list.clientHeight) list.scrollTop = bot - list.clientHeight;
      }
    });
  };

  /* Global close handlers */
  $(document).on('click', function(e){
    if (!openAc) return;
    if ($(e.target).closest(openAc.$wrap).length || $(e.target).closest(openAc.$drop).length) return;
    close(openAc);
  });
  window.addEventListener('scroll', closeAnyExternal, true);
  window.addEventListener('resize', closeAnyExternal);
  $(document).on('keydown', function(e){ if (e.key === 'Escape') closeAny(); });

  /* Enhance every native <select> on POS pages with the same premium
     posAutocomplete look as the Warehouse dropdown — except ones owned by
     other widgets (select2-hidden-accessible) or explicitly opted out. */
  function enhance(){
    posAutocomplete(
      'body.pos-mode select:not(.select2-hidden-accessible):not(.no-pos-ac):not([data-no-pos-ac])'
    );
  }
  setTimeout(enhance, 350);
  $(document).on('spa:ready', enhance);
  /* Also re-run when SPA partials swap into view. */
  if (typeof MutationObserver === 'function'){
    new MutationObserver(function(){
      clearTimeout(window._posAcDeb);
      window._posAcDeb = setTimeout(enhance, 200);
    }).observe(document.body, { childList:true, subtree:true });
  }
})();
</script>

<script>
/* ═══ Part-detail popup — 7-tab redesign (Figma PartDetailTabs.jsx) ═══
   Overrides pos.js's showFullInfo with a new builder that renders the new
   tabbed layout (Overview / Fitment / Specs / Stock / Donor / History / Photos).
   Reuses the same /sales/part-detail endpoint and existing #infoPage DOM.      */
(function(){
  if (typeof window.showFullInfo !== 'function') return;
  var _escHtml = function(s){ return String(s==null?'':s).replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); };
  var _fmt = function(n){ try { return (typeof F === 'function' ? F(n) : (parseFloat(n)||0).toFixed(2)); } catch(_){ return (parseFloat(n)||0).toFixed(2); } };
  var _fdt = function(d){ try { return (typeof smsFormatDateTime === 'function' ? smsFormatDateTime(d) : d); } catch(_){ return d; } };
  var REF_TYPE_LOCAL = (typeof REF_TYPE !== 'undefined') ? REF_TYPE : {};

  function _emptyPane(icon, ttl, sub){
    return '<div class="pdt-empty"><i class="bi '+icon+'"></i><div class="ttl">'+_escHtml(ttl)+'</div>'+(sub?'<div class="sub">'+_escHtml(sub)+'</div>':'')+'</div>';
  }

  window.showFullInfo = function(){
    if (!window._selPart){ if (window.toastr) toastr.warning('Select a part first.'); return; }
    var sp = window._selPart;
    if (!sp._full){
      if (window.toastr) toastr.info('Loading...');
      $.get(BASE_URL+'/sales/part-detail/'+sp.uuid, function(r){
        if (r && r.status===200 && r.data){ sp._full = r.data; window.showFullInfo(); }
        else if (window.toastr) toastr.error('Failed.');
      });
      return;
    }
    var pi = sp._full;
    var refs = pi.references||[], dmgs = pi.damages||[], attrs = pi.attribute_values||[];
    var imgs = pi.images||[], vids = pi.videos||[], locs = pi.locations||[];

    var sq       = parseInt(pi.quantity)||0;
    var price    = parseFloat(pi.price_1 || pi.price_2 || 0)||0;
    var priceCmp = (pi.price_2 && pi.price_1 && parseFloat(pi.price_2) > parseFloat(pi.price_1)) ? parseFloat(pi.price_2) : 0;
    var discount = (priceCmp && priceCmp > price) ? Math.round(((priceCmp - price) / priceCmp) * 100) : 0;
    var cost     = parseFloat(pi.part_cost_price||0)||0;
    var margin   = (cost && price > 0) ? Math.round(((price - cost) / price) * 100) : 0;
    var name     = pi.part_catalog_name || pi.part_code || 'Part';
    var code     = pi.part_code || '';
    var heroImg  = imgs.length ? (imgs[0].display_url || imgs[0].image_url || '') : '';

    /* ── Header: breadcrumb + SKU/chips/title + price (view-only, no Edit/Add-to-cart) ── */
    var crumbs = ['POS', 'Parts'];
    if (pi.part_catalog_name) crumbs.push(pi.part_catalog_name);
    var crumbsH = crumbs.map(function(c, i){
      return '<span'+(i === crumbs.length ? ' style="color:var(--pv2-text);font-weight:600;"' : '')+'>'+_escHtml(c)+'</span>';
    }).join('<span class="pdt-crumb-sep">·</span>');
    if (code) crumbsH += '<span class="pdt-crumb-sep">·</span><span style="color:var(--pv2-text);font-weight:600;font-family:var(--pv2-font-mono);">'+_escHtml(code)+'</span>';
    $('#infoCrumbs').html(crumbsH);

    /* Chips: SKU (mono) + condition + stock + discount */
    var chipsH = '';
    if (code) chipsH += '<span class="pdt-sku-chip">'+_escHtml(code)+'</span>';
    if (pi.condition_name || pi.condition) chipsH += '<span class="pdt-chip tone-brand">'+_escHtml(pi.condition_name || pi.condition)+'</span>';
    if (sq > 0) chipsH += '<span class="pdt-chip tone-'+(sq > 2 ? 'success' : 'warning')+'">'+sq+' in stock</span>';
    else chipsH += '<span class="pdt-chip tone-danger">Out of stock</span>';
    if (discount > 0) chipsH += '<span class="pdt-chip tone-warning">−'+discount+'%</span>';
    if (pi.part_state_name) chipsH += '<span class="pdt-chip tone-neutral">'+_escHtml(pi.part_state_name)+'</span>';
    $('#infoChips').html(chipsH);

    $('#infoTitle').text(name);

    /* Price block on the right */
    var priceH = '<div class="pdt-price-big">'+_fmt(price)+'</div>';
    var priceSub = [];
    if (pi.vat_included) priceSub.push('Tax incl.');
    if (priceCmp && priceCmp > price) priceSub.push('was '+_fmt(priceCmp));
    if (!priceSub.length) priceSub.push('Per unit');
    priceH += '<div class="pdt-price-sub">'+_escHtml(priceSub.join(' · '))+'</div>';
    $('#infoHeadPrice').html(priceH);

    /* ── Tabs — ORIGINAL labels (Details / References / Damages / Attributes / Locations / Media / Sub Parts) ── */
    var subs = pi.sub_parts || [];
    var mediaCnt = imgs.length + vids.length;
    var tabs = [
      { id:'ipInfo',   label:'Details',    icon:'bi-box-seam' },
      { id:'ipRefs',   label:'References', icon:'bi-link-45deg',           cnt: refs.length },
      { id:'ipDmgs',   label:'Damages',    icon:'bi-exclamation-triangle', cnt: dmgs.length },
      { id:'ipAttrs',  label:'Attributes', icon:'bi-list-check',           cnt: attrs.length },
      { id:'ipLocs',   label:'Locations',  icon:'bi-geo-alt',              cnt: locs.length },
      { id:'ipMedia',  label:'Media',      icon:'bi-images',               cnt: mediaCnt },
    ];
    if (subs.length) tabs.push({ id:'ipSubs', label:'Sub Parts', icon:'bi-diagram-3', cnt: subs.length });
    var tabH = tabs.map(function(t, i){
      return '<button class="ip-tab'+(i===0?' active':'')+'" onclick="ipTabClick(this)" data-t="'+t.id+'">'
        + '<i class="bi '+t.icon+'"></i> '+_escHtml(t.label)
        + (t.cnt ? ' <span class="ip-cnt">'+t.cnt+'</span>' : '')
        + '</button>';
    }).join('');
    $('#infoTabs').html(tabH);

    /* Helpers for original grouped-card layout */
    function _S(t, ic, items){ return '<div class="is"><div class="is-hdr"><i class="bi '+ic+'"></i>'+_escHtml(t)+'</div><div class="is-body">'+items+'</div></div>'; }
    function _r(l, v){
      var blank = (v == null || v === '');
      var val = blank ? '—' : String(v);
      return '<div class="is-item"><span class="is-lbl">'+_escHtml(l)+'</span><span class="is-val" style="'+(blank?'color:var(--pv2-muted);font-weight:400;font-size:12px;':'')+'">'+_escHtml(val)+'</span></div>';
    }
    var REF_TYPE_MAP = (typeof REF_TYPE !== 'undefined') ? REF_TYPE : {};
    var DMG_TYPE_MAP = (typeof DMG_TYPE !== 'undefined') ? DMG_TYPE : {};
    var DMG_LOC_MAP  = (typeof DMG_LOC  !== 'undefined') ? DMG_LOC  : {};
    function _stars(n){
      var v = parseFloat(n)||0, out = '';
      for (var i=1;i<=5;i++){
        var c = i<=v ? 'color:#eab308' : 'color:#d1d5db';
        out += '<i class="bi bi-star'+(i<=v?'-fill':'')+'" style="'+c+';font-size:13px;"></i>';
      }
      return out;
    }

    /* ═══ Build panes (original structure) ═══ */
    var h = '';

    /* Details */
    h += '<div class="ip-pane active" id="ipInfo">';
    h +=   _S('Catalog & Pricing', 'bi-book',
                _r('Catalog',      pi.part_catalog_name)
              + _r('Code',         pi.part_code)
              + _r('Internal ID',  pi.part_internal_id)
              + _r('Quantity',     pi.quantity)
              + _r('Price 1',      pi.price_1 ? _fmt(pi.price_1) : null)
              + _r('Price 2',      pi.price_2 ? _fmt(pi.price_2) : null)
              + _r('Cost Price',   pi.part_cost_price ? _fmt(pi.part_cost_price) : null)
              + _r('Brand',        pi.part_brand_name)
              + _r('Condition',    pi.condition_name || pi.condition)
              + _r('State',        pi.part_state_name || pi.part_state)
              + _r('Tax',          pi.vat_included ? 'Yes' : 'No'));
    h +=   _S('Vehicle', 'bi-truck',
                _r('Type',         pi.vehicle_type_name)
              + _r('Year',         pi.vehicle_year_name)
              + _r('Make',         pi.vehicle_make_name)
              + _r('Model',        pi.vehicle_model_name)
              + _r('Variant',      pi.vehicle_variant_name)
              + _r('Engine',       pi.vehicle_engine_name)
              + _r('Fuel',         pi.vehicle_fuel_name)
              + _r('Motorization', pi.motorization)
              + _r('CC',           pi.cc)
              + _r('CV',           pi.cv)
              + _r('KW',           pi.kw));
    var dimItems =
            _r('Weight',      pi.weight_kg ? pi.weight_kg+' kg' : null)
          + _r('Width',       pi.width_cm  ? pi.width_cm+' cm'  : null)
          + _r('Height',      pi.height_cm ? pi.height_cm+' cm' : null)
          + _r('Length',      pi.length_cm ? pi.length_cm+' cm' : null)
          + _r('Custom Size', pi.custom_size ? 'Yes' : 'No')
          + _r('Print Label', pi.print_label ? 'Yes' : 'No');
    if (pi.rating) dimItems += '<div class="is-item"><span class="is-lbl">Rating</span><span class="is-val">'+_stars(pi.rating)+' <span style="font-size:11px;color:var(--pv2-muted);margin-left:4px;">'+pi.rating+'/5</span></span></div>';
    h +=   _S('Dimensions & Options', 'bi-rulers', dimItems);
    if (pi.notes || pi.extra_notes || pi.internal_notes){
      var noteH = '';
      if (pi.notes)          noteH += '<div class="is-item" style="grid-column:1/-1;"><span class="is-lbl">Notes</span><span class="is-val" style="text-align:left;font-size:13px;font-weight:500;line-height:1.5;">'+_escHtml(pi.notes)+'</span></div>';
      if (pi.extra_notes)    noteH += '<div class="is-item" style="grid-column:1/-1;"><span class="is-lbl">Extra Notes</span><span class="is-val" style="text-align:left;font-size:13px;font-weight:500;line-height:1.5;">'+_escHtml(pi.extra_notes)+'</span></div>';
      if (pi.internal_notes) noteH += '<div class="is-item" style="grid-column:1/-1;"><span class="is-lbl">Internal Notes</span><span class="is-val" style="text-align:left;font-size:13px;font-weight:500;line-height:1.5;">'+_escHtml(pi.internal_notes)+'</span></div>';
      h += _S('Notes', 'bi-journal-text', noteH);
    }
    h += '</div>';

    /* References */
    h += '<div class="ip-pane" id="ipRefs">';
    if (refs.length){
      h += '<div class="is"><div class="is-hdr"><i class="bi bi-link-45deg"></i>References</div><div class="is-tbl-wrap"><table class="is-tbl is-tbl-resp"><thead><tr><th>#</th><th>Code</th><th>Type</th><th>Brand</th><th>Manufacturer</th><th>Condition</th></tr></thead><tbody>';
      refs.forEach(function(r, i){
        h += '<tr>'
          + '<td data-label="#">'+(i+1)+'</td>'
          + '<td data-label="Code" style="font-weight:600;">'+_escHtml(r.reference_code||'—')+'</td>'
          + '<td data-label="Type">'+_escHtml(REF_TYPE_MAP[r.reference_type]||r.reference_type||'—')+'</td>'
          + '<td data-label="Brand">'+_escHtml(r.brand||'—')+'</td>'
          + '<td data-label="Manufacturer">'+_escHtml(r.manufacturer||'—')+'</td>'
          + '<td data-label="Condition">'+_escHtml((typeof REF_COND!=='undefined' && REF_COND[r.condition]) || r.condition || '—')+'</td>'
          + '</tr>';
      });
      h += '</tbody></table></div></div>';
    } else {
      h += _emptyPane('bi-link-45deg', 'No references', null);
    }
    h += '</div>';

    /* Damages */
    h += '<div class="ip-pane" id="ipDmgs">';
    if (dmgs.length){
      h += '<div class="is"><div class="is-hdr"><i class="bi bi-exclamation-triangle"></i>Damages</div><div class="is-tbl-wrap"><table class="is-tbl is-tbl-resp"><thead><tr><th>#</th><th>Description</th><th>Type</th><th>Location</th><th>Rating</th></tr></thead><tbody>';
      dmgs.forEach(function(d, i){
        h += '<tr>'
          + '<td data-label="#">'+(i+1)+'</td>'
          + '<td data-label="Description">'+_escHtml(d.damage_description||'—')+'</td>'
          + '<td data-label="Type">'+_escHtml(DMG_TYPE_MAP[d.damage_type]||'—')+'</td>'
          + '<td data-label="Location">'+_escHtml(DMG_LOC_MAP[d.damage_location]||'—')+'</td>'
          + '<td data-label="Rating">'+(d.damage_rating?_stars(d.damage_rating):'—')+'</td>'
          + '</tr>';
      });
      h += '</tbody></table></div></div>';
    } else {
      h += _emptyPane('bi-exclamation-triangle', 'No damages', null);
    }
    h += '</div>';

    /* Attributes */
    h += '<div class="ip-pane" id="ipAttrs">';
    if (attrs.length){
      h += _S('Attributes', 'bi-list-check', attrs.map(function(a){ return _r(a.label_name || ('Attr #'+a.attribute_id), a.value); }).join(''));
    } else {
      h += _emptyPane('bi-list-check', 'No attributes', null);
    }
    h += '</div>';

    /* Locations */
    h += '<div class="ip-pane" id="ipLocs">';
    if (locs.length){
      h += '<div class="is"><div class="is-hdr"><i class="bi bi-geo-alt"></i>Locations</div><div class="is-tbl-wrap"><table class="is-tbl is-tbl-resp"><thead><tr><th>Unit</th><th>Warehouse</th><th>Zone</th><th>Shelf</th><th>Rack</th><th>Bin</th><th>Code</th><th>Notes</th></tr></thead><tbody>';
      locs.forEach(function(l){
        h += '<tr>'
          + '<td data-label="Unit" style="font-weight:700;">#'+(parseInt(l.unit_number)||1)+'</td>'
          + '<td data-label="Warehouse">'+_escHtml(l.warehouse_name||'—')+'</td>'
          + '<td data-label="Zone">'+_escHtml(l.warehouse_zone_name||'—')+'</td>'
          + '<td data-label="Shelf">'+_escHtml(l.warehouse_shelf_name||'—')+'</td>'
          + '<td data-label="Rack">'+_escHtml(l.warehouse_rack_name||'—')+'</td>'
          + '<td data-label="Bin">'+_escHtml(l.warehouse_bin_name||'—')+'</td>'
          + '<td data-label="Code">'+_escHtml(l.location_code||'—')+'</td>'
          + '<td data-label="Notes">'+_escHtml(l.notes||'—')+'</td>'
          + '</tr>';
      });
      h += '</tbody></table></div></div>';
    } else {
      h += _emptyPane('bi-geo-alt', 'No locations', null);
    }
    h += '</div>';

    /* Media (Images + Videos) */
    h += '<div class="ip-pane" id="ipMedia">';
    if (imgs.length){
      h += '<div class="is"><div class="is-hdr"><i class="bi bi-images"></i>Images <span class="ip-cnt" style="margin-left:auto;">'+imgs.length+'</span></div><div class="is-media">';
      imgs.forEach(function(img){
        var u = img.display_url || img.image_url || '';
        h += '<div class="is-media-item" onclick="posLightbox(\'image\',\''+_escHtml(u)+'\')"><img src="'+_escHtml(u)+'" alt=""/></div>';
      });
      h += '</div></div>';
    }
    if (vids.length){
      h += '<div class="is"><div class="is-hdr"><i class="bi bi-camera-video"></i>Videos <span class="ip-cnt" style="margin-left:auto;">'+vids.length+'</span></div><div class="is-media" style="grid-template-columns:repeat(auto-fill,minmax(140px,1fr));">';
      vids.forEach(function(v){
        var u = v.display_url || v.video_url || '';
        h += '<div class="is-media-item" style="aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;background:#111;" onclick="posLightbox(\'video\',\''+_escHtml(u)+'\')"><i class="bi bi-play-circle-fill" style="font-size:24px;color:rgba(255,255,255,.8);z-index:1;"></i></div>';
      });
      h += '</div></div>';
    }
    if (!imgs.length && !vids.length) h += _emptyPane('bi-images', 'No media', null);
    h += '</div>';

    /* Sub Parts */
    if (subs.length){
      h += '<div class="ip-pane" id="ipSubs">';
      h += '<div class="is"><div class="is-hdr"><i class="bi bi-diagram-3"></i>Sub Parts</div><div class="is-tbl-wrap"><table class="is-tbl is-tbl-resp"><thead><tr><th>Part</th><th>Code</th><th>Qty</th></tr></thead><tbody>';
      subs.forEach(function(s){
        h += '<tr>'
          + '<td data-label="Part" style="font-weight:600;">'+_escHtml(s.display_name||'—')+'</td>'
          + '<td data-label="Code">'+_escHtml(s.part_code||'—')+'</td>'
          + '<td data-label="Qty">'+(s.quantity||0)+'</td>'
          + '</tr>';
      });
      h += '</tbody></table></div></div>';
      h += '</div>';
    }

    $('#infoBody').html(h);
    $('#infoPage').addClass('open');
  };
})();
</script>
<script>
/* ═══ Active-filter chip strip (adv-search page) ═══
   Re-reads the filter form each time filters change, then renders a chip
   summary at the top of the drawer. Clicking × on a chip clears that field
   and re-applies. Purely additive — hooks the existing form, no logic changes. */
(function(){
  function _clearField(sel){
    var $el = $(sel);
    if ($el.length){
      if ($el.is(':checkbox') || $el.is(':radio')) $el.prop('checked', false);
      else if ($el.is('select')){
        $el.val('');
        try { $el.trigger('change.select2'); } catch(_){}
      } else $el.val('');
      try { $el.trigger('change'); } catch(_){}
    }
  }
  function _label(el){
    var t = $(el).closest('label').text().trim();
    if (t) return t;
    var id = $(el).attr('id') || '';
    return id.replace(/^af/, '').replace(/([A-Z])/g, ' $1').trim();
  }
  window.refreshAdvChips = function(){
    var $chips = $('#advActiveChips');
    var chips = [];
    // Text inputs with values
    $('#advSearchPage input[type=text], #advSearchPage input[type=number], #advSearchPage input[type=date]').each(function(){
      var v = ($(this).val()||'').trim();
      if (v){ chips.push({ sel:'#'+this.id, label:_label(this)+': '+v }); }
    });
    // Select values
    $('#advSearchPage select').each(function(){
      var v = ($(this).val()||'').trim();
      if (v){
        var txt = ($(this).find('option:selected').text()||v).trim();
        chips.push({ sel:'#'+this.id, label:_label(this)+': '+txt });
      }
    });
    // Checkbox toggles (skip deep-search)
    $('#advSearchPage input[type=checkbox]').each(function(){
      if (this.id === 'afDeepSearch') return;
      if (this.checked){ chips.push({ sel:'#'+this.id, label:_label(this) }); }
    });
    // Render
    var $bar = $('#advActiveBar');
    if (!chips.length){ $bar.addClass('empty'); $('#advActiveCount').text(0); $chips.empty(); return; }
    $bar.removeClass('empty');
    $('#advActiveCount').text(chips.length);
    var esc = function(s){ return String(s==null?'':s).replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); };
    $chips.html(chips.map(function(c){
      return '<span class="adv-chip" data-sel="'+esc(c.sel)+'">'+esc(c.label)+'<span class="x" onclick="(function(sel){var fn=window._clearAdvField||function(){};fn(sel);window.refreshAdvChips();})(\''+esc(c.sel)+'\')">×</span></span>';
    }).join(''));
  };
  window._clearAdvField = _clearField;
  /* Refresh chips whenever anything inside advSearchPage changes */
  $(document).on('change input', '#advSearchPage input, #advSearchPage select', function(){
    clearTimeout(window._advChipDebounce);
    window._advChipDebounce = setTimeout(refreshAdvChips, 80);
  });
  /* Toggle body class for desktop backdrop, and refresh chips when opening */
  var advObserver = null;
  function syncAdvBodyClass(){
    if ($('#advSearchPage').hasClass('open')) $(document.body).addClass('adv-search-open');
    else $(document.body).removeClass('adv-search-open');
    if ($('#advSearchPage').hasClass('open')) setTimeout(refreshAdvChips, 60);
  }
  var adv = document.getElementById('advSearchPage');
  if (adv){
    advObserver = new MutationObserver(syncAdvBodyClass);
    advObserver.observe(adv, { attributes:true, attributeFilter:['class'] });
  }
})();

/* ═══ Smart tooltip (data-tip) — themed + auto-positioned ═══
   Moved into /js/pages/pos.js so every page that loads pos.js (POS index +
   every pos-layout sub-page: wallet, payments-pending, orders, drafts,
   customers, settings) shares the same tooltip behaviour. The block below
   is kept as an early-init no-op so existing direct hits to /sales still
   wire tooltips before pos.js finishes parsing — the __pv2TipInit guard
   inside pos.js prevents a second registration. */
(function(){
  if (window.__pv2TipInit) return; window.__pv2TipInit = true;
  var TIP = document.createElement('div');
  TIP.className = 'pv2-tip';
  TIP.setAttribute('role','tooltip');
  document.body.appendChild(TIP);
  var PAD = 8, current = null, showTimer = null, hideTimer = null, animIn = null;

  function setText(el){
    var text = el.getAttribute('data-tip') || '';
    var kbd  = el.getAttribute('data-tip-kbd') || '';
    TIP.innerHTML = ''; TIP.appendChild(document.createTextNode(text));
    if (kbd){
      var k = document.createElement('span'); k.className = 'pv2-tip-kbd'; k.textContent = kbd;
      TIP.appendChild(k);
    }
  }
  function clearTone(){
    TIP.classList.remove('tone-blue','tone-green','tone-red','tone-orange');
  }
  function place(el){
    setText(el);
    clearTone();
    var tone = (el.getAttribute('data-tip-color')||'').toLowerCase();
    if (tone) TIP.classList.add('tone-'+tone);

    /* Show invisibly to measure */
    TIP.classList.add('show'); TIP.classList.remove('in');
    TIP.style.left = '-9999px'; TIP.style.top = '-9999px'; TIP.style.maxWidth = '';

    var er = el.getBoundingClientRect();
    var vw = window.innerWidth, vh = window.innerHeight;
    var maxW = Math.min(260, vw - PAD*2);
    TIP.style.maxWidth = maxW + 'px';
    var tr = TIP.getBoundingClientRect();

    var forced = (el.getAttribute('data-tip-pos')||'').toLowerCase();
    var sideOrder;
    if (forced && forced !== 'auto'){
      sideOrder = [forced, 'bottom','top','right','left'].filter(function(v,i,a){return a.indexOf(v)===i;});
    } else {
      /* Rank sides by available space minus required space; prefer bottom, then top */
      var spaces = {
        bottom: vh - er.bottom - PAD,
        top:    er.top - PAD,
        right:  vw - er.right - PAD,
        left:   er.left - PAD
      };
      var needs = { bottom: tr.height, top: tr.height, right: tr.width, left: tr.width };
      var fits = Object.keys(spaces).filter(function(s){ return spaces[s] >= needs[s]; });
      if (fits.length){
        var pref = ['bottom','top','right','left'];
        fits.sort(function(a,b){ return pref.indexOf(a) - pref.indexOf(b); });
        sideOrder = fits.concat(pref.filter(function(s){ return fits.indexOf(s)<0; }));
      } else {
        /* Nothing fits — pick the one with most room */
        sideOrder = Object.keys(spaces).sort(function(a,b){ return spaces[b]-spaces[a]; });
      }
    }
    var side = sideOrder[0];

    var x, y;
    if (side === 'bottom'){ x = er.left + er.width/2 - tr.width/2; y = er.bottom + PAD; }
    else if (side === 'top'){ x = er.left + er.width/2 - tr.width/2; y = er.top - tr.height - PAD; }
    else if (side === 'right'){ x = er.right + PAD; y = er.top + er.height/2 - tr.height/2; }
    else { x = er.left - tr.width - PAD; y = er.top + er.height/2 - tr.height/2; }

    /* Clamp inside viewport */
    var clampedX = Math.max(PAD, Math.min(vw - tr.width - PAD, x));
    var clampedY = Math.max(PAD, Math.min(vh - tr.height - PAD, y));
    var shiftX = clampedX - x, shiftY = clampedY - y;

    /* Arrow offset — point at center of source element, within tooltip bounds */
    var ax = er.left + er.width/2 - clampedX;
    var ay = er.top + er.height/2 - clampedY;
    ax = Math.max(12, Math.min(tr.width - 12, ax));
    ay = Math.max(12, Math.min(tr.height - 12, ay));

    TIP.setAttribute('data-side', side);
    TIP.style.setProperty('--pv2-tip-ax', ax + 'px');
    TIP.style.setProperty('--pv2-tip-ay', ay + 'px');
    TIP.style.left = clampedX + 'px';
    TIP.style.top  = clampedY + 'px';

    /* Fade in */
    cancelAnimationFrame(animIn);
    animIn = requestAnimationFrame(function(){ TIP.classList.add('in'); });
  }
  function show(el){
    if (!el || !el.getAttribute) return;
    if (!el.getAttribute('data-tip')) return;
    if (current === el) return;
    current = el;
    clearTimeout(hideTimer); clearTimeout(showTimer);
    showTimer = setTimeout(function(){ if (current===el) place(el); }, 60);
  }
  function hide(){
    current = null;
    clearTimeout(showTimer);
    TIP.classList.remove('in');
    clearTimeout(hideTimer);
    hideTimer = setTimeout(function(){ TIP.classList.remove('show'); }, 140);
  }

  function findTipEl(e){
    var n = e.target;
    while (n && n !== document.body){
      if (n.getAttribute && n.getAttribute('data-tip')) return n;
      n = n.parentNode;
    }
    return null;
  }
  document.addEventListener('mouseover', function(e){ var el=findTipEl(e); if(el) show(el); });
  document.addEventListener('mouseout', function(e){
    var from = findTipEl(e);
    var to   = e.relatedTarget ? findTipEl({target:e.relatedTarget}) : null;
    if (from && !to) hide();
  });
  document.addEventListener('focusin', function(e){ var el=findTipEl(e); if(el) show(el); });
  document.addEventListener('focusout', hide);
  document.addEventListener('click',    hide, true);
  document.addEventListener('keydown',  function(e){ if(e.key==='Escape') hide(); });
  window.addEventListener('scroll', hide, true);
  window.addEventListener('resize', hide);
})();
</script>
<script>
/* ═══ Category rail — backend-driven ═══
   Calls /sales/catalog-counts to populate the rail with real part catalog names
   and stock counts. Counts reflect the current search + warehouse filters.
   Clicking a catalog sets _advFilters.part_catalog_id so the existing /sales/products
   pagination filters on that catalog — the backend does the pagination, not us.   */
(function(){
  window._posCatalogs = [];

  // Icon mapping — map catalog-name keywords to Bootstrap Icons; falls back to a generic box
  var ICON_MAP = [
    [/engine|motor/i,      'bi-gear'],
    [/body|bumper|panel|door|hood|fender/i, 'bi-layers'],
    [/light|head.?light|tail.?light|lamp/i, 'bi-lightbulb'],
    [/brake|disc|rotor|caliper|pad/i,       'bi-shield'],
    [/suspen|shock|strut|spring|arm/i,      'bi-box'],
    [/interior|seat|dashboard|trim/i,       'bi-folder'],
    [/electron|ecu|sensor|module/i,         'bi-cpu'],
    [/wheel|tire|hub|rim/i,                 'bi-circle'],
    [/exhaust|cat|muffler/i,                'bi-wind'],
    [/transmission|gear|clutch|drivetrain/i,'bi-gear-wide-connected'],
    [/mirror|glass|window/i,                'bi-aspect-ratio'],
    [/cool|radiator|condens/i,              'bi-thermometer-snow'],
    [/fuel|injector|pump/i,                 'bi-droplet']
  ];
  function catalogIcon(name){
    for (var i=0; i<ICON_MAP.length; i++) if (ICON_MAP[i][0].test(name||'')) return ICON_MAP[i][1];
    return 'bi-box-seam';
  }
  function esc(s){ return String(s==null?'':s).replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }

  // Returns the current rail mode + extra params based on what's on-screen.
  //   • Parts tab (list)      → mode=parts   (count = parts per catalog)
  //   • Vehicles tab (list)   → mode=vehicles (count = vehicles that have parts in that catalog)
  //   • Inside a vehicle view → mode=vehicle  (count = parts in THIS vehicle per catalog)
  function railMode(){
    var tab = (typeof _tab !== 'undefined') ? _tab : 'parts';
    if (typeof _vMode !== 'undefined' && _vMode && typeof _vUuid !== 'undefined' && _vUuid){
      return { mode: 'vehicle', vehicle_uuid: _vUuid };
    }
    if (tab === 'vehicles') return { mode: 'vehicles' };
    return { mode: 'parts' };
  }

  function railLabels(mode){
    if (mode === 'vehicles') return { all: 'All vehicles', unit: 'vehicle' };
    if (mode === 'vehicle')  return { all: 'All parts',   unit: 'part' };
    return                          { all: 'All parts',   unit: 'part' };
  }

  window.loadCatalogCounts = function(){
    var ctx = railMode();
    var labels = railLabels(ctx.mode);
    $('#catRail').show().children().first().find('.pcr-label').text(labels.all);
    var params = {
      mode: ctx.mode,
      search: (typeof _search !== 'undefined' ? _search : '') || '',
      warehouse_id: (typeof _wh !== 'undefined' ? _wh : '') || ''
    };
    if (ctx.vehicle_uuid) params.vehicle_uuid = ctx.vehicle_uuid;

    $.get(BASE_URL + '/sales/catalog-counts', params, function(r){
      if (!r || r.status !== 200 || !r.data) return;
      window._posCatalogs = r.data.catalogs || [];
      var total = Number(r.data.total || 0);
      $('#catCountAll').text(total.toLocaleString());
      /* Tooltip on the "All" row — describes the current mode */
      var $all = $('#catRail .pcr-item').first();
      $all.attr('data-tip', labels.all + ' · ' + total.toLocaleString() + ' ' + labels.unit + (total===1?'':'s') + ' in stock');
      $all.attr('data-tip-pos', 'right');

      var $rail = $('#catRail');
      /* Keep the first item (All), remove the rest */
      $rail.children().slice(1).remove();
      if (!_posCatalogs.length){
        $rail.append('<div class="pcr-empty" style="padding:8px 10px;font-size:11px;color:var(--pv2-subtle);">No catalogs in stock</div>');
        syncActiveRail();
        return;
      }
      var h = '';
      _posCatalogs.forEach(function(c){
        var tipText = c.name + ' · ' + Number(c.count||0).toLocaleString() + ' ' + labels.unit + ((c.count||0)===1?'':'s');
        h += '<div class="pcr-item" data-catid="'+esc(c.id)+'" data-tip="'+esc(tipText)+'" data-tip-pos="right" onclick="selectCatalog(this,\''+esc(c.id)+'\')">'
          + '<i class="bi '+catalogIcon(c.name)+'"></i>'
          + '<span class="pcr-label">'+esc(c.name)+'</span>'
          + '<span class="pcr-count">'+Number(c.count||0).toLocaleString()+'</span>'
          + '</div>';
      });
      $rail.append(h);
      syncActiveRail();
    });
  };

  function syncActiveRail(){
    var cur = String((window._advFilters && _advFilters.part_catalog_id) || '');
    $('#catRail .pcr-item').removeClass('active').each(function(){
      if (String($(this).data('catid')||'') === cur) $(this).addClass('active');
    });
  }

  window.selectCatalog = function(el, id){
    if (typeof _advFilters === 'undefined') window._advFilters = {};
    if (!id){ delete _advFilters.part_catalog_id; }
    else { _advFilters.part_catalog_id = id; }
    $('#catRail .pcr-item').removeClass('active');
    $(el).addClass('active');
    /* Re-paginate using whichever listing is currently showing */
    if (typeof _vMode !== 'undefined' && _vMode && typeof loadVehiclePartsFiltered === 'function'){
      loadVehiclePartsFiltered();
    } else {
      _page = 1;
      if (typeof loadProducts === 'function') loadProducts();
    }
    updateGridInfo();
  };

  function updateGridInfo(){
    var ctx = railMode();
    var labels = railLabels(ctx.mode);
    var catId = (window._advFilters && _advFilters.part_catalog_id) || '';
    var catName = labels.all;
    if (catId){
      var found = (_posCatalogs || []).find(function(c){ return String(c.id) === String(catId); });
      if (found) catName = found.name;
    }
    var whName = ($('#fWarehouse option:selected').text() || '').trim();
    var search = ((typeof _search!=='undefined' ? _search : '')||'').trim();
    var bits = [catName];
    if (ctx.mode === 'vehicle'){
      var vTitle = ($('#vTitle').text()||'').trim();
      if (vTitle) bits.unshift(vTitle);
    }
    if (whName && whName !== 'All Warehouses') bits.push(whName);
    if (search) bits.push('matching "'+search+'"');
    $('#pgbInfo').text(bits.join(' · '));
  }

  /* Reload rail counts whenever search or warehouse changes. pos.js already
     debounces search input and resets page — we just piggyback on the same events. */
  $(document).on('input', '#fSearch', function(){
    clearTimeout(window._catRailDebounce);
    window._catRailDebounce = setTimeout(loadCatalogCounts, 350);
  });
  $(document).on('change', '#fWarehouse', function(){ loadCatalogCounts(); });
  /* Also refresh info-bar whenever pos.js rewrites the grid */
  (function(){
    var g = document.getElementById('prodGrid');
    if (g) new MutationObserver(updateGridInfo).observe(g, { childList: true });
  })();
  /* When pos.js hides the grid for SPA nav (Orders / Customers / ...), hide whole body
     AND hide the vehicle back bar. Also, when returning to POS, if vback is stale it
     gets force-closed so the layout doesn't break.                                       */
  (function(){
    var g = document.getElementById('prodGrid');
    if (!g) return;
    var wasHidden = false;
    function syncBody(){
      var hidden = g.style.display === 'none' || window.getComputedStyle(g).display === 'none';
      var body = document.querySelector('.pos-body');
      if (body) body.style.display = hidden ? 'none' : '';
      var $vBack = $('#vBackBar');
      if (hidden){
        /* SPA took over — hide vback too so it doesn't render above other pages */
        $vBack.removeClass('show');
      } else if (wasHidden){
        /* Just returned to POS from SPA. Force-reset any stale vehicle-parts view */
        if ($vBack.hasClass('show')){
          $vBack.removeClass('show');
          $('#posHeader').show();
          $('.pos-cats').show();
          try {
            if (typeof window._vMode !== 'undefined') window._vMode = false;
            if (typeof window._vUuid !== 'undefined') window._vUuid = '';
            if (typeof window._vParts !== 'undefined') window._vParts = [];
            if (window._advFilters) delete window._advFilters.part_catalog_id;
            $('#vPartSearch').val('');
            if (typeof loadProducts === 'function') loadProducts();
            if (typeof loadCatalogCounts === 'function') setTimeout(loadCatalogCounts, 80);
          } catch(_){ }
        }
      }
      wasHidden = hidden;
    }
    new MutationObserver(syncBody).observe(g,{attributes:true,attributeFilter:['style','class']});
    setTimeout(syncBody, 200);
  })();
  /* Switching tabs — reset catalog filter and reload rail in the new mode */
  $(document).on('click', '.pcat', function(){
    if (typeof _advFilters === 'undefined') window._advFilters = {};
    delete _advFilters.part_catalog_id;
    setTimeout(loadCatalogCounts, 60);
  });

  /* Detect vehicle-parts view entering/leaving — #vBackBar toggles .show */
  (function(){
    var bar = document.getElementById('vBackBar');
    if (!bar) return;
    var lastVisible = bar.classList.contains('show');
    new MutationObserver(function(){
      var v = bar.classList.contains('show');
      if (v === lastVisible) return;
      lastVisible = v;
      /* Reset catalog filter when switching between "vehicle list" and "inside-vehicle" */
      if (window._advFilters) delete window._advFilters.part_catalog_id;
      setTimeout(loadCatalogCounts, 60);
      setTimeout(updateGridInfo, 120);
    }).observe(bar, { attributes:true, attributeFilter:['class'] });
  })();

  /* Initial load — a beat after pos.js has initialized */
  setTimeout(loadCatalogCounts, 250);
})();

/* Sort — client-side, reorders already-rendered cards. Keeps "recent" = backend order. */
$(document).on('change','#fSort',function(){
  var mode = $(this).val();
  var $grid = $('#prodGrid');
  var arr = $grid.children('.pc').get();
  arr.sort(function(a,b){
    var pa = parseFloat($(a).data('price'))||0, pb = parseFloat($(b).data('price'))||0;
    if(mode==='price_asc') return pa-pb;
    if(mode==='price_desc') return pb-pa;
    return 0;
  });
  arr.forEach(function(el){ $grid.append(el); });
});

/* Mobile sticky cart bar — observes the existing cart DOM and syncs counts/totals.
   No pos.js changes; pure DOM observation. Hides bar when cart is empty or cart panel is open. */
(function(){
  function syncMobCart(){
    try{
      var cnt = parseInt(($('#cCnt').text()||'0').replace(/\D/g,''),10)||0;
      var tot = $('#cTotal').text()||'0.00';
      var custName = $('#custResult').text().trim();
      if(!custName || /walk/i.test(custName)) custName = 'Walk-in customer';
      $('#mcbBadge').text(cnt);
      $('#mcbLine1').text(cnt+' item'+(cnt===1?'':'s')+' · '+custName);
      $('#mcbLine2').text(tot);
      if(cnt>0) document.body.classList.remove('pos-cart-empty');
      else document.body.classList.add('pos-cart-empty');
    }catch(e){}
  }
  document.body.classList.add('pos-cart-empty');
  var target = document.getElementById('cItems');
  if(target){ new MutationObserver(syncMobCart).observe(target,{childList:true,subtree:true,characterData:true}); }
  var tot = document.getElementById('cTotal');
  if(tot){ new MutationObserver(syncMobCart).observe(tot,{childList:true,characterData:true,subtree:true}); }
  $(document).on('click','.pos-mobile-cart-bar .mcb-go',syncMobCart);
  setTimeout(syncMobCart,400);
})();
</script>
</body>
</html>
