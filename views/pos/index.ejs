<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="mobile-web-app-capable" content="yes"/>
<title>POS | <%- APP_NAME %></title>
<link rel="icon" type="image/svg+xml" href="/images/favicon.svg"/>
<link rel="stylesheet" href="/libs/css/tabler.min.css"/>
<link rel="stylesheet" href="/libs/css/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/libs/css/toastr.min.css"/>
<link rel="stylesheet" href="/libs/css/select2.min.css"/>
<link rel="stylesheet" href="/libs/css/select2-bootstrap-5-theme.min.css"/>
<link rel="stylesheet" href="/css/pos.css?v=<%= Date.now() %>"/>
</head>
<body class="pos-mode">
<script>
/* Theme loader — prefers DB-saved theme (shared across the organization) with
   localStorage as an instant-preview fallback. Cross-tab updates still flow via
   localStorage so saving in the UI Kit tab re-skins the open POS tab instantly. */
(function(){
  var ALL_VARS = ['--pv2-brand','--pv2-brand-dark','--pv2-brand-light','--pv2-brand-ghost','--pv2-accent',
    '--pv2-ink','--pv2-text','--pv2-muted','--pv2-subtle','--pv2-border','--pv2-border-strong',
    '--pv2-surface','--pv2-surface-alt','--pv2-surface-sunken',
    '--pv2-success','--pv2-warning','--pv2-danger','--pv2-purple'];
  function applyTheme(t){
    ALL_VARS.forEach(function(k){ document.documentElement.style.removeProperty(k); });
    Object.keys(t||{}).forEach(function(k){ if(k) document.documentElement.style.setProperty(k, t[k]); });
  }
  /* 1. Instant cached theme from localStorage (avoids flash while AJAX is in flight) */
  try { var raw = localStorage.getItem('pv2Theme'); if (raw){ var cached = JSON.parse(raw)||{}; applyTheme(cached); } } catch(_){}
  /* 2. Authoritative theme from the DB — overwrites cache when fetched */
  try {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', '/sales/theme', true);
    xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
    xhr.onload = function(){
      if (xhr.status === 200){
        try {
          var r = JSON.parse(xhr.responseText);
          var t = (r && r.data && r.data.theme) || {};
          applyTheme(t);
          try { localStorage.setItem('pv2Theme', JSON.stringify(t)); } catch(_){}
        } catch(_){}
      }
    };
    xhr.send();
  } catch(_){}
  /* 3. Cross-tab updates when the UI Kit page writes to localStorage */
  window.addEventListener('storage', function(e){ if(e.key!=='pv2Theme') return; try{ applyTheme(e.newValue?JSON.parse(e.newValue):{}); }catch(_){} });
})();
</script>

<div class="pos-layout">

  <!-- ═══ LEFT SIDEBAR ═══ -->
  <div class="pos-sidebar">
    <a href="/dashboard" class="ps-logo">S</a>
    <button class="ps-btn" onclick="toggleSidebar()" data-tip="Collapse sidebar" data-tip-pos="right" style="margin-bottom:8px;"><i class="bi bi-layout-sidebar-inset"></i></button>
    <div class="ps-nav">
      <%
         /* Each sidebar button is gated by the role-permission system via
            res.locals.can(). Org/super admins bypass every check; regular
            cashiers only see what their role grants. Mirrors how the main
            app sidebar (MenuController.sidebar) decides menu visibility. */
      %>
      <% if (can('view_pos')) { %>
      <button class="ps-btn active" data-tip="Point of Sale" data-tip-pos="right" onclick="spaNav('pos')"><i class="bi bi-grid-1x2-fill"></i></button>
      <% } %>
      <% if (can('view_pos_orders')) { %>
      <button class="ps-btn" data-tip="Sales Orders" data-tip-pos="right" onclick="spaNav('orders')"><i class="bi bi-bag-check"></i></button>
      <% } %>
      <% if (can('view_pos_customers')) { %>
      <button class="ps-btn" data-tip="Customers" data-tip-pos="right" onclick="spaNav('customers')"><i class="bi bi-people"></i></button>
      <% } %>
      <% /* Returns & Refunds — hidden per request. Remove the `if (false)`
            wrapper below to bring it back. */ %>
      <% if (false && can('view_pos_returns')) { %>
      <button class="ps-btn" data-tip="Returns &amp; Refunds" data-tip-pos="right" onclick="spaNav('returns')"><i class="bi bi-arrow-counterclockwise"></i></button>
      <% } %>
      <% if (can('view_pos_drafts')) { %>
      <button class="ps-btn" data-tip="Saved Drafts" data-tip-pos="right" onclick="spaNav('drafts')" style="position:relative;"><i class="bi bi-bookmark-heart"></i><span id="draftSidebarCnt" style="position:absolute;top:6px;right:6px;min-width:16px;height:16px;padding:0 4px;border-radius:8px;background:var(--pv2-warning,#f59e0b);color:#fff;font-size:9px;font-weight:700;display:none;align-items:center;justify-content:center;">0</span></button>
      <% } %>
      <% if (can('view_pos_pending_payments')) { %>
      <button class="ps-btn" data-tip="Pending Payments" data-tip-pos="right" onclick="spaNav('payments-pending')" style="position:relative;"><i class="bi bi-hourglass-split"></i><span id="pendingSidebarCnt" style="position:absolute;top:6px;right:6px;min-width:16px;height:16px;padding:0 4px;border-radius:8px;background:var(--pv2-warning,#f59e0b);color:#fff;font-size:9px;font-weight:700;display:none;align-items:center;justify-content:center;">0</span></button>
      <% } %>
      <% if (can('view_pos_wallet')) { %>
      <button class="ps-btn" data-tip="Wallet" data-tip-pos="right" onclick="window.location.href='/sales/wallet'"><i class="bi bi-wallet2"></i></button>
      <% } %>
      <% if (can('view_pos_settings')) { %>
      <button class="ps-btn" data-tip="POS Settings" data-tip-pos="right" onclick="spaNav('settings')"><i class="bi bi-gear"></i></button>
      <% } %>
    </div>
    <div class="ps-bottom">
      <a href="/sales/ui-kit" class="ps-btn" data-tip="UI Kit &middot; theme editor" data-tip-pos="right" data-tip-color="blue"><i class="bi bi-palette"></i></a>
      <button class="ps-btn" id="fsToggle" data-tip="Fullscreen" data-tip-pos="right" onclick="toggleFS()"><i class="bi bi-arrows-fullscreen"></i></button>
      <a href="/logout" class="ps-btn ps-logout-btn" data-tip="Logout" data-tip-pos="right" data-tip-color="red"><i class="bi bi-box-arrow-left"></i></a>
      <div class="ps-avatar" data-tip="<%= user ? user.name : 'User' %>" data-tip-pos="right"><i class="bi bi-person-fill"></i></div>
    </div>
  </div>

  <!-- ═══ CENTER ═══ -->
  <div class="pos-center">
    <button class="ps-toggle" onclick="toggleSidebar()" data-tip="Show sidebar" data-tip-pos="right"><i class="bi bi-layout-sidebar-inset"></i></button>

    <!-- Mobile top bar (hidden on desktop) -->
    <!-- Keeps the bar uncluttered: Home + Fullscreen + 3-dot menu on the
         left, flex-spacer, then the prominent Cart button on the right.
         All other nav items collapse into the kebab menu opened by `mobMoreToggle()`. -->
    <div class="mob-topbar" style="display:none;align-items:center;gap:6px;padding:8px 12px;background:var(--card);border-bottom:1px solid var(--border);position:relative;">
      <a href="/dashboard" class="ps-btn" data-tip="Dashboard" style="width:32px;height:32px;background:var(--bg);font-size:14px;color:var(--primary);"><i class="bi bi-grid-1x2-fill"></i></a>
      <button class="ps-btn" onclick="toggleFS()" style="width:32px;height:32px;background:var(--bg);font-size:14px;" data-tip="Fullscreen"><i class="bi bi-arrows-fullscreen"></i></button>
      <button class="ps-btn" id="mobMoreBtn" onclick="mobMoreToggle(event)" style="width:32px;height:32px;background:var(--bg);font-size:16px;position:relative;" data-tip="More menu"><i class="bi bi-three-dots-vertical"></i><span id="mobMoreDot" style="position:absolute;top:4px;right:4px;width:8px;height:8px;border-radius:50%;background:var(--pv2-warning,#f59e0b);display:none;"></span></button>
      <div style="flex:1;"></div>
      <button id="mobCartBtn" class="ps-btn" onclick="showCart();$('#posRight').toggleClass('open');" style="width:38px;height:38px;background:var(--primary);color:#fff;position:relative;font-size:16px;" data-tip="Cart"><i class="bi bi-cart3"></i><span id="mobCartCnt" style="position:absolute;top:-3px;right:-3px;min-width:18px;height:18px;border-radius:50%;background:var(--accent);color:#fff;font-size:10px;display:flex;align-items:center;justify-content:center;font-weight:700;padding:0 4px;">0</span></button>

      <!-- Backdrop — tapping anywhere on it closes the dropdown. Sits below
           the menu (z-index 8900) and above the page (z-index 9000 menu). -->
      <div id="mobMoreBackdrop" onclick="mobMoreClose()" style="display:none;position:fixed;inset:0;background:rgba(11,18,32,.18);z-index:8900;"></div>

      <!-- Mobile More dropdown — anchored to the topbar -->
      <div id="mobMoreMenu" style="display:none;position:absolute;top:48px;left:8px;right:8px;background:#fff;border:1px solid var(--border);border-radius:12px;box-shadow:0 14px 36px rgba(11,18,32,.18);padding:8px;z-index:9000;">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 8px 10px;border-bottom:1px solid var(--border);margin-bottom:6px;">
          <span style="font-size:13px;font-weight:800;color:var(--text2,#6b7280);text-transform:uppercase;letter-spacing:0.5px;">Menu</span>
          <button onclick="mobMoreClose()" aria-label="Close" style="background:var(--bg,#f3f4f6);border:none;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;color:var(--text,#1a2332);"><i class="bi bi-x-lg"></i></button>
        </div>
        <% if (can('view_pos')) { %>
        <button class="mob-mm-item" onclick="mobMoreClose();spaNav('pos')"><i class="bi bi-grid-1x2-fill"></i><span class="mob-mm-lbl">Point of Sale</span><i class="bi bi-chevron-right mob-mm-chev"></i></button>
        <% } %>
        <% if (can('view_pos_orders')) { %>
        <button class="mob-mm-item" onclick="mobMoreClose();spaNav('orders')"><i class="bi bi-bag-check"></i><span class="mob-mm-lbl">Sales Orders</span><i class="bi bi-chevron-right mob-mm-chev"></i></button>
        <% } %>
        <% if (can('view_pos_customers')) { %>
        <button class="mob-mm-item" onclick="mobMoreClose();spaNav('customers')"><i class="bi bi-people"></i><span class="mob-mm-lbl">Customers</span><i class="bi bi-chevron-right mob-mm-chev"></i></button>
        <% } %>
        <% /* Returns & Refunds — hidden from the mobile More menu. */ %>
        <% if (false && can('view_pos_returns')) { %>
        <button class="mob-mm-item" onclick="mobMoreClose();spaNav('returns')"><i class="bi bi-arrow-counterclockwise"></i><span class="mob-mm-lbl">Returns &amp; Refunds</span><i class="bi bi-chevron-right mob-mm-chev"></i></button>
        <% } %>
        <% if (can('view_pos_drafts')) { %>
        <button class="mob-mm-item" onclick="mobMoreClose();spaNav('drafts')"><i class="bi bi-bookmark-heart"></i><span class="mob-mm-lbl">Saved Drafts</span><span id="mobMmDraftCnt" class="mob-mm-cnt">0</span><i class="bi bi-chevron-right mob-mm-chev"></i></button>
        <% } %>
        <% if (can('view_pos_pending_payments')) { %>
        <button class="mob-mm-item" onclick="mobMoreClose();spaNav('payments-pending')"><i class="bi bi-hourglass-split"></i><span class="mob-mm-lbl">Pending Payments</span><span id="mobMmPendingCnt" class="mob-mm-cnt">0</span><i class="bi bi-chevron-right mob-mm-chev"></i></button>
        <% } %>
        <% if (can('view_pos_wallet')) { %>
        <button class="mob-mm-item" onclick="mobMoreClose();window.location.href='/sales/wallet'"><i class="bi bi-wallet2"></i><span class="mob-mm-lbl">Wallet</span><i class="bi bi-chevron-right mob-mm-chev"></i></button>
        <% } %>
        <% if (can('view_pos_settings')) { %>
        <button class="mob-mm-item" onclick="mobMoreClose();spaNav('settings')"><i class="bi bi-gear"></i><span class="mob-mm-lbl">POS Settings</span><i class="bi bi-chevron-right mob-mm-chev"></i></button>
        <% } %>
        <div style="height:1px;background:var(--border);margin:6px 4px;"></div>
        <a class="mob-mm-item" href="/logout" style="color:var(--red);"><i class="bi bi-box-arrow-left"></i><span class="mob-mm-lbl">Logout</span><i class="bi bi-chevron-right mob-mm-chev"></i></a>
      </div>
    </div>
    <style>
      .mob-mm-item{display:flex;align-items:center;gap:12px;width:100%;padding:11px 12px;border-radius:8px;border:none;background:transparent;text-align:left;cursor:pointer;font-size:14px;font-weight:600;color:var(--text,#1a2332);text-decoration:none;line-height:1.3;}
      .mob-mm-item:hover,.mob-mm-item:active{background:var(--bg,#f3f4f6);}
      .mob-mm-item>i:first-child{font-size:18px;color:var(--pv2-brand,#008060);width:22px;text-align:center;flex-shrink:0;}
      .mob-mm-item .mob-mm-lbl{flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
      .mob-mm-item .mob-mm-cnt{
        flex:0 0 auto;
        display:none;
        align-items:center;justify-content:center;
        min-width:22px;height:20px;padding:0 7px;
        background:var(--pv2-warning,#f59e0b);color:#fff;
        font-size:11px;font-weight:700;line-height:1;
        border-radius:999px;
      }
      .mob-mm-item .mob-mm-cnt.show{display:inline-flex;}
      .mob-mm-item .mob-mm-chev{font-size:13px;color:var(--text2,#6b7280);flex-shrink:0;}
      @media (min-width:1025px){#mobMoreMenu{display:none !important;}}
    </style>
    <script>
      window.mobMoreToggle = function(ev){
        if (ev) { ev.stopPropagation(); ev.preventDefault && ev.preventDefault(); }
        var $m = $('#mobMoreMenu'), $bd = $('#mobMoreBackdrop');
        var open = $m.is(':visible');
        if (open) { $m.hide(); $bd.hide(); return; }
        // Sync the count badges shown inside the menu
        var d = parseInt(($('#draftSidebarCnt').text() || '0'), 10);
        var p = parseInt(($('#pendingSidebarCnt').text() || '0'), 10);
        $('#mobMmDraftCnt').text(d > 0 ? d : '').toggleClass('show', d > 0);
        $('#mobMmPendingCnt').text(p > 0 ? p : '').toggleClass('show', p > 0);
        $bd.show();
        $m.show();
      };
      window.mobMoreClose = function(){
        $('#mobMoreMenu').hide();
        $('#mobMoreBackdrop').hide();
      };
      // jQuery loads further down the page, so defer the bits that run
      // immediately (Escape-key handler + the periodic dot refresh) until
      // $ is actually available. Without this guard we hit
      //   "Uncaught ReferenceError: $ is not defined"
      // because this <script> block executes before /libs/js/jquery.min.js.
      function _mobMoreDotUpdate(){
        var d = parseInt(($('#draftSidebarCnt').text() || '0'), 10);
        var p = parseInt(($('#pendingSidebarCnt').text() || '0'), 10);
        if (d > 0 || p > 0) $('#mobMoreDot').show(); else $('#mobMoreDot').hide();
      }
      (function waitForJQ(){
        if (typeof window.jQuery === 'undefined') { return setTimeout(waitForJQ, 50); }
        // Close on Escape — useful for keyboards / external bluetooth keyboards
        jQuery(document).on('keydown.mobmm', function(e){
          if (e.key === 'Escape' && jQuery('#mobMoreMenu').is(':visible')) mobMoreClose();
        });
        setInterval(_mobMoreDotUpdate, 5000);
        setTimeout(_mobMoreDotUpdate, 1500);
      })();
    </script>

    <!-- Header -->
    <div class="pos-header" id="posHeader">
      <div class="ph-heading">
        <h2 class="ph-title">POS</h2>
      </div>
      <div class="ph-search"><i class="bi bi-search"></i><input type="text" id="fSearch" placeholder="Scan or search SKU, name, or barcode..." autocomplete="off"/></div>
      <button class="pos-btn-outline pos-btn-sm" onclick="openAdvSearch()" data-tip="Advanced Search" data-tip-pos="bottom" id="advSearchBtn"><i class="bi bi-sliders"></i><span id="advCount" style="display:none;background:var(--accent);color:#fff;border-radius:50%;min-width:16px;height:16px;font-size:9px;align-items:center;justify-content:center;margin-left:4px;"></span></button>
      <button class="pos-btn-outline pos-btn-sm pos-refresh-btn" onclick="posRefresh(this)" data-tip="Refresh products" data-tip-pos="bottom" id="posRefreshBtn"><i class="bi bi-arrow-clockwise"></i></button>
      <div class="ph-filters">
        <select class="ph-sel" id="fWarehouse" data-vk-options data-tip="Filter by warehouse" data-tip-pos="bottom"><option value="">All Warehouses</option></select>
        <select class="ph-sel" id="fPerPage" data-tip="Items per page" data-tip-pos="bottom"><option value="20">20</option><option value="40">40</option><option value="60">60</option></select>
        <div class="ph-pg">
          <button id="pgPrev" disabled onclick="if(_page>1){_page--;loadProducts();}" data-tip="Previous page"><i class="bi bi-chevron-left"></i></button>
          <span id="pgInfo" data-tip="Current page / Total pages" data-tip-pos="bottom">1 / 1</span>
          <button id="pgNext" disabled onclick="_page++;loadProducts();" data-tip="Next page"><i class="bi bi-chevron-right"></i></button>
        </div>
      </div>
    </div>

    <!-- Category tabs -->
    <div class="pos-cats">
      <button class="pcat active" data-tab="parts" onclick="switchTab(this)"><i class="bi bi-gear-wide-connected"></i> Parts</button>
      <button class="pcat" data-tab="vehicles" onclick="switchTab(this)"><i class="bi bi-truck-front"></i> Vehicles</button>
    </div>

    <!-- Vehicle back bar + search -->
    <div class="pos-vback" id="vBackBar">
      <button class="pvb-btn" onclick="closeVehicleParts()" data-tip="Back to vehicles list"><i class="bi bi-arrow-left"></i> Back</button>
      <span class="pvb-title" id="vTitle"></span>
      <div class="ph-search" style="max-width:240px;flex:1;"><i class="bi bi-search"></i><input type="text" id="vPartSearch" placeholder="Search parts..." autocomplete="off" data-no-keyboard/></div>
      <button class="pvb-all" onclick="addAllVehicleParts()" data-tip="Add all parts to cart" data-tip-color="orange"><i class="bi bi-cart-plus"></i> Add All</button>
    </div>

    <!-- Body: left category rail + product grid -->
    <div class="pos-body">
      <!-- Category rail (desktop only; collapses to chips on tablet/mobile).
           Populated dynamically from /sales/catalog-counts so stock counts and the
           list itself reflect current search/warehouse filters. -->
      <aside class="pos-catrail" id="catRail">
        <div class="pcr-item active" data-catid="" onclick="selectCatalog(this, '')">
          <i class="bi bi-grid-3x3-gap-fill"></i>
          <span class="pcr-label">All parts</span>
          <span class="pcr-count" id="catCountAll">—</span>
        </div>
        <div class="pcr-loading" style="padding:8px 10px;font-size:11px;color:var(--pv2-subtle);">Loading catalogs…</div>
      </aside>

      <!-- Products -->
      <div class="pos-grid-wrap">
        <div class="pos-grid-bar">
          <div class="pgb-info" id="pgbInfo">Loading parts across warehouses…</div>
          <div class="pgb-sort">Sort:
            <select class="ph-sel" id="fSort">
              <option value="recent">Most recent</option>
              <option value="price_asc">Price — low</option>
              <option value="price_desc">Price — high</option>
            </select>
          </div>
        </div>
        <div class="pos-grid g-parts" id="prodGrid"></div>
      </div>
    </div>

    <!-- SPA content area (loaded via AJAX for orders/customers/returns/settings) -->
    <div id="spaContent" style="display:none;flex:1;overflow-y:auto;padding:20px;"></div>

    <!-- Mobile sticky bottom cart bar (visible ≤640px when cart has items) -->
    <div class="pos-mobile-cart-bar" id="mobCartBar" onclick="showCart();$('#posRight').addClass('open');">
      <div class="mcb-icon"><i class="bi bi-cart3"></i><span class="mcb-badge" id="mcbBadge">0</span></div>
      <div class="mcb-meta"><div class="line1" id="mcbLine1">0 items</div><div class="line2" id="mcbLine2">0.00</div></div>
      <button class="mcb-go" onclick="event.stopPropagation();showCart();$('#posRight').addClass('open');openCheckout();">Checkout <i class="bi bi-arrow-right"></i></button>
    </div>
  </div>

  <!-- ═══ RIGHT PANEL ═══ -->
  <div class="pos-right" id="posRight">
    <div class="mob-close-bar" onclick="$('#posRight').removeClass('open');"><div class="mob-handle"></div></div>

    <!-- Cart -->
    <div class="cart-view" id="cartView">
      <div class="cv-hdr"><h3><i class="bi bi-receipt" style="color:var(--primary);"></i> Order <span class="cnt" id="cCnt">0</span></h3><button class="clr" onclick="_cart=[];renderCart();" data-tip="Clear all items" data-tip-pos="left" data-tip-color="red"><i class="bi bi-trash3"></i> Clear</button></div>
      <div class="cv-items" id="cItems"><div class="ci-empty"><i class="bi bi-receipt"></i><p>No items yet</p></div></div>
      <div class="cv-foot">
        <div class="cf-row"><span>Subtotal</span><span id="cSub">0.00</span></div>
        <div id="cTaxArea"></div>
        <div class="cf-row tot"><span>Total</span><span id="cTotal">0.00</span></div>
        <!-- Print button moved into the Checkout panel footer (next to Cancel + Pay) -->
        <button class="cf-pay" id="payBtn" disabled onclick="openCheckout()" data-tip="Proceed to payment" data-tip-pos="left" data-tip-color="blue">
          <i class="bi bi-credit-card-2-front"></i> Pay <span id="cPayAmt">0.00</span>
        </button>
      </div>
    </div>

    <!-- Detail -->
    <div class="detail-view" id="detailView">
      <div class="dv-top">
        <button class="dv-back" onclick="showCart();closePanel();" data-tip="Back to cart" data-tip-pos="right"><i class="bi bi-arrow-left"></i></button>
        <span class="dv-title" id="dvTitle"></span>
        <span class="dv-badge" id="dvBadge">Part</span>
      </div>
      <div class="dv-hero">
        <div class="dv-img" id="dvImg"><i class="bi bi-gear no-img"></i></div>
        <div class="dv-meta">
          <div class="dv-meta-name" id="dvName"></div>
          <div class="dv-meta-code" id="dvCode"></div>
          <div class="dv-meta-row">
            <span class="dv-meta-price" id="dvPrice"></span>
            <span class="dv-meta-stock" id="dvStock"></span>
          </div>
        </div>
      </div>
      <div class="dv-body" id="dvBody"></div>
      <div class="dv-foot">
        <button class="dv-add-btn" id="dvAddBtn" onclick="dvAddClick()" data-tip="Add selected units to cart" data-tip-pos="left" data-tip-color="blue"><i class="bi bi-cart-plus"></i> Add Selected</button>
        <button class="dv-info-btn" id="dvInfoBtn" onclick="showFullInfo()" data-tip="View full part details" data-tip-pos="left"><i class="bi bi-info-circle"></i> More</button>
      </div>
    </div>
  </div>

</div>

<!-- Advanced Search Fullscreen Page -->
<div class="info-page adv-screen" id="advSearchPage">

  <!-- ════════ Header (icon + title + subtitle + Save View + close) ════════ -->
  <div class="adv-header">
    <div class="adv-header-icon"><i class="bi bi-funnel-fill"></i></div>
    <div class="adv-header-text">
      <div class="adv-header-title">Filter Parts</div>
      <div class="adv-header-sub" id="advHeaderSub">Find parts quickly with advanced filters</div>
    </div>
    <span id="advResultHint" class="adv-header-hint"></span>
    <button class="adv-save-btn" onclick="saveAdvSearchView()" data-tip="Save current filters as a view" data-tip-pos="bottom"><i class="bi bi-bookmark"></i> Save View</button>
    <button class="adv-close" onclick="$('#advSearchPage').removeClass('open');$(document.body).removeClass('adv-search-open');" data-tip="Close filters" data-tip-pos="left"><i class="bi bi-x-lg"></i></button>
  </div>

  <!-- Active filters chip strip (populated by JS whenever adv filters change) -->
  <div class="adv-active-bar empty" id="advActiveBar">
    <div class="aab-hdr">
      Active filters <span id="advActiveCount" style="margin-left:6px;color:var(--pv2-text);">0</span>
      <button class="aab-clear" onclick="clearAdvSearch()">Clear all</button>
    </div>
    <div class="aab-chips" id="advActiveChips"></div>
  </div>

  <!-- ════════ Deep Search row ════════ -->
  <div class="adv-deep-row">
    <label class="adv-toggle">
      <input type="checkbox" id="afDeepSearch"/>
      <span class="adv-toggle-track"><span class="adv-toggle-thumb"></span></span>
      <span class="adv-toggle-text">
        <strong>Deep Search</strong>
        <small>Searches notes, damages, locations, attributes and more</small>
      </span>
    </label>
  </div>

  <!-- ════════ Tabs ════════ -->
  <div class="adv-tabs" id="advTabs"></div>

  <!-- ════════ Tab content ════════ -->
  <div class="ip-body adv-body" id="advBody"></div>

  <!-- ════════ Footer (Reset · Cancel · Apply) ════════ -->
  <div class="ip-foot adv-footer">
    <button class="pos-btn-outline adv-reset-btn" onclick="clearAdvSearch()"><i class="bi bi-arrow-counterclockwise"></i> Reset</button>
    <div class="adv-footer-spacer"></div>
    <button class="pos-btn-outline adv-cancel-btn" onclick="$('#advSearchPage').removeClass('open');$(document.body).removeClass('adv-search-open');">Cancel</button>
    <button class="pos-btn-primary adv-apply-btn" onclick="applyAdvSearch()"><i class="bi bi-funnel"></i> <span id="advApplyLabel">Apply Filters</span></button>
  </div>
</div>

<!-- Info Fullscreen Page — tabbed part detail (read-only) -->
<div class="info-page" id="infoPage">
  <!-- Header rebuilt dynamically by showFullInfo() — breadcrumb + SKU chips + title + price -->
  <div class="pdt-topbar">
    <button class="ip-back" onclick="$('#infoPage').removeClass('open');" data-tip="Back to POS" data-tip-pos="right"><i class="bi bi-arrow-left"></i></button>
    <div class="pdt-crumbs" id="infoCrumbs"></div>
  </div>
  <div class="pdt-head" id="infoHead">
    <div class="pdt-head-main">
      <div class="pdt-head-chips" id="infoChips"></div>
      <div class="pdt-head-title" id="infoTitle"></div>
    </div>
    <div class="pdt-head-price" id="infoHeadPrice"></div>
  </div>
  <!-- Legacy hero element (kept hidden for backward compat with old CSS rules) -->
  <div class="ip-hero" id="infoHero" style="display:none;"></div>
  <div class="ip-tabs" id="infoTabs"></div>
  <div class="ip-body" id="infoBody"></div>
</div>

<!--
  Checkout — single-screen 3-column "Payment Screen" layout (web/desktop first).
  Header (navy) + 3 columns (Order details · Customer/Discount/Notes/Payment details ·
  Amount to Pay + Payment Modes) + sticky footer (Cancel · Print · Save · Pay Now).
  Same input IDs as before so existing JS hooks (calcCheckout, selPay, calcChange,
  doCheckout, cartPrintNow) keep working untouched.
-->
<div class="info-page cps-screen" id="coPage">
  <button class="cps-close-fab" onclick="$('#coPage').removeClass('open');" data-tip="Back to cart (Esc)" data-tip-pos="left">
    <i class="bi bi-arrow-left"></i>
  </button>

  <!-- ════════════ Top header bar (tablet + mobile only) ════════════ -->
  <div class="cps-header">
    <button class="cps-header-back cps-header-mobile" onclick="$('#coPage').removeClass('open');" data-tip="Back" data-tip-pos="bottom"><i class="bi bi-list"></i></button>
    <div class="cps-brand">
      <div class="cps-brand-icon"><i class="bi bi-truck-front"></i></div>
      <div class="cps-brand-txt">
        <div class="cps-brand-title" id="cpsBrandName">SCRAP MANAGEMENT</div>
        <div class="cps-brand-sub">POS — Payment Screen</div>
      </div>
    </div>
    <div class="cps-search cps-header-tablet">
      <input type="text" id="cpsSearch" placeholder="Search Vehicle / Order / Customer…" data-no-keyboard/>
      <kbd>F11</kbd>
      <i class="bi bi-search"></i>
    </div>
    <button class="cps-header-icon cps-header-mobile" data-tip="Search" data-tip-pos="bottom"><i class="bi bi-search"></i></button>
    <div class="cps-meta cps-header-tablet">
      <i class="bi bi-calendar3"></i>
      <div>
        <div class="cps-meta-d" id="cpsHdrDate">--</div>
        <div class="cps-meta-t" id="cpsHdrTime">--</div>
      </div>
    </div>
    <div class="cps-user cps-header-tablet">
      <div class="cps-user-av"><i class="bi bi-person"></i></div>
      <div class="cps-user-txt">
        <div class="cps-user-n" id="cpsHdrUserName">User</div>
        <div class="cps-user-r" id="cpsHdrUserRole">Operator</div>
      </div>
      <i class="bi bi-chevron-down cps-user-chev"></i>
    </div>
    <button class="cps-header-icon cps-header-mobile" data-tip="More" data-tip-pos="bottom"><i class="bi bi-three-dots-vertical"></i></button>
  </div>

  <!-- ════════════ Slim payment meta-strip (Order ID · Date · Created By) ════════════ -->
  <div class="cps-meta-strip" id="cpsMetaStrip">
    <div class="cps-meta-item">
      <span class="cps-meta-l">Order ID</span>
      <span class="cps-meta-v" id="cpsOrderId">DRAFT</span>
    </div>
    <span class="cps-meta-dot">·</span>
    <div class="cps-meta-item">
      <span class="cps-meta-l">Order Date</span>
      <span class="cps-meta-v" id="cpsOrderDate">--</span>
    </div>
    <span class="cps-meta-dot">·</span>
    <div class="cps-meta-item">
      <span class="cps-meta-l">Created By</span>
      <span class="cps-meta-v" id="cpsCreatedBy">--</span>
    </div>
  </div>

  <!-- ════════════ 3-column body ════════════ -->
  <div class="cps-body">

    <!-- ════════════ LEFT — Order details ════════════ -->
    <div class="cps-col cps-col-l">
      <div class="cps-card" data-mob="order">
        <div class="cps-card-h"><i class="bi bi-list-ul"></i> ORDER DETAILS</div>
        <div class="cps-card-b cps-card-b-flush">
          <div class="cps-order-hero" id="cpsOrderHero">
            <div class="cps-hero-img" id="cpsHeroImg"><i class="bi bi-box-seam"></i></div>
            <div class="cps-hero-meta">
              <div class="cps-hero-id" id="cpsHeroId">DRAFT</div>
              <div class="cps-hero-d1" id="cpsHeroD1">Multiple Items</div>
              <div class="cps-hero-d2" id="cpsHeroD2"></div>
              <div class="cps-hero-d3" id="cpsHeroD3"></div>
              <span class="cps-pill cps-pill-green" id="cpsHeroPill">Scrap Order</span>
            </div>
          </div>
          <!-- Mobile-only collapsible bar header (hidden on web/tablet) -->
          <button type="button" class="cps-collapse-bar cps-mobile-only" id="cpsItemsBar" onclick="cpsToggleItems()">
            <i class="bi bi-list-ul"></i>
            <span>Order Items <span id="cpsItemsBarCount">(0)</span></span>
            <i class="bi bi-chevron-down cps-collapse-chev"></i>
          </button>
          <div class="cps-items-wrap" id="cpsItemsWrap">
            <table class="cps-items">
              <thead><tr>
                <th>ITEM DESCRIPTION</th>
                <th>TYPE</th>
                <th class="num">QTY</th>
                <th class="num">RATE</th>
                <th class="num">AMOUNT</th>
              </tr></thead>
              <tbody id="cpsItems"></tbody>
            </table>
          </div>
          <div class="cps-totals" id="cpsTotals"></div>
          <div class="cps-grand">
            <span>Grand Total</span>
            <span id="cpsGrand">0.00</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════ CENTER — Customer · Discount · Notes · Payment Details ════════════ -->
    <div class="cps-col cps-col-c">

      <!-- Mobile-only "Amount to Pay" card (hidden on tablet/desktop) -->
      <div class="cps-amt-card cps-mobile-only" data-mob="amount">
        <div class="cps-amt-l-row">
          <i class="bi bi-credit-card"></i>
          <div class="cps-amt-l">Amount to Pay</div>
          <div class="cps-amt-v" id="cpsAmtPayMobile">0.00</div>
        </div>
        <div class="cps-amt-words">In Words: <span id="cpsAmtWordsMobile">Zero Rupees Only</span></div>
      </div>

      <div class="cps-card" data-mob="customer">
        <div class="cps-card-h"><i class="bi bi-person"></i> CUSTOMER SELECTION</div>
        <div class="cps-card-b">
          <div class="cps-cust-row">
            <div class="cps-input-wrap" style="flex:1;">
              <input type="text" id="custSearch" class="cps-input" placeholder="Search customer by name or phone…" autocomplete="off" data-vk-autocomplete="custResult"/>
              <button type="button" class="cps-kb-trigger" onclick="openVK('custSearch','text')" data-tip="Open keyboard" data-tip-pos="left"><i class="bi bi-keyboard"></i></button>
              <div id="custResult" class="cps-cust-results"></div>
            </div>
            <button class="cps-btn-primary" onclick="openNewCust()"><i class="bi bi-plus-lg"></i> New Customer</button>
          </div>
          <!-- Walk-in fallback fields: just two inputs side-by-side, no caption line. -->
          <div class="cps-walkin" id="cpsWalkin">
            <div class="cps-walkin-row">
              <div class="cps-input-wrap" style="flex:1;">
                <input type="text" id="walkInName" class="cps-input" placeholder="Walk-in customer name (optional)"/>
                <button type="button" class="cps-kb-trigger" onclick="openVK('walkInName','text')" data-tip="Open keyboard" data-tip-pos="left"><i class="bi bi-keyboard"></i></button>
              </div>
              <div class="cps-input-wrap" style="flex:1;">
                <input type="tel" id="walkInPhone" class="cps-input" placeholder="Phone (optional)"/>
                <button type="button" class="cps-kb-trigger" onclick="openVK('walkInPhone','text')" data-tip="Open keypad" data-tip-pos="left"><i class="bi bi-keyboard"></i></button>
              </div>
            </div>
          </div>
          <div class="cps-cust-info">
            <div class="ci-l">
              <i class="bi bi-person-circle"></i>
              <div class="ci-l-text">
                <div class="ci-name" id="ciName">Walk-in Customer</div>
                <div class="ci-sub" id="ciSub">General Customer</div>
              </div>
            </div>
            <div class="ci-r">
              <i class="bi bi-telephone-fill"></i>
              <div class="ci-r-text">
                <div class="ci-lbl">Phone</div>
                <div class="ci-val" id="ciPhone">-</div>
              </div>
            </div>
            <div class="ci-r">
              <i class="bi bi-envelope-fill"></i>
              <div class="ci-r-text">
                <div class="ci-lbl">Email</div>
                <div class="ci-val" id="ciEmail">-</div>
              </div>
            </div>
            <!-- Wallet status — shown only when the picked customer has wallet
                 enabled. Populated by cpsSetCustomer() via /sales/wallet/customers/:uuid. -->
            <div class="ci-r" id="ciWalletRow" style="display:none;">
              <i class="bi bi-wallet2" style="color:var(--cps-success,#10b981);"></i>
              <div class="ci-r-text">
                <div class="ci-lbl">Wallet</div>
                <div class="ci-val"><span id="ciWalletAvail">—</span> available <span id="ciWalletDot" style="color:var(--cps-muted,#6b7280);font-weight:500;"> · Owes <span id="ciWalletOwed">—</span></span></div>
              </div>
            </div>
          </div>
          <input type="hidden" id="custId" value=""/>
        </div>
      </div>

      <div class="cps-card" data-mob="discount">
        <div class="cps-card-h"><i class="bi bi-tag"></i> DISCOUNT SELECTION</div>
        <div class="cps-card-b">
          <div class="cps-disc-row">
            <div class="cps-fld">
              <label>Discount Type</label>
              <select id="dType" class="cps-input" onchange="onDiscountTypeChange();calcCheckout();">
                <option value="">Select Discount Type</option>
                <option value="percent">% Percent</option>
                <option value="fixed">Fixed amount</option>
              </select>
            </div>
            <div class="cps-fld">
              <label>Discount Amount (<span class="cps-cur"></span>)</label>
              <div class="cps-input-wrap">
                <input type="number" id="dVal" class="cps-input" placeholder="0.00" min="0" oninput="validateDiscount();calcCheckout();"/>
                <button type="button" class="cps-kb-trigger" onclick="openVK('dVal','amount')" data-tip="Open keypad" data-tip-pos="left"><i class="bi bi-keyboard"></i></button>
              </div>
            </div>
          </div>
          <div class="cps-3box">
            <div class="cps-box">
              <div class="cps-box-l">Discount (<span class="cps-cur"></span>)</div>
              <div class="cps-box-v" id="cpsDisc">0.00</div>
            </div>
            <div class="cps-box">
              <div class="cps-box-l">Taxable Amount</div>
              <div class="cps-box-v cps-box-blue" id="cpsTaxable">0.00</div>
            </div>
            <div class="cps-box">
              <div class="cps-box-l">Total Payable</div>
              <div class="cps-box-v cps-box-green" id="cpsTotalPayable">0.00</div>
            </div>
          </div>
        </div>
      </div>

      <div class="cps-card" data-mob="notes">
        <div class="cps-card-h"><i class="bi bi-pencil-square"></i> NOTES</div>
        <div class="cps-card-b">
          <div class="cps-input-wrap cps-input-wrap-textarea">
            <textarea id="oNotes" class="cps-input cps-textarea" maxlength="200" rows="3" placeholder="Enter notes here…" oninput="document.getElementById('cpsNotesCount').textContent=this.value.length;"></textarea>
            <button type="button" class="cps-kb-trigger cps-kb-trigger-tarea" onclick="openVK('oNotes','text')" data-tip="Open keyboard" data-tip-pos="left"><i class="bi bi-keyboard"></i></button>
          </div>
          <div class="cps-counter"><span id="cpsNotesCount">0</span> / 200</div>
        </div>
      </div>


    </div>

    <!-- ════════════ RIGHT — Payment Modes ════════════ -->
    <div class="cps-col cps-col-r">

      <!-- Hidden mirrors so legacy code (calcCheckout / cpsAmountInWords) can write here -->
      <div style="display:none;" aria-hidden="true">
        <span id="cpsAmtPay">0.00</span>
        <span id="cpsAmtWords">Zero Rupees Only</span>
      </div>

      <div class="cps-card" data-mob="modes">
        <div class="cps-card-h"><i class="bi bi-credit-card"></i> PAYMENT MODES</div>
        <div class="cps-card-b cps-pmodes">
          <div class="cps-pmode active co-pay-btn" data-method="upi" onclick="selPay(this)">
            <span class="cps-pmode-radio"><span></span></span>
            <div class="cps-pmode-l">
              <div class="cps-pmode-t">UPI / QR / Online</div>
              <div class="cps-pmode-s">Google Pay, PhonePe, Paytm, BHIM, UPI</div>
            </div>
            <i class="bi bi-qr-code cps-pmode-icon"></i>
            <span style="display:none;">UPI</span>
          </div>
          <div class="cps-pmode co-pay-btn" data-method="online" onclick="selPay(this)">
            <span class="cps-pmode-radio"><span></span></span>
            <div class="cps-pmode-l">
              <div class="cps-pmode-t">Net Banking</div>
              <div class="cps-pmode-s">All Major Banks</div>
            </div>
            <i class="bi bi-bank cps-pmode-icon"></i>
            <span style="display:none;">Net Banking</span>
          </div>
          <div class="cps-pmode co-pay-btn" data-method="card" onclick="selPay(this)">
            <span class="cps-pmode-radio"><span></span></span>
            <div class="cps-pmode-l">
              <div class="cps-pmode-t">Card Payment</div>
              <div class="cps-pmode-s">Debit / Credit Card</div>
            </div>
            <i class="bi bi-credit-card-2-front cps-pmode-icon"></i>
            <span style="display:none;">Card</span>
          </div>
          <div class="cps-pmode co-pay-btn" data-method="cash" onclick="selPay(this)">
            <span class="cps-pmode-radio"><span></span></span>
            <div class="cps-pmode-l">
              <div class="cps-pmode-t">Cash</div>
              <div class="cps-pmode-s">Cash Payment</div>
            </div>
            <i class="bi bi-cash-stack cps-pmode-icon"></i>
            <span style="display:none;">Cash</span>
          </div>
          <div class="cps-pmode co-pay-btn" data-method="cheque" onclick="selPay(this)">
            <span class="cps-pmode-radio"><span></span></span>
            <div class="cps-pmode-l">
              <div class="cps-pmode-t">Cheque</div>
              <div class="cps-pmode-s">Cheque Payment</div>
            </div>
            <i class="bi bi-receipt-cutoff cps-pmode-icon"></i>
            <span style="display:none;">Cheque</span>
          </div>
          <!-- Wallet (on-account) — hidden until a wallet-enabled customer is selected.
               Shown by cpsSetCustomer() when c.is_wallet_enabled. -->
          <div class="cps-pmode co-pay-btn cps-pmode-wallet" data-method="wallet" onclick="selPay(this)" style="display:none;">
            <span class="cps-pmode-radio"><span></span></span>
            <div class="cps-pmode-l">
              <div class="cps-pmode-t">Wallet (on account)</div>
              <div class="cps-pmode-s" id="cpsWalletAvail">Available credit: <span id="cpsWalletAvailVal">—</span></div>
            </div>
            <i class="bi bi-wallet2 cps-pmode-icon"></i>
            <span style="display:none;">Wallet</span>
          </div>
        </div>
      </div>

      <!-- Reference (UPI / Card / Cheque transaction id / cheque no) -->
      <div class="cps-card" id="cpsRefBox" data-mob="ref" style="display:none;">
        <div class="cps-card-h"><i class="bi bi-card-text"></i> <span id="cpsRefLabel">TRANSACTION REFERENCE</span></div>
        <div class="cps-card-b">
          <div class="cps-input-wrap">
            <input type="text" id="payRef" class="cps-input" placeholder="Transaction ID / UTR / Cheque No"/>
            <button type="button" class="cps-kb-trigger" onclick="openVK('payRef','text')" data-tip="Open keyboard" data-tip-pos="left"><i class="bi bi-keyboard"></i></button>
          </div>
        </div>
      </div>

      <!-- Amount received (Cash only) -->
      <div class="cps-card" id="cpsAmtRcvBox" data-mob="rcv">
        <div class="cps-card-h"><i class="bi bi-cash"></i> AMOUNT RECEIVED</div>
        <div class="cps-card-b">
          <div class="cps-input-wrap">
            <input type="number" id="amtRcv" class="cps-input cps-amt-input" min="0" step="0.01" oninput="calcChange()"/>
            <button type="button" class="cps-kb-trigger" onclick="openVK('amtRcv','amount')" data-tip="Open keypad" data-tip-pos="left"><i class="bi bi-keyboard"></i></button>
          </div>
          <div class="cps-quick" id="quickAmounts"></div>
          <div id="changeDisp" class="cps-change" style="display:none;"></div>
        </div>
      </div>

      <!-- Hidden mirrors so legacy JS keeps working -->
      <div style="display:none;" aria-hidden="true">
        <div id="cardTypeBox"></div>
        <div id="onlineHint"></div>
        <div id="linkBox"></div>
        <span id="coGrandTotal">0.00</span>
        <span id="coGrandTotal2">0.00</span>
        <span id="coStep2Total"></span>
        <span id="coPayTotal">0.00</span>
        <span id="coStep2BtnLabel"></span>
        <span id="coStep2BtnAmt"></span>
        <div id="coTotals"></div>
        <div id="coSummary"></div>
        <span id="coItemCount"></span>
        <span id="coItemsBtnCount"></span>
        <span id="coConfirmCust"></span>
        <span id="coConfirmItems"></span>
        <span id="coConfirmMethod"></span>
        <span id="coConfirmSub"></span>
        <span id="coConfirmDisc"></span>
        <span id="coConfirmTax"></span>
        <span id="coConfirmTotal"></span>
        <span id="coConfirmRef"></span>
        <div id="coConfirmRefRow"></div>
        <div id="coConfirmDiscRow"></div>
        <div id="coConfirmTaxRow"></div>
        <div id="step2RefBox"></div>
        <div id="step2AmtBox"></div>
      </div>

    </div>

  </div>

  <!-- ════════════ Sticky 4-button footer ════════════ -->
  <div class="cps-footer">
    <button class="cps-fbtn cps-fbtn-cancel" onclick="$('#coPage').removeClass('open');" data-tip="Esc — close without saving" data-tip-pos="top">
      <div class="cps-fbtn-i"><i class="bi bi-x-lg"></i></div>
      <div class="cps-fbtn-l"><div class="cps-fbtn-t">CANCEL</div><div class="cps-fbtn-k">ESC</div></div>
    </button>
    <button class="cps-fbtn cps-fbtn-print" id="coPrint" onclick="cartPrintNow()" data-tip="Print a draft receipt (no save)" data-tip-pos="top">
      <div class="cps-fbtn-i"><i class="bi bi-printer"></i></div>
      <div class="cps-fbtn-l"><div class="cps-fbtn-t">PRINT</div><div class="cps-fbtn-k">CTRL + P</div></div>
    </button>
    <button class="cps-fbtn cps-fbtn-save" id="cpsSaveBtn" onclick="cpsSaveOrder()" data-tip="Save as draft" data-tip-pos="top">
      <div class="cps-fbtn-i"><i class="bi bi-floppy"></i></div>
      <div class="cps-fbtn-l"><div class="cps-fbtn-t">SAVE AS DRAFT</div><div class="cps-fbtn-k">F6</div></div>
    </button>
    <button class="cps-fbtn cps-fbtn-pay" id="coComplete" onclick="doCheckout(false)" data-tip="Complete payment" data-tip-pos="top">
      <div class="cps-fbtn-i"><i class="bi bi-check-circle"></i></div>
      <div class="cps-fbtn-l"><div class="cps-fbtn-t" id="cpsPayLabel">PAY NOW</div><div class="cps-fbtn-k">F9</div></div>
    </button>
  </div>
</div>

<!-- ═══════════ Generic Confirm Payment popup (any payment mode) ═══════════ -->
<div class="sc-ov pc-ov" id="cashConfirmOv" style="display:none;" onclick="if(event.target===this)$('#cashConfirmOv').hide();">
  <div class="sc-card pc-card">
