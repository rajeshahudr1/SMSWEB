<%- layout('../layouts/main') %>
<%
var pc     = typeof partCatalog !== 'undefined' ? partCatalog : null;
var isEdit = !!pc;
var langs  = typeof languages !== 'undefined' ? languages : [];
var orgs   = typeof organizations !== 'undefined' ? organizations : [];
var formAction = isEdit ? '/part-catalogs/' + pc.uuid : '/part-catalogs';
var isSuperAdmin = user && user.is_super_admin;

var transMap = {};
if (pc && pc.translations) pc.translations.forEach(function(tr) { transMap[tr.language_id] = tr.name; });

var uploadedImgUrl = '';
var externalImgUrl = '';
if (isEdit) { uploadedImgUrl = pc.uploaded_image_url || ''; externalImgUrl = pc.image_full_url || ''; }
var displayImg = pc && pc.display_image_url ? pc.display_image_url : '';

var pcImages = (pc && pc.images) ? pc.images : [];
var assignedParts = (pc && pc.assigned_parts) ? pc.assigned_parts : [];
var pcAttributes = (pc && pc.attributes) ? pc.attributes : [];
%>

<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/part-catalogs" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i><%- t('general.back', 'Back') %></a>
  <h3 class="mb-0" style="font-size:16px;"><i class="bi bi-journal-bookmark me-2 text-primary"></i><%- isEdit ? t('part_catalogs.edit', 'Edit Part Catalog') : t('part_catalogs.add', 'Add Part Catalog') %></h3>
</div>

<% var isGlobalPart = isEdit && !pc.organization_id;
   var isCompanyEditingGlobal = isEdit && isGlobalPart && !isSuperAdmin; %>
<% if (isCompanyEditingGlobal) { %>
<div class="alert alert-info py-2 mb-3 d-flex align-items-center gap-2" style="font-size:13px;">
  <i class="bi bi-info-circle text-info" style="font-size:16px;"></i>
  <div>
    <strong><%- t('part_catalogs.editing_global', 'Editing Global Part') %></strong> —
    <%- t('part_catalogs.editing_global_hint', 'Your changes will be saved as a company-specific override. The original master data will not be modified.') %>
    <% if (pc._has_override) { %><span class="badge bg-azure-lt ms-1"><%- t('part_catalogs.has_override', 'Override exists') %></span><% } %>
  </div>
</div>
<% } %>

<form id="frmPartCatalog" method="POST" action="<%- formAction %>" enctype="multipart/form-data" novalidate>
<div class="row g-3">

  <div class="col-lg-8">

    <!-- Company selector (super admin only) -->
    <% if (isSuperAdmin) { %>
    <div class="card shadow-sm mb-3">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-building me-1 text-primary"></i><%- t('general.company', 'Company') %></div>
      </div>
      <div class="card-body">
        <select name="company_id" id="selCompany" class="form-select">
          <option value="global" <%- (!isEdit || !pc.organization_id) ? 'selected' : '' %>><%- t('general.global_super_admin', 'Global (Super Admin)') %></option>
          <% orgs.forEach(function(o) { %>
          <option value="<%- o.id %>" <%- (isEdit && pc.organization_id && String(pc.organization_id) === String(o.id)) ? 'selected' : '' %>><%- o.company_name %></option>
          <% }) %>
        </select>
        <div class="form-hint mt-1"><%- t('general.company_hint', 'Select which company this record belongs to.') %></div>
      </div>
    </div>
    <% } %>

    <!-- Part Catalog Information -->
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-info-circle me-1 text-primary"></i><%- t('part_catalogs.information', 'Part Catalog Information') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-12">
            <label class="form-label fw-medium"><%- t('part_catalogs.name_default', 'Part Name (Default)') %> <span class="text-danger">*</span></label>
            <input type="text" name="name" id="fPartName" class="form-control" required autofocus value="<%= isEdit ? (pc.name||'') : '' %>" placeholder="<%- t('part_catalogs.name', 'Name') %>"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('part_catalogs.part_type', 'Part Type') %> <span class="text-danger">*</span></label>
            <select name="part_type_id" id="selPartType" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('part_catalogs.part_location', 'Part Location') %> <span class="text-danger">*</span></label>
            <select name="part_location_id" id="selPartLocation" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('part_catalogs.part_group', 'Part Group') %> <span class="text-danger">*</span></label>
            <select name="part_group_id" id="selPartGroup" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('part_catalogs.part_side', 'Part Side') %> <span class="text-danger">*</span></label>
            <select name="part_side_id" id="selPartSide" class="form-select" style="width:100%;" required></select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('part_catalogs.vehicle_type', 'Vehicle Type') %></label>
            <select name="vehicle_type_id" id="selVehicleType" class="form-select" style="width:100%;"></select>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('part_catalogs.vehicle_percentage', 'Vehicle %') %></label>
            <div class="input-group">
              <input type="number" name="vehicle_percentage" id="fVehiclePercentage" class="form-control" step="0.01" min="0" max="100" value="<%= isEdit ? (pc.vehicle_percentage||0) : '' %>" placeholder="0"/>
              <span class="input-group-text">%</span>
            </div>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('part_catalogs.num_car_doors', 'Number of Car Doors') %></label>
            <input type="number" name="number_of_car_doors" id="fCarDoors" class="form-control" min="0" max="10" value="<%= isEdit ? (pc.number_of_car_doors||'') : '' %>" placeholder="0"/>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('part_catalogs.height', 'Height') %></label>
            <input type="number" name="height" id="fHeight" class="form-control" step="0.01" min="0" value="<%= isEdit ? (pc.height||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('part_catalogs.weight', 'Weight') %></label>
            <input type="number" name="weight" id="fWeight" class="form-control" step="0.01" min="0" value="<%= isEdit ? (pc.weight||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('part_catalogs.length', 'Length') %></label>
            <input type="number" name="length" id="fLength" class="form-control" step="0.01" min="0" value="<%= isEdit ? (pc.length||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('part_catalogs.width', 'Width') %></label>
            <input type="number" name="width" id="fWidth" class="form-control" step="0.01" min="0" value="<%= isEdit ? (pc.width||'') : '' %>" placeholder="0.00"/>
          </div>
          <div class="col-md-12">
            <div class="d-flex flex-wrap gap-4">
              <label class="form-check form-switch">
                <input type="checkbox" class="form-check-input" name="depends_body_car" id="fDependsBodyCar" value="1" <%- (isEdit && (pc.depends_body_car === true || pc.depends_body_car === 1 || pc.depends_body_car === '1')) ? 'checked' : '' %>/>
                <span class="form-check-label fw-medium"><%- t('part_catalogs.depends_body_car', 'Depends Body Car') %></span>
              </label>
              <label class="form-check form-switch">
                <input type="checkbox" class="form-check-input" name="is_individual" id="fIndividual" value="1" <%- (isEdit && (pc.is_individual === true || pc.is_individual === 1 || pc.is_individual === '1')) ? 'checked' : '' %>/>
                <span class="form-check-label fw-medium"><%- t('part_catalogs.individual', 'Individual') %></span>
              </label>
            </div>
          </div>
          <div class="col-md-12">
            <label class="form-label fw-medium"><%- t('part_catalogs.image_external', 'External Image URL') %></label>
            <input type="url" name="image_full_url" id="fImageUrl" class="form-control" value="<%= externalImgUrl %>" placeholder="https://example.com/images/part.jpg"/>
            <div class="form-hint"><%- t('part_catalogs.image_external_hint', 'Optional: external URL for part image.') %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Master Part Section -->
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0 d-flex align-items-center" style="font-size:14px;">
          <i class="bi bi-diagram-2 me-1 text-primary"></i><%- t('part_catalogs.is_master_part', 'Master Part') %>
        </div>
      </div>
      <div class="card-body">
        <label class="form-check form-switch mb-0">
          <input type="checkbox" class="form-check-input" name="is_master_part" id="fIsMasterPart" value="1" <%- (isEdit && (pc.is_master_part === true || pc.is_master_part === 1 || pc.is_master_part === '1')) ? 'checked' : '' %>/>
          <span class="form-check-label fw-medium"><%- t('part_catalogs.enable_master', 'Enable as Master Part') %></span>
        </label>
        <div class="form-hint mt-1"><%- t('part_catalogs.master_hint', 'Master parts can have sub-parts assigned to them.') %></div>

        <!-- Sub-parts section (shown when Is Master Part is checked) -->
        <div id="masterPartCard" style="<%= (isEdit && (pc.is_master_part === true || pc.is_master_part === 1 || pc.is_master_part === '1')) ? '' : 'display:none;' %>" class="mt-3">
          <hr class="my-2"/>
          <div class="d-flex align-items-center mb-2">
            <h6 class="mb-0 fw-semibold" style="font-size:13px;"><%- t('part_catalogs.assigned_parts', 'Assigned Sub-Parts') %></h6>
            <span class="badge bg-primary-lt ms-2" id="assignedCount"><%- assignedParts.length %></span>
          </div>

          <!-- Search box with dropdown -->
          <div class="mb-3 position-relative">
            <div class="input-group">
              <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
              <input type="text" class="form-control" id="assignPartSearch" placeholder="<%- t('part_catalogs.search_parts_to_add', 'Type part name to search and add...') %>" autocomplete="off"/>
            </div>
            <div id="assignPartDropdown" class="border rounded bg-white shadow position-absolute w-100 mt-1" style="max-height:220px;overflow-y:auto;display:none;z-index:100;"></div>
            <div id="assignPartPagination" class="d-flex justify-content-between align-items-center mt-1 px-1" style="display:none;"></div>
          </div>

          <!-- Assigned parts as badge chips (permission-style) -->
          <div id="assignedItems" class="d-flex flex-wrap gap-2">
            <% if (assignedParts.length === 0) { %>
            <div class="text-muted small text-center w-100 py-3" id="noAssignedMsg"><%- t('part_catalogs.no_assigned_parts', 'No sub-parts assigned yet. Use the search above to find and add parts.') %></div>
            <% } %>
            <% assignedParts.forEach(function(p) { %>
            <span class="assigned-chip badge bg-azure-lt d-inline-flex align-items-center gap-1 px-2 py-2" data-id="<%- p.id %>" data-uuid="<%- p.uuid || '' %>" style="font-size:12.5px;cursor:pointer;" title="<%- t('general.preview', 'Click to view details') %>">
              <span class="btn-view-part" data-uuid="<%- p.uuid || '' %>"><%- p.name %></span>
              <button type="button" class="btn-close btn-close-sm ms-1 btn-remove-assigned" data-id="<%- p.id %>" style="font-size:9px;" title="<%- t('btn.remove', 'Remove') %>"></button>
            </span>
            <% }) %>
          </div>

          <input type="hidden" name="assigned_part_ids" id="hiddenAssignedIds" value="<%- JSON.stringify(assignedParts.map(function(p){ return p.id; })) %>"/>
        </div>
      </div>
    </div>

    <!-- Translations -->
    <% if (langs.length > 0) { %>
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0 d-flex align-items-center" style="font-size:14px;">
          <span><i class="bi bi-translate me-1 text-primary"></i><%- t('part_catalogs.translations', 'Translations') %> <span class="badge bg-primary-lt ms-1" style="font-size:10px;"><%- langs.length %> <%- t('general.languages', 'languages') %></span></span>
          <button type="button" class="btn btn-sm btn-outline-info ms-auto d-none ai-translate-btn" id="btnTranslateAll" title="AI Translate All">
            <i class="bi bi-stars me-1"></i>Translate All
          </button>
        </div>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-3"><%- t('part_catalogs.translations_hint', 'Provide translations for each active language.') %></p>
        <div class="row g-3">
          <% langs.forEach(function(lang) { %>
          <div class="col-md-6">
            <label class="form-label fw-medium">
              <% if (lang.flag) { %><span class="me-1"><%- lang.flag %></span><% } %><%- lang.name %>
              <% if (lang.native_name) { %><span class="text-muted ms-1" style="font-size:11px;">(<%- lang.native_name %>)</span><% } %>
              <% if (lang.is_default) { %><span class="badge bg-warning-lt ms-1" style="font-size:9px;"><%- t('master_lang.default', 'Default') %></span><% } %>
            </label>
            <input type="text" name="trans_<%- lang.id %>" class="form-control" value="<%= transMap[lang.id] || '' %>" placeholder="<%- lang.name %>"
                   data-lang-id="<%- lang.id %>" data-lang-name="<%- lang.name %>" data-lang-code="<%- lang.code %>"/>
            <button type="button" class="btn btn-sm btn-ghost-info mt-1 d-none ai-translate-btn ai-single-btn"
                    data-lang-id="<%- lang.id %>" data-lang-name="<%- lang.name %>" data-lang-code="<%- lang.code %>"
                    title="Translate to <%- lang.name %> using AI">
              <i class="bi bi-stars me-1"></i><span class="d-none d-sm-inline">AI</span>
            </button>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Attributes Section (inline builder) -->
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0 d-flex align-items-center" style="font-size:14px;">
          <span><i class="bi bi-sliders me-1 text-primary"></i><%- t('part_catalogs.attributes', 'Custom Attributes') %></span>
          <span class="badge bg-secondary-lt ms-2" style="font-size:10px;" id="attrCount">0</span>
          <button type="button" class="btn btn-sm btn-outline-primary ms-auto" id="btnAddAttribute"><i class="bi bi-plus-lg me-1"></i><%- t('part_catalogs.add_attribute', 'Add Attribute') %></button>
        </div>
      </div>
      <div class="card-body" id="attributesContainer">
        <div class="text-muted small text-center py-3" id="noAttributesMsg">
          <i class="bi bi-sliders d-block mb-2" style="font-size:28px;opacity:.3;"></i>
          <%- t('part_catalogs.no_attributes_hint', 'No custom attributes yet. Click "Add Attribute" to create one.') %>
        </div>
        <!-- Attribute items will be added here dynamically -->
        <div id="attributesList"></div>
      </div>
    </div>

    <!-- Add Attribute Modal -->
    <div class="modal fade" id="modalAddAttribute" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content">
      <div class="modal-header py-2"><h6 class="modal-title fw-semibold mb-0"><i class="bi bi-sliders me-2 text-primary"></i><%- t('part_catalogs.add_attribute', 'Add Attribute') %></h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-medium"><%- t('part_catalogs.attr_type', 'Data Type') %> <span class="text-danger">*</span></label>
          <select id="attrDataType" class="form-select">
            <option value="">— Select Type —</option>
            <option value="1">Text</option>
            <option value="2">Number</option>
            <option value="3">Dropdown</option>
            <option value="4">Checkbox</option>
            <option value="5">Radio</option>
            <option value="6">Upload</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label fw-medium"><%- t('part_catalogs.attr_label', 'Label Name') %> <span class="text-danger">*</span></label>
          <input type="text" id="attrLabel" class="form-control" placeholder="e.g. Color, Material, Weight Grade"/>
        </div>
        <div class="mb-3" id="attrOptionsWrap" style="display:none;">
          <label class="form-label fw-medium"><%- t('part_catalogs.attr_options', 'Options') %></label>
          <div class="input-group input-group-sm mb-2">
            <input type="text" id="attrOptionInput" class="form-control" placeholder="Type option and press Add"/>
            <button type="button" class="btn btn-outline-primary" id="btnAddOption"><i class="bi bi-plus-lg"></i></button>
          </div>
          <div id="attrOptionsList" class="d-flex flex-wrap gap-1"></div>
        </div>
        <div class="d-flex gap-3">
          <div class="form-check">
            <input type="checkbox" class="form-check-input" id="attrRequired"/>
            <label class="form-check-label small"><%- t('part_catalogs.attr_mandatory', 'Required') %></label>
          </div>
          <div class="form-check" id="attrMultipleWrap" style="display:none;">
            <input type="checkbox" class="form-check-input" id="attrMultiple"/>
            <label class="form-check-label small"><%- t('part_catalogs.attr_multi', 'Multiple') %></label>
          </div>
        </div>
      </div>
      <div class="modal-footer py-2">
        <button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.cancel', 'Cancel') %></button>
        <button type="button" class="btn btn-primary btn-sm" id="btnSaveAttribute"><i class="bi bi-check-lg me-1"></i><%- t('btn.add', 'Add') %></button>
      </div>
    </div></div></div>

  </div>

  <div class="col-lg-4">
    <!-- Part Images -->
    <div class="card shadow-sm">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-images me-1 text-primary"></i><%- t('part_catalogs.images', 'Images') %> <% if (isEdit) { %><span class="badge bg-primary-lt ms-1" style="font-size:10px;" id="galleryCount"><%- pcImages.length %></span><% } %></div></div>
      <div class="card-body">
        <% if (isEdit && pcImages.length) { %>
        <div class="row g-2 mb-3" id="galleryGrid">
          <% pcImages.forEach(function(img) { var imgSrc = img.display_url || img.url || ''; %>
          <div class="col-4" id="galImg<%- img.id %>">
            <div class="border rounded p-1 text-center position-relative">
              <img src="<%- imgSrc %>" class="rounded" style="width:100%;height:70px;object-fit:cover;" onerror="this.src='/images/no-image.svg';"/>
              <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1 p-0" style="width:20px;height:20px;font-size:10px;line-height:20px;" onclick="deleteGalleryImage('<%- img.id %>')" title="<%- t('btn.delete', 'Delete') %>"><i class="bi bi-x"></i></button>
            </div>
          </div>
          <% }) %>
        </div>
        <% } else if (!isEdit) { %>
        <div id="imgPlaceholder" class="border rounded d-flex align-items-center justify-content-center mb-3" style="height:100px;background:var(--tblr-bg-surface-secondary);"><img src="/images/no-image.svg" style="width:60px;opacity:.6;"/></div>
        <% } else { %>
        <div class="text-muted small text-center py-2 mb-2"><%- t('part_catalogs.no_images', 'No images uploaded yet.') %></div>
        <% } %>
        <div id="multiImagePreview" class="row g-2 mb-3"></div>
        <input type="file" name="images" id="fImages" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.gif,.webp" multiple/>
        <div class="form-hint mt-1"><%- t('part_catalogs.images_upload_hint', 'Upload multiple images: JPG, PNG, GIF or WebP (max 5 MB each, up to 20 files).') %></div>
        <% if (isEdit) { %>
        <button type="button" class="btn btn-sm btn-outline-primary mt-2 d-none" id="btnUploadGallery" onclick="uploadGalleryImages()"><i class="bi bi-cloud-upload me-1"></i><%- t('part_catalogs.upload_images', 'Upload Images') %></button>
        <% } %>
      </div>
    </div>

    <!-- Status (edit only) -->
    <% if (isEdit) { %>
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-toggle-on me-1 text-primary"></i><%- t('general.status', 'Status') %></div></div>
      <div class="card-body"><select name="status" class="form-select"><option value="1" <%- parseInt(pc.status) ? 'selected' : '' %>><%- t('general.active', 'Active') %></option><option value="0" <%- !parseInt(pc.status) ? 'selected' : '' %>><%- t('general.inactive', 'Inactive') %></option></select></div>
    </div>
    <% } %>

    <!-- Save / Cancel -->
    <div class="card mt-3 shadow-sm">
      <div class="card-body py-3">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary" id="btnSubmit"><i class="bi bi-floppy me-1"></i><%- isEdit ? t('general.update', 'Update') : t('general.create', 'Create') %> <%- t('part_catalogs.title', 'Part Catalog') %></button>
          <a href="/part-catalogs" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i><%- t('btn.cancel', 'Cancel') %></a>
        </div>
      </div>
    </div>
  </div>

</div>
</form>

<!-- Image popup -->
<div class="modal fade" id="modalImageForm" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:600px;"><div class="modal-content"><div class="modal-header py-2"><h6 class="modal-title fw-semibold mb-0"><i class="bi bi-image me-2 text-primary"></i><span id="imgPopupTitle"><%- t('part_catalogs.image_preview', 'Image Preview') %></span></h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-3" id="imgPopupBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close', 'Close') %></button></div></div></div></div>

<!-- View Part Details Modal (same as list page view modal) -->
<div class="modal fade" id="modalViewPart" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:720px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-journal-bookmark me-2 text-primary"></i><%- t('part_catalogs.details', 'Part Catalog Details') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-0" id="viewPartBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close', 'Close') %></button></div></div></div></div>

<!-- Assign Role Permissions Modal -->
<div class="modal fade" id="modalAttrPerms" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:600px;"><div class="modal-content">
  <div class="modal-header py-2"><h6 class="modal-title fw-semibold mb-0"><i class="bi bi-shield-lock me-2 text-purple"></i>Assign Roles</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body p-0" id="attrPermBody"></div>
  <div class="modal-footer py-2">
    <button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.cancel', 'Cancel') %></button>
    <button type="button" class="btn btn-primary btn-sm" id="btnSavePermAttr"><i class="bi bi-check-lg me-1"></i><%- t('btn.save', 'Save') %></button>
  </div>
</div></div></div>

<script>
window._FORM_DATA = {
  isEdit: <%= isEdit ? 'true' : 'false' %>,
  uuid: '<%= isEdit ? pc.uuid : '' %>',
  langIds: [<%= langs.map(function(l){ return l.id; }).join(',') %>],
  langs: <%- JSON.stringify(langs.map(function(l){ return {id:l.id, name:l.name, code:l.code}; })) %>,
  partType: <%- isEdit && pc.part_type_id ? JSON.stringify({id: pc.part_type_id, text: pc.part_type_name || ''}) : 'null' %>,
  partLocation: <%- isEdit && pc.part_location_id ? JSON.stringify({id: pc.part_location_id, text: pc.part_location_name || ''}) : 'null' %>,
  partGroup: <%- isEdit && pc.part_group_id ? JSON.stringify({id: pc.part_group_id, text: pc.part_group_name || ''}) : 'null' %>,
  partSide: <%- isEdit && pc.part_side_id ? JSON.stringify({id: pc.part_side_id, text: pc.part_side_name || ''}) : 'null' %>,
  vehicleType: <%- isEdit && pc.vehicle_type_id ? JSON.stringify({id: pc.vehicle_type_id, text: pc.vehicle_type_name || ''}) : 'null' %>,
  assignedParts: <%- JSON.stringify(assignedParts.map(function(p){ return {id: p.id, text: p.name || '', uuid: p.uuid || ''}; })) %>,
  attributes: <%- JSON.stringify(pcAttributes.map(function(a){ return {id: a.id, label_name: a.label_name, data_type_id: a.data_type_id, is_required: !!a.is_required, is_multiple: !!a.is_multiple, options: (a.options||[]).map(function(o){ return o.option_value||''; }), permissions: (a.permissions||[]).map(function(p){ return {role_id:p.role_id, role_name:p.role_name||'', can_view:!!p.can_view, can_add:!!p.can_add, can_edit:!!p.can_edit, can_delete:!!p.can_delete}; })}; })) %>
};
</script>
<% block('scripts', '<script src="/js/pages/part-catalogs-form.js"></script>') %>
