<%- layout('../layouts/main') %>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-building me-2 text-primary"></i><%- t('cities.title', 'Cities') %> <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-download me-1"></i><span class="d-none d-sm-inline"><%- t('btn.export', 'Export') %></span></button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li><li><a class="dropdown-item" href="#" onclick="doExport('excel');return false;"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Excel</a></li><li><a class="dropdown-item" href="#" onclick="doExport('pdf');return false;"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i>PDF</a></li><li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li></ul>
      </div>
      <button class="btn btn-sm btn-outline-info" onclick="openImport()"><i class="bi bi-upload me-1"></i><span class="d-none d-sm-inline"><%- t('btn.import', 'Import') %></span></button>
      <a href="/cities/create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline"><%- t('btn.add', 'Add') %></span></a>
    </div>
  </div>
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <div class="col-12 col-sm-4 col-lg-3"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="<%- t('cities.search_ph', 'Search cities...') %>"/></div>
      <div class="col-6 col-sm-3 col-lg-2"><select class="form-select form-select-sm" id="filterStatus"><option value=""><%- t('general.all_status', 'All Status') %></option><option value="1"><%- t('general.active', 'Active') %></option><option value="0"><%- t('general.inactive', 'Inactive') %></option></select></div>
      <div class="col-6 col-sm-3 col-lg-2"><select class="form-select form-select-sm" id="filterDeleted"><option value=""><%- t('general.active_records', 'Active Records') %></option><option value="only"><%- t('general.deleted_only', 'Deleted Only') %></option><option value="all"><%- t('general.all_records', 'All Records') %></option></select></div>
      <div class="col-6 col-sm-3 col-lg-2"><select class="form-select form-select-sm" id="filterFK"><option value=""><%- t('cities.all_states', 'All States') %></option></select></div>
      <div class="col-auto"><button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button></div>
    </div>
  </div>
  <div id="bulkBar" class="d-none"><div class="sms-bulk-bar rounded-0 border-bottom px-3 py-2"><span class="fw-semibold"><span id="bulkCount">0</span> <%- t('general.selected', 'selected') %></span><div class="ms-auto d-flex gap-2"><button class="btn btn-sm btn-outline-light" onclick="bulkAction('deactivate')"><i class="bi bi-toggle-off me-1"></i><%- t('bulk.deactivate', 'Deactivate') %></button><button class="btn btn-sm btn-outline-light" onclick="bulkAction('activate')"><i class="bi bi-toggle-on me-1"></i><%- t('bulk.activate', 'Activate') %></button><button class="btn btn-sm btn-danger" onclick="bulkAction('delete')"><i class="bi bi-trash3 me-1"></i><%- t('bulk.delete', 'Delete') %></button><button class="btn btn-sm btn-outline-light d-none" id="btnBulkRecover" onclick="bulkAction('recover')"><i class="bi bi-arrow-counterclockwise me-1"></i><%- t('bulk.recover', 'Recover') %></button><button class="btn btn-sm btn-outline-light" id="btnClearBulk"><i class="bi bi-x-lg"></i></button></div></div></div>
  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead><tr>
        <th style="width:42px;"><input type="checkbox" class="form-check-input" id="selectAll"/></th>
        <th style="width:36px;" class="text-muted">#</th>
        <th class="sortable" data-field="name" style="cursor:pointer;"><%- t('general.name', 'Name') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th class="d-none d-md-table-cell"><%- t('cities.state', 'State') %></th>
        <th style="width:100px;"><%- t('general.status', 'Status') %></th>
        <th class="d-none d-md-table-cell sortable" data-field="created_at" style="cursor:pointer;"><%- t('general.created', 'Created') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th class="text-end" style="width:120px;"><%- t('general.actions', 'Actions') %></th>
      </tr></thead>
      <tbody id="tableBody"><tr><td colspan="20" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t('general.loading', 'Loading...') %></td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- View Modal -->
<div class="modal fade" id="modalView" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:600px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-building me-2 text-primary"></i><%- t('general.details', 'Details') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-0" id="viewBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close', 'Close') %></button></div></div></div></div>

<!-- Import Modal -->
<div class="modal fade" id="modalImport" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:750px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-upload me-2 text-info"></i><%- t('cities.import_title', 'Import Cities') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<div class="modal-body" style="max-height:75vh;overflow-y:auto;">
  <div id="importProcessing" class="d-none"><div class="text-center py-5"><div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;"></div><h5 class="text-primary mb-1"><%- t('general.import_in_process', 'Import in process...') %></h5><p class="text-muted small mb-0"><%- t('general.please_wait', 'Please wait.') %></p></div></div>
  <div id="importStep1">
<p class="small text-muted mb-2">Columns: <code>name</code> (required), <code>state</code> (state name — auto-creates if not found)</p>
    <div class="mt-3"><a href="/templates/cities-import-template.csv" class="btn btn-sm btn-outline-secondary" download><i class="bi bi-download me-1"></i><%- t('import.download_template', 'Download Template') %></a></div>
    <form id="frmImport" class="mt-3"><div class="input-group"><input type="file" name="file" class="form-control form-control-sm" accept=".csv,.xlsx,.xls" required/><button type="submit" class="btn btn-sm btn-primary" id="btnImport"><i class="bi bi-upload me-1"></i><%- t('btn.import', 'Import') %></button></div></form>
  </div>
  <div id="importStep2" class="d-none">
    <div id="importSummary" class="mb-3"></div>
    <div id="importResultTable" style="max-height:450px;overflow-y:auto;overflow-x:auto;"></div>
    <div id="importErrorActions" class="d-none mt-3 d-flex gap-2"><button class="btn btn-sm btn-warning" id="btnRetryAllErrors"><i class="bi bi-arrow-repeat me-1"></i><%- t('import.retry_all', 'Retry All Errors') %></button></div>
  </div>
  <!-- Step 3: Background processing -->
  <div id="importStep3" class="d-none">
    <div class="text-center py-3">
      <h6 class="mb-3"><i class="bi bi-hourglass-split me-2 text-primary"></i><%- t('general.processing_bg', 'Processing in background...') %></h6>
      <div class="progress mb-3" style="height:24px;"><div class="progress-bar progress-bar-striped progress-bar-animated" id="impProgressBar" role="progressbar" style="width:0%;">0%</div></div>
      <div class="d-flex justify-content-center gap-4 text-muted small">
        <span>Total: <strong id="impTotal">0</strong></span><span>Processed: <strong id="impProcessed">0</strong></span>
        <span class="text-success">Success: <strong id="impSuccess">0</strong></span><span class="text-danger">Errors: <strong id="impErrors">0</strong></span>
      </div>
      <div class="mt-2"><span id="impPercent" class="text-primary fw-bold">0%</span> complete</div>
    </div>
  </div>
</div>
<div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close', 'Close') %></button></div>
</div></div></div>

<% include ../partials/usage-modal %>

<script>window._IS_SUPER = true;</script>
<% block('scripts', '<script src="/js/pages/cities.js"></script>') %>
