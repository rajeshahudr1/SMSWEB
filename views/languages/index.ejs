<%- layout('../layouts/main') %>

<!-- ═══ Page Header ═══════════════════════════════════════ -->
<div class="card shadow-sm mb-3">

  <!-- Row 1: Title + Dropdown + Buttons -->
  <div class="card-header py-2 border-bottom">
    <div class="row align-items-center g-2">
      <div class="col-12 col-sm-auto">
        <h3 class="card-title mb-0">
          <i class="bi bi-translate me-2 text-primary"></i><%- t('lang.title') %>
        </h3>
      </div>
      <div class="col-12 col-sm">
        <select id="langSelect" class="form-select select2" style="width:100%;">
          <option value="">-- <%- t('lang.select') %> --</option>
          <% languages.forEach(function(l) { %>
            <option value="<%= l.code %>"><%= l.flag %>  <%= l.name %> (<%= l.nativeName %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="col-12 col-sm-auto d-none" id="headerBtns">
        <div class="d-flex gap-2 flex-wrap">
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="smsLangAddKey()">
            <i class="bi bi-plus-lg me-1"></i><span class="d-none d-md-inline">Add Key</span>
          </button>
          <button type="button" class="btn btn-sm btn-primary" id="btnSaveTop" onclick="smsLangSave()">
            <i class="bi bi-check-lg me-1"></i><%- t('btn.save') %>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Row 2: Toolbar -->
  <div id="toolbarRow" class="d-none">
    <div class="px-3 py-2 border-bottom bg-light">

      <!-- Line 1: Search + filter -->
      <div class="row g-2 align-items-center mb-2">
        <div class="col">
          <input type="text" id="searchInput" class="form-control form-control-sm"
                 placeholder="Search keys or values…" oninput="smsLangFilter()">
        </div>
        <div class="col-auto">
          <div class="d-flex gap-1">
            <button class="btn btn-sm btn-outline-secondary active" data-filter="all" onclick="smsLangSetFilter('all',this)">All</button>
            <button class="btn btn-sm btn-outline-secondary" data-filter="translated" onclick="smsLangSetFilter('translated',this)"><i class="bi bi-check2 text-success me-1"></i>Done</button>
            <button class="btn btn-sm btn-outline-secondary" data-filter="missing" onclick="smsLangSetFilter('missing',this)"><i class="bi bi-exclamation-triangle text-warning me-1"></i>Missing</button>
          </div>
        </div>
      </div>

      <!-- Line 2: Stats + AI Translate buttons -->
      <div class="row g-2 align-items-center">
        <div class="col-auto d-flex gap-1 flex-wrap">
          <span class="badge bg-secondary-lt"><i class="bi bi-key me-1"></i><span id="statTotal">0</span> Total</span>
          <span class="badge bg-success-lt"><i class="bi bi-check-circle me-1"></i><span id="statTranslated">0</span> Done</span>
          <span class="badge bg-warning-lt"><i class="bi bi-exclamation-triangle me-1"></i><span id="statMissing">0</span> Missing</span>
        </div>
        <div class="col"></div>
        <div class="col-auto gap-2 flex-wrap" id="aiButtonsWrap" style="display:none;">
          <!-- AI Provider badge (read-only, shows what's configured) -->
          <span class="badge bg-info-lt" id="aiProviderBadge" style="font-size:11px;"><i class="bi bi-robot me-1"></i>AI</span>
          <!-- Translate Missing -->
          <button type="button" class="btn btn-sm btn-outline-success sms-ai-btn" id="btnTrMissing" onclick="smsLangTrMissing()">
            <i class="bi bi-robot me-1"></i>Translate Missing
          </button>
          <!-- Translate All -->
          <button type="button" class="btn btn-sm btn-outline-primary sms-ai-btn" id="btnTrAll" onclick="smsLangTrAll()">
            <i class="bi bi-translate me-1"></i>Translate All
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ States ════════════════════════════════════════════ -->
<div id="editorLoading" class="card shadow-sm d-none">
  <div class="card-body text-center py-5">
    <div class="spinner-border text-primary mb-2"></div>
    <div class="text-muted"><%- t('general.loading') %></div>
  </div>
</div>
<div id="editorEmpty" class="card shadow-sm">
  <div class="card-body text-center py-5 text-muted">
    <i class="bi bi-translate d-block mb-3 sms-lang-empty-icon"></i>
    Pick a language from the dropdown to start editing
  </div>
</div>

<!-- ═══ Translation Groups ════════════════════════════════ -->
<div id="editorContainer" class="d-none"></div>

<!-- ═══ Bottom Bar ════════════════════════════════════════ -->
<div id="bottomBar" class="d-none mt-3">
  <div class="card shadow-sm sms-lang-sticky">
    <div class="card-body py-2">
      <div class="row align-items-center g-2">
        <div class="col">
          <span class="text-muted small"><i class="bi bi-info-circle me-1"></i><span id="bottomInfo">—</span></span>
        </div>
        <div class="col-auto">
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="smsLangAddKey()">
              <i class="bi bi-plus-lg me-1"></i><span class="d-none d-md-inline">Add Key</span>
            </button>
            <button type="button" class="btn btn-sm btn-primary" id="btnSaveBottom" onclick="smsLangSave()">
              <i class="bi bi-check-lg me-1"></i><%- t('btn.save') %>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ Add Key Modal ═════════════════════════════════════ -->
<div class="modal modal-blur fade" id="addKeyModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2 text-primary"></i>Add New Key</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label small fw-semibold">Group</label>
          <select id="newKeyGroup" class="form-select form-select-sm"><option value="">Select group…</option></select>
        </div>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Key Name</label>
          <div class="input-group input-group-sm">
            <span class="input-group-text" id="newKeyPrefix">group.</span>
            <input type="text" class="form-control" id="newKeyName" placeholder="my_key_name">
          </div>
          <div class="form-text">Preview: <code id="newKeyPreview">—</code></div>
        </div>
        <div class="mb-0">
          <label class="form-label small fw-semibold">English Value</label>
          <input type="text" class="form-control form-control-sm" id="newKeyValue" placeholder="Default English text">
        </div>
      </div>
      <div class="modal-footer py-2">
        <button type="button" class="btn btn-sm" data-bs-dismiss="modal"><%- t('btn.cancel') %></button>
        <button type="button" class="btn btn-sm btn-primary" onclick="smsLangSubmitKey()"><i class="bi bi-plus-lg me-1"></i>Add Key</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══ Key Usage Modal ════════════════════════════════════ -->
<div class="modal modal-blur fade" id="keyUsageModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h5 class="modal-title"><i class="bi bi-search me-2 text-primary"></i>Key Usage — <code id="usageKeyName">—</code></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="usageModalBody">
        <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
      </div>
      <div class="modal-footer py-2">
        <span class="text-muted small me-auto" id="usageCountInfo"></span>
        <button type="button" class="btn btn-sm" data-bs-dismiss="modal"><%- t('btn.close') || 'Close' %></button>
      </div>
    </div>
  </div>
</div>

<!-- ═══ Load CSS + JS via block (after jQuery) ═══════════ -->
<% block('scripts', '<link rel="stylesheet" href="/css/languages.css"/><script src="/js/pages/languages.js"></script>') %>
