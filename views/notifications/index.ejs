<%- layout('../layouts/main') %>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-bell me-2 text-primary"></i>Notifications <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <button class="btn btn-sm btn-outline-secondary" id="btnPageMarkAllRead"><i class="bi bi-check-all me-1"></i><span class="d-none d-sm-inline">Mark All Read</span></button>
    </div>
  </div>

  <!-- Inline Filters -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <div class="col-12 col-sm-4 col-lg-3"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="&#128269;  Search notifications..."/></div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterType"><option value="">All Types</option><option value="export_ready">Export</option><option value="import_complete">Import OK</option><option value="import_errors">Import Errors</option></select>
      </div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterRead"><option value="">All Status</option><option value="0">Unread</option><option value="1">Read</option></select>
      </div>
      <div class="col-auto"><button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button></div>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead><tr>
        <th style="width:36px;" class="text-muted">#</th>
        <th style="width:42px;"></th>
        <th>Title</th>
        <th class="d-none d-md-table-cell">Message</th>
        <th style="width:110px;">Type</th>
        <th style="width:80px;">Status</th>
        <th class="d-none d-md-table-cell" style="width:140px;">Date</th>
        <th class="text-end" style="width:100px;">Actions</th>
      </tr></thead>
      <tbody id="tableBody"><tr><td colspan="8" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...</td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<%
block('scripts', `
<script>
document.addEventListener('DOMContentLoaded', function(){
    if(typeof jQuery==='undefined')return;
    var $=jQuery;
    var _page=1,_pp=15;

    function _filters(){return{page:_page,per_page:_pp,search:$('#searchInput').val().trim(),type:$('#filterType').val()||'',is_read:$('#filterRead').val()||''};}

    function loadData(){
        $('#tableBody').html('<tr><td colspan="8" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...</td></tr>');
        $.get(BASE_URL+'/notifications/api-list',_filters(),function(res){
            if(!res||res.status!==200){$('#tableBody').html('<tr><td colspan="8" class="text-center py-4 text-danger">Failed to load.</td></tr>');return;}
            var items=(res.data&&res.data.data)||[],pg=(res.data&&res.data.pagination)||{};
            $('#badgeTotal').text(pg.total||0);
            if(!items.length){$('#tableBody').html('<tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-bell-slash d-block mb-2" style="font-size:36px;opacity:.3;"></i>No notifications found</td></tr>');$('#tableInfo').text('');$('#tablePagination').html('');return;}
            var start=((_page-1)*_pp),rows='';
            items.forEach(function(n,i){
                var cls=n.is_read?'':'bg-azure-lt';
                var icon=n.icon||'bi-bell';
                var color=n.color||'primary';
                var typeBadge='';
                if(n.type==='export_ready')typeBadge='<span class="badge bg-green-lt">Export</span>';
                else if(n.type==='import_complete')typeBadge='<span class="badge bg-blue-lt">Import OK</span>';
                else if(n.type==='import_errors')typeBadge='<span class="badge bg-warning-lt">Import Errors</span>';
                else typeBadge='<span class="badge bg-secondary-lt">'+H.esc(n.type||'General')+'</span>';
                var statusBadge=n.is_read?'<span class="badge bg-secondary-lt">Read</span>':'<span class="badge bg-danger-lt"><span class="status-dot status-dot-animated bg-danger me-1"></span>Unread</span>';
                var acts='<div class="btn-group btn-group-sm">';
                acts+='<button class="btn btn-ghost-primary btn-sm btn-notif-view" data-uuid="'+n.uuid+'" title="View"><i class="bi bi-eye"></i></button>';
                if(!n.is_read)acts+='<button class="btn btn-ghost-success btn-sm btn-notif-read" data-uuid="'+n.uuid+'" title="Mark Read"><i class="bi bi-check-lg"></i></button>';
                if(n.file_path&&n.file_url)acts+='<a href="'+H.esc(n.file_url)+'" class="btn btn-ghost-info btn-sm" title="Download" download><i class="bi bi-download"></i></a>';
                acts+='<button class="btn btn-ghost-danger btn-sm btn-notif-del" data-uuid="'+n.uuid+'" title="Delete"><i class="bi bi-trash3"></i></button>';
                acts+='</div>';
                rows+='<tr class="'+cls+'">';
                rows+='<td class="text-muted small">'+(start+i+1)+'</td>';
                rows+='<td><i class="bi '+icon+' text-'+color+'" style="font-size:18px;"></i></td>';
                rows+='<td><span class="fw-medium">'+H.esc(n.title)+'</span>';
                if(n.file_path)rows+=' <i class="bi bi-paperclip text-muted" style="font-size:11px;"></i>';
                rows+='</td>';
                rows+='<td class="d-none d-md-table-cell text-muted small" style="max-width:250px;"><span class="text-truncate d-inline-block" style="max-width:250px;">'+H.esc(n.message||'')+'</span></td>';
                rows+='<td>'+typeBadge+'</td>';
                rows+='<td>'+statusBadge+'</td>';
                rows+='<td class="d-none d-md-table-cell text-muted small">'+smsFormatDateTime(n.created_at)+'</td>';
                rows+='<td class="text-end">'+acts+'</td>';
                rows+='</tr>';
            });
            $('#tableBody').html(rows);
            $('#tableInfo').text('Showing '+(pg.from||1)+'\\u2013'+(pg.to||items.length)+' of '+(pg.total||0));
            $('#tablePagination').html(buildPagination(pg,function(p){_page=p;loadData();}));
        }).fail(function(){$('#tableBody').html('<tr><td colspan="8" class="text-center py-4 text-danger">Network error.</td></tr>');});
    }

    smsInitPerPage('#perPageSel');_pp=parseInt($('#perPageSel').val())||15;
    var st;$('#searchInput').on('keyup',function(){clearTimeout(st);st=setTimeout(function(){_page=1;loadData();},400);});
    $('#perPageSel').on('change',function(){_pp=($(this).val()==='all')?99999:(parseInt($(this).val())||15);_page=1;loadData();});
    $(document).on('change','#filterType,#filterRead',function(){_page=1;loadData();});
    $('#btnClearFilters').on('click',function(){$('#searchInput').val('');$('#filterType,#filterRead').val('');_page=1;loadData();});
    $(document).on('click','.sms-pg',function(e){e.preventDefault();var p=parseInt($(this).data('p'));if(p>0&&p!==_page){_page=p;loadData();}});

    // Mark all read
    $('#btnPageMarkAllRead').on('click',function(){
        $.ajax({url:BASE_URL+'/notifications/mark-all-read',type:'POST',success:function(r){
            if(r&&r.status===200){toastr.success('All marked as read.');loadData();if(typeof fetchUnreadCount==='function')fetchUnreadCount();}
            else toastr.error((r&&r.message)||'Failed.');
        },error:function(){toastr.error('Network error.');}});
    });

    // View detail
    $(document).on('click','.btn-notif-view',function(){
        var uuid=$(this).data('uuid');
        if(uuid&&typeof window.showNotifDetail==='function')window.showNotifDetail(uuid);
    });

    // Mark single read
    $(document).on('click','.btn-notif-read',function(){
        var uuid=$(this).data('uuid');
        $.ajax({url:BASE_URL+'/notifications/'+uuid+'/read',type:'PATCH',success:function(r){
            if(r&&r.status===200){toastr.success('Marked as read.');loadData();if(typeof fetchUnreadCount==='function')fetchUnreadCount();}
        }});
    });

    // Delete
    $(document).on('click','.btn-notif-del',function(){
        var uuid=$(this).data('uuid');
        smsConfirm({title:'Delete',msg:'Delete this notification?',btnClass:'btn-danger',btnText:'Delete',onConfirm:function(){
            $.ajax({url:BASE_URL+'/notifications/'+uuid,type:'DELETE',success:function(r){
                if(r&&r.status===200){toastr.success('Deleted.');loadData();if(typeof fetchUnreadCount==='function')fetchUnreadCount();}
                else toastr.error('Failed.');
            }});
        }});
    });

    loadData();
});
</script>
`);
%>
