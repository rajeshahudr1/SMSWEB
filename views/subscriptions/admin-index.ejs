<%- layout('../layouts/main') %>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-credit-card me-2 text-primary"></i>Subscriptions <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">-</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-download me-1"></i><span class="d-none d-sm-inline">Export</span></button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li><li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li></ul>
      </div>
      <button class="btn btn-sm btn-outline-warning" onclick="openAlertSettings()"><i class="bi bi-bell me-1"></i><span class="d-none d-sm-inline">Alert Settings</span></button>
    </div>
  </div>
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="d-flex align-items-center gap-2">
      <div class="flex-grow-1"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="Search organization, package..."/></div>
      <select class="form-select form-select-sm" id="filterStatus" style="width:140px;">
        <option value="">All Status</option><option value="active">Active</option><option value="trialing">Trialing</option><option value="pending">Pending</option><option value="expired">Expired</option><option value="cancelled">Cancelled</option>
      </select>
      <button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead><tr>
        <th style="width:36px;">#</th>
        <th>Organization</th>
        <th>Package</th>
        <th>Billing</th>
        <th>Status</th>
        <th>Start</th>
        <th>End</th>
        <th class="text-end">Amount</th>
        <th class="text-end" style="width:160px;">Actions</th>
      </tr></thead>
      <tbody id="tableBody"><tr><td colspan="9" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...</td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:700px;"><div class="modal-content">
  <div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-credit-card me-2 text-primary"></i>Subscription Details</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body p-0" id="detailBody"></div>
  <div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal">Close</button></div>
</div></div></div>

<!-- Alert Settings Modal -->
<div class="modal fade" id="alertModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:480px;"><div class="modal-content">
  <div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-bell me-2 text-warning"></i>Subscription Alert Settings</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body" id="alertBody"><div class="text-center py-4"><div class="spinner-border text-primary"></div></div></div>
  <div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal">Close</button><button type="button" class="btn btn-primary btn-sm" id="btnSaveAlert"><i class="bi bi-floppy me-1"></i>Save</button></div>
</div></div></div>

<%
block('scripts', `
<script>
var _page=1,_pp=15;
(function(){var sel=$('#perPageSel'),opts=[10,15,25,50];opts.forEach(function(v){sel.append('<option value="'+v+'"'+(v===_pp?' selected':'')+'>'+v+'</option>');});sel.on('change',function(){_pp=parseInt($(this).val());_page=1;loadData();});})();

var _stMap={active:{cls:'bg-success-lt',label:'Active'},trialing:{cls:'bg-info-lt',label:'Trialing'},pending:{cls:'bg-warning-lt',label:'Pending'},expired:{cls:'bg-danger-lt',label:'Expired'},cancelled:{cls:'bg-secondary-lt',label:'Cancelled'},past_due:{cls:'bg-orange-lt',label:'Past Due'},suspended:{cls:'bg-dark-lt',label:'Suspended'}};

function buildPagination(pg){if(!pg||pg.last_page<=1){$('#tablePagination').html('');return;}var h='<ul class="pagination pagination-sm mb-0">';h+='<li class="page-item'+(pg.current_page<=1?' disabled':'')+'"><a class="page-link" href="#" data-page="'+(pg.current_page-1)+'"><i class="bi bi-chevron-left"></i></a></li>';var s=Math.max(1,pg.current_page-2),e=Math.min(pg.last_page,pg.current_page+2);if(s>1){h+='<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';if(s>2)h+='<li class="page-item disabled"><span class="page-link">...</span></li>';}for(var i=s;i<=e;i++)h+='<li class="page-item'+(i===pg.current_page?' active':'')+'"><a class="page-link" href="#" data-page="'+i+'">'+i+'</a></li>';if(e<pg.last_page){if(e<pg.last_page-1)h+='<li class="page-item disabled"><span class="page-link">...</span></li>';h+='<li class="page-item"><a class="page-link" href="#" data-page="'+pg.last_page+'">'+pg.last_page+'</a></li>';}h+='<li class="page-item'+(pg.current_page>=pg.last_page?' disabled':'')+'"><a class="page-link" href="#" data-page="'+(pg.current_page+1)+'"><i class="bi bi-chevron-right"></i></a></li></ul>';$('#tablePagination').html(h);}

function loadData(){
    $('#tableBody').html('<tr><td colspan="9" class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>');
    $.post(BASE_URL+'/subscriptions/admin/paginate',{page:_page,per_page:_pp,search:$('#searchInput').val().trim(),status:$('#filterStatus').val()},function(res){
        if(!res||res.status!==200){$('#tableBody').html('<tr><td colspan="9" class="text-center py-4 text-danger">Failed.</td></tr>');return;}
        var data=res.data&&res.data.data?res.data.data:[];
        var pg=res.data&&res.data.pagination?res.data.pagination:{};
        $('#badgeTotal').text((pg.total||0).toLocaleString());
        if(!data.length){$('#tableBody').html('<tr><td colspan="9" class="text-center py-5 text-muted">No subscriptions found</td></tr>');$('#tableInfo').text('');$('#tablePagination').html('');return;}
        var rows='';
        data.forEach(function(s,i){
            var st=_stMap[s.status]||{cls:'bg-secondary-lt',label:s.status};
            rows+='<tr>';
            rows+='<td class="text-muted">'+((pg.from||1)+i)+'</td>';
            rows+='<td><div class="fw-medium">'+H.esc(s.company_name||'-')+'</div><div class="text-muted small">'+H.esc(s.org_email||'')+'</div></td>';
            rows+='<td><span class="badge bg-azure-lt">'+H.esc(s.package_name||'-')+'</span></td>';
            rows+='<td>'+H.esc(s.billing_cycle||'-')+'</td>';
            rows+='<td><span class="badge '+st.cls+'">'+st.label+'</span></td>';
            rows+='<td class="text-muted small">'+smsFormatDate(s.start_date)+'</td>';
            rows+='<td class="text-muted small">'+smsFormatDate(s.end_date)+'</td>';
            rows+='<td class="text-end fw-medium">'+H.esc(s.currency||'')+parseFloat(s.total_amount||0).toFixed(2)+'</td>';
            rows+='<td class="text-end">';
            rows+='<button class="btn btn-sm btn-ghost-primary" title="View" onclick="viewSub(\\''+s.uuid+'\\')"><i class="bi bi-eye"></i></button>';
            if(s.status!=='active'&&s.status!=='trialing')rows+='<button class="btn btn-sm btn-ghost-success" title="Activate" onclick="adminAction(\\''+s.uuid+'\\',\\'activate\\')"><i class="bi bi-check-circle"></i></button>';
            if(s.status==='active'||s.status==='trialing')rows+='<button class="btn btn-sm btn-ghost-danger" title="Cancel" onclick="adminAction(\\''+s.uuid+'\\',\\'cancel\\')"><i class="bi bi-x-circle"></i></button>';
            if(s.status==='active'||s.status==='trialing')rows+='<button class="btn btn-sm btn-ghost-dark" title="Suspend" onclick="adminAction(\\''+s.uuid+'\\',\\'suspend\\')"><i class="bi bi-pause-circle"></i></button>';
            rows+='<button class="btn btn-sm btn-ghost-info" title="Extend" onclick="extendSub(\\''+s.uuid+'\\')"><i class="bi bi-calendar-plus"></i></button>';
            rows+='</td></tr>';
        });
        $('#tableBody').html(rows);
        $('#tableInfo').text('Showing '+(pg.from||1)+'\\u2013'+(pg.to||data.length)+' of '+(pg.total||0));
        buildPagination(pg);
    });
}

var _evIcons={created:'bi-plus-circle text-primary',activated:'bi-check-circle text-success',renewed:'bi-arrow-repeat text-success',upgraded:'bi-arrow-up-circle text-info',downgraded:'bi-arrow-down-circle text-warning',cancelled:'bi-x-circle text-danger',expired:'bi-clock text-danger',payment_failed:'bi-exclamation-triangle text-danger',trial_started:'bi-gift text-info',trial_ended:'bi-clock text-warning',manually_extended:'bi-calendar-plus text-primary'};

function viewSub(uuid){
    var $b=$('#detailBody');$b.html('<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>');
    bootstrap.Modal.getOrCreateInstance($('#detailModal')[0]).show();
    $.get(BASE_URL+'/subscriptions/admin/'+uuid,function(res){
        if(!res||res.status!==200||!res.data){$b.html('<div class="alert alert-danger m-3">Not found.</div>');return;}
        var s=res.data,st=_stMap[s.status]||{cls:'bg-secondary-lt',label:s.status};
        var isCancelled=!!s.cancelled_at;
        var h='';

        // Header
        h+='<div class="p-3 border-bottom" style="background:var(--tblr-bg-surface-secondary);">';
        h+='<div class="d-flex align-items-center gap-3">';
        h+='<div><h5 class="mb-0 fw-bold">'+H.esc(s.company_name||'-')+'</h5>';
        h+='<div class="text-muted small">'+H.esc(s.org_email||'')+'</div></div>';
        h+='<div class="ms-auto"><span class="badge '+st.cls+' fs-6">'+st.label+'</span></div>';
        h+='</div></div>';

        // Tabs
        h+='<div class="px-3 pt-3">';
        h+='<ul class="nav nav-tabs nav-tabs-sm mb-3" id="admSubTabs">';
        h+='<li class="nav-item"><a class="nav-link active" href="#" data-adm-tab="info"><i class="bi bi-info-circle me-1"></i>Details</a></li>';
        h+='<li class="nav-item"><a class="nav-link" href="#" data-adm-tab="subs"><i class="bi bi-box-seam me-1"></i>Subscriptions <span class="badge bg-secondary-lt ms-1">'+(s.all_subscriptions?s.all_subscriptions.length:0)+'</span></a></li>';
        h+='<li class="nav-item"><a class="nav-link" href="#" data-adm-tab="pays"><i class="bi bi-wallet2 me-1"></i>Payments <span class="badge bg-secondary-lt ms-1">'+(s.payments?s.payments.length:0)+'</span></a></li>';
        h+='<li class="nav-item"><a class="nav-link" href="#" data-adm-tab="hist"><i class="bi bi-clock-history me-1"></i>History <span class="badge bg-secondary-lt ms-1">'+(s.events?s.events.length:0)+'</span></a></li>';
        h+='</ul></div>';

        // ── Info Tab ──
        h+='<div class="px-3 pb-3 adm-tab-pane" id="admTab_info">';
        h+='<div class="row g-3">';
        h+='<div class="col-sm-6"><div class="text-muted small">Current Package</div><div class="fw-semibold">'+H.esc(s.package_name||'-')+'</div></div>';
        h+='<div class="col-sm-6"><div class="text-muted small">Billing Cycle</div><div style="text-transform:capitalize;">'+H.esc(s.billing_cycle||'-')+'</div></div>';
        h+='<div class="col-sm-4"><div class="text-muted small">Start Date</div><div>'+smsFormatDateTime(s.start_date)+'</div></div>';
        h+='<div class="col-sm-4"><div class="text-muted small">End Date</div><div>'+smsFormatDateTime(s.end_date)+'</div></div>';
        h+='<div class="col-sm-4"><div class="text-muted small">Amount</div><div class="fw-bold">'+H.esc(s.currency||'')+parseFloat(s.total_amount||0).toFixed(2)+'</div></div>';
        h+='<div class="col-sm-4"><div class="text-muted small">Auto-Renew</div><div>'+(s.auto_renew?'<span class="text-success fw-medium">Yes</span>':'<span class="text-danger fw-medium">No</span>')+'</div></div>';
        if(isCancelled) h+='<div class="col-sm-4"><div class="text-muted small">Cancelled At</div><div class="text-danger">'+smsFormatDateTime(s.cancelled_at)+'</div></div>';
        if(s.cancel_reason) h+='<div class="col-sm-4"><div class="text-muted small">Cancel Reason</div><div>'+H.esc(s.cancel_reason)+'</div></div>';
        h+='</div></div>';

        // ── Subscriptions Tab ──
        h+='<div class="px-3 pb-3 adm-tab-pane" id="admTab_subs" style="display:none;">';
        var allSubs=s.all_subscriptions||[];
        if(allSubs.length){
            h+='<div class="table-responsive"><table class="table table-sm table-hover mb-0"><thead><tr><th>Package</th><th>Cycle</th><th>Status</th><th>Start</th><th>End</th><th class="text-end">Amount</th></tr></thead><tbody>';
            allSubs.forEach(function(ss){
                var sst=_stMap[ss.status]||{cls:'bg-secondary-lt',label:ss.status};
                var isCur=(ss.id===s.id);
                h+='<tr'+(isCur?' class="table-primary"':'')+'>';
                h+='<td class="fw-medium">'+H.esc(ss.package_name||'-')+(isCur?' <span class="badge bg-primary-lt" style="font-size:9px;">Current</span>':'')+'</td>';
                h+='<td style="text-transform:capitalize;">'+H.esc(ss.billing_cycle||'-')+'</td>';
                h+='<td><span class="badge '+sst.cls+'">'+sst.label+'</span></td>';
                h+='<td class="small">'+smsFormatDateTime(ss.start_date)+'</td>';
                h+='<td class="small">'+smsFormatDateTime(ss.end_date)+'</td>';
                h+='<td class="text-end">'+H.esc(ss.currency||'')+parseFloat(ss.total_amount||0).toFixed(2)+'</td></tr>';
            });
            h+='</tbody></table></div>';
        } else { h+='<div class="text-muted text-center py-3">No subscriptions.</div>'; }
        h+='</div>';

        // ── Payments Tab ──
        h+='<div class="px-3 pb-3 adm-tab-pane" id="admTab_pays" style="display:none;">';
        var pays=s.payments||[];
        if(pays.length){
            h+='<div class="table-responsive"><table class="table table-sm table-hover mb-0"><thead><tr><th>Date & Time</th><th>Package</th><th>Gateway</th><th>Method</th><th>Status</th><th class="text-end">Amount</th></tr></thead><tbody>';
            pays.forEach(function(p){
                var pst=p.status==='completed'?'bg-success-lt':p.status==='failed'?'bg-danger-lt':'bg-warning-lt';
                h+='<tr><td class="small">'+smsFormatDateTime(p.paid_at||p.created_at)+'</td>';
                h+='<td>'+H.esc(p.package_name||'-')+'</td>';
                h+='<td style="text-transform:capitalize;">'+H.esc(p.gateway||'-')+'</td>';
                h+='<td style="text-transform:capitalize;">'+H.esc(p.payment_method||'-')+'</td>';
                h+='<td><span class="badge '+pst+'">'+H.esc(p.status)+'</span></td>';
                h+='<td class="text-end fw-medium">'+H.esc(p.currency||'')+parseFloat(p.total_amount||0).toFixed(2)+'</td></tr>';
            });
            h+='</tbody></table></div>';
        } else { h+='<div class="text-muted text-center py-3">No payments.</div>'; }
        h+='</div>';

        // ── History Tab (Timeline) ──
        h+='<div class="px-3 pb-3 adm-tab-pane" id="admTab_hist" style="display:none;">';
        var evts=s.events||[];
        if(evts.length){
            h+='<div style="max-height:400px;overflow-y:auto;">';
            evts.forEach(function(e,i){
                var icon=_evIcons[e.event_type]||'bi-circle text-muted';
                var isLast=(i===evts.length-1);
                h+='<div class="d-flex gap-3 position-relative" style="padding-bottom:'+(isLast?'0':'14')+'px;">';
                if(!isLast) h+='<div style="position:absolute;left:15px;top:24px;bottom:0;width:2px;background:#e2e8f0;"></div>';
                h+='<div style="width:32px;height:32px;border-radius:50%;background:var(--tblr-bg-surface-secondary);display:flex;align-items:center;justify-content:center;z-index:1;border:2px solid #e2e8f0;flex-shrink:0;">';
                h+='<i class="bi '+icon+'" style="font-size:13px;"></i></div>';
                h+='<div class="flex-fill pt-1">';
                h+='<div class="fw-semibold" style="font-size:13px;">'+H.esc(e.description||e.event_type)+'</div>';
                h+='<div class="text-muted" style="font-size:11px;"><i class="bi bi-calendar3 me-1"></i>'+smsFormatDateTime(e.created_at)+'</div>';
                h+='</div></div>';
            });
            h+='</div>';
        } else { h+='<div class="text-muted text-center py-3">No activity history.</div>'; }
        h+='</div>';

        $b.html(h);
    });
}

// Admin detail tab switching
$(document).on('click','#admSubTabs .nav-link',function(e){
    e.preventDefault();
    var tab=$(this).data('adm-tab');
    $('#admSubTabs .nav-link').removeClass('active');$(this).addClass('active');
    $('.adm-tab-pane').hide();$('#admTab_'+tab).show();
});

function adminAction(uuid,action){
    var msgs={activate:'Activate this subscription?',cancel:'Cancel this subscription?',suspend:'Suspend this subscription? The organization will lose access immediately.'};
    var cls={activate:'btn-success',cancel:'btn-danger',suspend:'btn-dark'};
    smsConfirm({title:action.charAt(0).toUpperCase()+action.slice(1),msg:msgs[action]||'Are you sure?',btnClass:cls[action]||'btn-primary',btnText:action.charAt(0).toUpperCase()+action.slice(1),onConfirm:function(){
        $.ajax({url:BASE_URL+'/subscriptions/admin/'+uuid+'/'+action,type:'POST',contentType:'application/json',data:JSON.stringify({reason:'Admin action: '+action}),success:function(r){if(r.status===200){toastr.success(r.message||'Done.');loadData();}else toastr.error(r.message||'Failed.');}});
    }});
}

function extendSub(uuid){
    smsConfirm({title:'Extend Subscription',msg:'<div class="mb-2">Enter number of days to extend:</div><input type="number" class="form-control form-control-sm" id="extDays" value="30" min="1"/>',btnText:'Extend',btnClass:'btn-primary',onConfirm:function(){
        var days=parseInt($('#extDays').val())||30;
        $.ajax({url:BASE_URL+'/subscriptions/admin/'+uuid+'/extend',type:'POST',contentType:'application/json',data:JSON.stringify({days:days}),success:function(r){if(r.status===200){toastr.success(r.message||'Extended.');loadData();}else toastr.error(r.message||'Failed.');}});
    }});
}

function doExport(fmt){
    showLoading();
    $.post(BASE_URL+'/subscriptions/admin/export',{search:$('#searchInput').val().trim(),status:$('#filterStatus').val()},function(res){
        hideLoading();
        if(!res||res.status!==200||!res.data||!res.data.rows||!res.data.rows.length){toastr.error('No data.');return;}
        var rows=res.data.rows,cols=Object.keys(rows[0]);
        if(fmt==='csv'){var csv=cols.map(function(c){return '"'+c+'"';}).join(',')+String.fromCharCode(10);rows.forEach(function(r){csv+=cols.map(function(c){return '"'+String(r[c]==null?'':r[c]).replace(/"/g,'""')+'"';}).join(',')+String.fromCharCode(10);});var blob=new Blob([csv],{type:'text/csv'});var url=URL.createObjectURL(blob);var a=document.createElement('a');a.href=url;a.download='subscriptions-'+Date.now()+'.csv';document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);toastr.success('Exported.');return;}
        var html='<html><head><title>Subscriptions</title><style>body{font-family:Arial;font-size:12px;padding:20px;}table{border-collapse:collapse;width:100%;}th,td{border:1px solid #ccc;padding:6px 8px;}th{background:#f0f4f8;}</style></head><body><h2>Subscriptions ('+rows.length+')</h2><table><tr>';cols.forEach(function(c){html+='<th>'+H.esc(c)+'</th>';});html+='</tr>';rows.forEach(function(r){html+='<tr>';cols.forEach(function(c){html+='<td>'+H.esc(String(r[c]||''))+'</td>';});html+='</tr>';});html+='</table></body></html>';var w=window.open('','_blank');w.document.write(html);w.document.close();setTimeout(function(){w.print();},400);
    }).fail(function(){hideLoading();toastr.error('Failed.');});
}

/* Alert Settings */
function openAlertSettings(){
    var $b=$('#alertBody');
    $b.html('<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>');
    bootstrap.Modal.getOrCreateInstance($('#alertModal')[0]).show();
    $.get(BASE_URL+'/subscriptions/admin/alert-settings',function(res){
        if(!res||res.status!==200){$b.html('<div class="text-danger p-3">Failed to load.</div>');return;}
        var s=res.data||{};
        var h='';
        h+='<div class="mb-3"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="alEnabled"'+(s.sub_alert_enabled!=='0'?' checked':'')+'><label class="form-check-label fw-semibold" for="alEnabled">Enable Expiry Alerts</label></div>';
        h+='<div class="text-muted small mt-1">Send alerts to organization admins before their subscription expires.</div></div>';
        h+='<div class="mb-3"><label class="form-label small fw-semibold">Alert Days Before Expiry</label>';
        h+='<input type="text" class="form-control form-control-sm" id="alDays" value="'+H.esc(s.sub_alert_days_before||'7,3,1')+'" placeholder="e.g. 7,3,1"/>';
        h+='<div class="text-muted small mt-1">Comma-separated days. E.g. <strong>7,3,1</strong> = alert 7 days before, 3 days before, and 1 day before expiry. Use <strong>14,7,3,1</strong> for more alerts.</div></div>';
        h+='<div class="mb-3"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="alEmail"'+(s.sub_alert_send_email!=='0'?' checked':'')+'><label class="form-check-label" for="alEmail">Send Email Alerts</label></div></div>';
        h+='<div class="mb-3"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="alNotif"'+(s.sub_alert_send_notification!=='0'?' checked':'')+'><label class="form-check-label" for="alNotif">Send In-App Notifications</label></div></div>';
        h+='<hr class="my-3"/>';
        h+='<div class="mb-0"><label class="form-label small fw-semibold">Grace Period (Days)</label>';
        h+='<input type="number" class="form-control form-control-sm" id="alGrace" value="'+H.esc(s.sub_grace_period_days||'0')+'" min="0" max="30"/>';
        h+='<div class="text-muted small mt-1">After expiry, allow access for this many extra days before blocking. Set 0 for no grace period.</div></div>';
        $b.html(h);
    });
}
$(document).on('click','#btnSaveAlert',function(){
    var $btn=$(this);$btn.prop('disabled',true).html('<span class="spinner-border spinner-border-sm"></span>');
    $.ajax({url:BASE_URL+'/subscriptions/admin/alert-settings',type:'POST',contentType:'application/json',data:JSON.stringify({
        sub_alert_enabled:$('#alEnabled').is(':checked')?'1':'0',
        sub_alert_days_before:$('#alDays').val().trim()||'7,3,1',
        sub_alert_send_email:$('#alEmail').is(':checked')?'1':'0',
        sub_alert_send_notification:$('#alNotif').is(':checked')?'1':'0',
        sub_grace_period_days:$('#alGrace').val()||'0',
    }),success:function(r){
        $btn.prop('disabled',false).html('<i class="bi bi-floppy me-1"></i>Save');
        if(r.status===200){toastr.success('Alert settings saved.');bootstrap.Modal.getInstance($('#alertModal')[0]).hide();}
        else toastr.error(r.message||'Failed.');
    },error:function(){$btn.prop('disabled',false).html('<i class="bi bi-floppy me-1"></i>Save');toastr.error('Failed.');}});
});

$(function(){
    loadData();
    var st;$('#searchInput').on('input',function(){clearTimeout(st);st=setTimeout(function(){_page=1;loadData();},300);});
    $('#filterStatus').on('change',function(){_page=1;loadData();});
    $('#btnClearFilters').on('click',function(){$('#searchInput').val('');$('#filterStatus').val('');_page=1;loadData();});
    $(document).on('click','#tablePagination .page-link',function(e){e.preventDefault();var p=parseInt($(this).data('page'));if(p&&p>=1){_page=p;loadData();}});
});
</script>
