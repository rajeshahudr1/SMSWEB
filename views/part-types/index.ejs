<%- layout('../layouts/main') %>
<%
var orgs = typeof organizations !== 'undefined' ? organizations : [];
var isSuperAdmin = user && user.is_super_admin;
%>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-gear-wide-connected me-2 text-primary"></i><%- t('part_types.title') %> <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <% if (can('export_part_types')) { %>
      <div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-download me-1"></i><span class="d-none d-sm-inline"><%- t('btn.export') %></span></button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li><li><a class="dropdown-item" href="#" onclick="doExport('excel');return false;"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Excel</a></li><li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li></ul>
      </div><% } %>
      <% if (can('import_part_types')) { %><button class="btn btn-sm btn-outline-info" onclick="openImport()"><i class="bi bi-upload me-1"></i><span class="d-none d-sm-inline"><%- t('btn.import') %></span></button><% } %>
      <% if (can('add_part_types')) { %><a href="/part-types/create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline"><%- t('part_types.add') %></span></a><% } %>
    </div>
  </div>

  <!-- Filters -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <% if (isSuperAdmin && orgs.length) { %>
      <div class="col-12 col-sm-4 col-lg-2">
        <select class="form-select form-select-sm" id="filterCompany">
          <option value="all"><%- t('general.all_companies', 'All Companies') %></option>
          <option value="global"><%- t('general.global_super_admin', 'Global (Super Admin)') %></option>
          <% orgs.forEach(function(o) { %><option value="<%- o.id %>"><%- o.company_name %></option><% }) %>
        </select>
      </div><% } %>
      <div class="col-12 col-sm-4 col-lg-3"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="&#128269;  <%- t('part_types.search_ph') %>"/></div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterStatus"><option value=""><%- t('general.all_status') %></option><option value="1"><%- t('general.active') %></option><option value="0"><%- t('general.inactive') %></option></select>
      </div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterDeleted"><option value=""><%- t('general.active_records', 'Active Records') %></option><option value="only"><%- t('general.deleted_only', 'Deleted Only') %></option><option value="all"><%- t('general.all_records', 'All Records') %></option></select>
      </div>
      <div class="col-auto"><button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button></div>
    </div>
  </div>

  <!-- Bulk bar — fixed colors -->
  <div id="bulkBar" class="d-none">
    <div class="sms-bulk-bar rounded-0 border-bottom px-3 py-2">
      <span class="fw-semibold"><span id="bulkCount">0</span> <%- t('general.selected_count') %></span>
      <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-outline-light" onclick="bulkAction('deactivate')"><i class="bi bi-toggle-off me-1"></i><%- t('bulk.deactivate', 'Deactivate') %></button>
        <button class="btn btn-sm btn-outline-light" onclick="bulkAction('activate')"><i class="bi bi-toggle-on me-1"></i><%- t('bulk.activate', 'Activate') %></button>
        <button class="btn btn-sm btn-danger" onclick="bulkAction('delete')"><i class="bi bi-trash3 me-1"></i><%- t('btn.delete') %></button>
        <button class="btn btn-sm btn-outline-light d-none" id="btnBulkRecover" onclick="bulkAction('recover')"><i class="bi bi-arrow-counterclockwise me-1"></i><%- t('bulk.recover', 'Recover') %></button>
        <button class="btn btn-sm btn-outline-light" id="btnClearBulk"><i class="bi bi-x-lg"></i></button>
      </div>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead><tr>
        <th style="width:42px;"><input type="checkbox" class="form-check-input" id="selectAll"/></th>
        <th style="width:36px;" class="text-muted">#</th>
        <th style="width:60px;"><%- t('general.image') %></th>
        <th class="sortable" data-field="part_name"><%- t('part_types.name') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th class="sortable" data-field="status"><%- t('general.status') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th class="d-none d-md-table-cell sortable" data-field="created_at"><%- t('general.created_at') %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th class="text-end" style="width:160px;"><%- t('general.actions') %></th>
      </tr></thead>
      <tbody id="tableBody"><tr><td colspan="7" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t('general.loading') %></td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- View Modal -->
<div class="modal fade" id="modalView" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:640px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-gear-wide-connected me-2 text-primary"></i><%- t('part_types.details') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-0" id="viewBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close') %></button></div></div></div></div>

<!-- Image Modal -->
<div class="modal fade" id="modalImage" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:600px;"><div class="modal-content"><div class="modal-header py-2"><h6 class="modal-title fw-semibold mb-0" id="imgModalTitle"><i class="bi bi-image me-2 text-primary"></i><%- t('part_types.image_both_title') %></h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-3" id="imgModalBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close') %></button></div></div></div></div>

<% include ../partials/usage-modal %>

<!-- Import Modal -->
<div class="modal fade" id="modalImport" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:980px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-upload me-2 text-info"></i><%- t('part_types.import_title', 'Import Part Types') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<div class="modal-body" style="max-height:75vh;overflow-y:auto;">
  <div id="importProcessing" class="d-none">
    <div class="text-center py-5">
      <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;"></div>
      <h5 class="text-primary mb-1">Import in process...</h5>
      <p class="text-muted small mb-0">Please wait while we process your file.</p>
    </div>
  </div>
  <div id="importStep1">
    <div style="background:#f0f6ff;border:1px solid #c5d9f1;border-radius:8px;padding:20px;">
      <h6 class="mb-3"><i class="bi bi-info-circle me-1 text-primary"></i>Import Instructions</h6>
      <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="badge bg-danger-lt px-2 py-1"><code>name</code> <small>(required)</small></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>image_url</code></span>
        <span class="badge bg-green-lt px-2 py-1"><code>Language name/code</code></span>
      </div>
      <div class="table-responsive mb-3">
        <table class="table table-sm table-bordered mb-0" style="font-size:12px;">
          <thead class="table-light"><tr><th style="width:150px;">Column</th><th style="width:70px;">Required</th><th>Description</th><th style="width:120px;">Example</th></tr></thead>
          <tbody>
            <tr><td><code>name</code></td><td class="text-center"><span class="text-danger fw-bold">Yes</span></td><td>Part type name. Must be unique per company scope.</td><td><code>Body</code></td></tr>
            <tr><td><code>image_url</code></td><td class="text-center text-muted">No</td><td>External image URL (https://...).</td><td><code>https://img.com/type.jpg</code></td></tr>
            <tr><td><code>Hindi</code> / <code>hi</code></td><td class="text-center text-muted">No</td><td>Translation column. Use language name or ISO code as header.</td><td>Translated name</td></tr>
          </tbody>
        </table>
      </div>
      <div class="row g-3">
        <div class="col-md-6"><div class="border rounded p-2 bg-white" style="font-size:12px;"><strong class="text-success"><i class="bi bi-check-circle me-1"></i>Import Rules:</strong><ul class="mb-0 mt-1 ps-3"><li>Name must be unique per company scope</li><li>Duplicates are skipped with error</li><li>Small files processed instantly</li><li>Large files run in background with notification</li></ul></div></div>
        <div class="col-md-6"><div class="border rounded p-2 bg-white" style="font-size:12px;"><strong class="text-info"><i class="bi bi-file-earmark-text me-1"></i>File Requirements:</strong><ul class="mb-0 mt-1 ps-3"><li>Formats: <strong>.csv</strong>, <strong>.xlsx</strong>, <strong>.xls</strong></li><li>Unlimited rows per import</li><li>First row = column headers</li><li>Headers are case-insensitive</li></ul></div></div>
      </div>
    </div>
    <div class="mt-3 d-flex align-items-center gap-3">
      <a href="/templates/part-types-import-template.csv" class="btn btn-sm btn-outline-primary" download><i class="bi bi-download me-1"></i>Download Template</a>
      <form id="frmImport" enctype="multipart/form-data" class="d-flex align-items-center gap-2 flex-grow-1">
        <div class="flex-grow-1"><input type="file" name="file" id="importFile" class="form-control form-control-sm" accept=".csv,.xlsx,.xls" required/></div>
        <button type="submit" class="btn btn-info btn-sm" id="btnImport"><i class="bi bi-upload me-1"></i>Import</button>
      </form>
    </div>
  </div>
  <div id="importStep2" class="d-none">
    <div id="importSummary" class="mb-3"></div>
    <div id="importResultTable" style="max-height:450px;overflow-y:auto;overflow-x:auto;"></div>
    <div id="importErrorActions" class="d-none mt-3 d-flex gap-2">
      <button class="btn btn-sm btn-warning" id="btnRetryAllErrors"><i class="bi bi-arrow-repeat me-1"></i>Retry All Errors</button>
    </div>
  </div>
  <div id="importStep3" class="d-none">
    <div class="text-center py-4">
      <div class="mb-3"><i class="bi bi-cloud-upload text-primary" style="font-size:48px;"></i></div>
      <h5 class="fw-semibold mb-1">Importing in background...</h5>
      <p class="text-muted small mb-3">Processing your file. You can keep this window open.</p>
      <div class="progress mb-3" style="height:24px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated" id="impProgressBar" role="progressbar" style="width:0%;font-size:12px;"><span id="impPercent">0%</span></div>
      </div>
      <div class="d-flex justify-content-center gap-4 text-center">
        <div><div class="text-muted small">Total</div><strong id="impTotal">0</strong></div>
        <div><div class="text-muted small">Processed</div><strong id="impProcessed">0</strong></div>
        <div><div class="text-muted small text-success">Success</div><strong id="impSuccess" class="text-success">0</strong></div>
        <div><div class="text-muted small text-danger">Errors</div><strong id="impErrors" class="text-danger">0</strong></div>
      </div>
    </div>
  </div>
</div>
<div class="modal-footer py-2">
  <button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal" id="btnImportClose">Close</button>
</div>
</div></div></div>

<script>window._IS_SUPER = <%= isSuperAdmin ? 'true' : 'false' %>;</script>
<% block('scripts', '<script src="/js/pages/part-types.js"></script>') %>
