<%- layout('../layouts/main') %>
<%
var u      = typeof user !== 'undefined' ? user : null;
var isEdit = !!u;
var formAction = isEdit ? '/users/' + u.uuid : '/users';
var pageTitle  = isEdit ? t('users.edit', 'Edit User') : t('users.add', 'Add User');
%>

<!-- ── Back bar ── -->
<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/users" class="btn btn-sm btn-outline-secondary" title="<%- t('btn.back_to_list', 'Back to Users list') %>">
    <i class="bi bi-arrow-left me-1"></i><%- t('btn.back', 'Back') %>
  </a>
  <h3 class="mb-0" style="font-size:16px;">
    <i class="bi bi-person-fill me-2 text-primary"></i><%- pageTitle %>
  </h3>
</div>

<form id="frmUser" method="POST" action="<%- formAction %>" novalidate>
<div class="row g-3">

  <!-- Left column: core fields -->
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-person me-1 text-primary"></i><%- t('users.information', 'User Information') %>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">

          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t("form.full_name") %> <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" required autofocus
                   value="<%- isEdit ? (u.name||'') : '' %>"
                   placeholder="<%- t('form.full_name', 'Full name') %>"/>
          </div>

          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t("users.email") %> <% if (!isEdit) { %><span class="text-danger">*</span><% } %></label>
            <input type="email" name="email" class="form-control"
                   value="<%- isEdit ? (u.email||'') : '' %>"
                   placeholder="user@company.com"
                   <%- isEdit ? 'readonly' : 'required' %>/>
            <% if (isEdit) { %><div class="form-hint"><%- t('users.email_readonly', 'Email cannot be changed.') %></div><% } %>
          </div>

          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t("form.password") %> <% if (!isEdit) { %><span class="text-danger">*</span><% } %></label>
            <div class="input-group">
              <input type="password" name="password" id="fPwd" class="form-control"
                     placeholder="<%- isEdit ? t('form.password_keep', 'Leave blank to keep current') : t('form.password_min', 'Min 8 characters') %>"
                     <%- isEdit ? '' : 'required minlength="8"' %>/>
              <button type="button" class="btn btn-outline-secondary btn-pwd-toggle" title="<%- t('form.toggle_visibility', 'Toggle visibility') %>">
                <i class="bi bi-eye"></i>
              </button>
            </div>
          </div>

          <!-- Phone with country code -->
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t("users.phone") %></label>
            <input type="hidden" name="phone" id="phoneHidden" value="<%- isEdit ? (u.phone||'') : '' %>"/>
            <div id="phoneWrap"></div>
          </div>

          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t("users.role") %></label>
            <select name="role_id" id="selRole" class="form-select" style="width:100%;">
              <option value="">— <%- t('users.no_role', 'No Role') %> —</option>
              <% if (typeof roles !== 'undefined') { roles.forEach(function(r){ %>
              <option value="<%- r.id %>" <%- isEdit && u.role_id==r.id ? 'selected':'' %>><%- r.name %></option>
              <% }) } %>
            </select>
          </div>

          <% if (isEdit) { %>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t("users.status") %></label>
            <select name="status" class="form-select">
              <option value="1" <%- parseInt(u.status) ? 'selected':'' %>><%- t("users.active") %></option>
              <option value="0" <%- !parseInt(u.status) ? 'selected':'' %>><%- t("users.inactive") %></option>
            </select>
          </div>
          <% } %>

        </div>
      </div>
    </div>

    <!-- Location -->
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-geo-alt-fill me-1 text-primary"></i><%- t('form.location', 'Location') %>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-medium"><%- t("form.country") %></label>
            <select name="country_id" id="sCountry" class="form-select" style="width:100%;">
              <option value="">— <%- t('form.select_country', 'Select Country') %> —</option>
              <% if (typeof countries !== 'undefined') { countries.forEach(function(c){ %>
              <option value="<%- c.id %>"
                <% if (isEdit && u.country_id == c.id) { %><%- t("general.selected") %><% } %>><%- c.name %></option>
              <% }) } %>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium"><%- t("form.state") %></label>
            <select name="state_id" id="sState" class="form-select" style="width:100%;">
              <option value="">— <%- t('form.select_state', 'Select State') %> —</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium"><%- t("form.city") %></label>
            <select name="city_id" id="sCity" class="form-select" style="width:100%;">
              <option value="">— <%- t('form.select_city', 'Select City') %> —</option>
            </select>
          </div>
          <div class="col-md-8">
            <label class="form-label fw-medium"><%- t("form.address") %></label>
            <input type="text" name="address" class="form-control"
                   value="<%- isEdit ? (u.address||'') : '' %>" placeholder="<%- t('form.street_address', 'Street address') %>"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium"><%- t("form.zip_code") %></label>
            <input type="text" name="zip_code" class="form-control"
                   value="<%- isEdit ? (u.zip_code||'') : '' %>" placeholder="<%- t('form.zip_placeholder', 'ZIP / Postal code') %>"/>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right column -->
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-person-badge me-1 text-primary"></i><%- t('users.personal_details', 'Personal Details') %>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label fw-medium"><%- t("form.gender") %></label>
            <select name="gender" class="form-select">
              <option value="">— <%- t('form.select', 'Select') %> —</option>
              <option value="male"   <%- isEdit&&u.gender==='male'   ? 'selected':'' %>><%- t("form.male") %></option>
              <option value="female" <%- isEdit&&u.gender==='female' ? 'selected':'' %>><%- t("form.female") %></option>
              <option value="other"  <%- isEdit&&u.gender==='other'  ? 'selected':'' %>><%- t("form.other") %></option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label fw-medium"><%- t("form.dob") %></label>
            <input type="date" name="dob" class="form-control"
                   value="<%- isEdit&&u.dob ? String(u.dob).slice(0,10) : '' %>"/>
          </div>
          <div class="col-12">
            <label class="form-label fw-medium"><%- t("form.aadhar") %></label>
            <input type="text" name="aadhar_no" class="form-control"
                   value="<%- isEdit ? (u.aadhar_no||'') : '' %>"
                   placeholder="12-digit" maxlength="12"/>
          </div>
          <div class="col-12">
            <label class="form-label fw-medium"><%- t("form.pan") %></label>
            <input type="text" name="pan_no" class="form-control text-uppercase"
                   value="<%- isEdit ? (u.pan_no||'') : '' %>"
                   placeholder="ABCDE1234F" maxlength="10"/>
          </div>
        </div>
      </div>
    </div>

    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-shield-check me-1 text-primary"></i><%- t('users.access', 'Access') %>
        </div>
      </div>
      <div class="card-body">
        <label class="form-check form-switch">
          <input type="checkbox" class="form-check-input" name="is_org_admin" value="1"
                 <%- isEdit&&parseInt(u.is_org_admin) ? 'checked':'' %>/>
          <span class="form-check-label fw-medium"><%- t("form.org_admin") %></span>
        </label>
        <div class="form-hint"><%- t('form.org_admin_hint', 'Bypasses all permission checks within this org.') %></div>
      </div>
    </div>

    <!-- Action buttons -->
    <div class="card mt-3 shadow-sm">
      <div class="card-body py-3">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary" id="btnSubmit" title="<%- isEdit ? t('btn.update', 'Update') : t('btn.save', 'Save') %>">
            <i class="bi bi-floppy me-1"></i><%- isEdit ? t('btn.update', 'Update') : t('btn.save', 'Save') %>
          </button>
          <a href="/users" class="btn btn-outline-secondary" title="<%- t('btn.discard', 'Discard and go back') %>">
            <i class="bi bi-x-lg me-1"></i><%- t('btn.cancel', 'Cancel') %>
          </a>
        </div>
      </div>
    </div>
  </div>

</div>
</form>

<!-- Pass server data to JS without backticks -->
<script>
window._FORM_DATA = {
  isEdit:     <%= isEdit ? 'true' : 'false' %>,
  country_id: <%= isEdit && u.country_id ? u.country_id : 0 %>,
  state_id:   <%= isEdit && u.state_id   ? u.state_id   : 0 %>,
  city_id:    <%= isEdit && u.city_id    ? u.city_id    : 0 %>
};
</script>

<% block('scripts', '<script src="/js/common/phone.js"></script><script src="/js/pages/users-form.js"></script>') %>
