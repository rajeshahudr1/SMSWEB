<form id="frmUser"
      action="<%- user ? BASE_URL + '/users/' + user.uuid : BASE_URL + '/users' %>"
      method="POST" novalidate>
  <% if (user) { %><input type="hidden" name="_method" value="PUT"/><% } %>

  <div class="row g-3 mb-3">

    <!-- Name -->
    <div class="col-12">
      <label class="form-label required">Full Name</label>
      <div class="input-group">
        <span class="input-group-text bg-light"><i class="ti ti-user text-secondary"></i></span>
        <input type="text" name="name" class="form-control"
               value="<%- user ? user.name : '' %>" placeholder="Full name" required/>
      </div>
    </div>

    <!-- Email -->
    <div class="col-12">
      <label class="form-label required">Email Address</label>
      <div class="input-group">
        <span class="input-group-text bg-light"><i class="ti ti-mail text-secondary"></i></span>
        <input type="email" name="email" class="form-control"
               value="<%- user ? user.email : '' %>" placeholder="user@company.com" required/>
      </div>
    </div>

    <!-- Phone -->
    <div class="col-md-6">
      <label class="form-label">Phone</label>
      <div class="input-group">
        <span class="input-group-text bg-light"><i class="ti ti-phone text-secondary"></i></span>
        <input type="text" name="phone" class="form-control"
               value="<%- user ? (user.phone||'') : '' %>" placeholder="10-digit mobile"/>
      </div>
    </div>

    <!-- Role -->
    <div class="col-md-6">
      <label class="form-label required">Role</label>
      <select name="role_id" id="role_id" class="form-select select2" required>
        <option value="">— Select Role —</option>
        <% roles.forEach(function(r){ %>
          <option value="<%- r.id %>" <%- (user && user.role_id == r.id) ? 'selected' : '' %>><%- r.name %></option>
        <% }) %>
      </select>
    </div>

    <!-- Panel access -->
    <div class="col-md-6">
      <label class="form-label">Panel Access</label>
      <select name="panel_access" class="form-select">
        <option value="b2b"  <%- (!user || user.panel_access==='b2b')  ? 'selected':'' %>>B2B — Business</option>
        <option value="b2c"  <%- (user && user.panel_access==='b2c')   ? 'selected':'' %>>B2C — Individual</option>
        <option value="both" <%- (user && user.panel_access==='both')  ? 'selected':'' %>>Both</option>
      </select>
    </div>

    <!-- Status -->
    <div class="col-md-6">
      <label class="form-label">Status</label>
      <select name="status" class="form-select">
        <option value="1" <%- (!user || user.status==1) ? 'selected':'' %>>Active</option>
        <option value="0" <%- (user && user.status==0)  ? 'selected':'' %>>Inactive</option>
      </select>
    </div>

    <!-- Password -->
    <div class="col-md-6">
      <label class="form-label <%- !user ? 'required' : '' %>">
        Password
        <% if (user) { %><small class="text-muted fw-normal">(leave blank to keep)</small><% } %>
      </label>
      <div class="input-group">
        <span class="input-group-text bg-light"><i class="ti ti-lock text-secondary"></i></span>
        <input type="password" name="password" id="password" class="form-control"
               placeholder="Min 8 characters" <%- !user ? 'required' : '' %> minlength="8"/>
        <button type="button" class="input-group-text bg-light border-start-0" id="togglePassword" tabindex="-1">
          <i class="ti ti-eye text-secondary"></i>
        </button>
      </div>
    </div>

    <!-- Confirm password -->
    <div class="col-md-6">
      <label class="form-label">Confirm Password</label>
      <div class="input-group">
        <span class="input-group-text bg-light"><i class="ti ti-lock-check text-secondary"></i></span>
        <input type="password" name="confirm_password" id="confirm_password"
               class="form-control" placeholder="Repeat password"/>
      </div>
    </div>

    <!-- Divider: Address -->
    <div class="col-12">
      <div class="d-flex align-items-center gap-2">
        <hr class="flex-fill my-0"/>
        <small class="text-secondary fw-semibold text-uppercase" style="font-size:10.5px; letter-spacing:.07em; white-space:nowrap;">
          <i class="ti ti-map-pin me-1"></i>Address Info
        </small>
        <hr class="flex-fill my-0"/>
      </div>
    </div>

    <!-- Country -->
    <div class="col-md-4">
      <label class="form-label">Country</label>
      <select name="country_id" id="country_id" class="form-select select2"
              data-selected="<%- user ? (user.country_id||'') : '' %>">
        <option value="">— Country —</option>
        <% countries.forEach(function(c){ %>
          <option value="<%- c.id %>" <%- (user && user.country_id==c.id)?'selected':'' %>><%- c.name %></option>
        <% }) %>
      </select>
    </div>

    <!-- State (dynamic) -->
    <div class="col-md-4">
      <label class="form-label">State</label>
      <select name="state_id" id="state_id" class="form-select select2"
              data-selected="<%- user ? (user.state_id||'') : '' %>">
        <option value="">— State —</option>
      </select>
    </div>

    <!-- City (dynamic) -->
    <div class="col-md-4">
      <label class="form-label">City</label>
      <select name="city_id" id="city_id" class="form-select select2"
              data-selected="<%- user ? (user.city_id||'') : '' %>">
        <option value="">— City —</option>
      </select>
    </div>

    <!-- Address -->
    <div class="col-12">
      <label class="form-label">Street Address</label>
      <div class="input-group">
        <span class="input-group-text bg-light"><i class="ti ti-building text-secondary"></i></span>
        <input type="text" name="address" class="form-control"
               value="<%- user ? (user.address||'') : '' %>" placeholder="Building, street, area"/>
      </div>
    </div>

    <!-- ZIP -->
    <div class="col-md-4">
      <label class="form-label">PIN / ZIP Code</label>
      <input type="text" name="zip_code" class="form-control"
             value="<%- user ? (user.zip_code||'') : '' %>" placeholder="6-digit PIN" maxlength="10"/>
    </div>

    <!-- Profile Image upload -->
    <div class="col-12">
      <div class="d-flex align-items-center gap-2 mb-2">
        <hr class="flex-fill my-0"/>
        <small class="text-secondary fw-semibold text-uppercase" style="font-size:10.5px; letter-spacing:.07em; white-space:nowrap;">
          <i class="ti ti-photo me-1"></i>Profile Photo
        </small>
        <hr class="flex-fill my-0"/>
      </div>
      <% if (user && user.profile_image) { %>
      <div class="mb-2 d-flex align-items-center gap-2">
        <img src="<%- user.profile_image %>" style="width:48px;height:48px;border-radius:50%;object-fit:cover;border:2px solid #e9ecef;"/>
        <span class="text-secondary small">Current photo. Upload new to replace.</span>
      </div>
      <% } %>
      <div class="sms-dropzone" id="imgDropzone">
        <input type="file" name="profile_image" id="profileImageInput" class="sms-dropzone__input"
               accept="image/jpeg,image/png,image/gif,image/webp"/>
        <div class="sms-dropzone__icon"><i class="ti ti-photo"></i></div>
        <div class="sms-dropzone__title">Drop photo here or click to browse</div>
        <div class="sms-dropzone__hint">JPEG, PNG, GIF, WebP · Max 2 MB</div>
      </div>
      <div class="sms-file-list" id="imgPreviewList"></div>
    </div>

  </div><!-- /row -->

  <!-- Footer buttons -->
  <div class="offcanvas-footer">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas">
      <i class="ti ti-x me-1"></i>Cancel
    </button>
    <button type="submit" id="btnSubmit" class="btn btn-primary">
      <i class="ti ti-device-floppy me-1"></i>
      <%- user ? 'Update User' : 'Create User' %>
    </button>
  </div>

</form>

<script>
$(function () {
  // Select2 inside offcanvas
  $('#frmUser .select2').select2({
    theme: 'bootstrap-5', width: '100%',
    dropdownParent: $('#canvasUser'),
  });

  // Country → state cascade
  $('#country_id').on('change', function () { loadStates($(this).val(),'',''); });
  $('#state_id').on('change',   function () { loadCities($(this).val(),''); });

  // Edit: preload state+city
  var sc = '<%- user ? (user.state_id||"")  : "" %>';
  var cc = '<%- user ? (user.city_id ||"")  : "" %>';
  var cv = $('#country_id').val();
  if (cv && sc) loadStates(cv, sc, cc);

  // Image upload
  var $dz    = $('#imgDropzone');
  var $input = $('#profileImageInput');
  var $list  = $('#imgPreviewList');
  var ALLOWED = ['jpg','jpeg','png','gif','webp'];
  var MAX_MB  = 2;

  $dz.on('click', function(e){ if (!$(e.target).is('input')) $input.click(); });
  $input.on('change', function(){ validateImg(this.files[0]); });
  $dz.on('dragover', function(e){ e.preventDefault(); $dz.addClass('dragover'); });
  $dz.on('dragleave drop', function(e){
    e.preventDefault(); $dz.removeClass('dragover');
    if (e.type==='drop' && e.originalEvent.dataTransfer.files[0])
      validateImg(e.originalEvent.dataTransfer.files[0]);
  });

  function validateImg(file) {
    if (!file) return;
    var ext  = file.name.split('.').pop().toLowerCase();
    var size = file.size/(1024*1024);
    $list.empty();
    if (!ALLOWED.includes(ext)) {
      $list.html('<div class="sms-file-item error"><i class="ti ti-alert-circle text-danger sms-file-item__icon"></i><span>Only JPEG/PNG/GIF/WebP allowed.</span></div>');
      toastr.error('Invalid image type.'); return;
    }
    if (size > MAX_MB) {
      $list.html('<div class="sms-file-item error"><i class="ti ti-alert-circle text-danger sms-file-item__icon"></i><span>Image exceeds 2 MB limit.</span></div>');
      toastr.error('Image too large.'); return;
    }
    var reader = new FileReader();
    reader.onload = function(e) {
      $list.html('<div class="sms-file-item"><img src="'+e.target.result+'" style="width:36px;height:36px;border-radius:50%;object-fit:cover;"><span class="sms-file-item__name">'+file.name+'</span><span class="badge-ext">'+ext+'</span><span class="sms-file-item__size">'+Math.round(size*1024)+' KB</span></div>');
      $dz.find('.sms-dropzone__title').text('Photo selected ✓');
    };
    reader.readAsDataURL(file);
  }
});
</script>
