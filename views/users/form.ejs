<%- layout('../layouts/main') %>
<%
var u      = typeof user !== 'undefined' ? user : null;
var isEdit = !!u;
var formAction = isEdit ? '/users/' + u.uuid : '/users';
var pageTitle  = isEdit ? 'Edit User' : 'Add User';
%>

<!-- ── Back bar ── -->
<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/users" class="btn btn-sm btn-outline-secondary" title="Back to Users list">
    <i class="bi bi-arrow-left me-1"></i>Back
  </a>
  <h3 class="mb-0" style="font-size:16px;">
    <i class="bi bi-person-fill me-2 text-primary"></i><%- pageTitle %>
  </h3>
</div>

<form id="frmUser" method="POST" action="<%- formAction %>" novalidate>
<div class="row g-3">

  <!-- Left column: core fields -->
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-person me-1 text-primary"></i>User Information
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">

          <div class="col-md-6">
            <label class="form-label fw-medium">Full Name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" required autofocus
                   value="<%- isEdit ? (u.name||'') : '' %>"
                   placeholder="Full name"/>
          </div>

          <div class="col-md-6">
            <label class="form-label fw-medium">Email <% if (!isEdit) { %><span class="text-danger">*</span><% } %></label>
            <input type="email" name="email" class="form-control"
                   value="<%- isEdit ? (u.email||'') : '' %>"
                   placeholder="user@company.com"
                   <%- isEdit ? 'readonly' : 'required' %>/>
            <% if (isEdit) { %><div class="form-hint">Email cannot be changed.</div><% } %>
          </div>

          <div class="col-md-6">
            <label class="form-label fw-medium">Password <% if (!isEdit) { %><span class="text-danger">*</span><% } %></label>
            <div class="input-group">
              <input type="password" name="password" id="fPwd" class="form-control"
                     placeholder="<%- isEdit ? 'Leave blank to keep current' : 'Min 8 characters' %>"
                     <%- isEdit ? '' : 'required minlength="8"' %>/>
              <button type="button" class="btn btn-outline-secondary btn-pwd-toggle" title="Toggle visibility">
                <i class="bi bi-eye"></i>
              </button>
            </div>
          </div>

          <!-- Phone with country code -->
          <div class="col-md-6">
            <label class="form-label fw-medium">Phone</label>
            <input type="hidden" name="phone" id="phoneHidden" value="<%- isEdit ? (u.phone||'') : '' %>"/>
            <div id="phoneWrap"></div>
          </div>

          <div class="col-md-6">
            <label class="form-label fw-medium">Role</label>
            <select name="role_id" id="selRole" class="form-select" style="width:100%;">
              <option value="">— No Role —</option>
              <% if (typeof roles !== 'undefined') { roles.forEach(function(r){ %>
              <option value="<%- r.id %>" <%- isEdit && u.role_id==r.id ? 'selected':'' %>><%- r.name %></option>
              <% }) } %>
            </select>
          </div>

          <% if (isEdit) { %>
          <div class="col-md-6">
            <label class="form-label fw-medium">Status</label>
            <select name="status" class="form-select">
              <option value="1" <%- parseInt(u.status) ? 'selected':'' %>>Active</option>
              <option value="0" <%- !parseInt(u.status) ? 'selected':'' %>>Inactive</option>
            </select>
          </div>
          <% } %>

        </div>
      </div>
    </div>

    <!-- Location -->
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-geo-alt-fill me-1 text-primary"></i>Location
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-medium">Country</label>
            <select name="country_id" id="sCountry" class="form-select" style="width:100%;">
              <option value="">— Select Country —</option>
              <% if (typeof countries !== 'undefined') { countries.forEach(function(c){ %>
              <option value="<%- c.id %>"
                <% if (isEdit && u.country_id == c.id) { %>selected<% } %>><%- c.name %></option>
              <% }) } %>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">State</label>
            <select name="state_id" id="sState" class="form-select" style="width:100%;">
              <option value="">— Select State —</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">City</label>
            <select name="city_id" id="sCity" class="form-select" style="width:100%;">
              <option value="">— Select City —</option>
            </select>
          </div>
          <div class="col-md-8">
            <label class="form-label fw-medium">Address</label>
            <input type="text" name="address" class="form-control"
                   value="<%- isEdit ? (u.address||'') : '' %>" placeholder="Street address"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-medium">ZIP Code</label>
            <input type="text" name="zip_code" class="form-control"
                   value="<%- isEdit ? (u.zip_code||'') : '' %>" placeholder="ZIP / Postal code"/>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right column -->
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-person-badge me-1 text-primary"></i>Personal Details
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label fw-medium">Gender</label>
            <select name="gender" class="form-select">
              <option value="">— Select —</option>
              <option value="male"   <%- isEdit&&u.gender==='male'   ? 'selected':'' %>>Male</option>
              <option value="female" <%- isEdit&&u.gender==='female' ? 'selected':'' %>>Female</option>
              <option value="other"  <%- isEdit&&u.gender==='other'  ? 'selected':'' %>>Other</option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label fw-medium">Date of Birth</label>
            <input type="date" name="dob" class="form-control"
                   value="<%- isEdit&&u.dob ? String(u.dob).slice(0,10) : '' %>"/>
          </div>
          <div class="col-12">
            <label class="form-label fw-medium">Aadhar Number</label>
            <input type="text" name="aadhar_no" class="form-control"
                   value="<%- isEdit ? (u.aadhar_no||'') : '' %>"
                   placeholder="12-digit" maxlength="12"/>
          </div>
          <div class="col-12">
            <label class="form-label fw-medium">PAN Number</label>
            <input type="text" name="pan_no" class="form-control text-uppercase"
                   value="<%- isEdit ? (u.pan_no||'') : '' %>"
                   placeholder="ABCDE1234F" maxlength="10"/>
          </div>
        </div>
      </div>
    </div>

    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;">
          <i class="bi bi-shield-check me-1 text-primary"></i>Access
        </div>
      </div>
      <div class="card-body">
        <label class="form-check form-switch">
          <input type="checkbox" class="form-check-input" name="is_org_admin" value="1"
                 <%- isEdit&&parseInt(u.is_org_admin) ? 'checked':'' %>/>
          <span class="form-check-label fw-medium">Organisation Admin</span>
        </label>
        <div class="form-hint">Bypasses all permission checks within this org.</div>
      </div>
    </div>

    <!-- Action buttons -->
    <div class="card mt-3 shadow-sm">
      <div class="card-body py-3">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary" id="btnSubmit" title="<%- isEdit ? 'Update user' : 'Create new user' %>">
            <i class="bi bi-floppy me-1"></i><%- isEdit ? 'Update User' : 'Create User' %>
          </button>
          <a href="/users" class="btn btn-outline-secondary" title="Discard and go back">
            <i class="bi bi-x-lg me-1"></i>Cancel
          </a>
        </div>
      </div>
    </div>
  </div>

</div>
</form>

<!-- Pass server data to JS without backticks -->
<script>
window._FORM_DATA = {
  isEdit:     <%= isEdit ? 'true' : 'false' %>,
  country_id: <%= isEdit && u.country_id ? u.country_id : 0 %>,
  state_id:   <%= isEdit && u.state_id   ? u.state_id   : 0 %>,
  city_id:    <%= isEdit && u.city_id    ? u.city_id    : 0 %>
};
</script>

<% block('scripts', '<script src="/js/common/phone.js"></script><script src="/js/pages/users-form.js"></script>') %>
