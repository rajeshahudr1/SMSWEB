<%- layout('../layouts/main') %>

<!-- ── PAGE HEADER ──────────────────────────────── -->
<div class="page-header d-print-none mb-3">
  <div class="row align-items-center g-2">
    <div class="col">
      <h2 class="page-title mb-0">
        <i class="ti ti-users me-2 text-primary"></i>User Management
      </h2>
      <nav aria-label="breadcrumb" class="mt-1">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/dashboard"><i class="ti ti-home me-1"></i>Dashboard</a></li>
          <li class="breadcrumb-item active">Users</li>
        </ol>
      </nav>
    </div>
    <div class="col-auto d-flex gap-2">
      <% if (can('add_users')) { %>
      <button class="btn btn-primary" id="btnAddUser">
        <i class="ti ti-user-plus me-1"></i>
        <span class="d-none d-sm-inline">Add User</span>
      </button>
      <% } %>
    </div>
  </div>
</div>

<!-- ── MAIN LISTING CARD ─────────────────────────── -->
<div class="card">

  <!-- Card toolbar -->
  <div class="card-header">
    <div class="card-title d-flex align-items-center gap-2">
      <i class="ti ti-table text-secondary"></i>
      All Users
      <span class="badge bg-blue-lt" id="badgeTotal">–</span>
    </div>
    <div class="card-options gap-2">

      <!-- Export dropdown -->
      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
          <i class="ti ti-download me-1"></i><span class="d-none d-md-inline">Export</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
          <li class="dropdown-header" style="font-size:11px;">Export Data</li>
          <li><a class="dropdown-item" href="#" id="expCsv">
            <i class="ti ti-file-text me-2 text-success"></i>CSV
          </a></li>
          <li><a class="dropdown-item" href="#" id="expExcel">
            <i class="ti ti-file-spreadsheet me-2 text-success"></i>Excel (.xlsx)
          </a></li>
          <li><a class="dropdown-item" href="#" id="expPdf">
            <i class="ti ti-file-type-pdf me-2 text-danger"></i>PDF
          </a></li>
          <li><a class="dropdown-item" href="#" id="expPrint">
            <i class="ti ti-printer me-2 text-primary"></i>Print
          </a></li>
          <li><hr class="dropdown-divider"></li>
          <li class="dropdown-header" style="font-size:11px;">Import</li>
          <li><a class="dropdown-item" href="#" id="btnImport">
            <i class="ti ti-upload me-2 text-warning"></i>Import CSV / Excel
          </a></li>
        </ul>
      </div>

      <!-- Column visibility -->
      <div class="dropdown d-none d-md-block">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
          <i class="ti ti-columns me-1"></i>Columns
        </button>
        <ul class="dropdown-menu shadow-sm" id="colToggleMenu" style="min-width:160px;">
          <li class="dropdown-header" style="font-size:11px;">Show / Hide Columns</li>
          <li><label class="dropdown-item d-flex align-items-center gap-2 cursor-pointer">
            <input class="form-check-input m-0" type="checkbox" data-col="2" checked> Email
          </label></li>
          <li><label class="dropdown-item d-flex align-items-center gap-2 cursor-pointer">
            <input class="form-check-input m-0" type="checkbox" data-col="3" checked> Phone
          </label></li>
          <li><label class="dropdown-item d-flex align-items-center gap-2 cursor-pointer">
            <input class="form-check-input m-0" type="checkbox" data-col="4" checked> Role
          </label></li>
          <li><label class="dropdown-item d-flex align-items-center gap-2 cursor-pointer">
            <input class="form-check-input m-0" type="checkbox" data-col="5" checked> Panel
          </label></li>
          <li><label class="dropdown-item d-flex align-items-center gap-2 cursor-pointer">
            <input class="form-check-input m-0" type="checkbox" data-col="6" checked> Status
          </label></li>
        </ul>
      </div>

      <!-- Refresh -->
      <button class="btn btn-sm btn-outline-secondary" id="btnRefresh" title="Refresh table">
        <i class="ti ti-refresh"></i>
      </button>
    </div>
  </div>

  <!-- ── Filters row ── -->
  <div class="card-body border-bottom py-2">
    <div class="row g-2 align-items-end">

      <div class="col-12 col-md-4">
        <div class="input-group input-group-sm">
          <span class="input-group-text bg-white border-end-0">
            <i class="ti ti-search text-secondary"></i>
          </span>
          <input type="text" id="searchInput" class="form-control border-start-0 ps-0"
                 placeholder="Search name, email, phone…"/>
          <button class="btn btn-outline-secondary d-none" type="button" id="btnClearSearch" title="Clear">
            <i class="ti ti-x" style="font-size:12px;"></i>
          </button>
        </div>
      </div>

      <div class="col-6 col-sm-3 col-md-2">
        <select id="filterRole" class="form-select form-select-sm">
          <option value="">All Roles</option>
          <% roles.forEach(function(r){ %><option value="<%- r.id %>"><%- r.name %></option><% }) %>
        </select>
      </div>

      <div class="col-6 col-sm-3 col-md-2">
        <select id="filterStatus" class="form-select form-select-sm">
          <option value="">All Status</option>
          <option value="1">Active</option>
          <option value="0">Inactive</option>
        </select>
      </div>

      <div class="col-6 col-sm-3 col-md-2">
        <select id="filterPanel" class="form-select form-select-sm">
          <option value="">All Panels</option>
          <option value="b2b">B2B</option>
          <option value="b2c">B2C</option>
          <option value="both">Both</option>
        </select>
      </div>

      <div class="col-6 col-sm-3 col-md-2">
        <button class="btn btn-sm btn-outline-primary w-100"
                data-bs-toggle="collapse" data-bs-target="#advSearch" id="btnAdvSearch">
          <i class="ti ti-adjustments-horizontal me-1"></i>Advanced
        </button>
      </div>

    </div>

    <!-- Advanced search panel -->
    <div class="collapse" id="advSearch">
      <div class="mt-2 p-3 rounded-3" style="background:#f8fafc; border:1px solid #e9ecef;">
        <div class="row g-2">
          <div class="col-12"><small class="fw-bold text-uppercase text-secondary" style="letter-spacing:.06em;font-size:11px;"><i class="ti ti-filter me-1"></i>Advanced Filters</small></div>
          <div class="col-6 col-md-3">
            <label class="form-label small mb-1">Date Joined (From)</label>
            <input type="date" id="advFrom" class="form-control form-control-sm"/>
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label small mb-1">Date Joined (To)</label>
            <input type="date" id="advTo" class="form-control form-control-sm"/>
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label small mb-1">Email Verified</label>
            <select id="advVerified" class="form-select form-select-sm">
              <option value="">Any</option>
              <option value="1">Verified ✓</option>
              <option value="0">Unverified ✗</option>
            </select>
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label small mb-1">Org Admin</label>
            <select id="advAdmin" class="form-select form-select-sm">
              <option value="">Any</option>
              <option value="1">Admin Only</option>
              <option value="0">Staff Only</option>
            </select>
          </div>
          <div class="col-12 d-flex gap-2 justify-content-end pt-1">
            <button class="btn btn-sm btn-outline-secondary" id="btnResetAdv">
              <i class="ti ti-x me-1"></i>Reset
            </button>
            <button class="btn btn-sm btn-primary" id="btnApplyAdv">
              <i class="ti ti-filter me-1"></i>Apply Filters
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Table ── -->
  <div class="table-responsive">
    <table class="table table-vcenter table-hover card-table" id="datalist" style="min-width:600px;">
      <thead>
        <tr>
          <th style="width:40px; padding-left:1rem;">
            <input type="checkbox" class="form-check-input" id="chkAll"/>
          </th>
          <th style="width:42px;" class="text-secondary text-center">#</th>
          <th class="sortable" data-field="name">
            Name <i class="ti ti-selector ms-1 text-secondary" style="font-size:11px;"></i>
          </th>
          <th class="d-none d-md-table-cell sortable" data-field="email">
            Email <i class="ti ti-selector ms-1 text-secondary" style="font-size:11px;"></i>
          </th>
          <th class="d-none d-lg-table-cell">Phone</th>
          <th class="d-none d-sm-table-cell">Role</th>
          <th class="d-none d-md-table-cell">Panel</th>
          <th>Status</th>
          <th style="width:130px;" class="text-end pe-3">Actions</th>
        </tr>
      </thead>
      <tbody id="tableBody">
        <tr><td colspan="9" class="text-center py-4 text-secondary">
          <div class="spinner-border spinner-border-sm me-2"></div> Loading...
        </td></tr>
      </tbody>
    </table>
  </div>

  <!-- Bulk action bar (hidden by default) -->
  <div class="sms-bulk-bar d-none" id="bulkBar">
    <span class="fw-semibold text-primary small">
      <i class="ti ti-checkbox me-1"></i><span id="bulkCount">0</span> row(s) selected
    </span>
    <div class="d-flex gap-2">
      <button class="btn btn-sm btn-outline-success" onclick="bulkAction('activate')">
        <i class="ti ti-check me-1"></i>Activate
      </button>
      <button class="btn btn-sm btn-outline-warning" onclick="bulkAction('deactivate')">
        <i class="ti ti-ban me-1"></i>Deactivate
      </button>
      <button class="btn btn-sm btn-outline-danger" onclick="bulkAction('delete')">
        <i class="ti ti-trash me-1"></i>Delete
      </button>
    </div>
  </div>

  <!-- Table footer: info + pagination -->
  <div class="card-footer d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="text-secondary small" id="tableInfo">–</div>
    <div class="sms-pagination" id="tablePagination"></div>
  </div>
</div>

<!-- ═══ OFFCANVAS: Add / Edit User Form ══════════════════ -->
<div class="offcanvas offcanvas-end" id="canvasUser" tabindex="-1" data-bs-backdrop="true">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title" id="canvasUserTitle">
      <i class="ti ti-user-plus me-2 text-primary"></i>Add User
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body" id="canvasUserBody">
    <!-- loaded by AJAX -->
  </div>
</div>

<!-- ═══ MODAL: Confirm Action ════════════════════════════ -->
<div class="modal fade sms-confirm-modal" id="confirmModal" tabindex="-1">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body">
        <span class="confirm-emoji" id="confirmEmoji">⚠️</span>
        <h4 id="confirmTitle">Are you sure?</h4>
        <p id="confirmMsg" class="mb-0">This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">
          <i class="ti ti-x me-1"></i>Cancel
        </button>
        <button class="btn btn-danger" id="btnConfirmDo">
          <i class="ti ti-check me-1"></i>Confirm
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ═══ MODAL: Import ════════════════════════════════════ -->
<div class="modal fade" id="modalImport" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-upload me-2 text-warning"></i>Import Users</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3 d-flex gap-2">
          <a href="/users/import-template" class="btn btn-sm btn-outline-secondary">
            <i class="ti ti-download me-1"></i>Download Template
          </a>
          <span class="text-secondary small d-flex align-items-center">CSV or Excel format</span>
        </div>

        <!-- Dropzone -->
        <div class="sms-dropzone" id="importDropzone">
          <input type="file" id="importFile" class="sms-dropzone__input" accept=".csv,.xlsx,.xls"/>
          <div class="sms-dropzone__icon"><i class="ti ti-cloud-upload"></i></div>
          <div class="sms-dropzone__title">Drop file here or click to browse</div>
          <div class="sms-dropzone__hint">Supports <strong>.csv</strong>, <strong>.xlsx</strong>, <strong>.xls</strong></div>
          <div class="sms-dropzone__meta">Maximum file size: 5 MB</div>
        </div>

        <!-- File preview -->
        <div class="sms-file-list" id="importFileList"></div>

        <!-- Progress -->
        <div class="mt-3 d-none" id="importProgress">
          <div class="d-flex justify-content-between small mb-1">
            <span>Uploading…</span><span id="importPct">0%</span>
          </div>
          <div class="progress" style="height:6px;">
            <div class="progress-bar" id="importBar" style="width:0;"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" id="btnDoImport" disabled>
          <i class="ti ti-upload me-1"></i>Import Now
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Export libs -->
<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

<script src="/js/pages/users.js"></script>
