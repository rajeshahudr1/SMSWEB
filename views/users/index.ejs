<%- layout('../layouts/main') %>

<div class="card shadow-sm">

  <!-- ── Card header ── -->
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto">
        <i class="bi bi-people-fill me-2 text-primary"></i><%- t('users.title', 'Users') %>
        <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span>
      </h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;" title="<%- t('general.rows_per_page', 'Rows per page') %>"></select>
      <% if (can('add_users')) { %>
      <a href="/users/create" class="btn btn-sm btn-primary" title="<%- t('users.add', 'Add User') %>">
        <i class="bi bi-person-plus me-1"></i><span class="d-none d-sm-inline"><%- t("users.add") %></span>
      </a>
      <% } %>
    </div>
  </div>

  <!-- ── Filters ── -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <div class="col-12 col-sm-4 col-lg-3">
        <input type="text" class="form-control form-control-sm sms-filter-search" id="searchInput"
               placeholder="&#128269;  Search name, email, phone…"/>
      </div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterRole" style="width:100%;">
          <option value=""><%- t("general.all") %> <%- t("nav.roles") %></option>
          <% if (typeof roles !== 'undefined') { roles.forEach(function(r){ %>
          <option value="<%- r.id %>" data-name="<%- r.name %>"><%- r.name %></option>
          <% }) } %>
        </select>
      </div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterStatus" style="width:100%;">
          <option value=""><%- t("general.all") %> <%- t("users.status") %></option>
          <option value="1"><%- t("users.active") %></option>
          <option value="0"><%- t("users.inactive") %></option>
        </select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-outline-secondary sms-filter-clear" id="btnClearFilters" title="<%- t('general.clear_filters', 'Clear all filters') %>">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Bulk bar ── -->
  <div id="bulkBar" class="d-none">
    <div class="sms-bulk-bar rounded-0 border-bottom px-3 py-2">
      <span class="fw-semibold"><span id="bulkCount">0</span> <%- t('general.selected', 'selected') %></span>
      <button class="btn btn-sm btn-white ms-auto" onclick="bulkAction('delete')" title="<%- t('bulk.delete_selected', 'Delete selected users') %>">
        <i class="bi bi-trash3 me-1 text-danger"></i><%- t('bulk.delete', 'Delete') %>
      </button>
      <button class="btn btn-sm btn-ghost-white" id="btnClearBulk" title="<%- t('bulk.clear_selection', 'Clear selection') %>"><i class="bi bi-x-lg"></i></button>
    </div>
  </div>

  <!-- ── Table ── -->
  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead>
        <tr>
          <th style="width:42px;"><input type="checkbox" class="form-check-input" id="selectAll" title="<%- t('general.select_all', 'Select all') %>"/></th>
          <th style="width:36px;" class="text-muted">#</th>
          <th class="sortable" data-field="name"><%- t("users.name") %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th class="d-none d-md-table-cell sortable" data-field="email"><%- t("users.email") %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th class="d-none d-lg-table-cell"><%- t("users.phone") %></th>
          <th class="d-none d-sm-table-cell"><%- t("users.role") %></th>
          <th class="sortable" data-field="status"><%- t("users.status") %> <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th class="text-end" style="width:120px;"><%- t("general.actions") %></th>
        </tr>
      </thead>
      <tbody id="tableBody">
        <tr><td colspan="8" class="text-center py-5 text-muted">
          <div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t("general.loading") %>
        </td></tr>
      </tbody>
    </table>
  </div>

  <div class="card-footer d-flex align-items-center flex-wrap gap-2">
    <div class="text-muted small" id="tableInfo"></div>
    <div class="ms-auto" id="tablePagination"></div>
  </div>
</div>

<!-- ════════ View User Modal — full width, split layout ════════ -->
<div class="modal fade" id="modalViewUser" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="max-width:960px;">
    <div class="modal-content">
      <div class="modal-header border-bottom py-3">
        <h5 class="modal-title fw-semibold">
          <i class="bi bi-person-badge me-2 text-primary"></i><%- t('users.details', 'User Details') %>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0" id="viewUserBody">
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
      </div>
      <div class="modal-footer py-2 border-top">
        <button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t("btn.close") %></button>
      </div>
    </div>
  </div>
</div>

<% block('scripts', '<link rel="stylesheet" href="/css/permissions.css"/><script src="/js/pages/users.js"></script>') %>
