<%- layout('../layouts/main') %>
<%
var orgs = typeof organizations !== 'undefined' ? organizations : [];
var isSuperAdmin = user && user.is_super_admin;
%>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-droplet-half me-2 text-primary"></i>Depollutions <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">-</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <% if (can('export_depollutions')) { %>
      <div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-download me-1"></i><span class="d-none d-sm-inline">Export</span></button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li><li><a class="dropdown-item" href="#" onclick="doExport('excel');return false;"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Excel</a></li><li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li></ul>
      </div><% } %>
      <% if (can('add_depollutions')) { %><a href="/depollutions/create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline">Add Depollution</span></a><% } %>
    </div>
  </div>

  <!-- Inline Filters -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="d-flex align-items-center gap-2">
      <div class="flex-grow-1"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="Search description, vehicle, parts..."/></div>
      <button class="btn btn-sm btn-outline-primary" data-bs-toggle="offcanvas" data-bs-target="#filterSidebar" title="Filters"><i class="bi bi-funnel me-1"></i><span class="d-none d-sm-inline">Filters</span> <span class="badge bg-primary-lt ms-1 d-none" id="filterCount">0</span></button>
      <button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button>
    </div>
  </div>

  <!-- Bulk bar -->
  <div id="bulkBar" class="d-none">
    <div class="sms-bulk-bar rounded-0 border-bottom px-3 py-2">
      <span class="fw-semibold"><span id="bulkCount">0</span> selected</span>
      <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-danger" onclick="bulkAction('delete')"><i class="bi bi-trash3 me-1"></i>Delete</button>
        <button class="btn btn-sm btn-outline-light d-none" id="btnBulkRecover" onclick="bulkAction('recover')"><i class="bi bi-arrow-counterclockwise me-1"></i>Recover</button>
        <button class="btn btn-sm btn-outline-light" id="btnClearBulk"><i class="bi bi-x-lg"></i></button>
      </div>
    </div>
  </div>

  <!-- View Tabs -->
  <ul class="nav nav-tabs px-3 pt-2" role="tablist">
    <li class="nav-item"><a class="nav-link active" href="#" id="tabAllRecords" data-view="all"><i class="bi bi-list-ul me-1"></i>All Records</a></li>
    <li class="nav-item"><a class="nav-link" href="#" id="tabGroupLer" data-view="ler"><i class="bi bi-collection me-1"></i>Group by LER</a></li>
  </ul>

  <!-- All Records View -->
  <div id="viewAll">
    <div class="table-responsive">
      <table class="table table-hover table-vcenter mb-0">
        <thead><tr>
          <th style="width:42px;"><input type="checkbox" class="form-check-input" id="selectAll"/></th>
          <th style="width:36px;" class="text-muted">#</th>
          <th>Type</th>
          <th>Vehicle / Part Info</th>
          <th>Description</th>
          <th class="sortable" data-field="total_wastage_value">Total Wastage <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th>LERs</th>
          <th class="d-none d-md-table-cell sortable" data-field="created_at">Created <i class="bi bi-arrow-down-up text-muted small"></i></th>
          <th class="text-end" style="width:120px;">Actions</th>
        </tr></thead>
        <tbody id="tableBody"><tr><td colspan="9" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...</td></tr></tbody>
      </table>
    </div>
    <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
  </div>

  <!-- Group by LER View -->
  <div id="viewLer" style="display:none;">
    <div class="table-responsive">
      <table class="table table-hover table-vcenter mb-0">
        <thead><tr>
          <th style="width:36px;" class="text-muted">#</th>
          <th>LER Name</th>
          <th>LER Code</th>
          <th>Unit</th>
          <th class="text-end">Default Value (Sum)</th>
          <th class="text-end">Actual Value (Sum)</th>
          <th class="text-end">Records</th>
        </tr></thead>
        <tbody id="lerGroupBody"><tr><td colspan="7" class="text-center py-5 text-muted">Switch to this tab to load data</td></tr></tbody>
      </table>
    </div>
  </div>
</div>

<!-- Advanced Filter Sidebar -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="filterSidebar" style="width:380px;">
  <div class="offcanvas-header py-2">
    <h5 class="offcanvas-title fw-semibold mb-0"><i class="bi bi-funnel me-2"></i>Advanced Filters</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body">
    <% if (isSuperAdmin && orgs.length) { %>
    <div class="mb-3">
      <label class="form-label small fw-semibold text-muted text-uppercase">Company</label>
      <select class="form-select form-select-sm" id="filterCompany">
        <option value="all">All Companies</option>
        <% orgs.forEach(function(o) { %><option value="<%- o.id %>"><%- o.company_name %></option><% }) %>
      </select>
    </div>
    <% } %>
    <div class="mb-3">
      <label class="form-label small fw-semibold text-muted text-uppercase">Type</label>
      <select class="form-select form-select-sm" id="advFilterType">
        <option value="">All Types</option>
        <option value="1">Vehicle Waste</option>
        <option value="2">Part Waste</option>
        <option value="3">Other Waste</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label small fw-semibold text-muted text-uppercase">Deleted</label>
      <select class="form-select form-select-sm" id="filterDeleted">
        <option value="">Active Records</option>
        <option value="only">Deleted Only</option>
        <option value="all">All Records</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label small fw-semibold text-muted text-uppercase">Created Date Range</label>
      <div class="row g-2">
        <div class="col-6"><input type="date" class="form-control form-control-sm" id="filterCreatedFrom" placeholder="From"/></div>
        <div class="col-6"><input type="date" class="form-control form-control-sm" id="filterCreatedTo" placeholder="To"/></div>
      </div>
    </div>
  </div>
  <div class="offcanvas-footer border-top p-3 d-flex gap-2">
    <button class="btn btn-sm btn-outline-secondary flex-fill" id="btnClearAdvFilters"><i class="bi bi-x-lg me-1"></i>Clear All</button>
    <button class="btn btn-sm btn-primary flex-fill" data-bs-dismiss="offcanvas"><i class="bi bi-check-lg me-1"></i>Apply</button>
  </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="modalView" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:720px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-droplet-half me-2 text-primary"></i>Depollution Details</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-0" id="viewBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal">Close</button></div></div></div></div>

<!-- Import Modal -->
<div class="modal fade" id="modalImport" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:980px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-upload me-2 text-info"></i>Import Depollutions</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<div class="modal-body" style="max-height:75vh;overflow-y:auto;">
  <div id="importProcessing" class="d-none">
    <div class="text-center py-5">
      <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;"></div>
      <h5 class="text-primary mb-1">Import in process...</h5>
      <p class="text-muted small mb-0">Please wait while we process your file.</p>
    </div>
  </div>
  <div id="importStep1">
    <div style="background:#f0f6ff;border:1px solid #c5d9f1;border-radius:8px;padding:20px;">
      <h6 class="mb-3"><i class="bi bi-info-circle me-1 text-primary"></i>Import Instructions</h6>
      <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="badge bg-danger-lt px-2 py-1"><code>type</code> <small>(required)</small></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>vehicle_internal_id</code></span>
        <span class="badge bg-blue-lt px-2 py-1"><code>description</code></span>
        <span class="badge bg-green-lt px-2 py-1"><code>ler_codes</code></span>
        <span class="badge bg-green-lt px-2 py-1"><code>wastage_values</code></span>
      </div>
      <div class="table-responsive mb-3">
        <table class="table table-sm table-bordered mb-0" style="font-size:12px;">
          <thead class="table-light"><tr><th style="width:150px;">Column</th><th style="width:70px;">Required</th><th>Description</th><th style="width:140px;">Example</th></tr></thead>
          <tbody>
            <tr><td><code>type</code></td><td class="text-center"><span class="text-danger fw-bold">Yes</span></td><td>Type: Vehicle Waste, Part Waste, or Other Waste</td><td><code>Vehicle Waste</code></td></tr>
            <tr><td><code>vehicle_internal_id</code></td><td class="text-center text-muted">No</td><td>Vehicle internal ID (for Vehicle Waste type)</td><td><code>VH-00012</code></td></tr>
            <tr><td><code>description</code></td><td class="text-center text-muted">No</td><td>Description text</td><td><code>Engine oil drain</code></td></tr>
            <tr><td><code>ler_codes</code></td><td class="text-center text-muted">No</td><td>Pipe-separated LER codes</td><td><code>13 02 05|16 01 07</code></td></tr>
            <tr><td><code>wastage_values</code></td><td class="text-center text-muted">No</td><td>Pipe-separated wastage values matching LER codes</td><td><code>5.0000|2.5000</code></td></tr>
          </tbody>
        </table>
      </div>
      <div class="row g-3">
        <div class="col-md-6"><div class="border rounded p-2 bg-white" style="font-size:12px;"><strong class="text-success"><i class="bi bi-check-circle me-1"></i>Import Rules:</strong><ul class="mb-0 mt-1 ps-3"><li>Type is required for each row</li><li>Vehicle Internal ID needed for Vehicle Waste</li><li>LER codes matched by code from your LER list</li><li>Large files run in background with notification</li></ul></div></div>
        <div class="col-md-6"><div class="border rounded p-2 bg-white" style="font-size:12px;"><strong class="text-info"><i class="bi bi-file-earmark-text me-1"></i>File Requirements:</strong><ul class="mb-0 mt-1 ps-3"><li>Formats: <strong>.csv</strong>, <strong>.xlsx</strong>, <strong>.xls</strong></li><li>Unlimited rows per import</li><li>First row = column headers</li><li>Headers are case-insensitive</li></ul></div></div>
      </div>
    </div>
    <div class="mt-3 d-flex align-items-center gap-3">
      <a href="/templates/depollutions-import-template.csv" class="btn btn-sm btn-outline-primary" download><i class="bi bi-download me-1"></i>Download Template</a>
      <form id="frmImport" enctype="multipart/form-data" class="d-flex align-items-center gap-2 flex-grow-1">
        <div class="flex-grow-1"><input type="file" name="file" id="importFile" class="form-control form-control-sm" accept=".csv,.xlsx,.xls" required/></div>
        <button type="submit" class="btn btn-info btn-sm" id="btnImport"><i class="bi bi-upload me-1"></i>Import</button>
      </form>
    </div>
  </div>
  <div id="importStep2" class="d-none">
    <div id="importSummary" class="mb-3"></div>
    <div id="importResultTable" style="max-height:450px;overflow-y:auto;overflow-x:auto;"></div>
    <div id="importErrorActions" class="d-none mt-3 d-flex gap-2">
      <button class="btn btn-sm btn-warning" id="btnRetryAllErrors"><i class="bi bi-arrow-repeat me-1"></i>Retry All Errors</button>
    </div>
  </div>
  <div id="importStep3" class="d-none">
    <div class="text-center py-4">
      <div class="mb-3"><i class="bi bi-cloud-upload text-primary" style="font-size:48px;"></i></div>
      <h5 class="fw-semibold mb-1">Importing in background...</h5>
      <p class="text-muted small mb-3">Processing your file. You can keep this window open.</p>
      <div class="progress mb-3" style="height:24px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated" id="impProgressBar" role="progressbar" style="width:0%;font-size:12px;"><span id="impPercent">0%</span></div>
      </div>
      <div class="d-flex justify-content-center gap-4 text-center">
        <div><div class="text-muted small">Total</div><strong id="impTotal">0</strong></div>
        <div><div class="text-muted small">Processed</div><strong id="impProcessed">0</strong></div>
        <div><div class="text-muted small text-success">Success</div><strong id="impSuccess" class="text-success">0</strong></div>
        <div><div class="text-muted small text-danger">Errors</div><strong id="impErrors" class="text-danger">0</strong></div>
      </div>
    </div>
  </div>
</div>
<div class="modal-footer py-2">
  <button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal" id="btnImportClose">Close</button>
</div>
</div></div></div>

<script>window._IS_SUPER = <%= isSuperAdmin ? 'true' : 'false' %>;</script>
<% block('scripts', '<script src="/js/pages/depollutions.js"></script>') %>
