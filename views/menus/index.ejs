<%- layout('../layouts/main') %>

<!-- ── Main grid ── -->
<div class="row g-3 align-items-start">

  <!-- Tree column -->
  <div class="col-xl-9 col-lg-8">
    <div class="card shadow-sm">

      <!-- Card header — title + B2B/B2C switch + actions -->
      <div class="card-header py-2">
        <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
          <h3 class="card-title mb-0 me-auto">
            <i class="bi bi-diagram-2 me-2 text-primary"></i>Menu Structure
          </h3>

          <!-- B2B / B2C pill toggle -->
          <div class="sms-panel-toggle" id="panelGroup">
            <button class="sms-panel-btn active" data-panel="b2b">
              <i class="bi bi-building"></i>
              <span>B2B</span>
            </button>
            <button class="sms-panel-btn" data-panel="b2c">
              <i class="bi bi-person"></i>
              <span>B2C</span>
            </button>
          </div>

          <div class="vr d-none d-sm-block" style="height:20px;opacity:.2;"></div>

          <!-- Stats — shown after tree loads -->
          <span id="statsBar" class="d-none d-md-flex align-items-center gap-2" style="display:none;">
            <span class="badge bg-secondary-lt rounded-pill" id="sBadgeTotal"></span>
            <span class="badge bg-success-lt  rounded-pill" id="sBadgeVisible"></span>
            <span class="badge bg-warning-lt  rounded-pill" id="sBadgeHidden" style="display:none;"></span>
          </span>
          <div class="vr d-none" id="statsVr"></div>

          <!-- Expand / Collapse -->
          <button class="btn btn-sm btn-outline-secondary" id="btnExpand" title="Expand all">
            <i class="bi bi-chevron-bar-down"></i>
          </button>
          <button class="btn btn-sm btn-outline-secondary" id="btnCollapse" title="Collapse all">
            <i class="bi bi-chevron-bar-up"></i>
          </button>

          <!-- Sort top-level menus -->
          <button class="btn btn-sm btn-outline-secondary" id="btnSortMain"
                  title="Sort / reorder main menus">
            <i class="bi bi-sort-down-alt me-1"></i>Sort
          </button>
          <!-- Add main menu — always L1 -->
          <button class="btn btn-sm btn-primary" id="btnAddMain"
                  title="Add a new top-level main menu">
            <i class="bi bi-plus-lg me-1"></i>Add Menu
          </button>
        </div>
      </div>

      <div class="px-3 py-2 bg-body-secondary border-top border-bottom sms-hint">
        <i class="bi bi-grip-vertical"></i> Drag to reorder within same level
        &nbsp;·&nbsp;
        <i class="bi bi-plus-lg text-success"></i> Row <strong>+</strong> adds child inside
        &nbsp;·&nbsp;
        <i class="bi bi-arrows-move text-primary"></i> <strong>Move</strong> reparents anywhere
      </div>

      <div class="card-body p-2" style="min-height:180px;">
        <div id="treeLoading" class="text-center py-5 text-muted">
          <div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t("general.loading") %>
        </div>
        <div id="treeRoot"></div>
      </div>

    </div>
  </div>

  <!-- Help column -->
  <div class="col-xl-3 col-lg-4">

    <!-- Level guide -->
    <div class="card shadow-sm mb-3">
      <div class="card-header py-2">
        <h3 class="card-title" style="font-size:13px;">
          <i class="bi bi-layers me-1 text-primary"></i>Level Guide
        </h3>
      </div>
      <div class="list-group list-group-flush sms-guide">
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
          <span class="sms-lbadge sms-lbadge-1">L1</span>
          <div><div class="fw-medium" style="font-size:13px;">Main menu</div><small class="text-muted">Top-level group</small></div>
        </div>
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
          <span class="sms-lbadge sms-lbadge-2">L2</span>
          <div><div class="fw-medium" style="font-size:13px;">Sub-menu</div><small class="text-muted">Inside main menu</small></div>
        </div>
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
          <span class="sms-lbadge sms-lbadge-3">L3</span>
          <div><div class="fw-medium" style="font-size:13px;">Child menu</div><small class="text-muted">Inside sub-menu</small></div>
        </div>
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3 border-0">
          <span class="sms-lbadge sms-lbadge-4">L4+</span>
          <div><div class="fw-medium" style="font-size:13px;">Deep child</div><small class="text-muted">Unlimited nesting</small></div>
        </div>
      </div>
    </div>

    <!-- Button guide -->
    <div class="card shadow-sm mb-3">
      <div class="card-header py-2">
        <h3 class="card-title" style="font-size:13px;">
          <i class="bi bi-cursor me-1 text-primary"></i>Button Guide
        </h3>
      </div>
      <div class="list-group list-group-flush sms-guide">
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
          <span class="sms-abtn sms-abtn-green"><i class="bi bi-plus-lg"></i></span>
          <div><div class="fw-medium" style="font-size:12.5px;">Add child</div><small class="text-muted">Sub-menu inside this item</small></div>
        </div>
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
          <span class="sms-abtn sms-abtn-blue"><i class="bi bi-arrows-move"></i></span>
          <div><div class="fw-medium" style="font-size:12.5px;">Move</div><small class="text-muted">Reparent to any level</small></div>
        </div>
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
          <span class="sms-abtn sms-abtn-violet"><i class="bi bi-sort-down-alt"></i></span>
          <div><div class="fw-medium" style="font-size:12.5px;">Sort children</div><small class="text-muted">Reorder this item's children</small></div>
        </div>
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
          <span class="sms-abtn sms-abtn-orange"><i class="bi bi-pencil"></i></span>
          <div><div class="fw-medium" style="font-size:12.5px;">Edit</div><small class="text-muted">Title, icon, route, permission</small></div>
        </div>
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3">
          <span class="sms-abtn sms-abtn-teal"><i class="bi bi-eye"></i></span>
          <div><div class="fw-medium" style="font-size:12.5px;">Visibility</div><small class="text-muted">Show/hide in sidebar</small></div>
        </div>
        <div class="list-group-item d-flex align-items-center gap-2 py-2 px-3 border-0">
          <span class="sms-abtn sms-abtn-red"><i class="bi bi-trash3"></i></span>
          <div><div class="fw-medium" style="font-size:12.5px;"><%- t("btn.delete") %></div><small class="text-muted">Remove + all sub-menus</small></div>
        </div>
      </div>
    </div>

    <!-- Tips -->
    <div class="card shadow-sm" style="border-left:3px solid var(--tblr-primary)!important;">
      <div class="card-body py-2 px-3 sms-guide">
        <div class="fw-semibold text-primary mb-1" style="font-size:12.5px;">
          <i class="bi bi-sort-up me-1"></i>Sorting Tips
        </div>
        <ul class="mb-0 ps-3 text-muted" style="font-size:12px;line-height:1.95;">
          <li>Drag <i class="bi bi-grip-vertical"></i> to reorder within same parent</li>
          <li>Row <strong>Sort</strong> button reorders that item's children</li>
          <li>Top <strong>Sort</strong> button reorders main L1 menus</li>
          <li>Each level has its own independent sort order</li>
        </ul>
      </div>
    </div>

  </div>
</div>

<!-- ════════ Sort Modal ════════ -->
<div class="modal fade" id="modalSort" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
    <div class="modal-content">
      <div class="modal-header border-bottom py-3">
        <h5 class="modal-title fw-semibold">
          <i class="bi bi-sort-down-alt me-2 text-primary"></i>Sort Menu Items
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-3">
        <div class="mb-2 px-2 py-1 bg-body-secondary rounded border d-flex align-items-center gap-2"
             style="font-size:12px;">
          <i class="bi bi-arrow-return-right text-muted"></i>
          Reordering children of: <strong id="sortParentName" class="ms-1"></strong>
        </div>
        <p class="text-muted mb-2" style="font-size:11.5px;">
          Drag rows up/down, or type numbers. Lower = appears first.
        </p>
        <div id="sortList" style="max-height:360px;overflow-y:auto;"></div>
      </div>
      <div class="modal-footer py-2 border-top">
        <button class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t("btn.cancel") %></button>
        <button class="btn btn-primary btn-sm" id="btnSortSave">
          <i class="bi bi-floppy me-1"></i>Save Order
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ════════ Move Modal ════════ -->
<div class="modal fade" id="modalMove" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width:440px;">
    <div class="modal-content">
      <div class="modal-header border-bottom py-3">
        <h5 class="modal-title fw-semibold">
          <i class="bi bi-arrows-move me-2 text-primary"></i>Move Menu Item
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-3">
        <div class="mb-3 px-3 py-2 rounded d-flex align-items-center gap-2"
             style="background:rgba(32,107,196,.07);border:1px solid rgba(32,107,196,.2);">
          <i class="bi bi-dot text-primary fs-4 flex-shrink-0"></i>
          <div>
            <div class="fw-semibold" id="moveItemName" style="font-size:13.5px;"></div>
            <div class="text-muted" style="font-size:11.5px;">
              Current parent: <span id="moveItemCurrent"></span>
            </div>
          </div>
        </div>
        <label class="form-label fw-medium mb-1">Move into</label>
        <select id="moveTarget" class="form-select form-select-sm">
          <option value="">— Top Level (becomes Main Menu L1) —</option>
        </select>
        <div class="mt-2 px-2 py-2 bg-body-secondary rounded border"
             style="font-size:11.5px;color:var(--tblr-text-muted);">
          <i class="bi bi-info-circle text-primary me-1"></i>
          All children move with it. Levels recalculate automatically.
          Self and descendants excluded from list.
        </div>
      </div>
      <div class="modal-footer py-2 border-top">
        <button class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t("btn.cancel") %></button>
        <button class="btn btn-primary btn-sm" id="btnMoveConfirm">
          <i class="bi bi-check-lg me-1"></i>Confirm Move
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ════════ Delete Confirm Modal ════════ -->
<div class="modal fade" id="modalDelete" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-header border-bottom py-3">
        <h5 class="modal-title fw-semibold text-danger">
          <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-3">
        <p class="mb-1" style="font-size:13.5px;">Delete <strong id="delItemName"></strong>?</p>
        <div class="alert alert-warning py-2 mb-0 mt-2" style="font-size:12px;"
             id="delHasKidsWarning">
          <i class="bi bi-exclamation-circle me-1"></i>
          This will also delete all sub-menus inside it.
        </div>
        <p class="text-muted mt-2 mb-0" style="font-size:12px;">This cannot be undone.</p>
      </div>
      <div class="modal-footer py-2 border-top">
        <button class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t("btn.cancel") %></button>
        <button class="btn btn-danger btn-sm" id="btnDeleteConfirm">
          <i class="bi bi-trash3 me-1"></i>Yes, Delete
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ════════ Offcanvas: Add / Edit form ════════ -->
<div class="offcanvas offcanvas-end shadow-lg" tabindex="-1" id="ocMenu"
     style="width:min(520px,100vw);">
  <div class="offcanvas-header border-bottom bg-body-secondary py-3">
    <div>
      <h5 class="offcanvas-title fw-semibold mb-0" id="ocTitle"><%- t("menus.menu_item") %></h5>
      <small class="text-muted d-block mt-1" id="ocSub"></small>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body p-3" id="ocBody">
    <div class="text-center py-5">
      <div class="spinner-border text-primary"></div>
    </div>
  </div>
</div>

<%
/* Load menus.css then menus.js via the scripts block.
   The layout only has a 'scripts' block (no 'styles' block),
   so the link tag is injected there — valid in HTML5. */
%>
<% include ../partials/usage-modal %>

<% block('scripts', '<link rel="stylesheet" href="/css/menus.css"/><script src="/js/pages/menus.js"></script>') %>
