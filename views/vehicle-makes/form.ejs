<%- layout('../layouts/main') %>
<%
var rec    = typeof partType !== 'undefined' ? partType : null;
var isEdit = !!rec;
var langs  = typeof languages !== 'undefined' ? languages : [];
var orgs   = typeof organizations !== 'undefined' ? organizations : [];
var formAction = isEdit ? '/vehicle-makes/' + rec.uuid : '/vehicle-makes';
var isSuperAdmin = user && user.is_super_admin;

var transMap = {};
if (rec && rec.translations) rec.translations.forEach(function(tr) { transMap[tr.language_id] = tr.name; });

var uploadedImgUrl = '';
var externalImgUrl = '';
if (isEdit) { uploadedImgUrl = rec.uploaded_image_url || ''; externalImgUrl = rec.image_full_url || ''; }
var displayImg = rec && rec.display_image_url ? rec.display_image_url : '';
%>

<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/vehicle-makes" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i><%- t('general.back') %></a>
  <h3 class="mb-0" style="font-size:16px;"><i class="bi bi-building me-2 text-primary"></i><%- isEdit ? t('vehicle_makes.edit') : t('vehicle_makes.add') %></h3>
</div>

<form id="frmPartType" method="POST" action="<%- formAction %>" enctype="multipart/form-data" novalidate>
<div class="row g-3">

  <div class="col-lg-8">

    <% if (isSuperAdmin) { %>
    <div class="card shadow-sm mb-3">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-building me-1 text-primary"></i><%- t('general.company') %></div></div>
      <div class="card-body">
        <select name="company_id" id="selCompany" class="form-select">
          <option value="global" <%- (!isEdit || !rec.organization_id) ? 'selected' : '' %>><%- t('general.global_super_admin') %></option>
          <% orgs.forEach(function(o) { %>
          <option value="<%- o.id %>" <%- (isEdit && rec.organization_id && String(rec.organization_id) === String(o.id)) ? 'selected' : '' %>><%- o.company_name %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <% } %>

    <!-- FK Dropdowns -->
    <div class="card shadow-sm mb-3">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-link-45deg me-1 text-primary"></i><%- t('vehicle_makes.linked_to') %></div></div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-12">
            <label class="form-label fw-medium"><%- t('vehicle_makes.vehicle_type') %> <span class="text-danger">*</span></label>
            <select name="vehicle_type_id" id="selVehicleType" class="form-select" style="width:100%;">
              <% if (isEdit && rec.vehicle_type_id) { %>
              <option value="<%- rec.vehicle_type_id %>" selected><%- rec.vehicle_type_name || rec.vehicle_type_id %></option>
              <% } %>
            </select>
            <div class="form-hint"><%- t('vehicle_makes.vehicle_type_hint') %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-info-circle me-1 text-primary"></i><%- t('vehicle_makes.information') %></div></div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-12">
            <label class="form-label fw-medium"><%- t('vehicle_makes.name_default') %> <span class="text-danger">*</span></label>
            <input type="text" name="name" id="fName" class="form-control" required autofocus value="<%= isEdit ? (rec.name||'') : '' %>" placeholder="<%- t('vehicle_makes.name') %>"/>
          </div>
          <div class="col-md-12">
            <label class="form-label fw-medium"><%- t('vehicle_makes.image_external') %></label>
            <input type="url" name="image_full_url" id="fImageUrl" class="form-control" value="<%= externalImgUrl %>" placeholder="https://example.com/images/make.jpg"/>
          </div>
        </div>
      </div>
    </div>

    <% if (langs.length > 0) { %>
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0 d-flex align-items-center" style="font-size:14px;">
          <span><i class="bi bi-translate me-1 text-primary"></i><%- t('vehicle_makes.translations') %> <span class="badge bg-primary-lt ms-1" style="font-size:10px;"><%- langs.length %> <%- t('general.languages') %></span></span>
          <button type="button" class="btn btn-sm btn-outline-info ms-auto d-none ai-translate-btn" id="btnTranslateAll" title="AI Translate All"><i class="bi bi-stars me-1"></i>Translate All</button>
        </div>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-3"><%- t('vehicle_makes.translations_hint') %></p>
        <div class="row g-3">
          <% langs.forEach(function(lang) { %>
          <div class="col-md-6">
            <label class="form-label fw-medium">
              <% if (lang.flag) { %><span class="me-1"><%- lang.flag %></span><% } %><%- lang.name %>
              <% if (lang.native_name) { %><span class="text-muted ms-1" style="font-size:11px;">(<%- lang.native_name %>)</span><% } %>
            </label>
            <input type="text" name="trans_<%- lang.id %>" class="form-control" value="<%= transMap[lang.id] || '' %>" placeholder="<%- lang.name %>" data-lang-id="<%- lang.id %>" data-lang-name="<%- lang.name %>" data-lang-code="<%- lang.code %>"/>
            <button type="button" class="btn btn-sm btn-ghost-info mt-1 d-none ai-translate-btn ai-single-btn" data-lang-id="<%- lang.id %>" data-lang-name="<%- lang.name %>" data-lang-code="<%- lang.code %>"><i class="bi bi-stars me-1"></i><span class="d-none d-sm-inline">AI</span></button>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-image me-1 text-primary"></i><%- t('vehicle_makes.image') %></div></div>
      <div class="card-body text-center">
        <% if (isEdit && (uploadedImgUrl || externalImgUrl)) { %>
        <div class="mb-3">
          <img src="<%- uploadedImgUrl || externalImgUrl %>" class="rounded border" style="max-width:100%;max-height:140px;object-fit:contain;" onerror="this.src='/images/no-image.svg'"/>
        </div>
        <% } else { %>
        <div class="border rounded d-flex align-items-center justify-content-center mb-3" style="height:100px;background:var(--tblr-bg-surface-secondary);"><img src="/images/no-image.svg" style="width:60px;opacity:.5;"/></div>
        <% } %>
        <div id="newImagePreview"></div>
        <input type="file" name="image" id="fImage" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.gif,.webp"/>
        <% if (isEdit && uploadedImgUrl) { %>
        <label class="form-check form-switch mt-2 d-inline-flex"><input type="checkbox" class="form-check-input" name="remove_image" id="fRemoveImg" value="1"/><span class="form-check-label text-danger small"><%- t('vehicle_makes.image_remove') %></span></label>
        <% } %>
      </div>
    </div>

    <% if (isEdit) { %>
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-toggle-on me-1 text-primary"></i><%- t('general.status') %></div></div>
      <div class="card-body"><select name="status" class="form-select"><option value="1" <%- parseInt(rec.status) ? 'selected' : '' %>><%- t('general.active') %></option><option value="0" <%- !parseInt(rec.status) ? 'selected' : '' %>><%- t('general.inactive') %></option></select></div>
    </div>
    <% } %>

    <div class="card mt-3 shadow-sm">
      <div class="card-body py-3">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary" id="btnSubmit"><i class="bi bi-floppy me-1"></i><%- isEdit ? t('general.update') : t('general.create') %></button>
          <a href="/vehicle-makes" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i><%- t('btn.cancel') %></a>
        </div>
      </div>
    </div>
  </div>

</div>
</form>

<script>
window._FORM_DATA = { isEdit: <%= isEdit ? 'true' : 'false' %>, langIds: [<%= langs.map(function(l){ return l.id; }).join(',') %>],
  langs: <%- JSON.stringify(langs.map(function(l){ return {id:l.id, name:l.name, code:l.code}; })) %>,
  vehicleTypeId: <%- isEdit && rec.vehicle_type_id ? rec.vehicle_type_id : 'null' %>,
  vehicleTypeName: "<%- isEdit && rec.vehicle_type_name ? rec.vehicle_type_name : '' %>"
};
</script>
<% block('scripts', '<script src="/js/pages/vehicle-makes-form.js"></script>') %>
