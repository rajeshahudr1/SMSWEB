<%- layout('../layouts/auth') %>

<div class="sms-auth-cover" style="justify-content:center;background:#f0f4f8;">
  <div class="sms-auth-cover__right" style="width:100%;max-width:480px;border-radius:16px;margin:2rem auto;min-height:unset;box-shadow:0 6px 32px rgba(0,0,0,.10);">
    <div class="sms-auth-form-wrap" style="max-width:100%;">

      <div class="text-center mb-4">
        <div style="font-size:52px;line-height:1;">🔐</div>
        <div class="sms-auth-title mt-2">Forgot your password?</div>
        <p class="sms-auth-subtitle">Enter your email and we'll send you a reset link.</p>
      </div>

      <form id="frmForgot" novalidate>
        <div class="mb-3">
          <label class="sms-label">Email address</label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-envelope"></i></span>
            <input type="email" name="email" id="fEmail" placeholder="your@company.com" autofocus/>
          </div>
          <div class="sms-field-error" id="err-email"></div>
        </div>
        <button type="submit" class="sms-btn-auth" id="btnForgot">
          <i class="bi bi-circle me-1"></i> Send Reset Link
        </button>
      </form>

      <p class="text-center text-secondary mt-4 mb-0" style="font-size:13px;">
        Remember it? <a href="/login" class="text-primary fw-medium">Sign in</a>
      </p>

    </div>
  </div>
</div>

<% block('scripts', '<script src="/js/pages/forgot-password.js"></script>') %>
