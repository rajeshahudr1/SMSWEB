<%- layout('../layouts/auth') %>

<%
var pg        = locals.pageData || null;
var title     = pg ? pg.title   : 'Privacy Policy';
var content   = pg ? pg.content : '';
var updatedAt = pg ? pg.updated_at : null;
var hasData   = pg && pg.content && pg.content.trim().length > 10;
%>

<div class="sms-legal-wrap">
<div class="sms-legal-container">

  <!-- ═══ HEADER ════════════════════════════════════════════ -->
  <div class="sms-legal-header" style="background:linear-gradient(145deg,#065f46 0%,#059669 50%,#34d399 100%);">
    <a href="/login" class="sms-legal-header__back">
      <i class="bi bi-arrow-left-circle-fill" style="font-size:16px;"></i>
      <span>Back to Login</span>
    </a>
    <div class="sms-legal-header__row">
      <div class="sms-legal-header__icon">
        <i class="bi bi-shield-lock-fill" style="font-size:30px;"></i>
      </div>
      <div>
        <h1><%- title %></h1>
        <p>
          <% if (updatedAt) { %>
          <i class="bi bi-calendar3 me-1"></i>Last updated: <%- new Date(updatedAt).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' }) %>
          &nbsp;&middot;&nbsp;
          <% } %>
          <i class="bi bi-clock me-1"></i>~6 min read
        </p>
      </div>
    </div>
    <div class="d-flex gap-2 mt-3 flex-wrap">
      <a href="/terms" class="sms-legal-pill">
        <i class="bi bi-file-earmark-text me-1"></i> Terms &amp; Conditions
      </a>
      <a href="/privacy" class="sms-legal-pill active">
        <i class="bi bi-shield-lock me-1"></i> Privacy Policy
      </a>
      <a href="/faq" class="sms-legal-pill">
        <i class="bi bi-question-circle me-1"></i> FAQ
      </a>
    </div>
  </div>

  <!-- ═══ BODY ══════════════════════════════════════════════ -->
  <div class="sms-legal-body">

    <% if (hasData) { %>
      <%- content %>
    <% } else { %>

    <div class="sms-legal-highlight" style="border-left-color:#059669;">
      <strong>🔒 Your privacy matters to us.</strong> SMS Platform collects only what is necessary, uses it solely
      for service delivery, and never sells your data to third parties. All data is stored in India on
      encrypted infrastructure.
    </div>

    <div class="sms-data-cards">
      <div class="sms-data-card" style="background:#eef4ff;border-color:#c9deff;">
        <div style="font-size:28px;margin-bottom:6px;">🚫</div>
        <div class="fw-semibold small" style="color:#0054a6;">No Data Selling</div>
      </div>
      <div class="sms-data-card" style="background:#f0fdf4;border-color:#bbf7d0;">
        <div style="font-size:28px;margin-bottom:6px;">🔒</div>
        <div class="fw-semibold small" style="color:#065f46;">256-bit Encryption</div>
      </div>
      <div class="sms-data-card" style="background:#fefce8;border-color:#fde68a;">
        <div style="font-size:28px;margin-bottom:6px;">🇮🇳</div>
        <div class="fw-semibold small" style="color:#92400e;">India Data Residency</div>
      </div>
      <div class="sms-data-card" style="background:#fdf4ff;border-color:#e9d5ff;">
        <div style="font-size:28px;margin-bottom:6px;">⚙️</div>
        <div class="fw-semibold small" style="color:#6b21a8;">You Control Data</div>
      </div>
    </div>

    <div class="sms-legal-toc">
      <div class="sms-legal-toc__title"><i class="bi bi-list-ul me-1"></i>Table of Contents</div>
      <a href="#p1">1. Information We Collect</a>
      <a href="#p2">2. How We Use Your Information</a>
      <a href="#p3">3. Data Sharing &amp; Disclosure</a>
      <a href="#p4">4. Data Storage &amp; Security</a>
      <a href="#p5">5. Cookies &amp; Tracking</a>
      <a href="#p6">6. Your Rights</a>
      <a href="#p7">7. Data Retention</a>
      <a href="#p8">8. Children's Privacy</a>
      <a href="#p9">9. Changes to This Policy</a>
      <a href="#p10">10. Grievance Officer</a>
    </div>

    <h3 id="p1"><span class="sec-num">01</span> Information We Collect</h3>
    <p><strong>Account Information:</strong> Name, email, phone number, organisation name, yard type, and registration number collected at signup.</p>
    <p><strong>Operational Data:</strong> Vehicle intake records, weighbridge data, inventory entries, compliance documents, and all data you enter while operating the Platform.</p>
    <p><strong>Technical Data:</strong> IP address, browser type, device information, pages visited, and session duration collected for security monitoring and service improvement.</p>
    <p><strong>Payment Data:</strong> Billing information processed via RBI-compliant gateways. Raw card numbers are never stored on our servers.</p>

    <h3 id="p2"><span class="sec-num">02</span> How We Use Your Information</h3>
    <ul>
      <li>To provide, operate, and maintain the SMS Platform services</li>
      <li>To process transactions and send related billing communications</li>
      <li>To generate compliance reports under MoRTH Vehicle Scrappage Policy 2021</li>
      <li>To send service notifications, security alerts, and account messages</li>
      <li>To improve Platform features using anonymised usage analytics</li>
      <li>To respond to support requests and resolve disputes</li>
      <li>To comply with legal obligations under Indian law</li>
    </ul>

    <h3 id="p3"><span class="sec-num">03</span> Data Sharing &amp; Disclosure</h3>
    <p>We <strong>never sell, trade, or rent</strong> your personal information. We may share data with:</p>
    <ul>
      <li><strong>Service Providers:</strong> AWS India (hosting), email delivery, and payment processors under strict data processing agreements</li>
      <li><strong>Government Authorities:</strong> As required by MoRTH, VAHAN portal integration, or lawful government orders</li>
      <li><strong>Business Transfers:</strong> In a merger or acquisition scenario with prior user notification</li>
      <li><strong>With Consent:</strong> Any other sharing only with your explicit permission</li>
    </ul>

    <h3 id="p4"><span class="sec-num">04</span> Data Storage &amp; Security</h3>
    <p>All data is stored on servers in India (AWS ap-south-1 Mumbai). Security measures include:</p>
    <ul>
      <li>AES-256 encryption at rest and TLS 1.3 in transit</li>
      <li>Multi-factor authentication for all administrative access</li>
      <li>Annual third-party penetration testing</li>
      <li>Automated daily backups with 30-day retention</li>
      <li>SOC 2 Type II compliant infrastructure</li>
    </ul>

    <h3 id="p5"><span class="sec-num">05</span> Cookies &amp; Tracking</h3>
    <p>We use <strong>strictly necessary session cookies</strong> to maintain your login state. We do not use advertising cookies or third-party tracking pixels.</p>

    <h3 id="p6"><span class="sec-num">06</span> Your Rights</h3>
    <ul>
      <li><strong>Access:</strong> Request a copy of your personal data</li>
      <li><strong>Correction:</strong> Request correction of inaccurate data</li>
      <li><strong>Deletion:</strong> Request account and data deletion (subject to legal retention requirements)</li>
      <li><strong>Portability:</strong> Export operational data in CSV/Excel from the Platform at any time</li>
      <li><strong>Objection:</strong> Object to processing for specific purposes</li>
    </ul>
    <p>To exercise rights, email <a href="mailto:privacy@sms-platform.in">privacy@sms-platform.in</a>.</p>

    <h3 id="p7"><span class="sec-num">07</span> Data Retention</h3>
    <p>Account data is retained for the duration of your subscription plus 90 days for recovery, then permanently deleted. Compliance documents may be retained longer as required by law.</p>

    <h3 id="p8"><span class="sec-num">08</span> Children's Privacy</h3>
    <p>The Platform is not directed at persons under 18. If we become aware a minor has provided data, we delete it promptly.</p>

    <h3 id="p9"><span class="sec-num">09</span> Changes to This Policy</h3>
    <p>Material changes are communicated via email at least 14 days before taking effect. Continued use indicates acceptance.</p>

    <h3 id="p10"><span class="sec-num">10</span> Grievance Officer</h3>
    <p>As required under the IT (Reasonable Security Practices) Rules 2011:</p>
    <div class="sms-legal-info-box">
      <div class="fw-bold mb-1">Data Protection / Grievance Officer</div>
      <div class="text-secondary small mb-3"><%- APP_NAME %></div>
      <div class="d-flex flex-column gap-2">
        <span class="small"><i class="bi bi-envelope-fill text-primary me-2"></i><a href="mailto:grievance@sms-platform.in">grievance@sms-platform.in</a></span>
        <span class="small"><i class="bi bi-telephone-fill text-primary me-2"></i>+91 79 XXXX XXXX (Mon–Fri, 10AM–6PM IST)</span>
        <span class="small"><i class="bi bi-geo-alt-fill text-primary me-2"></i>Ahmedabad, Gujarat – 380001, India</span>
        <span class="small text-secondary"><i class="bi bi-clock-fill text-primary me-2"></i>Response within 30 days of receipt</span>
      </div>
    </div>

    <% } %>

    <!-- ═══ FOOTER ════════════════════════════════════════════ -->
    <div class="sms-lf">
      <div class="sms-lf__btns">
        <a href="/terms" class="sms-lf__btn sms-lf__btn--outline">
          <i class="bi bi-file-earmark-text"></i>
          <span>Terms &amp; Conditions</span>
          <i class="bi bi-arrow-right sms-lf__arrow"></i>
        </a>
        <a href="/login" class="sms-lf__btn sms-lf__btn--fill">
          <i class="bi bi-box-arrow-in-right"></i>
          <span>Back to Login</span>
          <i class="bi bi-arrow-right sms-lf__arrow"></i>
        </a>
      </div>
      <div class="sms-lf__copy">&copy; <%= new Date().getFullYear() %> <%- APP_NAME %>. All rights reserved.</div>
    </div>

  </div>
</div>
</div>

<button id="scrollTop" class="sms-scroll-top" title="Back to top"><i class="bi bi-chevron-up"></i></button>

<style>
.sms-legal-pill{display:inline-flex;align-items:center;padding:6px 14px;border-radius:50px;font-size:12px;font-weight:600;text-decoration:none;transition:all .2s;background:rgba(255,255,255,.12);color:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.15)}
.sms-legal-pill:hover{background:rgba(255,255,255,.2);color:#fff}
.sms-legal-pill.active{background:rgba(255,255,255,.25);color:#fff;border-color:rgba(255,255,255,.35)}

.sms-lf{margin-top:3rem;padding-top:2rem;border-top:2px solid #eef4ff}
.sms-lf__copy{text-align:center;color:#94a3b8;font-size:12px;margin-top:1.5rem}
.sms-lf__btns{display:flex;gap:14px;flex-wrap:wrap}
.sms-lf__btn{
  flex:1;min-width:200px;
  display:inline-flex;align-items:center;gap:10px;
  padding:14px 24px;border-radius:12px;
  font-size:14px;font-weight:600;color:#fff !important;
  text-decoration:none;transition:all .25s;cursor:pointer;
}
.sms-lf__arrow{margin-left:auto;opacity:.6;font-size:13px;transition:transform .25s,opacity .25s}
.sms-lf__btn:hover .sms-lf__arrow{transform:translateX(4px);opacity:1}
.sms-lf__btn:hover{transform:translateY(-2px);color:#fff !important}

.sms-lf__btn--fill{
  background:linear-gradient(135deg,#059669 0%,#10b981 100%);
  box-shadow:0 4px 15px rgba(5,150,105,.3);border:none;
}
.sms-lf__btn--fill:hover{box-shadow:0 8px 25px rgba(5,150,105,.4);color:#fff}

.sms-lf__btn--outline{
  background:linear-gradient(135deg,#334155 0%,#475569 100%);
  box-shadow:0 4px 15px rgba(51,65,85,.2);border:none;
}
.sms-lf__btn--outline:hover{box-shadow:0 8px 25px rgba(51,65,85,.3);color:#fff}

.sms-scroll-top{
  position:fixed;bottom:24px;right:24px;width:44px;height:44px;border-radius:50%;
  background:#059669;color:#fff;border:none;font-size:18px;
  display:none;align-items:center;justify-content:center;
  box-shadow:0 4px 16px rgba(0,0,0,.15);cursor:pointer;transition:all .2s;z-index:99;
}
.sms-scroll-top:hover{background:#047857;transform:translateY(-2px)}
.sms-scroll-top.show{display:flex}

@media(max-width:575px){
  .sms-lf__btns{flex-direction:column}
  .sms-lf__btn{min-width:unset;justify-content:center}
}
</style>
<script>
$(function(){var $s=$('#scrollTop');$(window).on('scroll',function(){$(window).scrollTop()>300?$s.addClass('show'):$s.removeClass('show');});$s.on('click',function(){$('html,body').animate({scrollTop:0},400);});});
</script>
