<%- layout('../layouts/auth') %>

<div class="sms-auth-cover">

  <div class="sms-auth-cover__left">
    <div class="blob blob-1"></div><div class="blob blob-2"></div>
    <div class="blob blob-3"></div><div class="blob blob-4"></div>
    <div class="sms-cover-content">
      <div class="sms-cover-brand">
        <div class="sms-cover-brand__icon">♻</div>
        <div>
          <div class="sms-cover-brand__name"><%- t('auth.sms_platform', 'SMS Platform') %></div>
          <div class="sms-cover-brand__sub"><%- t('auth.scrap_mgmt', 'Scrap Management System') %></div>
        </div>
      </div>
      <div class="sms-cover-features" style="margin-top:2rem;">
        <div class="sms-cover-feat"><span class="sms-cover-feat__dot"></span><%- t('auth.register_minutes', 'Register your company in minutes') %></div>
        <div class="sms-cover-feat"><span class="sms-cover-feat__dot"></span><%- t('auth.signup_feature_2', 'MoRTH & VAHAN compliance built-in') %></div>
        <div class="sms-cover-feat"><span class="sms-cover-feat__dot"></span><%- t('auth.signup_feature_3', 'Multi-user & role-based access') %></div>
        <div class="sms-cover-feat"><span class="sms-cover-feat__dot"></span><%- t('auth.signup_feature_4', 'Both B2B & B2C panel access') %></div>
      </div>
      <div class="sms-cover-badges mt-4">
        <span class="sms-cover-badge"><%- t('auth.badge_free', '✅ Free to start') %></span>
        <span class="sms-cover-badge"><%- t('auth.badge_multiuser', '🏢 Multi-user') %></span>
      </div>
    </div>
  </div>

  <div class="sms-auth-cover__right">
    <div class="sms-auth-form-wrap">

      <div class="sms-mobile-logo">
        <div class="sms-mobile-logo__icon">♻</div>
        <div style="font-size:18px;font-weight:800;color:#1a2332;"><%- t('auth.sms_platform', 'SMS Platform') %></div>
        <div style="font-size:12px;color:#667380;"><%- t('auth.scrap_mgmt', 'Scrap Management System') %></div>
      </div>

      <div class="sms-steps mb-3">
        <div class="sms-step active" id="ind1">1 · <%- t('auth.step_company', 'Company') %></div>
        <div class="sms-step" id="ind2">2 · <%- t('auth.step_location', 'Location') %></div>
        <div class="sms-step" id="ind3">3 · <%- t('auth.step_account', 'Account') %></div>
        <div class="sms-step" id="ind4">4 · <%- t('auth.step_verify', 'Verify') %></div>
      </div>

      <!-- ── STEP 1 ── -->
      <div id="step1">
        <div class="sms-auth-title"><%- t('auth.company_details', 'Company Details') %></div>
        <div class="sms-auth-subtitle"><%- t('auth.company_details_sub', 'Tell us about your organisation') %></div>

        <button type="button" class="sms-btn-google mb-3" id="btnGoogleSignup">
          <img src="/images/google-color.svg" width="20" height="20" alt="Google"/>
          <%- t('auth.signup_google', 'Sign up with Google') %>
        </button>
        <div class="sms-divider"><%- t('auth.or_signup_email', 'or sign up with email') %></div>

        <div class="mb-3">
          <label class="sms-label"><%- t('auth.company_org_name', 'Company / Organisation Name') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-building"></i></span>
            <input type="text" id="s1_company" placeholder="e.g. Rajesh Metals Pvt Ltd"/>
          </div>
          <div class="sms-field-error" id="err-company_name"></div>
        </div>

        <div class="mb-3">
          <label class="sms-label"><%- t('auth.company_reg', 'Company Registration Number') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-hash"></i></span>
            <input type="text" id="s1_reg" placeholder="e.g. U27100MH2023PTC123456"/>
          </div>
          <div class="sms-field-error" id="err-registration_number"></div>
        </div>

        <div class="mb-3">
          <label class="sms-label"><%- t('auth.business_email', 'Business Email') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-envelope"></i></span>
            <input type="email" id="s1_email" placeholder="admin@yourcompany.com"/>
          </div>
          <div class="sms-field-error" id="err-email"></div>
        </div>

        <div class="mb-3">
          <label class="sms-label"><%- t('form.phone', 'Phone') %></label>
          <div id="s1PhoneWrap"></div>
          <input type="hidden" id="s1_phone"/>
          <div class="sms-field-error" id="err-phone"></div>
        </div>

        <button type="button" class="sms-btn-auth" id="btnS1Next">
          <%- t('btn.continue', 'Continue') %> <i class="bi bi-arrow-right ms-1"></i>
        </button>
      </div>

      <!-- ── STEP 2 ── -->
      <div id="step2" style="display:none;">
        <div class="sms-auth-title"><%- t('auth.location_details', 'Location Details') %></div>
        <div class="sms-auth-subtitle"><%- t('auth.location_details_sub', 'Company address information') %></div>

        <div class="mb-3">
          <label class="sms-label"><%- t('form.country', 'Country') %> <span class="text-danger">*</span></label>
          <select id="s2_country" class="form-select"><option value=""><%- t('auth.select_country', '— Select Country —') %></option></select>
          <div class="sms-field-error" id="err-country_id"></div>
        </div>
        <div class="mb-3">
          <label class="sms-label"><%- t('form.state', 'State') %> <span class="text-danger">*</span></label>
          <select id="s2_state" class="form-select" disabled><option value=""><%- t('auth.select_state', '— Select State —') %></option></select>
          <div class="sms-field-error" id="err-state_id"></div>
        </div>
        <div class="mb-3">
          <label class="sms-label"><%- t('form.city', 'City') %> <span class="text-danger">*</span></label>
          <select id="s2_city" class="form-select" disabled><option value=""><%- t('auth.select_city', '— Select City —') %></option></select>
          <div class="sms-field-error" id="err-city_id"></div>
        </div>
        <div class="mb-3">
          <label class="sms-label"><%- t('auth.zip_code', 'ZIP / Postal Code') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-geo"></i></span>
            <input type="text" id="s2_zip" placeholder="e.g. 400001"/>
          </div>
          <div class="sms-field-error" id="err-zip_code"></div>
        </div>
        <div class="mb-3">
          <label class="sms-label"><%- t('auth.full_address', 'Full Address') %> <span class="text-danger">*</span></label>
          <textarea id="s2_address" class="form-control" rows="2"
                    placeholder="Plot No, Street, Area, Landmark" style="resize:none;"></textarea>
          <div class="sms-field-error" id="err-address"></div>
        </div>

        <!-- Address Proof Upload -->
        <div class="mb-4">
          <label class="sms-label">
            <%- t('auth.address_proof', 'Address Proof') %>
            <span class="text-muted fw-normal" style="font-size:11px;">
              JPG / PNG / PDF / DOC — max 10MB (<%- t('form.optional', 'optional') %>)
            </span>
          </label>
          <div class="sms-file-upload" id="s2ProofUploadBox">
            <input type="file" id="s2_proof" accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"
                   style="display:none;"/>
            <label for="s2_proof" class="sms-file-upload__label" id="s2ProofLabel">
              <i class="bi bi-cloud-upload fs-4 d-block mb-1 text-primary"></i>
              <span class="fw-medium"><%- t('form.click_upload', 'Click to upload') %></span>
              <small class="d-block text-muted mt-1"><%- t('form.or_drag_drop', 'or drag & drop here') %></small>
            </label>
          </div>
          <div class="sms-field-error" id="err-address_proof"></div>
        </div>

        <div class="d-flex gap-2">
          <button type="button" class="sms-btn-outline" style="flex:1;" id="btnS2Back">
            <i class="bi bi-arrow-left"></i> <%- t('btn.back', 'Back') %>
          </button>
          <button type="button" class="sms-btn-auth" style="flex:2;" id="btnS2Next">
            <%- t('btn.continue', 'Continue') %> <i class="bi bi-arrow-right ms-1"></i>
          </button>
        </div>
      </div>

      <!-- ── STEP 3 ── -->
      <div id="step3" style="display:none;">
        <div class="sms-auth-title"><%- t('auth.admin_account', 'Your Admin Account') %></div>
        <div class="sms-auth-subtitle"><%- t('auth.admin_account_sub', 'Set up your login credentials') %></div>

        <div class="mb-3">
          <label class="sms-label"><%- t('form.full_name', 'Full Name') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-person"></i></span>
            <input type="text" id="s3_name" placeholder="Your full name"/>
          </div>
          <div class="sms-field-error" id="err-name"></div>
        </div>
        <div class="mb-3">
          <label class="sms-label"><%- t('auth.password', 'Password') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-lock"></i></span>
            <input type="password" id="s3_pw" placeholder="Min 8 characters"/>
            <button class="sms-input-group__btn" type="button" id="btnToggleS3Pw" tabindex="-1">
              <i class="bi bi-eye" id="s3EyeIcon"></i>
            </button>
          </div>
          <div class="sms-pw-strength mt-1"><div class="sms-pw-bar" id="pwBar"></div></div>
          <div class="sms-field-error" id="err-password"></div>
        </div>
        <div class="mb-4">
          <label class="sms-label"><%- t('auth.confirm_password', 'Confirm Password') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-lock-fill"></i></span>
            <input type="password" id="s3_cpw" placeholder="Repeat password"/>
          </div>
          <div class="sms-field-error" id="err-confirm_password"></div>
        </div>

        <div class="d-flex gap-2">
          <button type="button" class="sms-btn-outline" style="flex:1;" id="btnS3Back">
            <i class="bi bi-arrow-left"></i> <%- t('btn.back', 'Back') %>
          </button>
          <button type="button" class="sms-btn-auth" style="flex:2;" id="btnS3Submit">
            <%- t('auth.create_account', 'Create Account') %> <i class="bi bi-check-lg ms-1"></i>
          </button>
        </div>
      </div>

      <!-- ── STEP 4 ── -->
      <div id="step4" style="display:none;">
        <div class="text-center mb-3">
          <div style="font-size:52px;">📧</div>
          <div class="sms-auth-title mt-2"><%- t('auth.verify_email', 'Verify your email') %></div>
          <p class="sms-auth-subtitle">
            <%- t('auth.otp_sent_to', 'We sent a') %> <strong><%- t('auth.otp_digits', '6-digit OTP') %></strong> <%- t('auth.otp_to', 'to') %><br/>
            <span class="fw-semibold text-primary" id="otpEmailDisplay"></span>
          </p>
        </div>
        <div class="sms-otp-row">
          <input type="text" class="sms-otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
          <input type="text" class="sms-otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
          <input type="text" class="sms-otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
          <input type="text" class="sms-otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
          <input type="text" class="sms-otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
          <input type="text" class="sms-otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
        </div>
        <div class="sms-field-error text-center" id="err-otp"></div>
        <button type="button" class="sms-btn-auth mt-3" id="btnVerifyOTP"><%- t('auth.verify_login', 'Verify & Login') %></button>
        <p class="text-center text-secondary mt-3 mb-0" style="font-size:13px;">
          <%- t('auth.didnt_receive', "Didn't receive it?") %>
          <button type="button" class="btn btn-link p-0 text-primary" id="btnResendOTP"
                  style="font-size:13px;vertical-align:baseline;"><%- t('auth.resend_otp', 'Resend OTP') %></button>
        </p>
      </div>

      <p class="text-center text-secondary mt-4 mb-0" style="font-size:13px;">
        <%- t('auth.have_account', 'Already have an account?') %> <a href="/login" class="text-primary fw-medium"><%- t('auth.login', 'Sign in') %></a>
      </p>

    </div>
  </div>
</div>

<div id="g_id_onload"
     data-client_id="<%= process.env.GOOGLE_CLIENT_ID || '' %>"
     data-callback="handleGoogleCredential"
     data-auto_prompt="false"></div>

<% block('scripts', '<script src="/js/pages/signup.js"></script>') %>