<%- layout('../layouts/auth') %>

<div class="sms-auth-cover" style="justify-content:center;background:#f0f4f8;">
  <div class="sms-auth-cover__right" style="width:100%;max-width:480px;border-radius:16px;margin:2rem auto;min-height:unset;box-shadow:0 6px 32px rgba(0,0,0,.10);">
    <div class="sms-auth-form-wrap" style="max-width:100%;">

      <div class="text-center mb-4">
        <div style="font-size:52px;line-height:1;">🔑</div>
        <div class="sms-auth-title mt-2">Set new password</div>
        <p class="sms-auth-subtitle">Choose a strong password for your account.</p>
      </div>

      <form id="frmReset" novalidate>
        <input type="hidden" name="token" value="<%- locals.token || '' %>"/>

        <div class="mb-3">
          <label class="sms-label">New Password</label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="ti ti-lock"></i></span>
            <input type="password" name="password" id="newPw" placeholder="Min 8 characters"/>
            <button class="sms-input-group__btn" type="button" id="btnTogglePw" tabindex="-1">
              <i class="ti ti-eye" id="eyeIcon"></i>
            </button>
          </div>
          <div class="sms-pw-strength mt-1"><div class="sms-pw-bar" id="pwBar"></div></div>
          <div class="sms-field-error" id="err-password"></div>
        </div>

        <div class="mb-4">
          <label class="sms-label">Confirm New Password</label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="ti ti-lock-check"></i></span>
            <input type="password" name="confirm_password" id="cfmPw" placeholder="Repeat password"/>
          </div>
          <div class="sms-field-error" id="err-confirm_password"></div>
        </div>

        <button type="submit" class="sms-btn-auth" id="btnReset">
          <i class="ti ti-check me-1"></i> Reset Password
        </button>
      </form>

      <p class="text-center text-secondary mt-4 mb-0" style="font-size:13px;">
        <a href="/login" class="text-primary fw-medium">← Back to Sign In</a>
      </p>

    </div>
  </div>
</div>

<% block('scripts', '<script src="/js/pages/reset-password.js"></script>') %>
