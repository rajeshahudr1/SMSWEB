<%- layout('../layouts/auth') %>

<div class="sms-auth-cover" style="justify-content:center;background:#f0f4f8;">
  <div class="sms-auth-cover__right" style="width:100%;max-width:480px;border-radius:16px;margin:2rem auto;min-height:unset;box-shadow:0 6px 32px rgba(0,0,0,.10);">
    <div class="sms-auth-form-wrap" style="max-width:100%;">

      <div class="text-center mb-4">
        <div style="font-size:52px;line-height:1;">🔑</div>
        <div class="sms-auth-title mt-2"><%- t('auth.reset_title', 'Set new password') %></div>
        <p class="sms-auth-subtitle"><%- t('auth.reset_subtitle', 'Choose a strong password for your account.') %></p>
      </div>

      <%
        // Validate token is present before rendering form
        var hasToken = token && token.trim().length > 10;
      %>

      <% if (!hasToken) { %>
      <!-- Token missing or invalid — show error with redirect -->
      <div class="alert alert-danger text-center" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong><%- t('auth.invalid_link', 'Invalid or expired reset link.') %></strong><br/>
        <%- t('auth.request_new_reset', 'Please request a new password reset.') %>
      </div>
      <a href="/forgot-password" class="sms-btn-auth text-decoration-none" style="display:flex;">
        <i class="bi bi-arrow-left me-2"></i> <%- t('auth.request_new_link', 'Request new reset link') %>
      </a>
      <% } else { %>

      <form id="frmReset" novalidate>
        <!-- Token passed as hidden field — critical for reset to work -->
        <input type="hidden" name="token" id="resetToken" value="<%- token %>"/>

        <div class="mb-3">
          <label class="sms-label"><%- t('auth.new_password', 'New Password') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-lock"></i></span>
            <input type="password" name="password" id="newPw" placeholder="Min 8 characters"/>
            <button class="sms-input-group__btn" type="button" id="btnTogglePw" tabindex="-1">
              <i class="bi bi-eye" id="eyeIcon"></i>
            </button>
          </div>
          <div class="sms-pw-strength mt-1"><div class="sms-pw-bar" id="pwBar"></div></div>
          <div class="sms-field-error" id="err-password"></div>
        </div>

        <div class="mb-4">
          <label class="sms-label"><%- t('auth.confirm_password', 'Confirm New Password') %> <span class="text-danger">*</span></label>
          <div class="sms-input-group">
            <span class="sms-input-group__icon"><i class="bi bi-lock-fill"></i></span>
            <input type="password" name="confirm_password" id="cfmPw" placeholder="Repeat password"/>
          </div>
          <div class="sms-field-error" id="err-confirm_password"></div>
        </div>

        <button type="submit" class="sms-btn-auth" id="btnReset">
          <i class="bi bi-check-lg me-1"></i> <%- t('auth.reset_btn', 'Reset Password') %>
        </button>
      </form>

      <% } %>

      <p class="text-center text-secondary mt-4 mb-0" style="font-size:13px;">
        <a href="/login" class="text-primary fw-medium">← <%- t('auth.back_to_signin', 'Back to Sign In') %></a>
      </p>

    </div>
  </div>
</div>

<% block('scripts', '<script src="/js/pages/reset-password.js"></script>') %>
