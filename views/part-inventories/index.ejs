<%- layout('../layouts/main') %>
<% block('styles', '<link rel="stylesheet" href="/css/part-inventories.css"/>') %>
<%
var isSuperAdmin = user && user.is_super_admin;
%>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-box-seam me-2 text-primary"></i><%- t('part_inventories.title', 'Part Inventory') %> <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">–</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
      <% if (can('export_part_inventories')) { %>
      <div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-download me-1"></i><span class="d-none d-sm-inline"><%- t('btn.export', 'Export') %></span></button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="#" onclick="doExport('csv');return false;"><i class="bi bi-filetype-csv me-2 text-success"></i>CSV</a></li><li><a class="dropdown-item" href="#" onclick="doExport('excel');return false;"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Excel</a></li><li><a class="dropdown-item" href="#" onclick="doExport('print');return false;"><i class="bi bi-printer me-2"></i>Print</a></li></ul>
      </div><% } %>
      <% if (can('add_part_inventories')) { %>
      <div class="dropdown"><button class="btn btn-sm btn-primary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-plus-lg me-1"></i><span class="d-none d-sm-inline"><%- t('part_inventories.add', 'Add Part') %></span></button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item" href="/part-inventories/create"><i class="bi bi-box-seam me-2 text-primary"></i><%- t('part_inventories.add_part', 'Add Part') %></a></li>
          <li><a class="dropdown-item" href="/part-inventories/create?from_vehicle=1"><i class="bi bi-truck me-2 text-info"></i><%- t('part_inventories.add_from_vehicle', 'Add from Vehicle') %></a></li>
        </ul>
      </div><% } %>
    </div>
  </div>

  <!-- Inline Filters -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="row g-2 align-items-center">
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="input-group input-group-sm">
          <input type="text" class="form-control" id="searchInput" placeholder="&#128269;  <%- t('part_inventories.search_ph', 'Search by code, name, brand, catalog...') %>"/>
          <span class="input-group-text p-0">
            <label class="form-check m-0 px-2" style="cursor:pointer;font-size:11px;">
              <input type="checkbox" class="form-check-input m-0 me-1" id="deepSearch"/> Deep
            </label>
            <button type="button" class="btn btn-sm btn-link p-0 pe-2 text-info" id="deepSearchInfo"
              data-bs-toggle="popover" data-bs-trigger="focus hover" data-bs-html="true" data-bs-placement="bottom"
              data-bs-title="Search modes"
              data-bs-content="
                <div style='font-size:11.5px;line-height:1.5;'>
                  <strong class='text-primary'><i class='bi bi-lightning-charge me-1'></i>Normal search</strong>
                  <span class='badge bg-success-lt ms-1'>fast ~50–200&nbsp;ms</span>
                  <ul class='ps-3 mb-2'>
                    <li>Part Code, Notes, Motorization, CC, CV, KW, Reg #</li>
                    <li>Catalog name, Brand name</li>
                    <li>Vehicle Make / Model / Variant</li>
                    <li>Vehicle Internal ID</li>
                  </ul>
                  <strong class='text-warning'><i class='bi bi-search me-1'></i>Deep search</strong>
                  <span class='badge bg-warning-lt ms-1'>slower ~200&nbsp;ms&ndash;2&nbsp;s</span>
                  <ul class='ps-3 mb-2'>
                    <li>Everything in Normal +</li>
                    <li>Extra / Internal Notes</li>
                    <li>Vehicle Type, Fuel, Engine, Year</li>
                    <li><strong>References</strong> (code, brand, manufacturer)</li>
                    <li><strong>Damages</strong> (description)</li>
                    <li><strong>Locations</strong> (code, notes)</li>
                    <li><strong>Attribute values</strong></li>
                  </ul>
                  <em class='text-muted'>Tip: turn Deep ON only when normal search misses what you're looking for.</em>
                </div>"
              tabindex="0" style="line-height:1;"><i class="bi bi-info-circle"></i></button>
          </span>
        </div>
      </div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterStatus"><option value=""><%- t('general.all_status', 'All Status') %></option><option value="1"><%- t('general.active', 'Active') %></option><option value="0"><%- t('general.inactive', 'Inactive') %></option></select>
      </div>
      <div class="col-6 col-sm-3 col-lg-2">
        <select class="form-select form-select-sm" id="filterDeleted"><option value=""><%- t('general.active_records', 'Active Records') %></option><option value="only"><%- t('general.deleted_only', 'Deleted Only') %></option><option value="all"><%- t('general.all_records', 'All Records') %></option></select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="offcanvas" data-bs-target="#filterSidebar" title="<%- t('general.filters', 'Filters') %>"><i class="bi bi-funnel me-1"></i><span class="d-none d-sm-inline"><%- t('general.filters', 'Filters') %></span> <span class="badge bg-primary-lt ms-1 d-none" id="filterCount">0</span></button>
        <button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button>
      </div>
    </div>
  </div>

  <!-- Bulk bar -->
  <div id="bulkBar" class="d-none">
    <div class="sms-bulk-bar rounded-0 border-bottom px-3 py-2">
      <span class="fw-semibold"><span id="bulkCount">0</span> <%- t('general.selected_count', 'selected') %></span>
      <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-outline-light" onclick="bulkAction('deactivate')"><i class="bi bi-toggle-off me-1"></i><%- t('bulk.deactivate', 'Deactivate') %></button>
        <button class="btn btn-sm btn-outline-light" onclick="bulkAction('activate')"><i class="bi bi-toggle-on me-1"></i><%- t('bulk.activate', 'Activate') %></button>
        <button class="btn btn-sm btn-danger" onclick="bulkAction('delete')"><i class="bi bi-trash3 me-1"></i><%- t('btn.delete', 'Delete') %></button>
        <button class="btn btn-sm btn-outline-light d-none" id="btnBulkRecover" onclick="bulkAction('recover')"><i class="bi bi-arrow-counterclockwise me-1"></i><%- t('bulk.recover', 'Recover') %></button>
        <button class="btn btn-sm btn-outline-light" id="btnClearBulk"><i class="bi bi-x-lg"></i></button>
      </div>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead id="piTableHead"><tr><td colspan="20" class="text-center py-3 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading columns...</td></tr></thead>
      <tbody id="tableBody"><tr><td colspan="20" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div><%- t('general.loading', 'Loading...') %></td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- ADVANCED FILTER SIDEBAR (tabbed sections) -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="filterSidebar" style="width:420px;">
  <div class="offcanvas-header py-2">
    <h5 class="offcanvas-title fw-semibold mb-0"><i class="bi bi-funnel me-2"></i><%- t('general.advanced_filters', 'Advanced Filters') %></h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>
  <!-- Filter tabs -->
  <ul class="nav nav-tabs px-3 pt-1" style="font-size:12px;">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#ftVehicle"><%- t('part_inventories.tab_vehicle', 'Vehicle') %></a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ftPart"><%- t('part_inventories.tab_part', 'Part') %></a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ftStatus"><%- t('part_inventories.tab_status', 'Status') %></a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ftDates">Dates & Text</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ftLocation"><%- t('part_inventories.tab_location', 'Location') %></a></li>
  </ul>
  <div class="offcanvas-body tab-content" style="padding-top:12px;">

    <!-- Tab: Vehicle (dependent cascading) -->
    <div class="tab-pane fade show active" id="ftVehicle">
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.vehicle_type', 'Vehicle Type') %></label>
        <select class="form-select form-select-sm" id="filterVehicleType" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.vehicle_make', 'Vehicle Make') %></label>
        <select class="form-select form-select-sm" id="filterVehicleMake" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.vehicle_model', 'Vehicle Model') %></label>
        <select class="form-select form-select-sm" id="filterVehicleModel" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.vehicle_variant', 'Vehicle Variant') %></label>
        <select class="form-select form-select-sm" id="filterVehicleVariant" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.vehicle_year', 'Vehicle Year') %></label>
        <select class="form-select form-select-sm" id="filterVehicleYear" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.vehicle_fuel', 'Vehicle Fuel') %></label>
        <select class="form-select form-select-sm" id="filterVehicleFuel" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.vehicle_engine', 'Vehicle Engine') %></label>
        <select class="form-select form-select-sm" id="filterVehicleEngine" style="width:100%;"></select>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-3"><label class="form-label small fw-semibold text-muted text-uppercase">Motor</label><input type="text" class="form-control form-control-sm" id="filterMotorization" placeholder="..."/></div>
        <div class="col-3"><label class="form-label small fw-semibold text-muted text-uppercase">CC</label><input type="text" class="form-control form-control-sm" id="filterCC"/></div>
        <div class="col-3"><label class="form-label small fw-semibold text-muted text-uppercase">CV</label><input type="text" class="form-control form-control-sm" id="filterCV"/></div>
        <div class="col-3"><label class="form-label small fw-semibold text-muted text-uppercase">KW</label><input type="text" class="form-control form-control-sm" id="filterKW"/></div>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Vehicle Internal ID</label>
        <input type="text" class="form-control form-control-sm" id="filterVehicleInternalId"/>
      </div>
    </div>

    <!-- Tab: Part -->
    <div class="tab-pane fade" id="ftPart">
      <div class="row g-2 mb-3">
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Part Code</label><input type="text" class="form-control form-control-sm" id="filterPartCode"/></div>
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Internal ID</label><input type="text" class="form-control form-control-sm" id="filterPartInternalId"/></div>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.part_brand', 'Part Brand') %></label>
        <select class="form-select form-select-sm" id="filterPartBrand" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.part_catalog', 'Part Catalog') %></label>
        <select class="form-select form-select-sm" id="filterPartCatalog" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Reg Number Dismantler</label>
        <input type="text" class="form-control form-control-sm" id="filterRegNumber"/>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Qty Min</label><input type="number" min="0" step="1" class="form-control form-control-sm" id="filterQtyMin"/></div>
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Qty Max</label><input type="number" min="0" step="1" class="form-control form-control-sm" id="filterQtyMax"/></div>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Price Min (<%= (settings && settings.currency_symbol) || '€' %>)</label><input type="number" step="0.01" class="form-control form-control-sm" id="filterPriceMin"/></div>
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Price Max (<%= (settings && settings.currency_symbol) || '€' %>)</label><input type="number" step="0.01" class="form-control form-control-sm" id="filterPriceMax"/></div>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Cost Min (<%= (settings && settings.currency_symbol) || '€' %>)</label><input type="number" step="0.01" class="form-control form-control-sm" id="filterCostMin"/></div>
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Cost Max (<%= (settings && settings.currency_symbol) || '€' %>)</label><input type="number" step="0.01" class="form-control form-control-sm" id="filterCostMax"/></div>
      </div>
      <div class="row g-2 mb-3">
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Rating Min</label><input type="number" step="0.5" min="0" max="5" class="form-control form-control-sm" id="filterRatingMin"/></div>
        <div class="col-6"><label class="form-label small fw-semibold text-muted text-uppercase">Rating Max</label><input type="number" step="0.5" min="0" max="5" class="form-control form-control-sm" id="filterRatingMax"/></div>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase d-block">Flags</label>
        <div class="row g-2">
          <div class="col-6"><select class="form-select form-select-sm" id="filterIsMaster"><option value="">Master Part: Any</option><option value="1">Yes</option><option value="0">No</option></select></div>
          <div class="col-6"><select class="form-select form-select-sm" id="filterPrintLabel"><option value="">Print Label: Any</option><option value="1">Yes</option><option value="0">No</option></select></div>
          <div class="col-6"><select class="form-select form-select-sm" id="filterVatIncluded"><option value="">VAT: Any</option><option value="1">Included</option><option value="0">Not Inc.</option></select></div>
          <div class="col-6"><select class="form-select form-select-sm" id="filterCustomSize"><option value="">Custom Size: Any</option><option value="1">Yes</option><option value="0">No</option></select></div>
        </div>
      </div>
    </div>

    <!-- Tab: Status -->
    <div class="tab-pane fade" id="ftStatus">
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.inventory_status', 'Inventory Status') %></label>
        <select class="form-select form-select-sm" id="filterInventoryStatus">
          <option value=""><%- t('general.all', 'All') %></option><option value="1"><%- t('part_inventories.in_stock', 'In Stock') %></option><option value="2"><%- t('part_inventories.out_of_stock', 'Out of Stock') %></option><option value="3"><%- t('part_inventories.reserved', 'Reserved') %></option><option value="4"><%- t('part_inventories.sold', 'Sold') %></option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.condition', 'Condition') %></label>
        <select class="form-select form-select-sm" id="filterCondition">
          <option value=""><%- t('general.all', 'All') %></option><option value="1"><%- t('part_inventories.oem', 'OEM') %></option><option value="2"><%- t('part_inventories.aftermarket', 'Aftermarket') %></option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.part_state', 'Part State') %></label>
        <select class="form-select form-select-sm" id="filterPartState">
          <option value=""><%- t('general.all', 'All') %></option><option value="1"><%- t('part_inventories.new', 'New') %></option><option value="2"><%- t('part_inventories.used', 'Used') %></option><option value="3"><%- t('part_inventories.remanufactured', 'Remanufactured') %></option><option value="4"><%- t('part_inventories.not_working', 'Not Working') %></option>
        </select>
      </div>
    </div>

    <!-- Tab: Dates & Text -->
    <div class="tab-pane fade" id="ftDates">
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Created Date Range</label>
        <div class="row g-2">
          <div class="col-6"><input type="date" class="form-control form-control-sm" id="filterCreatedFrom" placeholder="From"/></div>
          <div class="col-6"><input type="date" class="form-control form-control-sm" id="filterCreatedTo" placeholder="To"/></div>
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Updated Date Range</label>
        <div class="row g-2">
          <div class="col-6"><input type="date" class="form-control form-control-sm" id="filterUpdatedFrom"/></div>
          <div class="col-6"><input type="date" class="form-control form-control-sm" id="filterUpdatedTo"/></div>
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase">Notes Contains</label>
        <input type="text" class="form-control form-control-sm" id="filterNotes" placeholder="Search in notes / extra notes / internal notes"/>
      </div>
    </div>

    <!-- Tab: Location (dependent cascading) -->
    <div class="tab-pane fade" id="ftLocation">
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.warehouse', 'Warehouse') %></label>
        <select class="form-select form-select-sm" id="filterWarehouse" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.zone', 'Zone') %></label>
        <select class="form-select form-select-sm" id="filterZone" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.shelf', 'Shelf') %></label>
        <select class="form-select form-select-sm" id="filterShelf" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.rack', 'Rack') %></label>
        <select class="form-select form-select-sm" id="filterRack" style="width:100%;"></select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold text-muted text-uppercase"><%- t('part_inventories.bin', 'Bin') %></label>
        <select class="form-select form-select-sm" id="filterBin" style="width:100%;"></select>
      </div>
    </div>

  </div>
  <div class="offcanvas-footer border-top p-3 d-flex gap-2">
    <button class="btn btn-sm btn-outline-secondary flex-fill" id="btnClearAdvFilters"><i class="bi bi-x-lg me-1"></i><%- t('general.clear_all', 'Clear All') %></button>
    <button class="btn btn-sm btn-primary flex-fill" data-bs-dismiss="offcanvas"><i class="bi bi-check-lg me-1"></i><%- t('general.apply', 'Apply') %></button>
  </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="modalView" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl" style="max-width:960px;"><div class="modal-content"><div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-box-seam me-2 text-primary"></i><%- t('part_inventories.details', 'Part Inventory Details') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-0" id="viewBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close', 'Close') %></button></div></div></div></div>

<!-- Image Modal -->
<div class="modal fade" id="modalImage" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:600px;"><div class="modal-content"><div class="modal-header py-2"><h6 class="modal-title fw-semibold mb-0" id="imgModalTitle"><i class="bi bi-image me-2 text-primary"></i><%- t('part_inventories.image_title', 'Part Image') %></h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-3" id="imgModalBody"></div><div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal"><%- t('btn.close', 'Close') %></button></div></div></div></div>

<!-- Usage Modal -->
<% include ../partials/usage-modal %>

<script>window._IS_SUPER = <%= isSuperAdmin ? 'true' : 'false' %>;</script>
<% block('scripts', '<script src="/js/pages/part-inventories.js"></script>') %>
