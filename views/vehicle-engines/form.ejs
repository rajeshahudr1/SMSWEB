<%- layout('../layouts/main') %>
<%
var rec    = typeof record !== 'undefined' ? record : null;
var isEdit = !!rec;
var langs  = typeof languages !== 'undefined' ? languages : [];
var orgs   = typeof organizations !== 'undefined' ? organizations : [];
var formAction = isEdit ? '/vehicle-engines/' + rec.uuid : '/vehicle-engines';
var isSuperAdmin = user && user.is_super_admin;

var transMap = {};
if (rec && rec.translations) rec.translations.forEach(function(tr) { transMap[tr.language_id] = tr.name; });

var existingVariants = (rec && rec.variants) ? rec.variants : [];
%>

<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/vehicle-engines" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i><%- t('general.back') %></a>
  <h3 class="mb-0" style="font-size:16px;"><i class="bi bi-gear-wide me-2 text-primary"></i><%- isEdit ? t('vehicle_engines.edit') : t('vehicle_engines.add') %></h3>
</div>

<form id="frmEngine" method="POST" action="<%- formAction %>" novalidate>
<div class="row g-3">

  <div class="col-lg-8">

    <!-- Company selector (super admin only) -->
    <% if (isSuperAdmin) { %>
    <div class="card shadow-sm mb-3">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-building me-1 text-primary"></i>Company</div>
      </div>
      <div class="card-body">
        <select name="company_id" id="selCompany" class="form-select">
          <option value="global" <%- (!isEdit || !rec.organization_id) ? 'selected' : '' %>>Global (Super Admin)</option>
          <% orgs.forEach(function(o) { %>
          <option value="<%- o.id %>" <%- (isEdit && rec.organization_id && String(rec.organization_id) === String(o.id)) ? 'selected' : '' %>><%- o.company_name %></option>
          <% }) %>
        </select>
        <div class="form-hint mt-1">Select which company this engine belongs to.</div>
      </div>
    </div>
    <% } %>

    <!-- Main Information -->
    <div class="card shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-info-circle me-1 text-primary"></i><%- t('vehicle_engines.information') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_engines.manufacturer_engine') %> <span class="text-danger">*</span></label>
            <input type="text" name="manufacturer_engine" id="fManufacturerEngine" class="form-control" required autofocus value="<%= isEdit ? (rec.manufacturer_engine||'') : '' %>" placeholder="<%- t('vehicle_engines.manufacturer_engine_ph') %>"/>
            <div class="form-hint"><%- t('vehicle_engines.manufacturer_engine_hint') %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-medium"><%- t('vehicle_engines.motor_code') %> <span class="text-danger">*</span></label>
            <input type="text" name="motor_code" id="fMotorCode" class="form-control" required value="<%= isEdit ? (rec.motor_code||'') : '' %>" placeholder="<%- t('vehicle_engines.motor_code_ph') %>"/>
            <div class="form-hint"><%- t('vehicle_engines.motor_code_hint') %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Specs -->
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-speedometer me-1 text-primary"></i><%- t('vehicle_engines.specs') %></div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('vehicle_engines.start_year') %></label>
            <input type="number" name="start_year" id="fStartYear" class="form-control" min="1900" max="2100" step="1" value="<%= isEdit && rec.start_year ? rec.start_year : '' %>" placeholder="2018"/>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('vehicle_engines.end_year') %></label>
            <input type="number" name="end_year" id="fEndYear" class="form-control" min="1900" max="2100" step="1" value="<%= isEdit && rec.end_year ? rec.end_year : '' %>" placeholder="2024"/>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('vehicle_engines.kw') %></label>
            <input type="number" name="kw" id="fKw" class="form-control" min="0" step="1" value="<%= isEdit && rec.kw ? rec.kw : '' %>" placeholder="150"/>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-medium"><%- t('vehicle_engines.hp') %></label>
            <input type="number" name="hp" id="fHp" class="form-control" min="0" step="1" value="<%= isEdit && rec.hp ? rec.hp : '' %>" placeholder="204"/>
          </div>
        </div>
      </div>
    </div>

    <!-- Vehicle Variants (multi-select autocomplete) -->
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-sliders2-vertical me-1 text-primary"></i><%- t('vehicle_engines.variants') %></div>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-2"><%- t('vehicle_engines.variants_hint') %></p>
        <select name="variant_ids" id="selVariants" class="form-select" multiple style="width:100%;">
          <% existingVariants.forEach(function(v) { %>
          <option value="<%- v.id %>" selected><%- v.name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <!-- Translations -->
    <% if (langs.length > 0) { %>
    <div class="card mt-3 shadow-sm">
      <div class="card-header py-2">
        <div class="card-title mb-0 d-flex align-items-center" style="font-size:14px;">
          <span><i class="bi bi-translate me-1 text-primary"></i><%- t('vehicle_engines.translations') %> <span class="badge bg-primary-lt ms-1" style="font-size:10px;"><%- langs.length %> <%- t('general.languages') %></span></span>
          <button type="button" class="btn btn-sm btn-outline-info ms-auto d-none ai-translate-btn" id="btnTranslateAll" title="AI Translate All">
            <i class="bi bi-stars me-1"></i>Translate All
          </button>
        </div>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-3"><%- t('vehicle_engines.translations_hint') %></p>
        <div class="row g-3">
          <% langs.forEach(function(lang) { %>
          <div class="col-md-6">
            <label class="form-label fw-medium">
              <% if (lang.flag) { %><span class="me-1"><%- lang.flag %></span><% } %><%- lang.name %>
              <% if (lang.native_name) { %><span class="text-muted ms-1" style="font-size:11px;">(<%- lang.native_name %>)</span><% } %>
              <% if (lang.is_default) { %><span class="badge bg-warning-lt ms-1" style="font-size:9px;"><%- t('master_lang.default') %></span><% } %>
            </label>
            <input type="text" name="trans_<%- lang.id %>" class="form-control" value="<%= transMap[lang.id] || '' %>" placeholder="<%- lang.name %>"
                   data-lang-id="<%- lang.id %>" data-lang-name="<%- lang.name %>" data-lang-code="<%- lang.code %>"/>
            <button type="button" class="btn btn-sm btn-ghost-info mt-1 d-none ai-translate-btn ai-single-btn"
                    data-lang-id="<%- lang.id %>" data-lang-name="<%- lang.name %>" data-lang-code="<%- lang.code %>"
                    title="Translate to <%- lang.name %> using AI">
              <i class="bi bi-stars me-1"></i><span class="d-none d-sm-inline">AI</span>
            </button>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <div class="col-lg-4">
    <% if (isEdit) { %>
    <div class="card shadow-sm">
      <div class="card-header py-2"><div class="card-title mb-0" style="font-size:14px;"><i class="bi bi-toggle-on me-1 text-primary"></i><%- t('general.status') %></div></div>
      <div class="card-body"><select name="status" class="form-select"><option value="1" <%- parseInt(rec.status) ? 'selected' : '' %>><%- t('general.active') %></option><option value="0" <%- !parseInt(rec.status) ? 'selected' : '' %>><%- t('general.inactive') %></option></select></div>
    </div>
    <% } %>

    <div class="card mt-3 shadow-sm">
      <div class="card-body py-3">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary" id="btnSubmit"><i class="bi bi-floppy me-1"></i><%- isEdit ? t('general.update') : t('general.create') %> <%- t('vehicle_engines.title_singular') %></button>
          <a href="/vehicle-engines" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i><%- t('btn.cancel') %></a>
        </div>
      </div>
    </div>
  </div>

</div>
</form>

<script>
window._FORM_DATA = {
    isEdit: <%= isEdit ? 'true' : 'false' %>,
    langIds: [<%= langs.map(function(l){ return l.id; }).join(',') %>],
    langs: <%- JSON.stringify(langs.map(function(l){ return {id:l.id, name:l.name, code:l.code}; })) %>,
    existingVariants: <%- JSON.stringify(existingVariants.map(function(v){ return {id:v.id, text:v.name}; })) %>
};
</script>
<% block('scripts', '<script src="/js/pages/vehicle-engines-form.js"></script>') %>
