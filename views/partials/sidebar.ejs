<%
var sbTheme = (settings && settings.sidebar_style === 'light') ? 'light' : 'dark';
%>
<aside class="navbar navbar-vertical navbar-expand-lg sms-sidebar" data-bs-theme="<%- sbTheme %>">
  <div class="container-fluid">

    <!-- Logo -->
    <a href="/dashboard" class="navbar-brand sms-sidebar-brand d-flex align-items-center gap-2">
      <div class="sms-sidebar-logo">
        <i class="bi bi-recycle"></i>
      </div>
      <div class="lh-sm">
        <div class="fw-bold" style="font-size:15px;"><%- APP_NAME %></div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.5px;opacity:.5;">Management</div>
      </div>
    </a>

    <!-- Mobile toggler -->
    <button class="navbar-toggler border-0 p-2" type="button" id="smsBtnMenu" aria-label="Toggle menu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="smsNavCollapse">

      <!-- User card -->
      <div class="sms-sidebar-user">
        <% if (user && user.profile_image) { %>
        <span class="avatar avatar-sm" style="background-image:url(<%- user.profile_image %>)"></span>
        <% } else { %>
        <span class="sms-sidebar-avatar"><%- user ? user.name.charAt(0).toUpperCase() : 'U' %></span>
        <% } %>
        <div class="flex-fill overflow-hidden">
          <div class="fw-semibold text-truncate" style="font-size:13px;"><%- user ? user.name : '' %></div>
          <div class="sms-sidebar-role">
            <span class="sms-role-dot"></span>
            <%- user && user.is_org_admin ? 'Administrator' : 'Staff' %>
          </div>
        </div>
        <a href="/settings" class="sms-user-settings-btn" title="Settings"><i class="bi bi-gear"></i></a>
      </div>

      <ul class="navbar-nav flex-column">

        <% if (menus && menus.length > 0) { %>
        <% menus.forEach(function(group) { %>

          <% if (group.children && group.children.length > 0) { %>
            <%
              var anyVisible = group.children.some(function(c){ return !c.permission_key || can(c.permission_key); });
              if (!anyVisible) return;
              var groupActive = group.children.some(function(c){
                return c.route_path && activeLink === c.route_path.replace('/','');
              });
            %>
            <li class="nav-item sms-nav-section"><span><%- group.title %></span></li>
            <% group.children.forEach(function(child) { %>
              <% if (!child.permission_key || can(child.permission_key)) { %>
                <% if (child.children && child.children.length > 0) { %>
                  <% var ca = child.children.some(function(s){ return activeLink===(s.route_path||'').replace('/',''); }); %>
                  <li class="nav-item">
                    <a class="nav-link sms-nav-link <%- ca?'active':'' %>"
                       href="#sb-<%- child.id %>" data-bs-toggle="collapse" aria-expanded="<%- ca?'true':'false' %>">
                      <span class="sms-nav-icon"><i class="bi <%- (child.icon||'bi-dot').replace('ti ti-','bi-').replace('ti-','bi-') %>"></i></span>
                      <span><%- child.title %></span>
                      <i class="bi bi-chevron-down ms-auto sms-chevron"></i>
                    </a>
                    <div class="collapse <%- ca?'show':'' %>" id="sb-<%- child.id %>">
                      <% child.children.forEach(function(sub){ %>
                        <% if (!sub.permission_key || can(sub.permission_key)) { %>
                        <a class="nav-link sms-nav-sublink <%- activeLink===(sub.route_path||'').replace('/','') ?'active':'' %>"
                           href="<%- sub.route_path %>">
                          <span class="sms-nav-dot"></span><%- sub.title %>
                        </a>
                        <% } %>
                      <% }) %>
                    </div>
                  </li>
                <% } else { %>
                  <li class="nav-item">
                    <a class="nav-link sms-nav-link <%- activeLink===(child.route_path||'').replace('/','') ?'active':'' %>"
                       href="<%- child.route_path %>">
                      <span class="sms-nav-icon"><i class="bi <%- (child.icon||'bi-dot').replace('ti ti-','bi-').replace('ti-','bi-') %>"></i></span>
                      <span><%- child.title %></span>
                    </a>
                  </li>
                <% } %>
              <% } %>
            <% }) %>

          <% } else { %>
            <% if (group.permission_key && !can(group.permission_key)) { return; } %>
            <li class="nav-item">
              <a class="nav-link sms-nav-link <%- activeLink===(group.route_path||'').replace('/','') ?'active':'' %>"
                 href="<%- group.route_path || '#' %>">
                <span class="sms-nav-icon"><i class="bi <%- (group.icon||'bi-circle').replace('ti ti-','bi-').replace('ti-','bi-') %>"></i></span>
                <span><%- group.title %></span>
              </a>
            </li>
          <% } %>

        <% }) %><% } %>

      </ul>



    </div>
  </div>
</aside>
