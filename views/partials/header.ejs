<!-- Desktop header — hidden below 992px (mobile uses topbar in main.ejs) -->
<header class="navbar navbar-expand-md d-none d-lg-flex d-print-none">
    <div class="container-xl">

        <!-- Page title on desktop -->
        <div class="navbar-nav me-auto">
            <span class="navbar-text fw-semibold text-body" style="font-size:15px;">
                <%- page_title %>
            </span>
        </div>

        <!-- Right side controls -->
        <div class="navbar-nav flex-row align-items-center gap-2 ms-auto">

            <!-- Dark mode toggle -->
            <div class="nav-item d-flex align-items-center">
                <label class="form-check form-switch mb-0" title="Toggle dark mode">
                    <input class="form-check-input" type="checkbox" id="darkModeToggle"
                           <%- (settings && settings.dark_mode == '1') ? 'checked' : '' %>>
                    <span class="form-check-label">
                        <i class="ti ti-moon-stars"></i>
                    </span>
                </label>
            </div>

            <!-- Notifications -->
            <div class="nav-item dropdown">
                <a href="#" class="nav-link px-2 position-relative" data-bs-toggle="dropdown" title="Notifications">
                    <i class="ti ti-bell" style="font-size:20px;"></i>
                    <span class="badge bg-red badge-notification" style="font-size:9px;">0</span>
                </a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow" style="min-width:280px;">
                    <div class="dropdown-header d-flex justify-content-between">
                        <span>Notifications</span>
                        <small class="text-muted">0 new</small>
                    </div>
                    <div class="text-center text-muted py-4">
                        <i class="ti ti-bell-off" style="font-size:28px; opacity:.4;"></i>
                        <p class="mb-0 mt-2" style="font-size:13px;">No new notifications</p>
                    </div>
                </div>
            </div>

            <!-- User dropdown -->
            <div class="nav-item dropdown">
                <a href="#" class="nav-link d-flex align-items-center gap-2 p-0 lh-1 text-reset"
                   data-bs-toggle="dropdown" style="text-decoration:none;">
                    <% if (user && user.profile_image) { %>
                        <span class="avatar avatar-sm"
                              style="background-image:url(<%- user.profile_image %>)"></span>
                    <% } else { %>
                        <span class="avatar avatar-sm bg-primary text-white"
                              style="font-weight:700;font-size:14px;">
                            <%- user ? user.name.charAt(0).toUpperCase() : 'U' %>
                        </span>
                    <% } %>
                    <div class="d-none d-xl-block">
                        <div class="fw-semibold lh-1" style="font-size:13px;">
                            <%- user ? user.name : '' %>
                        </div>
                        <div class="text-secondary mt-1" style="font-size:11px;">
                            <%- user && user.is_org_admin ? 'Administrator' : 'User' %>
                        </div>
                    </div>
                    <i class="ti ti-chevron-down text-secondary d-none d-xl-block" style="font-size:14px;"></i>
                </a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                    <div class="dropdown-header">
                        <div class="fw-semibold"><%- user ? user.name : '' %></div>
                        <div class="text-secondary" style="font-size:12px;"><%- user ? user.email : '' %></div>
                    </div>
                    <div class="dropdown-divider"></div>
                    <a href="/profile"  class="dropdown-item">
                        <i class="ti ti-user me-2"></i> My Profile
                    </a>
                    <a href="/settings" class="dropdown-item">
                        <i class="ti ti-settings me-2"></i> Settings
                    </a>
                    <div class="dropdown-divider"></div>
                    <a href="/logout" class="dropdown-item text-danger">
                        <i class="ti ti-logout me-2"></i> Logout
                    </a>
                </div>
            </div>

        </div>
    </div>
</header>

<script>
$(function () {
    // Desktop dark mode toggle
    $('#darkModeToggle').on('change', function () {
        $.post('/settings/user', { dark_mode: $(this).is(':checked') ? '1' : '0' }, function () {
            location.reload();
        });
    });
});
</script>
