<%
var s = settings || {};
var curLang = lang || 'en';
var curLangObj = (SUPPORTED_LANGUAGES||[]).find(function(l){ return l.code===curLang; });
%>

<!-- ══ Desktop Header ════════════════════════════════════════════ -->
<header class="sms-header d-none d-lg-flex d-print-none">

  <!-- Sidebar toggle button — LEFT side of header -->
  <button class="sms-header__toggle" id="smsSidebarToggle" title="Toggle sidebar">
    <i class="bi bi-layout-sidebar" id="smsToggleIcon"></i>
  </button>

  <!-- Page title -->
  <div class="sms-header__title"><%- page_title %></div>

  <!-- Right actions -->
  <div class="sms-header__actions">

    <!-- Dark mode toggle -->
    <label class="form-check form-switch mb-0" title="Dark mode">
      <input class="form-check-input" type="checkbox" id="smsDarkToggle"
             <%- s.dark_mode==='1' ? 'checked' : '' %> role="switch"/>
    </label>

    <!-- Language -->
    <div class="dropdown">
      <a href="#" class="sms-header__btn d-flex align-items-center gap-1" data-bs-toggle="dropdown">
        <span style="font-size:16px;"><%- curLangObj ? curLangObj.flag : '🌐' %></span>
        <span class="d-none d-xl-inline small fw-medium"><%- curLangObj ? curLangObj.nativeName : 'EN' %></span>
        <i class="bi bi-chevron-down text-muted" style="font-size:10px;"></i>
      </a>
      <div class="dropdown-menu dropdown-menu-end shadow" style="min-width:160px;">
        <h6 class="dropdown-header text-uppercase">Language</h6>
        <% (SUPPORTED_LANGUAGES||[]).forEach(function(lng){ %>
        <a href="#" class="dropdown-item d-flex align-items-center gap-2 sms-lang-btn
                           <%- curLang===lng.code?'active':'' %>" data-lang="<%- lng.code %>">
          <span><%- lng.flag %></span>
          <div>
            <div class="fw-medium" style="font-size:13px;"><%- lng.nativeName %></div>
            <div class="text-muted" style="font-size:11px;"><%- lng.name %></div>
          </div>
          <% if(curLang===lng.code){ %><i class="bi bi-check-lg ms-auto text-primary"></i><% } %>
        </a>
        <% }) %>
      </div>
    </div>

    <!-- Theme panel -->
    <button class="sms-header__btn sms-header__icon-btn" id="smsBtnTheme" title="Customise">
      <i class="bi bi-sliders"></i>
    </button>

    <!-- Notifications -->
    <div class="dropdown">
      <button class="sms-header__btn sms-header__icon-btn position-relative" data-bs-toggle="dropdown">
        <i class="bi bi-bell"></i>
        <span class="sms-notif-dot">0</span>
      </button>
      <div class="dropdown-menu dropdown-menu-end shadow" style="min-width:290px;">
        <div class="dropdown-header d-flex justify-content-between align-items-center">
          <span class="fw-semibold">Notifications</span>
          <span class="text-muted small">0 new</span>
        </div>
        <div class="text-center text-muted py-4 px-3">
          <i class="bi bi-bell-slash mb-2 d-block" style="font-size:32px;opacity:.3;"></i>
          <p class="mb-0 small">No new notifications</p>
        </div>
      </div>
    </div>

    <!-- User dropdown -->
    <div class="dropdown">
      <a href="#" class="sms-header__user" data-bs-toggle="dropdown">
        <% if (user && user.profile_image) { %>
        <span class="sms-header__avatar" style="background-image:url(<%- user.profile_image %>);background-size:cover;background-position:center;"></span>
        <% } else { %>
        <span class="sms-header__avatar sms-header__avatar--init">
          <%- user ? user.name.charAt(0).toUpperCase() : 'U' %>
        </span>
        <% } %>
        <div class="sms-header__userinfo d-none d-xl-block">
          <div class="sms-header__username"><%- user ? user.name : '' %></div>
          <div class="sms-header__userrole"><%- user&&user.is_org_admin ? 'Admin' : 'User' %></div>
        </div>
        <i class="bi bi-chevron-down text-muted d-none d-xl-inline" style="font-size:11px;"></i>
      </a>
      <div class="dropdown-menu dropdown-menu-end shadow">
        <div class="dropdown-header">
          <div class="fw-semibold"><%- user ? user.name : '' %></div>
          <div class="text-muted small"><%- user ? user.email : '' %></div>
        </div>
        <div class="dropdown-divider"></div>
        <a href="/profile"  class="dropdown-item"><i class="bi bi-person me-2"></i><%- t?t('nav.profile'):'Profile' %></a>
        <a href="/settings" class="dropdown-item"><i class="bi bi-gear me-2"></i><%- t?t('nav.settings'):'Settings' %></a>
        <div class="dropdown-divider"></div>
        <a href="/logout" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i><%- t?t('nav.logout'):'Logout' %></a>
      </div>
    </div>

  </div>
</header>

<!-- ══ Mobile Topbar ══════════════════════════════════════════════ -->
<div class="sms-topbar d-flex d-lg-none align-items-center gap-2 px-3 py-2 sticky-top">
  <!-- Hamburger to open sidebar -->
  <button class="sms-topbar__btn" id="smsBtnMenu">
    <i class="bi bi-list fs-4"></i>
  </button>
  <div class="flex-fill fw-semibold text-truncate" style="font-size:15px;"><%- page_title %></div>

  <!-- Mobile lang -->
  <div class="dropdown">
    <button class="sms-topbar__btn" data-bs-toggle="dropdown">
      <span style="font-size:16px;"><%- curLangObj ? curLangObj.flag : '🌐' %></span>
    </button>
    <div class="dropdown-menu dropdown-menu-end shadow">
      <% (SUPPORTED_LANGUAGES||[]).forEach(function(lng){ %>
      <a href="#" class="dropdown-item sms-lang-btn <%- curLang===lng.code?'active':'' %>"
         data-lang="<%- lng.code %>">
        <span class="me-2"><%- lng.flag %></span><%- lng.nativeName %>
      </a>
      <% }) %>
    </div>
  </div>

  <!-- Mobile theme -->
  <button class="sms-topbar__btn" id="smsBtnThemeMobile">
    <i class="bi bi-sliders fs-5"></i>
  </button>

  <!-- Mobile dark -->
  <label class="form-check form-switch mb-0">
    <input class="form-check-input" type="checkbox" id="smsDarkToggleMobile"
           <%- s.dark_mode==='1' ? 'checked' : '' %> role="switch"/>
  </label>

  <!-- Mobile user -->
  <div class="dropdown">
    <button class="sms-header__avatar sms-header__avatar--init border-0"
            style="width:32px;height:32px;font-size:13px;"
            data-bs-toggle="dropdown">
      <%- user ? user.name.charAt(0).toUpperCase() : 'U' %>
    </button>
    <div class="dropdown-menu dropdown-menu-end shadow">
      <div class="dropdown-header">
        <div class="fw-semibold"><%- user ? user.name : '' %></div>
        <div class="text-muted small"><%- user ? user.email : '' %></div>
      </div>
      <div class="dropdown-divider"></div>
      <a href="/profile"  class="dropdown-item"><i class="bi bi-person me-2"></i>Profile</a>
      <a href="/settings" class="dropdown-item"><i class="bi bi-gear me-2"></i>Settings</a>
      <div class="dropdown-divider"></div>
      <a href="/logout" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
    </div>
  </div>
</div>
