<%
var s = settings || {};
var curLang = lang || 'en';
var curLangObj = (SUPPORTED_LANGUAGES||[]).find(function(l){ return l.code===curLang; });
%>

<!-- ══ Desktop Header ════════════════════════════════════════════ -->
<header class="sms-header d-none d-lg-flex d-print-none">

  <!-- Sidebar toggle button — LEFT side of header -->
  <button class="sms-header__toggle" id="smsSidebarToggle" title="Toggle sidebar">
    <i class="bi bi-layout-sidebar" id="smsToggleIcon"></i>
  </button>

  <!-- Page title -->
  <div class="sms-header__title"><%- page_title %></div>

  <!-- Right actions -->
  <div class="sms-header__actions">

    <!-- Dark mode toggle -->
    <label class="form-check form-switch mb-0" title="Dark mode">
      <input class="form-check-input" type="checkbox" id="smsDarkToggle"
             <%- s.dark_mode==='1' ? 'checked' : '' %> role="switch"/>
    </label>

    <!-- Language — opens search modal -->
    <button type="button" class="sms-header__btn d-flex align-items-center gap-1" id="btnLangDesktop"
            data-bs-toggle="modal" data-bs-target="#langModal" title="Change language">
      <span style="font-size:16px;"><%- curLangObj ? curLangObj.flag : '🌐' %></span>
      <span class="d-none d-xl-inline small fw-medium"><%- curLangObj ? curLangObj.nativeName : 'EN' %></span>
      <i class="bi bi-chevron-down text-muted" style="font-size:10px;"></i>
    </button>

    <!-- Theme panel -->
    <button class="sms-header__btn sms-header__icon-btn" id="smsBtnTheme" title="Customise">
      <i class="bi bi-sliders"></i>
    </button>

    <!-- Notifications -->
    <div class="dropdown">
      <button class="sms-header__btn sms-header__icon-btn position-relative" data-bs-toggle="dropdown">
        <i class="bi bi-bell"></i>
        <span class="sms-notif-dot">0</span>
      </button>
      <div class="dropdown-menu dropdown-menu-end shadow" style="min-width:290px;">
        <div class="dropdown-header d-flex justify-content-between align-items-center">
          <span class="fw-semibold">Notifications</span>
          <span class="text-muted small">0 new</span>
        </div>
        <div class="text-center text-muted py-4 px-3">
          <i class="bi bi-bell-slash mb-2 d-block" style="font-size:32px;opacity:.3;"></i>
          <p class="mb-0 small">No new notifications</p>
        </div>
      </div>
    </div>

    <!-- User dropdown -->
    <div class="dropdown">
      <a href="#" class="sms-header__user" data-bs-toggle="dropdown">
        <% if (user && (user.profile_image_url || user.profile_image)) { %>
        <span class="sms-header__avatar" style="background-image:url(<%- user.profile_image_url || user.profile_image %>);background-size:cover;background-position:center;"></span>
        <% } else { %>
        <span class="sms-header__avatar sms-header__avatar--init">
          <%- user ? user.name.charAt(0).toUpperCase() : 'U' %>
        </span>
        <% } %>
        <div class="sms-header__userinfo d-none d-xl-block">
          <div class="sms-header__username"><%- user ? user.name : '' %></div>
          <div class="sms-header__userrole"><%- user&&user.is_org_admin ? 'Admin' : 'User' %></div>
        </div>
        <i class="bi bi-chevron-down text-muted d-none d-xl-inline" style="font-size:11px;"></i>
      </a>
      <div class="dropdown-menu dropdown-menu-end shadow">
        <div class="dropdown-header">
          <div class="fw-semibold"><%- user ? user.name : '' %></div>
          <div class="text-muted small"><%- user ? user.email : '' %></div>
        </div>
        <div class="dropdown-divider"></div>
        <a href="/profile"  class="dropdown-item"><i class="bi bi-person me-2"></i><%- t?t('nav.profile'):'Profile' %></a>
        <a href="/settings" class="dropdown-item"><i class="bi bi-gear me-2"></i><%- t?t('nav.settings'):'Settings' %></a>
        <div class="dropdown-divider"></div>
        <a href="/logout" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i><%- t?t('nav.logout'):'Logout' %></a>
      </div>
    </div>

  </div>
</header>

<!-- ══ Mobile Topbar ══════════════════════════════════════════════ -->
<div class="sms-topbar d-flex d-lg-none align-items-center gap-2 px-3 py-2 sticky-top">
  <!-- Hamburger to open sidebar -->
  <button class="sms-topbar__btn" id="smsBtnMenu">
    <i class="bi bi-list fs-4"></i>
  </button>
  <div class="flex-fill fw-semibold text-truncate" style="font-size:15px;"><%- page_title %></div>

  <!-- Mobile lang — opens same modal -->
  <button type="button" class="sms-topbar__btn" data-bs-toggle="modal" data-bs-target="#langModal">
    <span style="font-size:16px;"><%- curLangObj ? curLangObj.flag : '🌐' %></span>
  </button>

  <!-- Mobile theme -->
  <button class="sms-topbar__btn" id="smsBtnThemeMobile">
    <i class="bi bi-sliders fs-5"></i>
  </button>

  <!-- Mobile dark -->
  <label class="form-check form-switch mb-0">
    <input class="form-check-input" type="checkbox" id="smsDarkToggleMobile"
           <%- s.dark_mode==='1' ? 'checked' : '' %> role="switch"/>
  </label>

  <!-- Mobile user -->
  <div class="dropdown">
    <button class="sms-header__avatar sms-header__avatar--init border-0"
            style="width:32px;height:32px;font-size:13px;"
            data-bs-toggle="dropdown">
      <%- user ? user.name.charAt(0).toUpperCase() : 'U' %>
    </button>
    <div class="dropdown-menu dropdown-menu-end shadow">
      <div class="dropdown-header">
        <div class="fw-semibold"><%- user ? user.name : '' %></div>
        <div class="text-muted small"><%- user ? user.email : '' %></div>
      </div>
      <div class="dropdown-divider"></div>
      <a href="/profile"  class="dropdown-item"><i class="bi bi-person me-2"></i>Profile</a>
      <a href="/settings" class="dropdown-item"><i class="bi bi-gear me-2"></i>Settings</a>
      <div class="dropdown-divider"></div>
      <a href="/logout" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
    </div>
  </div>
</div>

<!-- ══ Language Picker Modal — shared by desktop + mobile ═════════ -->
<div class="modal fade" id="langModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2 border-bottom">
        <h5 class="modal-title fw-semibold" style="font-size:14px;">
          <i class="bi bi-translate me-2 text-primary"></i><%- t ? t('settings.language') : 'Language' %>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="px-3 pt-2 pb-1">
        <input type="text" class="form-control form-control-sm" id="langSearchInput"
               placeholder="&#128269; Search language…" autocomplete="off">
      </div>
      <div class="modal-body p-0" style="max-height:350px;overflow-y:auto;">
        <div class="list-group list-group-flush" id="langListBody">
          <% (SUPPORTED_LANGUAGES||[]).forEach(function(lng){ %>
          <a href="#" class="list-group-item list-group-item-action sms-lang-btn d-flex align-items-center gap-2 py-2 px-3
                            <%- curLang===lng.code ? 'active' : '' %>"
             data-lang="<%- lng.code %>"
             data-search="<%- (lng.name + ' ' + lng.nativeName + ' ' + lng.code).toLowerCase() %>">
            <span style="font-size:18px;"><%- lng.flag %></span>
            <div class="flex-fill" style="min-width:0;">
              <div class="fw-medium text-truncate" style="font-size:13px;"><%- lng.nativeName %></div>
              <div class="text-muted text-truncate" style="font-size:11px;"><%- lng.name %> (<%- lng.code %>)</div>
            </div>
            <% if(curLang===lng.code){ %><i class="bi bi-check-lg text-primary"></i><% } %>
          </a>
          <% }) %>
        </div>
        <div class="text-center text-muted py-3 d-none" id="langNoResult" style="font-size:13px;">
          <i class="bi bi-search me-1"></i>No language found
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  /* ── Language search filter ── */
  var searchInp = document.getElementById('langSearchInput');
  var listBody  = document.getElementById('langListBody');
  var noResult  = document.getElementById('langNoResult');
  if (searchInp && listBody) {
    searchInp.addEventListener('input', function(){
      var q = this.value.toLowerCase().trim();
      var items = listBody.querySelectorAll('.sms-lang-btn');
      var visible = 0;
      items.forEach(function(item){
        var match = !q || (item.dataset.search || '').indexOf(q) !== -1;
        item.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (noResult) noResult.classList.toggle('d-none', visible > 0);
    });
  }
  /* Auto-focus search when modal opens */
  var langModal = document.getElementById('langModal');
  if (langModal) {
    langModal.addEventListener('shown.bs.modal', function(){
      if (searchInp) { searchInp.value = ''; searchInp.dispatchEvent(new Event('input')); searchInp.focus(); }
      /* Scroll active item into view */
      var active = listBody.querySelector('.sms-lang-btn.active');
      if (active) active.scrollIntoView({ block: 'center', behavior: 'instant' });
    });
  }
})();
</script>