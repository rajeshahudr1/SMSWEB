<%- layout('../layouts/main') %>
<div class="card shadow-sm">
  <div class="card-header py-2 border-bottom">
    <div class="d-flex align-items-center gap-2 flex-grow-1 flex-wrap">
      <h3 class="card-title mb-0 me-auto"><i class="bi bi-star me-2 text-warning"></i>Reviews <span class="badge bg-secondary-lt rounded-pill ms-1" id="badgeTotal" style="font-size:11px;vertical-align:middle;">-</span></h3>
      <select class="form-select form-select-sm" id="perPageSel" style="width:100px;"></select>
    </div>
  </div>

  <!-- Filters -->
  <div class="px-3 py-2 border-bottom" style="background:var(--tblr-bg-surface-secondary);">
    <div class="d-flex align-items-center gap-2">
      <div class="flex-grow-1"><input type="text" class="form-control form-control-sm" id="searchInput" placeholder="Search user, company, review..."/></div>
      <select class="form-select form-select-sm" id="filterStatus" style="width:130px;">
        <option value="">All Status</option><option value="pending">Pending</option><option value="approved">Approved</option><option value="rejected">Rejected</option>
      </select>
      <select class="form-select form-select-sm" id="filterRating" style="width:120px;">
        <option value="">All Ratings</option><option value="5">5 Stars</option><option value="4">4 Stars</option><option value="3">3 Stars</option><option value="2">2 Stars</option><option value="1">1 Star</option>
      </select>
      <button class="btn btn-sm btn-outline-secondary" id="btnClearFilters"><i class="bi bi-x-lg"></i></button>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover table-vcenter mb-0">
      <thead><tr>
        <th style="width:36px;">#</th>
        <th>User</th>
        <th>Company</th>
        <th>Rating</th>
        <th>Review</th>
        <th>Status</th>
        <th class="sortable" data-field="created_at">Date <i class="bi bi-arrow-down-up text-muted small"></i></th>
        <th class="text-end" style="width:180px;">Actions</th>
      </tr></thead>
      <tbody id="tableBody"><tr><td colspan="8" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...</td></tr></tbody>
    </table>
  </div>
  <div class="card-footer d-flex align-items-center flex-wrap gap-2"><div class="text-muted small" id="tableInfo"></div><div class="ms-auto" id="tablePagination"></div></div>
</div>

<!-- View Modal -->
<div class="modal fade" id="viewModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:520px;"><div class="modal-content">
  <div class="modal-header py-3"><h5 class="modal-title fw-semibold"><i class="bi bi-star me-2 text-warning"></i>Review Details</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body p-0" id="viewBody"></div>
  <div class="modal-footer py-2"><button type="button" class="btn btn-ghost-secondary btn-sm" data-bs-dismiss="modal">Close</button></div>
</div></div></div>

<%
block('scripts', `
<script>
var _page=1,_pp=15;
var stMap={pending:{cls:'bg-warning-lt',label:'Pending'},approved:{cls:'bg-success-lt',label:'Approved'},rejected:{cls:'bg-danger-lt',label:'Rejected'}};

/* Per-page selector */
_pp=smsInitPerPage('#perPageSel');
$('#perPageSel').on('change',function(){_pp=parseInt($(this).val())||15;_page=1;loadData();});

function stars(n,size){size=size||12;var h='';for(var i=1;i<=5;i++)h+='<i class="bi bi-star-fill" style="color:'+(i<=n?'#f59e0b':'#e5e7eb')+';font-size:'+size+'px;"></i>';return h;}

/* Pagination */
function buildPagination(pg){
    if(!pg||pg.last_page<=1){$('#tablePagination').html('');return;}
    var h='<ul class="pagination pagination-sm mb-0">';
    h+='<li class="page-item'+(pg.current_page<=1?' disabled':'')+'"><a class="page-link" href="#" data-page="'+(pg.current_page-1)+'"><i class="bi bi-chevron-left"></i></a></li>';
    var s=Math.max(1,pg.current_page-2),e=Math.min(pg.last_page,pg.current_page+2);
    if(s>1){h+='<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';if(s>2)h+='<li class="page-item disabled"><span class="page-link">…</span></li>';}
    for(var i=s;i<=e;i++)h+='<li class="page-item'+(i===pg.current_page?' active':'')+'"><a class="page-link" href="#" data-page="'+i+'">'+i+'</a></li>';
    if(e<pg.last_page){if(e<pg.last_page-1)h+='<li class="page-item disabled"><span class="page-link">…</span></li>';h+='<li class="page-item"><a class="page-link" href="#" data-page="'+pg.last_page+'">'+pg.last_page+'</a></li>';}
    h+='<li class="page-item'+(pg.current_page>=pg.last_page?' disabled':'')+'"><a class="page-link" href="#" data-page="'+(pg.current_page+1)+'"><i class="bi bi-chevron-right"></i></a></li></ul>';
    $('#tablePagination').html(h);
}

function loadData(){
    $('#tableBody').html('<tr><td colspan="8" class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>');
    $.post(BASE_URL+'/reviews/paginate',{page:_page,per_page:_pp,status:$('#filterStatus').val(),rating:$('#filterRating').val(),search:$('#searchInput').val().trim()},function(res){
        if(!res||res.status!==200){$('#tableBody').html('<tr><td colspan="8" class="text-center text-danger py-4">Failed to load.</td></tr>');return;}
        var data=res.data&&res.data.data?res.data.data:[],pg=res.data&&res.data.pagination?res.data.pagination:{};
        $('#badgeTotal').text((pg.total||0).toLocaleString());
        if(!data.length){$('#tableBody').html('<tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-star d-block mb-2" style="font-size:36px;opacity:.3;"></i>No reviews found</td></tr>');$('#tableInfo').text('');$('#tablePagination').html('');return;}
        var rows='';
        data.forEach(function(r,i){
            var st=stMap[r.status]||stMap.pending;
            var initials=(r.user_name||'?').split(' ').map(function(w){return w[0];}).join('').substring(0,2).toUpperCase();
            rows+='<tr>';
            rows+='<td class="text-muted">'+((pg.from||1)+i)+'</td>';
            rows+='<td><div class="d-flex align-items-center gap-2"><span class="avatar avatar-sm rounded-circle bg-warning-lt" style="font-size:11px;width:32px;height:32px;">'+initials+'</span><div class="fw-medium">'+H.esc(r.user_name||'-')+'</div></div></td>';
            rows+='<td>'+(r.company_name?H.esc(r.company_name):'<span class="text-muted">-</span>')+'</td>';
            rows+='<td>'+stars(r.rating)+' <span class="text-muted small ms-1">'+r.rating+'/5</span></td>';
            rows+='<td style="max-width:250px;">'+(r.review?H.trunc(r.review,50):'<span class="text-muted">-</span>')+'</td>';
            rows+='<td><span class="badge '+st.cls+'">'+st.label+'</span></td>';
            rows+='<td class="text-muted small">'+smsFormatDateTime(r.created_at)+'</td>';
            rows+='<td class="text-end">';
            rows+='<button class="btn btn-sm btn-ghost-primary" title="View" onclick="viewReview(\\''+r.uuid+'\\','+i+')"><i class="bi bi-eye"></i></button>';
            if(r.status!=='approved')rows+='<button class="btn btn-sm btn-ghost-success" title="Approve" onclick="updateReview(\\''+r.uuid+'\\',\\'approved\\')"><i class="bi bi-check-circle"></i></button>';
            if(r.status!=='rejected')rows+='<button class="btn btn-sm btn-ghost-warning" title="Reject" onclick="updateReview(\\''+r.uuid+'\\',\\'rejected\\')"><i class="bi bi-x-circle"></i></button>';
            rows+='<button class="btn btn-sm btn-ghost-danger" title="Delete" onclick="deleteReview(\\''+r.uuid+'\\')"><i class="bi bi-trash3"></i></button>';
            rows+='</td></tr>';
        });
        $('#tableBody').html(rows);
        $('#tableInfo').text('Showing '+(pg.from||1)+'\\u2013'+(pg.to||data.length)+' of '+(pg.total||0));
        buildPagination({current_page:pg.current_page,last_page:pg.last_page});
        window._reviewData=data;
    });
}

function viewReview(uuid,idx){
    var r=window._reviewData&&window._reviewData[idx];
    if(!r) return;
    var st=stMap[r.status]||stMap.pending;
    var initials=(r.user_name||'?').split(' ').map(function(w){return w[0];}).join('').substring(0,2).toUpperCase();
    var h='';
    h+='<div class="p-3 border-bottom" style="background:var(--tblr-bg-surface-secondary);">';
    h+='<div class="d-flex align-items-center gap-3">';
    h+='<span class="avatar avatar-lg rounded-circle bg-warning-lt" style="font-size:18px;width:52px;height:52px;">'+initials+'</span>';
    h+='<div><h5 class="mb-0 fw-semibold">'+H.esc(r.user_name||'-')+'</h5>';
    if(r.company_name)h+='<div class="text-muted small">'+H.esc(r.company_name)+'</div>';
    h+='</div>';
    h+='<div class="ms-auto"><span class="badge '+st.cls+' fs-6">'+st.label+'</span></div>';
    h+='</div></div>';
    h+='<div class="p-4">';
    h+='<div class="text-center mb-3">'+stars(r.rating,24)+' <span class="fw-bold ms-2" style="font-size:18px;">'+r.rating+'/5</span></div>';
    if(r.review){
        h+='<div class="border rounded p-3 mb-3" style="background:var(--tblr-bg-surface-secondary);font-size:14px;line-height:1.7;font-style:italic;">"'+H.esc(r.review)+'"</div>';
    } else {
        h+='<div class="text-muted text-center mb-3" style="font-size:13px;">No written review.</div>';
    }
    h+='<div class="text-muted small text-center"><i class="bi bi-calendar3 me-1"></i>Submitted: '+smsFormatDateTime(r.created_at)+'</div>';
    h+='<div class="d-flex gap-2 justify-content-center mt-3">';
    if(r.status!=='approved')h+='<button class="btn btn-sm btn-success" onclick="updateReview(\\''+r.uuid+'\\',\\'approved\\');bootstrap.Modal.getInstance(document.getElementById(\\'viewModal\\')).hide();"><i class="bi bi-check-circle me-1"></i>Approve</button>';
    if(r.status!=='rejected')h+='<button class="btn btn-sm btn-warning" onclick="updateReview(\\''+r.uuid+'\\',\\'rejected\\');bootstrap.Modal.getInstance(document.getElementById(\\'viewModal\\')).hide();"><i class="bi bi-x-circle me-1"></i>Reject</button>';
    h+='</div></div>';
    $('#viewBody').html(h);
    bootstrap.Modal.getOrCreateInstance($('#viewModal')[0]).show();
}

function updateReview(uuid,status){
    $.ajax({url:BASE_URL+'/reviews/'+uuid,type:'POST',contentType:'application/json',data:JSON.stringify({status:status}),success:function(r){
        if(r.status===200){toastr.success(r.message||'Updated.');loadData();}else toastr.error(r.message||'Failed.');
    }});
}

function deleteReview(uuid){
    smsConfirm({title:'Delete Review',msg:'Delete this review permanently?',btnClass:'btn-danger',btnText:'Delete',onConfirm:function(){
        $.post(BASE_URL+'/reviews/'+uuid+'/delete',function(r){if(r.status===200){toastr.success('Deleted.');loadData();}else toastr.error(r.message||'Failed.');});
    }});
}

$(function(){
    loadData();
    var st;$('#searchInput').on('input',function(){clearTimeout(st);st=setTimeout(function(){_page=1;loadData();},300);});
    $('#filterStatus,#filterRating').on('change',function(){_page=1;loadData();});
    $('#btnClearFilters').on('click',function(){$('#searchInput').val('');$('#filterStatus').val('');$('#filterRating').val('');_page=1;loadData();});
    $(document).on('click','#tablePagination .page-link',function(e){e.preventDefault();var p=parseInt($(this).data('page'));if(p&&p>=1){_page=p;loadData();}});
});
</script>
`);
%>
